---
theme: responsive_full_width
---

:ruby
  @header["title"] = hoc_s(:hour_of_code)
  hoc_mode = DCDO.get('hoc_mode', CDO.default_hoc_mode)

%link{href: "/css/generated/design-system-pegasus.css", rel: "stylesheet"}
%link{href: "/css/generated/page/hour-of-code-styles.css", rel: "stylesheet", type: "text/css"}

%section.hero-banner-basic
  .wrapper.centered.flex-container.align-items-center.flex-direction-column.gap-2
    %figure
      %img{src: "/images/banners/banner-hoc-2024.png", alt: ""}
    .text-wrapper
      %h1=hoc_s("hoc_2024.header")
      %a.link-button.black.has-external-link{href: CDO.hourofcode_url('events', locale: 'fa-IR'), target: "_blank", rel: "noopener noreferrer"}
        =hoc_s("hoc_2024.button_host_an_event")

%section.bg-neutral-light
  .wrapper.flex-container.justify-space-between.wrap
    .text-wrapper.col-50
      %h2=hoc_s(:hoc_page_what_is_hoc_heading)
      %p.body-three.has-external-link
        = hoc_s(:hoc_page_desc, markdown: :inline, locals: {hoc_url: CDO.hourofcode_url(locale: 'fa-IR')})
      %p.body-three
        =hoc_s(:hoc_page_desc_2023)
    %div.col-45
      = view :display_video_thumbnail, id: "hoc_celebrities_2023", video_code: "ybBUd9-0ZJQ", play_button: 'center', letterbox: 'false', download_path: CDO.video_url('hour_of_code_celebrities_2023.mp4')
      %a.body-three{href: CDO.code_org_url('videos', ge_region: request.ge_region)}
        =hoc_s(:call_to_action_see_more_insp_videos)
  .clear

%section
  .wrapper
    %h2=hoc_s(:hoc_page_lead_activity_heading)
    %p.has-external-link
      = hoc_s(:"hoc_page.activities.desc", markdown: :inline, locals:{register_url: CDO.hourofcode_url('events', locale: 'fa-IR')})
    = view :"global/fa/hoc_activities_featured"
    %div.centered{style: "margin-top: 2rem"}
      %a.link-button.secondary{href: CDO.studio_url('catalog?marketingInitiative=hoc', ge_region: request.ge_region)}
        =hoc_s(:call_to_action_explore_all_hoc_activities)
