    <td style="padding: 8px; font-size: 14pt; border: 1px solid #ccc;">None!</td>
  </tr>
  <tr>
    <td style="padding: 8px; font-size: 14pt; border: 1px solid #ccc;"><strong>Coding Environment</strong></td>
    <td style="padding: 8px; font-size: 14pt; border: 1px solid #ccc;">Music Lab</td>
  </tr>
  <tr>
    <td style="padding: 8px; font-size: 14pt; border: 1px solid #ccc;"><strong>Projects</strong></td>
