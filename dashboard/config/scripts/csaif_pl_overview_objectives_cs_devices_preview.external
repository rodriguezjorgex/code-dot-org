    <div style="position: absolute; top: 50%; left: 35%; transform: translate(-50%, -50%); padding: 20px; width: 90%; max-width: 800px; border-radius: 10px; display: flex; align-items: center; gap: 20px; justify-content: center;">
        <img src="https://images.code.org/23f8e4b3c5fa388bddebcf8eaf5ce33c-image-1741879027462.png" alt="Banner Icon" style="width: 100px; height: auto; border-radius: 10px; margin-left: 75px; ">
        <p style="color: white; line-height: 1; font-size: 32px; font-weight: bold; margin: 0;">Teaching Computer Systems and Devices</p>
    </div>
