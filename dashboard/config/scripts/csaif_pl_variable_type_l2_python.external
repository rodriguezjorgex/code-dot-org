        <p style="font-size:14pt;">"Sam" <br>"Jordan"<br> "Maria" <br><br><b> Resident Names</b></p>
    </div>
</div>

<div style="display: flex; justify-content: center; gap: 20px; padding: 20px; width: 95%;">
    <div style="background-color: #f8f8f8; padding: 20px; border-radius: 10px; width: 30%; height: 220px; 
