    <!-- Card 3 -->
    <div style="background-color: #F5F7F8; color: #000000; padding: 20px; border-radius: 10px; box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.1); width: 25%; text-align: center;">
        <p style="font-size: 14pt; font-weight: bold; margin: 0;">The ability to leave feedback for students on levels</p>
 
