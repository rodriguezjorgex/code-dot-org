    {
      "key": "fff016b3-33a8-4afd-8d96-b11607791cb3",
      "position": 7,
      "properties": {
        "progression_name": "Reflection",
        "tips": [
          {
            "type": "teachingTip",
            "markdown": "**Career Connection:** This reflection is an opportunity for students to make a connection between their own future story and the career spotlight. Consider additional ways you want to explore connecting students to careers in computer science or how students can be exposed to professionals currently working in computer science or music careers, such as [Amazon's Career Tours](https://www.amazonfutureengineer.com/careertours) experiences."
          }
        ]
