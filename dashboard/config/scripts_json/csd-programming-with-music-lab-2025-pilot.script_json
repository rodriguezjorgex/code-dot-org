        "progression_name": "Student Survey"
      },
      "seeding_key": {
        "activity_section.key": "7a695e4b-2f8b-4b51-85a7-ff265a79dc1b",
        "lesson_activity.key": "5160e9b6-7544-4597-8ba9-07d8727eb928"
      }
    },
    {
