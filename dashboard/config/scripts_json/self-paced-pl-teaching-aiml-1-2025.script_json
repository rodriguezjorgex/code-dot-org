  "lessons": [
    {
      "key": "Introduction to AI and Machine Learning",
      "name": "Introduction to AI and Machine Learning",
      "absolute_position": 1,
      "lockable": false,
      "has_lesson_plan": false,
      "relative_position": 1,
      "properties": {
        "overview": "**You will:**\n\n* Get an introduction to artificial intelligence and machine learning.\n* Get a preview of the first week of the AI and Machine Learning unit content.\n\n**Suggested time:** 15 minutes",
        "student_overview": "**You will:**\n\n* Get an introduction to artificial intelligence and machine learning.\n* Get a preview of the first week of the AI and Machine Learning unit content.\n\n**Suggested time:** 15 minutes"
      },
      "seeding_key": {
        "lesson.key": "Introduction to AI and Machine Learning",
        "lesson_group.key": "",
        "script.name": "self-paced-pl-teaching-aiml-1-2025"
      }
    },
    {
      "key": "Train a Machine Learning Model",
      "name": "Train a Machine Learning Model",
      "absolute_position": 2,
      "lockable": false,
      "has_lesson_plan": false,
      "relative_position": 2,
      "properties": {
        "overview": "**You will:**\n\n* Train a machine learning model using AI Lab.\n\n**Suggested time:** 30 minutes",
        "student_overview": "**You will:**\n\n* Train a machine learning model using AI Lab.\n\n**Suggested time:** 30 minutes"
      },
      "seeding_key": {
        "lesson.key": "Train a Machine Learning Model",
