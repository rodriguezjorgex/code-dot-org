    {
      "key": "Engage with Machine Learning Apps",
      "name": "Engage with Machine Learning Apps",
      "absolute_position": 3,
      "lockable": false,
      "has_lesson_plan": false,
      "relative_position": 3,
      "properties": {
        "overview": "**You will:**\n\n* Engage with machine learning apps in App Lab.\n\n**Suggested time:** 10 minutes",
        "student_overview": "**You will:**\n\n* Engage with machine learning apps in App Lab.\n\n**Suggested time:** 10 minutes"
      },
      "seeding_key": {
        "lesson.key": "Engage with Machine Learning Apps",
        "lesson_group.key": "",
        "script.name": "self-paced-pl-teaching-aiml-1-2025"
      }
    },
    {
      "key": "Consider Real-World Implications",
      "name": "Consider Real-World Implications",
      "absolute_position": 4,
      "lockable": false,
      "has_lesson_plan": false,
      "relative_position": 4,
      "properties": {
        "overview": "**You will:**\n\n* Consider real-world implications of AI and machine learning.\n\n**Suggested time:** 15 minutes",
        "student_overview": "**You will:**\n\n* Consider real-world implications of AI and machine learning.\n\n**Suggested time:** 15 minutes"
      },
      "seeding_key": {
        "lesson.key": "Consider Real-World Implications",
        "lesson_group.key": "",
        "script.name": "self-paced-pl-teaching-aiml-1-2025"
