      }
    },
    {
      "key": "Introduction to Music Lab",
      "name": "Introduction to Music Lab",
      "absolute_position": 2,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 1,
      "properties": {
        "announcements": [
          {
            "key": "05827675-5685-4018-9b5e-5dc0e7267f56",
            "notice": "NEW! Self-Paced Professional Learning is here!",
            "details": "Get started with our new Self-Paced Professional Learning to explore the curriculum and Music Lab! Feel confident and prepared as you start teaching the unit!",
            "link": "https://studio.code.org/s/self-paced-pl-teaching-computer-science-discoveries-music-lab/lessons/1/levels/1",
            "type": "information",
            "visibility": "Teacher-only",
            "dismissible": true,
            "buttonText": "Start Learning!"
          }
        ],
        "overview": "To kick off a unit focused on creative coding and designing interactive music experiences, students will take on the role of music experience designers. Their challenge: help clients bring their ideas for unique songs to life using Music Lab.\n\nStudents begin by reviewing a variety of early songs, each showcasing different musical genres, sounds, and techniques. Then, they read through short client stories—each with a specific goal or mood in mind—and match each client with the song that best fits their vision.\n\nTo wrap up, students reflect on how understanding a user’s goals can shape creative decisions and consider how they might adapt or remix prototypes in Music Lab to better serve different needs.",
        "preparation": "* Print a copy of the activity guide for each student\n- Preview the examples in Code Studio to get familiar with the student experience\n- Get familiar with the musical terms in the [Music Lab Glossary](https://docs.google.com/presentation/d/1wvllTFs0IBWJI8uzfUhuFW4mUYItUK5nmmVjArNRlCM/edit?slide=id.g33d63a1df26_0_86#slide=id.g33d63a1df26_0_86) begin highlighting the connections between coding and music.",
        "student_overview": "Today, you’ll be a music experience designer! Your job is to help different “clients” bring their song ideas to life. First, you’ll check out some song prototypes in Music Lab. Then, you’ll read each client’s story and decide which prototype fits their idea best.\n\nYou’ll explain your choice and think about how to make the music even better for them."
      },
      "seeding_key": {
        "lesson.key": "Introduction to Music Lab",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Sequencing - Explore",
      "name": "Sequencing - Explore",
      "absolute_position": 3,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 2,
      "properties": {
        "announcements": [
          {
            "key": "2f635d5a-70b6-4f4f-808e-8c42df337e21",
            "notice": "Just-In-Time Professional Learning",
            "details": "About to start these lessons on Sequencing? Feel prepared by reviewing our Self-Paced Professional Learning specifically for these lessons - in under 30 minutes!",
            "link": "https://studio.code.org/s/self-paced-pl-teaching-computer-science-discoveries-music-lab/lessons/2/levels/1",
            "type": "information",
            "visibility": "Teacher-only",
            "dismissible": false,
            "buttonText": "Start Now!"
          }
        ],
        "overview": "Students are introduced to sequencing by following step-by-step instructions to build a song. They learn how to layer tracks and use blocks like play together to combine sounds. Teachers guide discussions, highlight patterns, and encourage students to make predictions before running code.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be). \n\n- Print out the [Sequencing Cheat Sheet](https://drive.google.com/file/d/1wO6RJOBslmoDm2Wwua50BW2v6XpShcuV/view) to keep handy while reviewing students’ work on Check-In and Assessment levels"
      },
      "seeding_key": {
        "lesson.key": "Sequencing - Explore",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Sequencing - Practice",
      "name": "Sequencing - Practice",
      "absolute_position": 4,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 3,
      "properties": {
        "overview": "Students practice sequencing by combining tracks of different lengths and adding rests to create offsets. Working in pairs, they apply concepts from the Explore lesson and build fluency through guided challenges. Teachers circulate to support and adjust instruction as needed.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Sequencing - Practice",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Sequencing - Synthesize",
      "name": "Sequencing - Synthesize",
      "absolute_position": 5,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 4,
      "properties": {
        "overview": "Students review and apply sequencing skills in a more open-ended context, using new Effect blocks to enhance their songs. Inspired by a real-world producer, they explore how to layer tracks creatively—bridging structured learning with creative expression.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Sequencing - Synthesize",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Mini Project: Walk-Up Songs",
      "name": "Mini Project: Walk-Up Songs",
      "absolute_position": 6,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 5,
      "properties": {
        "overview": "Students create personalized walk-up songs for characters using everything they've learned about sequencing. They explore a new feature, triggers, to add flair and timing to their music. This creative project gives students space to express themselves while demonstrating mastery of key concepts.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Mini Project: Walk-Up Songs",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Loops - Explore",
      "name": "Loops - Explore",
      "absolute_position": 7,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 6,
      "properties": {
        "announcements": [
          {
            "key": "5347d987-f350-4175-bdd8-5c8a09f09804",
            "notice": "Just-In-Time Professional Learning",
            "details": "About to start these lessons on Loops? Feel prepared by reviewing our Self-Paced Professional Learning specifically for these lessons - in under 30 minutes!",
            "link": "https://studio.code.org/s/self-paced-pl-teaching-computer-science-discoveries-music-lab/lessons/3/levels/1",
            "type": "information",
            "visibility": "Teacher-only",
            "dismissible": false,
            "buttonText": "Start Now!"
          }
        ],
        "overview": "Students are introduced to loops through real-world performances using loop pedals. They make predictions about how a repeat block will behave and explore how looping can simplify and strengthen musical structure. Shadow blocks are introduced to help students visually identify patterns in their code.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be).\n- Print out the [Loops Cheat Sheet](https://drive.google.com/file/d/1hdfC0eaWgQAljeCJK209qWt_uCoWQsAk/view) to keep handy while reviewing students’ work on Check-In and Assessment levels"
      },
      "seeding_key": {
        "lesson.key": "Loops - Explore",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Loops - Practice",
      "name": "Loops - Practice",
      "absolute_position": 8,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 7,
      "properties": {
        "overview": "Students deepen their understanding of loops by working with more complex structures, including nested loops and loops with rests. Pair programming supports peer collaboration, and check-in levels allow teachers to adapt pacing based on student progress.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Loops - Practice",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Loops - Synthesize",
      "name": "Loops - Synthesize",
      "absolute_position": 9,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 8,
      "properties": {
        "overview": "Students explore the idea of live coding through the lens of creative performer Roxanne Harris. They review loops and build confidence using them in performance-like settings. This lesson gives students space to blend musical structure with real-time experimentation.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Loops - Synthesize",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Mini Project: Cat GIF Loops",
      "name": "Mini Project: Cat GIF Loops",
      "absolute_position": 10,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 9,
      "properties": {
        "overview": "Students choose a looping cat GIF and design a musical loop that matches its mood. They explore the use of random blocks to introduce variety and surprise in their code. This project is a playful way to demonstrate mastery of loops while reinforcing creative expression.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Mini Project: Cat GIF Loops",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Functions - Explore",
      "name": "Functions - Explore",
      "absolute_position": 11,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 10,
      "properties": {
        "announcements": [
          {
            "key": "926e7a4b-21eb-4116-b6e3-5850cb0c2d77",
            "notice": "Just-In-Time Professional Learning",
            "details": "About to start these lessons on Functions? Feel prepared by reviewing our Self-Paced Professional Learning specifically for these lessons - in under 30 minutes!",
            "link": "https://studio.code.org/s/self-paced-pl-teaching-computer-science-discoveries-music-lab/lessons/4/levels/1",
            "type": "information",
            "visibility": "Teacher-only",
            "dismissible": false,
            "buttonText": "Start Now!"
          }
        ],
        "overview": "Students listen to mashups and identify patterns that make each part of a song stand out. In Music Lab, they learn to use functions to organize code into reusable sections. Through Predict and Investigate levels, students discover how functions help reduce repetition and clarify musical structure.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be).\n- Print out the [Functions Cheat Sheet](https://drive.google.com/file/d/1PFQdLhk1Yi4HdzBmI17N31GtybQcm2Nm/view) to keep handy while reviewing students’ work on Check-In and Assessment levels"
      },
      "seeding_key": {
        "lesson.key": "Functions - Explore",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Functions - Practice",
      "name": "Functions - Practice",
      "absolute_position": 12,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 11,
      "properties": {
        "overview": "Students apply their understanding of functions by defining, reusing, and composing multiple functions to structure a song. They explore function blocks alongside nested musical ideas, deepening their understanding of abstraction and reducing repetition.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Functions - Practice",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Functions - Synthesis",
      "name": "Functions - Synthesize",
      "absolute_position": 13,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 12,
      "properties": {
        "overview": "Students compare two versions of a song (the original and a remix) then remix their own track using functions. Inspired by remix artist Altrice, students apply functions to reorganize and reinterpret familiar musical patterns, reinforcing abstraction while fostering creative expression.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Functions - Synthesis",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
    {
      "key": "Project: Genre Mash-Up",
      "name": "Project: Genre Mash-Up",
      "absolute_position": 14,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 13,
      "properties": {
        "overview": "In this end-of-unit project, students select an existing song and remix it into a new genre using the structure of functions. They draw on skills from the entire unit to define musical sections, apply abstraction, and shift tone or style, just like real-world remix artists.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Project: Genre Mash-Up",
        "lesson_group.key": "lessonGroup-3",
        "script.name": "programming-with-music-lab-2025"
      }
    },
