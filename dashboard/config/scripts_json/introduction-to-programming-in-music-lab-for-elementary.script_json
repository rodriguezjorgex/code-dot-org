    {
      "key": "08bf6cda-2ecc-4375-8fab-410d75e151fe",
      "position": 6,
      "properties": {
        "name": "Lesson Plan:"
      },
      "seeding_key": {
        "activity_section.key": "08bf6cda-2ecc-4375-8fab-410d75e151fe",
        "lesson_activity.key": "7086910d-4698-49f4-92ea-ec29d5fb9ad7"
