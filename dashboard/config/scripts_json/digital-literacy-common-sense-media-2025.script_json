  "vocabularies": [
    {
      "key": "advertisement_csm",
      "word": "Advertisement",
      "definition": "a message that promotes a product, service, opportunity, or event using television, the internet, billboards, or other public spaces",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "advertisement_csm"
      }
    },
    {
      "key": "advertiser_csm",
      "word": "Advertiser",
      "definition": "a person or company who is hired to create advertisements",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "advertiser_csm"
      }
    },
    {
      "key": "clickbait_csm",
      "word": "Clickbait",
      "definition": "an image or headline that tries to get you to click on it, usually for advertising purposes",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "clickbait_csm"
      }
    },
    {
      "key": "cookies_csm",
      "word": "Cookies",
      "definition": "small text files stored on a computer that keep track of what a person does on a website",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "cookies_csm"
      }
    },
    {
      "key": "corroboration_csm",
      "word": "Corroboration",
      "definition": "additional source(s) that confirm or support the claims of a news story, article or piece of information",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "corroboration_csm"
      }
    },
    {
      "key": "creative_commons",
      "word": "Creative Commons",
      "definition": "A collection of public copyright licenses that enable the free distribution of an otherwise copyrighted work, used when an author wants to give people the right to share, use, and build upon a work that they have created",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "creative_commons"
      }
    },
    {
      "key": "digital_dilemma",
      "word": "digital dilemma",
      "definition": "a situation in digital life where it's not always clear what's best to do",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "digital_dilemma"
      }
    },
    {
      "key": "digital_footprint_csm",
      "word": "Digital Footprint",
      "definition": "all the information online about a person either posted by that person or others, intentionally or unintentionally",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "digital_footprint_csm"
      }
    },
    {
      "key": "disinformation_csm",
      "word": "Disinformation",
      "definition": "false or inaccurate information intended to deceive",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "disinformation_csm"
      }
    },
    {
      "key": "facial_recognition_csm",
      "word": "Facial Recognition",
      "definition": "a type of AI technology that can use a digital image of a face to identify a person",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "facial_recognition_csm"
      }
    },
    {
      "key": "intellectual_property",
      "word": "Intellectual Property",
      "definition": "A work or invention that is the result of creativity, such as a piece of writing or a design, to which one has rights and for which one may apply for a patent, copyright, trademark, etc.",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "intellectual_property"
      }
    },
    {
      "key": "lateral_reading_csm",
      "word": "Lateral Reading",
      "definition": "a method of determining credibility of online information in which you open multiple tabs to search for other information to validate the site’s claims",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "lateral_reading_csm"
      }
    },
    {
      "key": "misinformation_csm",
      "word": "Misinformation",
      "definition": "false or inaccurate information, especially that which is intended to deceive",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "misinformation_csm"
      }
    },
    {
      "key": "online_tracking_csm",
      "word": "Online Tracking",
      "definition": "apps, websites, or third parties collecting information about your online activity (other sites you visit, links you click, how long you stay, etc.)",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "online_tracking_csm"
      }
    },
    {
      "key": "personal_branding_csm",
      "word": "Personal Branding",
      "definition": "the practice of marketing yourself to the public using social media, a personal website, advertisements, or other non-digital tools",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "personal_branding_csm"
      }
    },
    {
      "key": "personalized_content_csm",
      "word": "Personalized Content",
      "definition": "information that a website or app shows you based on what they think you want to see",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "personalized_content_csm"
      }
    },
    {
      "key": "publisher_website_csm",
      "word": "Publisher (website)",
      "definition": "the person or company who created the website and its contents",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "publisher_website_csm"
      }
    },
    {
      "key": "rescinded_csm",
      "word": "Rescinded",
      "definition": "to take away or cancel",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "rescinded_csm"
      }
    },
    {
      "key": "targeted_advertising_csm",
      "word": "Targeted Advertising",
      "definition": "advertisements that are shown to you based on information that has been collected about you (location, browsing history, interests, age, etc.)",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "targeted_advertising_csm"
      }
    },
    {
      "key": "third_party_csm",
      "word": "Third-party",
      "definition": "a company other than the company that owns the website or app you are using",
      "properties": {
        "common_sense_media": true
      },
      "seeding_key": {
        "vocabulary.key": "third_party_csm"
      }
    }
  ],
