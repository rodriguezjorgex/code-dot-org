  "objectives": [
    {
      "key": "047bb8b3-1013-44d2-a30f-8b30a2540462",
      "properties": {
        "description": "Learn that they have a public presence online called a digital footprint."
      },
      "seeding_key": {
        "lesson.key": "lesson-4",
        "objective.key": "047bb8b3-1013-44d2-a30f-8b30a2540462"
      }
    },
    {
      "key": "0d0b6e13-f427-4d95-b984-705f21c60bfb",
      "properties": {
        "description": " Identify the benefits and drawbacks of online tracking to both companies and users."
      },
      "seeding_key": {
        "lesson.key": "lesson-5",
        "objective.key": "0d0b6e13-f427-4d95-b984-705f21c60bfb"
      }
    },
    {
      "key": "102b5581-238d-455a-bbee-76fd4c62a935",
      "properties": {
        "description": "Learn how to use lateral reading as a strategy to verify the accuracy of information online."
      },
      "seeding_key": {
        "lesson.key": "lesson-6",
        "objective.key": "102b5581-238d-455a-bbee-76fd4c62a935"
      }
    },
    {
      "key": "10f02043-a3be-4643-bef4-5c7436254c53",
      "properties": {
        "description": "Use the Take a Stand thinking routine to consider both the benefits and the risks of new technologies."
      },
      "seeding_key": {
        "lesson.key": "lesson-3",
        "objective.key": "10f02043-a3be-4643-bef4-5c7436254c53"
      }
    },
    {
      "key": "122a4cd2-2d13-4dfe-932d-c42cc6e2596f",
      "properties": {
        "description": "Identify important benefits and privacy risks that new technologies present."
      },
      "seeding_key": {
        "lesson.key": "lesson-3",
        "objective.key": "122a4cd2-2d13-4dfe-932d-c42cc6e2596f"
      }
    },
    {
      "key": "1d5417b7-628e-424f-ba35-0f171022f443",
      "properties": {
        "description": "Describe how clickbait can contribute to the spread of fake news and disinformation."
      },
      "seeding_key": {
        "lesson.key": "lesson-2",
        "objective.key": "1d5417b7-628e-424f-ba35-0f171022f443"
      }
    },
    {
      "key": "3c5e0ff6-8a5e-41ff-b26c-e13d835a30fb",
      "properties": {
        "description": "Decide whether or not the benefits of new technologies outweigh their privacy risks."
      },
      "seeding_key": {
        "lesson.key": "lesson-3",
        "objective.key": "3c5e0ff6-8a5e-41ff-b26c-e13d835a30fb"
      }
    },
    {
      "key": "45db538a-5894-456a-b07f-4c8a21e55937",
      "properties": {
        "description": "Identify examples of online behaviors that may hurt, embarrass, or offend others."
      },
      "seeding_key": {
        "lesson.key": "lesson-1",
        "objective.key": "45db538a-5894-456a-b07f-4c8a21e55937"
      }
    },
    {
      "key": "51d6d214-2f3a-4b5c-a17f-61366ec8a2f7",
      "properties": {
        "description": "Define online tracking and describe how companies use it."
      },
      "seeding_key": {
        "lesson.key": "lesson-5",
        "objective.key": "51d6d214-2f3a-4b5c-a17f-61366ec8a2f7"
      }
    },
    {
      "key": "7d6263e4-ef94-4451-8d90-29496cc38bf7",
      "properties": {
        "description": "Analyze specific examples of online tracking and take a position for or against them."
      },
      "seeding_key": {
        "lesson.key": "lesson-5",
        "objective.key": "7d6263e4-ef94-4451-8d90-29496cc38bf7"
      }
    },
    {
      "key": "a0c9f294-b8ac-42b4-96a3-50b7a6196ae8",
      "properties": {
        "description": "Use the Take a Stand thinking routine to consider different perspectives about whose responsibility it is to fight fake news and disinformation."
      },
      "seeding_key": {
        "lesson.key": "lesson-2",
        "objective.key": "a0c9f294-b8ac-42b4-96a3-50b7a6196ae8"
      }
    },
    {
      "key": "afd8cc9a-f54c-4ee4-9ed3-58b631513af6",
      "properties": {
        "description": "Use the Feelings & Options thinking routine to analyze and respond to a digital dilemma."
      },
      "seeding_key": {
        "lesson.key": "lesson-1",
        "objective.key": "afd8cc9a-f54c-4ee4-9ed3-58b631513af6"
      }
    },
    {
      "key": "c57e8bab-731d-4855-99ea-df359bb504bb",
      "properties": {
        "description": "Describe how advertisers and publishers make money through online advertising."
      },
      "seeding_key": {
        "lesson.key": "lesson-2",
        "objective.key": "c57e8bab-731d-4855-99ea-df359bb504bb"
      }
    },
    {
      "key": "cdd76c81-e08f-456c-b771-715717d33cbe",
      "properties": {
        "description": "Define \"misinformation\" and explore the consequences of spreading misinformation online."
      },
      "seeding_key": {
        "lesson.key": "lesson-6",
        "objective.key": "cdd76c81-e08f-456c-b771-715717d33cbe"
      }
    },
    {
      "key": "d4d063d2-b9ec-4221-80e0-6ba11def20b1",
      "properties": {
        "description": "Apply lateral reading to examples of questionable videos to determine their accuracy."
      },
      "seeding_key": {
        "lesson.key": "lesson-6",
        "objective.key": "d4d063d2-b9ec-4221-80e0-6ba11def20b1"
      }
    },
    {
      "key": "dad9eccc-894d-4da1-8f90-36fadd84bcc9",
      "properties": {
        "description": "Explain how copyright and Creative Commons Licenses can be applied to digital works of creativity"
      },
      "seeding_key": {
        "lesson.key": "Lesson 11: Intellectual Property",
        "objective.key": "dad9eccc-894d-4da1-8f90-36fadd84bcc9"
      }
    },
    {
      "key": "e706cded-c855-4a64-ac5c-172f5e6dfd83",
      "properties": {
        "description": "Recognize that any information they post online can help or hurt their future opportunities (college admission, employment, etc.)."
      },
      "seeding_key": {
        "lesson.key": "lesson-4",
        "objective.key": "e706cded-c855-4a64-ac5c-172f5e6dfd83"
      }
    },
    {
      "key": "e7e54bdb-2409-48bc-91e5-b928c7940672",
      "properties": {
        "description": "Argue if current copyright laws are helping or harming society using evidence from an article"
      },
      "seeding_key": {
        "lesson.key": "Lesson 11: Intellectual Property",
        "objective.key": "e7e54bdb-2409-48bc-91e5-b928c7940672"
      }
    },
    {
      "key": "efad24ae-025a-4129-88ba-c87d4eef4fff",
      "properties": {
        "description": "Create a vignette that shows how a positive digital footprint can help someone take advantage of an opportunity."
      },
      "seeding_key": {
        "lesson.key": "lesson-4",
        "objective.key": "efad24ae-025a-4129-88ba-c87d4eef4fff"
      }
    }
  ],
