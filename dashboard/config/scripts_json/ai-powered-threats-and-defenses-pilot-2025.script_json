      }
    },
    {
      "key": "bcfe4293-3344-491d-8dbc-7a703cc0dc80",
      "position": 3,
      "properties": {
        "description": "<i class=\"fa fa-check-square-o\" aria-hidden=\"true\"></i> **Do This:** Review the Key Vocabulary.\n\n<i class=\"fa fa-desktop\" aria-hidden=\"true\"></i> **Transition:** Direct students to Lesson 2, Level 7 to complete the End of Lesson Survey."
      },
      "seeding_key": {
        "activity_section.key": "bcfe4293-3344-491d-8dbc-7a703cc0dc80",
