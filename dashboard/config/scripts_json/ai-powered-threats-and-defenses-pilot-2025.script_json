  "vocabularies": [
    {
      "key": "aaa_tools",
      "word": "AAA tools",
      "definition": "a set of tools used in cybersecurity to help systems protect information and manage what users can do",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "aaa_tools"
      }
    },
    {
      "key": "access_control",
      "word": "access control",
      "definition": "rules a system uses to decide what you’re allowed to do once you’re logged in",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "access_control"
      }
    },
    {
      "key": "accounting",
      "word": "accounting",
      "definition": "when a system keeps track of what users do so suspicious activity can be detected and reviewed",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "accounting"
      }
    },
    {
      "key": "asymmetric_encryption",
      "word": "asymmetric encryption",
      "definition": "encryption that uses two different keys: a public key to lock the message and a private key to unlock it",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "asymmetric_encryption"
      }
    },
    {
      "key": "authentication",
      "word": "authentication",
      "definition": "the process a system uses to check that you are who you say you are",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "authentication"
      }
    },
    {
      "key": "availability",
      "word": "availability",
      "definition": "making information accessible to the people who need it, when they need it",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "availability"
      }
    },
    {
      "key": "cia_triad",
      "word": "CIA Triad",
      "definition": "a set of core rules for protecting information and stands for Confidentiality, Integrity, and Availability",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "cia_triad"
      }
    },
    {
      "key": "confidentiality",
      "word": "confidentiality",
      "definition": "keeping information private so only the right people can see it",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "confidentiality"
      }
    },
    {
      "key": "cybersecurity",
      "word": "cybersecurity",
      "definition": "the practice of protecting computers, networks, and personal data from being stolen, changed, or damaged",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "cybersecurity"
      }
    },
    {
      "key": "decryption",
      "word": "decryption",
      "definition": "the process of using a key to turn encrypted data back into its original form",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "decryption"
      }
    },
    {
      "key": "deepfake",
      "word": "deepfake",
      "definition": "a video or audio that has been manipulated using AI to look or sound like a real person",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "deepfake"
      }
    },
    {
      "key": "encryption",
      "word": "encryption",
      "definition": "a way to make data unreadable to anyone without the right key",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "encryption"
      }
    },
    {
      "key": "integrity",
      "word": "integrity",
      "definition": "ensuring that information stays correct and hasn't been changed without permission",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "integrity"
      }
    },
    {
      "key": "smishing",
      "word": "smishing",
      "definition": "a type of phishing that happens over text message (SMS)",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "smishing"
      }
    },
    {
      "key": "social_engineering",
      "word": "social engineering",
      "definition": "manipulating people into giving up private information or doing something risky",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "social_engineering"
      }
    },
    {
      "key": "symmetric_encryption",
      "word": "symmetric encryption",
      "definition": "encryption where the same key is used to lock and unlock the message",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "symmetric_encryption"
      }
    },
    {
      "key": "vishing",
