        "lesson_activity.key": "bba1b74b-f7d6-43e7-8051-895bf458a8e7"
      }
    },
    {
      "key": "a11b2c89-a878-48ea-8ae7-e433ed25ca29",
      "position": 2,
      "properties": {
      },
      "seeding_key": {
        "activity_section.key": "a11b2c89-a878-48ea-8ae7-e433ed25ca29",
