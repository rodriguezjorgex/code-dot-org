    {
      "key": "e4978f26-6261-4a01-82a8-686e0dc5e66c",
      "position": 12,
      "properties": {
        "description": "**Data for Social Good Project:** Use the rubric in the Data for Social Good Project Planning Guide to assess the projects.",
