    {
      "key": "c3ee440d-5c31-476e-b53e-f7f5eebc310a",
      "position": 8,
      "properties": {
        "description": "Congratulations! You have completed your data for social good project for this unit. Let's show off our work through a Gallery Walk so you can share your work with your classmates.",
