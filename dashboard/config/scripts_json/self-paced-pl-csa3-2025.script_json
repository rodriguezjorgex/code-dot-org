  "lessons": [
    {
      "key": "Introduction to Java Lab",
      "name": "Introduction to Java Lab",
      "absolute_position": 1,
      "lockable": false,
      "has_lesson_plan": false,
      "relative_position": 1,
      "properties": {
        "overview": "**You will:**\n\n* Create a new file in the Java Lab IDE\n* Name Java files using conventions for naming\n* Learn the basics of Java syntax\n* Print information to the console\n\n**Estimated time:** 60 minutes"
      },
      "seeding_key": {
        "lesson.key": "Introduction to Java Lab",
        "lesson_group.key": "",
        "script.name": "self-paced-pl-csa3-2025"
      }
    },
    {
      "key": "Variables in Java",
      "name": "Variables in Java",
      "absolute_position": 2,
      "lockable": false,
      "has_lesson_plan": false,
      "relative_position": 2,
      "properties": {
        "overview": "**You will:**\n\n* Describe the different primitive data types covered in the AP subset\n* Declare and initialize variables\n* Use the assignment operator and compound assignment operators\n* Use variables in arithmetic operations\n* Print variables and text to the console\n\n**Estimated time:** 60 minutes",
        "student_overview": "**You will:**\n\n* Describe the different primitive data types covered in the AP subset\n* Declare and initialize variables\n* Use the assignment operator and compound assignment operators\n* Use variables in arithmetic operations\n* Print variables and text to the console\n\n**Estimated time:** 90 minutes"
      },
      "seeding_key": {
        "lesson.key": "Variables in Java",
        "lesson_group.key": "",
        "script.name": "self-paced-pl-csa3-2025"
      }
    },
    {
      "key": "If statements in Java",
      "name": "If statements in Java",
      "absolute_position": 3,
      "lockable": false,
      "has_lesson_plan": false,
      "relative_position": 3,
      "properties": {
        "overview": "**You will:**\n\n* Evaluate boolean expressions\n* Write and read if, if-else, if-else-if-else statements\n* Describe the difference between the assignment operator and the comparison operator\n\n**Estimated time:** 90 minutes",
        "student_overview": "**You will:**\n\n* Evaluate boolean expressions\n* Write and read if, if-else, if-else-if-else statements\n* Describe the difference between the assignment operator and the comparison operator\n\n**Estimated time:** 90 minutes"
      },
      "seeding_key": {
        "lesson.key": "If statements in Java",
        "lesson_group.key": "",
        "script.name": "self-paced-pl-csa3-2025"
      }
    },
    {
      "key": "Loops in Java",
      "name": "Loops in Java",
      "absolute_position": 4,
      "lockable": false,
      "has_lesson_plan": false,
      "relative_position": 4,
      "properties": {
        "overview": "**You will:**\n\n* Read, write, and debug for loops in Java\n\n**Estimated time:** 60 minutes",
        "student_overview": "**You will:**\n\n* Read, write, and debug for loops in Java\n\n**Estimated time:** 90 minutes"
      },
      "seeding_key": {
        "lesson.key": "Loops in Java",
        "lesson_group.key": "",
        "script.name": "self-paced-pl-csa3-2025"
      }
    },
    {
