  "lessons": [
    {
      "key": "Mini-Project: Career Journeys ",
      "name": "Career Journeys for Elementary",
      "absolute_position": 1,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 1,
      "properties": {
        "overview": "In this lesson, students explore careers that use computer science and AI, then create a meaningful, interest-driven project in Sprite Lab that shows how technology is used in a job they care about. The content is designed to support all students, whether they’re new to coding or have prior experience, by offering flexible pacing. If your students are new to coding, consider spreading the lesson across several sessions. If they’ve used Sprite Lab before, one class period is enough."
      },
      "seeding_key": {
        "lesson.key": "Mini-Project: Career Journeys ",
        "lesson_group.key": "",
        "script.name": "career-journeys-for-elementary"
      }
    }
  ],
  "lesson_activities": [
    {
      "key": "fa778bf5-53f8-4934-8b2a-7832c764cc52",
      "position": 1,
      "properties": {
