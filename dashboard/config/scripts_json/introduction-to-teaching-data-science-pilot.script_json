      "key": "Introduction to Teaching Data Science",
      "name": "Introduction to Teaching Data Science",
      "absolute_position": 1,
      "lockable": false,
      "has_lesson_plan": false,
      "relative_position": 1,
      "properties": {
        "overview": "**In this lesson, you will:**\n\n- Get an introduction to teaching Data Science  \n- Define and explore foundational concepts of data science  \n- Explore features of the Data Science curriculum\n\n**Suggested Time:**  10 minutes  ",
        "student_overview": "**In this lesson, you will:**\n\n- Get an introduction to teaching Data Science  \n- Define and explore foundational concepts of data science  \n- Explore features of the Data Science curriculum\n\n**Suggested Time:**  10 minutes  "
      },
      "seeding_key": {
