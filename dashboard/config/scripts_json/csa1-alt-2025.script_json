    {
      "key": "f7ce6fbf-c940-43e4-81b0-7adb5e505a4a",
      "position": 8,
      "properties": {
        "description": "Congratulations! You have completed your first project for this class. Let's show off our work through a Gallery Walk so you can share your work with your classmates.",
