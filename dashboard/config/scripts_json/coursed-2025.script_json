    {
      "key": "ade32b60-de15-438d-8156-3911df7bacb6",
      "position": 3,
      "properties": {
        "description": "\n<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Display**: Show “Reflect” slide",
        "name": "Reflect"
      },
      "seeding_key": {
        "activity_section.key": "ade32b60-de15-438d-8156-3911df7bacb6",
