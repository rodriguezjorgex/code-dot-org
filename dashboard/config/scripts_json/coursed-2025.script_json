      "seeding_key": {
        "activity_section.key": "2e4daff6-af42-44e2-b692-ced8a1b9cb6a",
        "lesson_activity.key": "9b9abe28-1735-44ac-a458-aec6dc2540d2"
      }
    },
    {
      "key": "0befa788-3bc6-49ac-be2a-295cd8c2e47b",
      "position": 2,
      "properties": {
      },
      "seeding_key": {
        "activity_section.key": "0befa788-3bc6-49ac-be2a-295cd8c2e47b",
        "lesson_activity.key": "9b9abe28-1735-44ac-a458-aec6dc2540d2"
