    {
      "key": "0ae5a499-da37-446a-a3c9-c217c565e09f",
      "position": 3,
      "properties": {
        "progression_name": "Skill Building"
      },
      "seeding_key": {
        "activity_section.key": "0ae5a499-da37-446a-a3c9-c217c565e09f",
        "lesson_activity.key": "9b9abe28-1735-44ac-a458-aec6dc2540d2"
