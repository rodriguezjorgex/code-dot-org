    {
      "key": "ac6dd075-f162-493f-8259-6a1e3dc15031",
      "position": 1,
      "properties": {
        "description": "We are almost done with our project! You should be proud of what you have accomplished in this unit and this project.",
        "duration": "5",
        "name": "Warm Up",
        "remarks": true
