      "properties": {
        "description": "<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Do This:** Direct students to respond to the End of Project Reflection prompt on the Creative Coding with The Theater Project Planning Guide.",
        "name": "End of Project Reflection",
        "tips": [
          {
            "type": "teachingTip",
            "markdown": "If time permits, have students share their thoughts and ideas with a neighbor."
          }
        ]
      },
      "seeding_key": {
