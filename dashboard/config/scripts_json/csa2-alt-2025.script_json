    {
      "key": "1b067cf5-aab3-4d3c-a06c-0353114a2cdc",
      "position": 3,
      "properties": {
        "description": "**Creative Coding with the Console Project:** Use the rubric in the Creative Coding with the Console Project Planning Guide to assess the projects.",
        "name": "Assessment: Grading the Project"
      },
      "seeding_key": {
        "activity_section.key": "1b067cf5-aab3-4d3c-a06c-0353114a2cdc",
