    {
      "key": "0291fd95-e04b-43ce-b9e8-12ac4e5870bb",
      "position": 5,
      "properties": {
        "description": "This is a good time to commit our code and save our superclass and subclasses to the Backpack. Anytime we make changes to our programs, it is helpful to commit, or save, our work as a new version in case we need to revert to a previous version.",
        "duration": "15",
        "name": "Code Review",
        "remarks": true
