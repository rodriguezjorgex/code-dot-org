  "lessons": [
    {
      "key": "Sequencing - Explore",
      "name": "Sequencing - Explore",
      "absolute_position": 1,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 1,
      "properties": {
        "announcements": [
          {
            "key": "2f635d5a-70b6-4f4f-808e-8c42df337e21",
            "notice": "Just-In-Time Professional Learning",
            "details": "About to start these lessons on Sequencing? Feel prepared by reviewing our Self-Paced Professional Learning specifically for these lessons - in under 30 minutes!",
            "link": "https://studio.code.org/s/self-paced-pl-teaching-computer-science-discoveries-music-lab/lessons/2/levels/1",
            "type": "information",
            "visibility": "Teacher-only",
            "dismissible": false,
            "buttonText": "Start Now!"
          }
        ],
        "overview": "Students are introduced to sequencing by following step-by-step instructions to build a song. They learn how to layer tracks and use blocks like play together to combine sounds. Teachers guide discussions, highlight patterns, and encourage students to make predictions before running code.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be). \n\n- Print out the [Sequencing Cheat Sheet](https://drive.google.com/file/d/1wO6RJOBslmoDm2Wwua50BW2v6XpShcuV/view) to keep handy while reviewing students’ work on Check-In and Assessment levels"
      },
      "seeding_key": {
        "lesson.key": "Sequencing - Explore",
        "lesson_group.key": "",
        "script.name": "musiclab-instructions-bash"
      }
    },
    {
      "key": "Sequencing - Practice",
      "name": "Sequencing - Practice",
      "absolute_position": 2,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 2,
      "properties": {
        "overview": "Students practice sequencing by combining tracks of different lengths and adding rests to create offsets. Working in pairs, they apply concepts from the Explore lesson and build fluency through guided challenges. Teachers circulate to support and adjust instruction as needed.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Sequencing - Practice",
        "lesson_group.key": "",
        "script.name": "musiclab-instructions-bash"
      }
    },
    {
      "key": "Mini Project: Walk-Up Songs",
      "name": "Mini Project: Walk-Up Songs",
      "absolute_position": 3,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 3,
      "properties": {
        "overview": "Students create personalized walk-up songs for characters using everything they've learned about sequencing. They explore a new feature, triggers, to add flair and timing to their music. This creative project gives students space to express themselves while demonstrating mastery of key concepts.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Mini Project: Walk-Up Songs",
        "lesson_group.key": "",
        "script.name": "musiclab-instructions-bash"
      }
    },
    {
      "key": "Project: Genre Mash-Up",
      "name": "Project: Genre Mash-Up",
      "absolute_position": 4,
      "lockable": false,
      "has_lesson_plan": true,
      "relative_position": 4,
      "properties": {
        "overview": "In this end-of-unit project, students select an existing song and remix it into a new genre using the structure of functions. They draw on skills from the entire unit to define musical sections, apply abstraction, and shift tone or style, just like real-world remix artists.",
        "preparation": "- Review the levels from the curriculum and their example solutions. [Click here to see how to access example solutions](https://www.loom.com/share/36ee8c6709aa4e8dbe2449103e1b07be)."
      },
      "seeding_key": {
        "lesson.key": "Project: Genre Mash-Up",
        "lesson_group.key": "",
        "script.name": "musiclab-instructions-bash"
      }
    }
  ],
