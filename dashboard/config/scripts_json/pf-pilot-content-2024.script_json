    {
      "key": "6ee8aa4a-0633-4cc0-be53-e96a07e08e9f",
      "position": 1,
      "properties": {
        "description": "Here are several examples of objects. The objects have characteristics like has a lens, resolution, zoom level, size.etc. And they have actions they can do like, zoom, record video, record in slow motion.",
        "remarks": true
      },
      "seeding_key": {
        "activity_section.key": "6ee8aa4a-0633-4cc0-be53-e96a07e08e9f",
        "lesson_activity.key": "6cdb96a4-a6d3-49eb-a9ee-08bf2473d8b5"
      }
    },
    {
      "key": "2143d478-ecc7-4471-9add-22736d480d57",
      "position": 2,
      "properties": {
        "description": "<i class=\"fa fa-check-square-o\" aria-hidden=\"true\"></i> **Do This:** Put students in pairs.\n\n<i class=\"fa fa-check-square-o\" aria-hidden=\"true\"></i> **Do This:** Click through the animated slide to display the steps. Have students complete the steps with their partner recording their answers in their Unit Guide.",
        "tips": [
          {
            "type": "teachingTip",
            "markdown": "Activate prior knowledge about objects, characteristics, and actions in order to connect to objects, attributes and methods in Python during the activity."
          }
        ]
      },
      "seeding_key": {
        "activity_section.key": "2143d478-ecc7-4471-9add-22736d480d57",
        "lesson_activity.key": "6cdb96a4-a6d3-49eb-a9ee-08bf2473d8b5"
      }
    },
