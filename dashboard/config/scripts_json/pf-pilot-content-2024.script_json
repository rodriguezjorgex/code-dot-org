      }
    },
    {
      "key": "cf39e546-43c4-4a35-a4e3-8102775f1494",
      "position": 15,
      "properties": {
        "description": "<i class=\"fa fa-desktop\" aria-hidden=\"true\"></i> **Transition:** Direct students to complete Levels 4 and 5.\n- **Level 4:** Students choose a level to practice moving the `Painter`.\n- **Level 5:** Students choose a level to practice painting with the `Painter`.",
        "duration": "10",
        "name": "Practice"
      },
      "seeding_key": {
        "activity_section.key": "cf39e546-43c4-4a35-a4e3-8102775f1494",
