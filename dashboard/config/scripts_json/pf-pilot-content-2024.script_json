    {
      "key": "fb8bba1d-e8fb-4327-bec4-c9f944d79dfc",
      "position": 1,
      "properties": {
        "description": "<i class=\"fa fa-check-square-o\" aria-hidden=\"true\"></i> **Do This:** Review the learning objectives.\n\n<i class=\"fa fa-check-square-o\" aria-hidden=\"true\"></i> **Do This:** Read the Question of the Day aloud for students. Give students a moment to think about and record their answer individually in their Unit Guide.\n\n<i class=\"fa fa-refresh\" aria-hidden=\"true\"></i> **Circulate:** Look for students who might be unsure of their response and provide guidance. ",
        "tips": [
          {
            "type": "assessmentOpportunity",
            "markdown": "The question of the day in the Unit Guide can be used to assess the lesson objectives."
          }
        ]
      },
      "seeding_key": {
