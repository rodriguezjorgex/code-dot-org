      "position": 2,
      "properties": {
        "description": "<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Do This:** Direct students to respond to the prompt on the Natural Language Processing Project Planning Guide.",
        "tips": [
          {
            "type": "teachingTip",
            "markdown": "If time permits, have students share their thoughts and ideas with a neighbor."
          }
        ]
      },
      "seeding_key": {
        "activity_section.key": "c40954b7-af7b-48a6-b257-2f7d1cf18392",
        "lesson_activity.key": "55e5f698-887c-4814-8d1e-6683aef0ba50"
      }
    },
    {
      "key": "31225081-dd57-42d6-b76c-2831f4043c87",
      "position": 3,
      "properties": {
        "description": "Continue to work on your Natural Language Processing Project. Be sure to refer to the project requirements and rubric to make sure you include the necessary components.",
        "duration": "10",
