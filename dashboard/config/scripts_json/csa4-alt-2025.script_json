    {
      "key": "99865bd1-b38f-4b41-a009-961fe03567e8",
      "position": 2,
      "properties": {
        "description": "**Group:** Place students in pairs.\n\n<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Do This:** Review the instructions for playing CS Pyramid.\n\n<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Do This:** Play the music clip to cue the CS Pyramid activity, and direct students to play CS Pyramid. Click through the animated slide to display each pyramid, and direct students to switch roles with each new pyramid."
      },
      "seeding_key": {
        "activity_section.key": "99865bd1-b38f-4b41-a009-961fe03567e8",
