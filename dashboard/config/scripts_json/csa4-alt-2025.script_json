      "position": 2,
      "properties": {
        "description": "<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Do This:** Direct students to Level 1 on Code Studio to develop their Abstract Data Art Good Project.",
        "duration": "20",
        "name": "Development",
        "progression_name": "Abstract Data Art Project"
      },
