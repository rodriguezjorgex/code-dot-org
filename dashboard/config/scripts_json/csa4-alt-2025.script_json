    {
      "key": "c4a02f33-dbfa-477d-bdc0-a710d8e016d8",
      "position": 11,
      "properties": {
        "description": "<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Do This:** Have students complete a short end-of-unit survey. Although their answers are anonymous, the aggregated data will be available to you once at least five students have completed the survey.",
        "name": "End of Unit Survey",
        "progression_name": "End of Unit Survey",
        "tips": [
          {
            "type": "teachingTip",
            "markdown": "We also have a teacher end-of-unit survey to learn more about how the unit went for you and your students. While students take their survey, please complete [**this end of unit survey for teachers**](https://studio.code.org/form/teacher_end_of_unit_survey?survey_data%5Bunit_number%5D=3) as well. Your feedback is valued and appreciated!"
          }
