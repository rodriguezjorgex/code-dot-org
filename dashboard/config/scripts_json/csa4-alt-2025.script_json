      "position": 10,
      "properties": {
        "description": "<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Do This:** Have students create a prioritized list of upgrades, changes, and things they still need to complete on the Personal Narrative Project Planning Guide based on the feedback they received from the code review.",
        "tips": [
          {
            "type": "teachingTip",
            "markdown": "If students finish their prioritized list early, encourage them to start working on their #1 priority."
          }
        ]
      },
      "seeding_key": {
