        "lesson_activity.key": "0c5e4471-3923-476e-97ba-5ebfa9146d3a"
      }
    },
    {
      "key": "ef15f1d1-e275-4e0c-8277-accd91615592",
      "position": 3,
      "properties": {
        "description": "<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Display:** Key Vocabulary"
      },
