    {
      "key": "f06ac072-fb83-4d7e-b2be-d8cd5335f42e",
      "position": 3,
      "properties": {
        "description": "<i class=\"fa fa-list-alt\" aria-hidden=\"true\"></i> **Do This:** Review the steps for Day 3 of the project.",
