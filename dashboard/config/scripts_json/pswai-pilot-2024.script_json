    {
      "key": "ebb096bc-4107-4a70-910d-9e2efd871726",
      "position": 5,
      "properties": {
        "description": "<i class=\"fa fa-check-square-o\" aria-hidden=\"true\"></i> **Do This:** Read the example aloud, then direct students to move to the spot on the spectrum that matches their opinion.",
        "tips": [
          {
            "type": "teachingTip",
            "markdown": "Consider highlighting the example of the 2023, AI-generated song with the voices of Drake and The Weeknd going viral even though neither artist was involved."
          }
        ]
      },
