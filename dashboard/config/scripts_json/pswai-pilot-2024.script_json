    {
      "key": "d84b7cab-5d68-45df-a8d9-2f44d3db5277",
      "position": 7,
      "properties": {
        "description": "<i class=\"fa fa-check-square-o\" aria-hidden=\"true\"></i> **Do This:** Read the example aloud, then direct students to move to the spot on the spectrum that matches their opinion.\n\n<i class=\"fa fa-check-square-o\" aria-hidden=\"true\"></i> **Do This:** Read the example aloud, then direct students to move to the spot on the spectrum that matches their opinion.\n\n<i class=\"fa fa-check-square-o\" aria-hidden=\"true\"></i> **Do This:** Read the example aloud, then direct students to move to the spot on the spectrum that matches their opinion.",
        "tips": [
          {
            "type": "teachingTip",
            "markdown": "Consider highlighting the example of CNET, in 2023, publishing dozens of AI-written articles in 2023, many with factual errors or plagiarism, leading to public backlash."
          }
        ]
      },
      "seeding_key": {
        "activity_section.key": "d84b7cab-5d68-45df-a8d9-2f44d3db5277",
        "lesson_activity.key": "3251a330-ea88-448e-b2fd-fb96a9a6ed5a"
      }
    },
    {
      "key": "66b3f19c-5eb3-45f2-a124-bbccc1e727cb",
      "position": 8,
      "properties": {
      },
      "seeding_key": {
        "activity_section.key": "66b3f19c-5eb3-45f2-a124-bbccc1e727cb",
