  "vocabularies": [
    {
      "key": "digital_divide",
      "word": "digital divide",
      "definition": "the gap between people who have easy access to the Internet and technology and those who do not, often due to differences in income, location, or resources",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "digital_divide"
      }
    },
    {
      "key": "domain_name_system_dns_",
      "word": "Domain Name System (DNS)",
      "definition": "a system that translates human-friendly website names (like www.example.com) into numerical IP addresses that computers use to find and communicate with each other on the Internet",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "domain_name_system_dns_"
      }
    },
    {
      "key": "hypertext_transfer_protocol_http_",
      "word": "HyperText Transfer Protocol (HTTP)",
      "definition": "a protocol that allows computers to request and share web content, like webpages, images, and videos",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "hypertext_transfer_protocol_http_"
      }
    },
    {
      "key": "internet_tower",
      "word": "Internet tower",
      "definition": "a piece of infrastructure that sends and receives wireless signals",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "internet_tower"
      }
    },
    {
      "key": "ip_address",
      "word": "IP address",
      "definition": "a unique number assigned to each device on a network",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "ip_address"
      }
    },
    {
      "key": "net_neutrality",
      "word": "Net Neutrality",
      "definition": "the idea that all websites and online services should be treated equally by Internet providers",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "net_neutrality"
      }
    },
    {
      "key": "router",
      "word": "router",
      "definition": "a type of computer that forwards data across a network",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "router"
      }
    },
    {
      "key": "server",
      "word": "server",
      "definition": "a powerful computer that stores and delivers websites, files, and messages when requested by a user",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "server"
      }
    },
    {
      "key": "switch",
      "word": "switch",
      "definition": "a component that helps send data to the right place inside a local network",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "switch"
      }
    },
    {
      "key": "transmission_control_protocol_tcp_",
      "word": "Transmission Control Protocol (TCP)",
      "definition": "a protocol that ensures that all parts of a message are received and ordered correctly",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "transmission_control_protocol_tcp_"
      }
    },
    {
      "key": "user_datagram_protocol_udp_",
      "word": "User Datagram Protocol (UDP)",
      "definition": "a protocol that focuses on speed and does not guarantee all packets arrive",
      "properties": {
      },
      "seeding_key": {
        "vocabulary.key": "user_datagram_protocol_udp_"
      }
    }
  ],
