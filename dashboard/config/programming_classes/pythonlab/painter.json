  "fields": "[{\"name\":\"x_location\",\"type\":\"int\",\"description\":\"the x coordinate of the `Painter` object\"},{\"name\":\"y_location\",\"type\":\"int\",\"description\":\"the y coordinate of the `Painter` object\"},{\"name\":\"direction\",\"type\":\"string\",\"description\":\"the direction the `Painter` object is facing (`\\\"North\\\"`, `\\\"South\\\"`, `\\\"East\\\"`, or `\\\"West\\\"`)\"}]",
