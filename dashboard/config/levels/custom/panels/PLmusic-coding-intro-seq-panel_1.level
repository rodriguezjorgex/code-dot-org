  <config><![CDATA[{
  "published": true,
  "game_id": 73,
  "created_at": "2025-02-05T22:34:20.000Z",
  "level_num": "custom",
  "user_id": 18605,
  "properties": {
    "encrypted": "false",
    "panels": [
      {
        "text": "#### Click next for an overview of the Music Lab platform. ",
        "imageUrl": "https://images.code.org/5234d8faef5afb0152365043af53a647-Screenshot 2025-02-05 at 3.47.11 PM.png",
        "key": "music-coding-intro-seq-panel-5c8e1776-1332-425c-8237-86189507ca3c",
        "layout": "text-top-center",
        "fadeInOverPrevious": true
      },
      {
        "text": "#### This is what the student view of Music Lab looks like. Directions are shown here.",
        "imageUrl": "https://images.code.org/4846ded901431f36e4ce9b42884b20f2-Untitled design.jpg",
        "key": "music-coding-intro-seq-panel-eef7e23a-96dd-448a-a2c6-7e458e637905",
        "layout": "text-bottom-left",
        "fadeInOverPrevious": true
      },
      {
        "text": "#### This module includes additional teacher tips and hints that students will not see. ",
        "imageUrl": "https://images.code.org/3afea108d11663bba85c3c636e3589b6-Screenshot 2025-02-07 at 9.24.27 AM.png",
        "key": "PLmusic-coding-intro-seq-panel_1-34c7ae8a-4234-4e44-aabc-1afa35b4c8de",
        "layout": "text-bottom-right"
      },
      {
        "text": "#### The directions that students see will be below any teacher tips and hints. ",
        "imageUrl": "https://images.code.org/77c5249fb1335039ed86c39feaed62a9-Screenshot 2025-02-07 at 9.26.22 AM.png",
        "key": "PLmusic-coding-intro-seq-panel_1-5e510044-a37a-47d5-bc34-b15d7af7911c",
        "layout": "text-bottom-right"
      },
      {
        "text": "#### After running code, feedback messages are shown here. ",
        "imageUrl": "https://images.code.org/aa58f4579d8d288d3f2146f684d128da-Untitled design (2).jpg",
        "key": "PLmusic-coding-intro-seq-panel_1-072027bf-4a76-4a83-b71c-b26c84e48317",
        "layout": "text-bottom-left",
        "fadeInOverPrevious": true
      },
      {
        "text": "#### Bold words in the instructions are call outs. When clicked, call outs provide a visual hint using a blue arrow. ",
        "imageUrl": "https://images.code.org/29e2e405ba4fda45299ae5b17881e1f4-bold words.gif",
        "key": "music-coding-intro-seq-panel-d44bed52-d4c8-45eb-9e23-4821e9210a2d",
        "layout": "text-bottom-center",
        "fadeInOverPrevious": true
      },
      {
        "text": "If there is no code in the workspace, a hint will be given. ",
        "imageUrl": "https://images.code.org/161fe2b22073965a30811614beec267b-feedback.gif",
        "key": "PLmusic-coding-intro-seq-panel_1-23eca036-2ed7-4e70-b0e6-e3139acbff7a",
        "layout": "text-bottom-right",
        "fadeInOverPrevious": true
      },
      {
        "text": "#### In Music Lab, there is no dropdown arrow to make selections in your code. Click directly on the box to change the code. ",
        "imageUrl": "https://images.code.org/44694a1655aa4b5c6b45fd775b605b6a-down arrow.gif",
        "key": "PLmusic-coding-intro-seq-panel_1-e92de425-c829-4bcf-a83b-9c10b9405fe4"
      }
    ],
    "offer_browser_tts": "true",
    "name_suffix": "_1"
  },
