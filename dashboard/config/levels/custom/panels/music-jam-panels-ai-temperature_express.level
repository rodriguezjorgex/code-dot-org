    "panels": [
      {
        "text": "You can now change A.I.'s temperature to make its predictions more adventurous. ",
        "imageUrl": "https://images.code.org/3c00bbf0b268c3f84819ce6fccd76b2e-AI Temp Panel_1.jpeg",
