<Panels>
  <config><![CDATA[{
  "published": true,
  "game_id": 73,
  "created_at": "2025-08-29T15:34:25.000Z",
  "level_num": "custom",
  "user_id": 18605,
  "properties": {
    "encrypted": "false",
    "offer_browser_tts": "false",
    "panels": [
      {
        "text": "###BEHIND THE SCENES\nHow does AI make new images using words you choose?\n",
        "imageUrl": "https://images.code.org/f4e72135e0159235245e9bdabf4bb338-text .gif",
        "key": "Generate_dancer_info-e349bed8-89d6-4efc-8a0e-29b8a1e5afb1",
        "layout": "text-bottom-right"
      },
      {
        "text": "AI has learned from watching images turn into noise many, many times.",
        "imageUrl": "https://images.code.org/9a1d25b5aa76b3a6c9b4e0fabdd11b21-scan.gif",
        "key": "Generate_dancer_info-35731f8b-92f2-4309-954a-d8481cc58b14",
        "layout": "text-top-center"
      },
      {
        "text": "After lots of practice, this tool can start with a lot of noise...",
        "imageUrl": "https://images.code.org/5744367bcf7b79063f715cc930c1ad54-noise1.jpg",
        "key": "Generate_dancer_info-93102ee9-aa96-4429-aafb-52f8fe7fd787",
        "layout": "text-top-center"
      },
      {
        "text": "Then slowly remove the noise...",
        "imageUrl": "https://images.code.org/f99ba1c8919dd4a405883ba98572f77b-noise2.jpg",
        "key": "Generate_dancer_info-07287924-c7c1-45c4-86e6-1dc2621827a0",
        "layout": "text-top-center"
      },
      {
        "text": "When it removes all noise it shows a picture that matches your prompt. \n\nYou choose to accept the image, have AI try again or make a new prompt. ",
        "imageUrl": "https://images.code.org/9c60620148ebcefaca6d8e52792953ba-noise3.jpg",
        "key": "Generate_dancer_info-54a8b63a-7ea3-4479-8c8a-170fba853898",
        "layout": "text-top-center"
      }
    ]
  },
