                </block>
              </value>
              <next>
                <block type="Poetry_setBackgroundEffect">
                  <title name="EFFECT">"darkCircles"</title>
                  <title name="PALETTE">"sunset"</title>
                  <next>
                    <block type="Poetry_startBehavior">
                      <title name="ANIMATION_NAME">"flowers_white"</title>
                      <title name="BEHAVIOR">shrinking</title>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="Poetry_whenLineShows">
          <title name="N">3</title>
