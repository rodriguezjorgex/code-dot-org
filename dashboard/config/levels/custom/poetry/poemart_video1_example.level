                  <title name="SPRITE">"flowers_white"</title>
                  <title name="VAL">200</title>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="Poetry_whenLineShows">
          <title name="N">1</title>
          <next>
            <block type="Poetry_setForegroundEffect">
              <title name="EFFECT">"rain"</title>
              <next>
                <block type="Poetry_setForegroundEffect">
                  <title name="EFFECT">"rain"</title>
                  <next>
                    <block type="Poetry_startBehavior">
                      <title name="ANIMATION_NAME">"flowers_white"</title>
                      <title name="BEHAVIOR">jittering</title>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="Poetry_whenLineShows">
          <title name="N">2</title>
          <next>
            <block type="Poetry_setFontColor">
