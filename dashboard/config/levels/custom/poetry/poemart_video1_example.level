  <blocks>
    <start_blocks>
      <xml>
        <block type="when_run">
          <next>
            <block type="Poetry_makeNewSpriteAnon">
              <title name="ANIMATION_NAME">"flowers_white"</title>
              <title name="LOCATION">{"x":200,"y":252}</title>
