              <title name="EFFECT">"fadeColors"</title>
              <title name="PALETTE">"rainbow"</title>
              <next>
                <block type="Poetry_stopBehavior">
                  <title name="ANIMATION_NAME">"flowers_white"</title>
                  <title name="BEHAVIOR">shrinking</title>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="Poetry_whenLineShows">
