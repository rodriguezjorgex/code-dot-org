          <next>
            <block type="Poetry_startBehavior">
              <title name="ANIMATION_NAME">"flowers_white"</title>
              <title name="BEHAVIOR">spinning_right</title>
              <next>
                <block type="Poetry_startBehavior">
                  <title name="ANIMATION_NAME">"flowers_white"</title>
                  <title name="BEHAVIOR">wandering</title>
                  <next>
                    <block type="Poetry_makeBurst">
                      <title name="EFFECT">"pop"</title>
                      <title name="NUM">10</title>
                      <title name="ANIMATION_NAME">"twinkling_star"</title>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
      </xml>
    </start_blocks>
