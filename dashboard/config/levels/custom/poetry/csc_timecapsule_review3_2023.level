    "display_name": "Set text effect",
    "thumbnail_url": "https://images.code.org/a2b20db2eb2c66edcd4b518aa185592c-animate poem.gif",
    "validation_code": "var validationInfo = getValidationInfo();\r\nvar hasTextEffect = validationInfo.textEffects.length > 0;\r\nif (World.frameCount == 1) {\r\n\tsetFailTime(100); // Frames to wait before failing student\r\n  \tsetDelayTime(420); // Frames to wait after success before stopping program\r\n   setSuccessMessage('reinfFeedbackMsg');\r\n  \taddCriteria(function() {\r\n      return (hasTextEffect);\r\n\t}, \"noTextEffect\");\r\n}\r\n\r\ncheck();",
    "short_instructions": "Set a text effect for your poem.",
    "preload_asset_list": null
  },
