    "start_sources": {
      "DocumentRunner.java": {
        "text": "import java.util.ArrayList;\n\npublic class DocumentRunner {\n  public static void main(String[] args) {\n    \n    ArrayList<String> documentWords = new ArrayList<String>();\n    documentWords.add(\"Thank\");\n    documentWords.add(\"you\");\n    documentWords.add(\"for\");\n    documentWords.add(\"the\");\n    documentWords.add(\"help\");\n    documentWords.add(\"You\");\n    documentWords.add(\"were\");\n    documentWords.add(\"very\");\n    documentWords.add(\"kind\");\n    \n    ArrayList<String> functionWords = new ArrayList<String>();\n    functionWords.add(\"a\");\n    functionWords.add(\"an\");\n    functionWords.add(\"the\");\n    functionWords.add(\"and\");\n    functionWords.add(\"but\");\n    functionWords.add(\"or\");\n    functionWords.add(\"in\");\n    functionWords.add(\"on\");\n    functionWords.add(\"at\");\n    functionWords.add(\"he\");\n    functionWords.add(\"she\");\n    functionWords.add(\"they\");\n    functionWords.add(\"am\");\n    functionWords.add(\"is\");\n    functionWords.add(\"are\");\n    functionWords.add(\"was\");\n    functionWords.add(\"were\");\n\n    // Create a Document object\n    Document document = new Document(documentWords, functionWords);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the removeFunctionWords() method and print the result\n     * -----------------------------------------------------------------------------\n     */\n\n    \n    \n  }\n}",
        "isVisible": true,
        "tabOrder": 0
      },
      "Document.java": {
        "text": "import java.util.ArrayList;\n\n/*\n * Represents a document\n */\npublic class Document {\n\n  private ArrayList<String> documentWords; // document text\n  private ArrayList<String> functionWords; // function words\n\n  public Document(ArrayList<String> documentWords, ArrayList<String>functionWords) {\n    this.documentWords = documentWords;\n    this.functionWords = functionWords;\n  }\n  \n  \n  public ArrayList<String> removeFunctionWords() {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Remove all function words from documentWords and return documentWords\n     * -----------------------------------------------------------------------------\n     */\n\n    return null;\n  }\n  \n}",
        "isVisible": true,
        "tabOrder": 1
      }
    },
