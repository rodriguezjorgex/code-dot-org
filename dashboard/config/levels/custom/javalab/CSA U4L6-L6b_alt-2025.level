    "ai_tutor_available": "false",
    "start_sources": {
      "VideoRunner.java": {
        "text": "public class VideoRunner {\n  public static void main(String[] args) {\n\n    // Creates Video objects \n    Video v1 = new Video(\"The Lion King\", 1994);\n    Video v2 = new Video(\"Beauty and the Beast\", 1991);\n    Video v3 = new Video(\"Aladdin\", 1992);\n    Video v4 = new Video(\"Frozen\", 2013);\n    Video v5 = new Video(\"Moana\", 2016);\n\n    // Creates a Catalog object\n    Catalog videoCatalog = new Catalog(v1, v2, v3, v4, v5);\n\n    // Creates two Video objects to find\n    Video frozen = new Video(\"Frozen\", 2013);\n    Video toyStory = new Video(\"Toy Story\", 1995);\n\n    // Calls the findMatchingVideo() method and prints the result\n    System.out.println(videoCatalog.findMatchingVideo(frozen) + \"\\n\");\n    System.out.println(videoCatalog.findMatchingVideo(toyStory));\n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Catalog.java": {
        "text": "/*\n * Represents a catalog of videos\n */\npublic class Catalog {\n\n  private Video v1;\n  private Video v2;\n  private Video v3;\n  private Video v4;\n  private Video v5;\n\n  /*\n   * Initializes the catalog with 5 Video objects\n   */\n  public Catalog(Video v1, Video v2, Video v3, Video v4, Video v5) {\n    this.v1 = v1;\n    this.v2 = v2;\n    this.v3 = v3;\n    this.v4 = v4;\n    this.v5 = v5;\n  }\n\n  /*\n   * Returns a String containing information about the Video\n   * object that has the same title as the parameter videoToFind\n   */\n  public String findMatchingVideo(Video videoToFind) {\n    String result = \"\";\n\n    // Bug for students to fix: should use equals(), not ==\n    if (v1 == videoToFind) {\n      result += \"Matching video found!\\n\" + v1;\n    }\n    if (v2 == videoToFind) {\n      result += \"Matching video found!\\n\" + v2;\n    }\n    if (v3 == videoToFind) {\n      result += \"Matching video found!\\n\" + v3;\n    }\n    if (v4 == videoToFind) {\n      result += \"Matching video found!\\n\" + v4;\n    }\n    if (v5 == videoToFind) {\n      result += \"Matching video found!\\n\" + v5;\n    }\n\n    if (result.equals(\"\")) {\n      result += \"No matching video found.\";\n    }\n\n    return result;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Video.java": {
        "text": "/*\n * Represents a video\n */\npublic class Video {\n\n  private String title;     // The title of a video\n  private int year;         // The year the video was released\n\n  /*\n   * Sets title to the specified title and year to the specified year\n   */\n  public Video(String title, int year) {\n    this.title = title;\n    this.year = year;\n  }\n\n  /*\n   * Returns the title of the video\n   */\n  public String getTitle() {\n    return title;\n  }\n\n  /*\n   * Returns the year of the video\n   */\n  public int getYear() {\n    return year;\n  }\n\n  /*\n   * Returns true if the title of other is the same as this Video\n   */\n  public boolean equals(Object other) {\n    if (other == this) {\n      return true;\n    }\n\n    if (!(other instanceof Video)) {\n      return false;\n    }\n\n    Video otherVideo = (Video) other;\n    return this.title.equals(otherVideo.title);\n  }\n\n  /*\n   * Returns a String containing the video's title\n   */\n  public String toString() {\n    return title + \"(\" + year + \")\";\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      }
    }
  },
  "published": true,
  "audit_log": "[{\"changed_at\":\"2024-08-02T22:18:07.267+00:00\",\"changed\":[\"cloned from \\\"CSA U4L6-L6b_pilot-2025\\\"\"],\"cloned_from\":\"CSA U4L6-L6b_pilot-2025\"},{\"changed_at\":\"2025-05-26 01:11:28 +0000\",\"changed\":[\"long_instructions\",\"contained_level_names\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-26 01:12:12 +0000\",\"changed\":[\"start_sources\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-26 01:12:26 +0000\",\"changed\":[\"encrypted_validation\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-26 01:12:53 +0000\",\"changed\":[\"encrypted_exemplar_sources\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"}]"
