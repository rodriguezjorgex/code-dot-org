      "ScheduleRunner.java": {
        "text": "public class ScheduleRunner {\n  public static void main(String[] args) {\n    \n    SchoolDay day = new SchoolDay();\n    System.out.println(day.getSchedule());\n    \n  }\n}",
        "isVisible": true,
        "tabOrder": 0
      },
      "SchoolDay.java": {
        "text": "/*\n * Represents a student's school day\n */\npublic class SchoolDay {\n\n  \n\n  /*\n   * Returns a schedule showing time spent in different classes\n   */\n  public String getSchedule() {\n    String result = \"My School Day\\n---------------\\n\";\n\n    result += \"Math: \" + (6 * 0.25) + \" hours\\n\";\n    result += \"English: \" + (6 * 0.20) + \" hours\\n\";\n    result += \"Science: \" + (6 * 0.30) + \" hours\\n\";\n    result += \"Electives: \" + (6 * 0.25) + \" hours\\n\";\n\n    return result;\n  }\n}",
        "isVisible": true,
        "tabOrder": 1
      }
    },
