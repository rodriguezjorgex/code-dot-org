      "NamesRunner.java": {
        "text": "public class NamesRunner {\n  public static void main(String[] args) {\n\n    Names topNames = new Names(\"Jayden\", \"Aiden\", \"Joshua\", \"Daniel\", \"Nathaniel\");\n\n    System.out.println(\"Top Baby Names:\");\n    System.out.println(topNames.rankedList());\n\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Names.java": {
        "text": "/*\n * Stores popular name data\n */\npublic class Names {\n\n  private String name1, name2, name3, name4, name5;\n\n  /*\n   * Initializes five name values\n   */\n  public Names(String n1, String n2, String n3, String n4, String n5) {\n    name1 = n1;\n    name2 = n2;\n    name3 = n3;\n    name4 = n4;\n    name5 = n5;\n  }\n\n  /*\n   * Returns a ranked list of the names (e.g., \"1. Jayden\")\n   */\n  public String rankedList() {\n    String result = \"\";\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use a for loop to build a string that looks like:\n     *    1. Jayden\n     *    2. Aiden\n     *    ...\n     * -----------------------------------------------------------------------------\n     */\n\n    return result;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
