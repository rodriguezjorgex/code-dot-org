      "SalaryRunner.java": {
        "text": "public class SalaryRunner {\n  public static void main(String[] args) {\n\n    // Sample software engineer salaries\n    int salary1 = 145000;\n    int salary2 = 115000;\n    int salary3 = 112000;\n    int salary4 = 133000;\n    int salary5 = 104000;\n\n    // Create a Salary object\n    Salary research = new Salary();\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call getDeviation() with the five salaries and print the result.\n     * -----------------------------------------------------------------------------\n     */\n    \n\n\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Salary.java": {
        "text": "/*\n * Analyzes software engineering salaries\n */\npublic class Salary {\n\n  private String researcherName;\n\n  /*\n   * Initializes the researcher's name\n   */\n  public Salary() {\n    researcherName = \"Software Salary Analyst\";\n  }\n\n  /*\n   * Returns the researcher's name\n   */\n  public String getResearcherName() {\n    return researcherName;\n  }\n\n  /*\n   * Returns the standard deviation of five salaries\n   */\n  public double getDeviation(int s1, int s2, int s3, int s4, int s5) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use the average of all five salaries to compute and return the\n     * standard deviation using Math.sqrt().\n     * -----------------------------------------------------------------------------\n     */\n    return 0.0;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    }
