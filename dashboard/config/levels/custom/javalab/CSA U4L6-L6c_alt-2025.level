    "start_sources": {
      "PlaylistRunner.java": {
        "text": "public class PlaylistRunner {\n  public static void main(String[] args) {\n\n    // Creates Song objects\n    Song s1 = new Song(\"Eye of the Tiger\");\n    Song s2 = new Song(\"I Will Survive\");\n    Song s3 = new Song(\"Don't Stop Believin'\");\n    Song s4 = new Song(\"Stronger\");\n    Song s5 = new Song(\"Hero\");\n\n    // Creates a Playlist object\n    Playlist inspire = new Playlist(s1, s2, s3, s4, s5);\n\n    // Creates first test Playlist with same titles\n    Playlist first = new Playlist(\n      new Song(\"Eye of the Tiger\"), \n      new Song(\"I Will Survive\"),\n      new Song(\"Don't Stop Believin'\"),\n      new Song(\"Stronger\"),\n      new Song(\"Hero\")\n    );\n\n    // Creates second test Playlist with different titles\n    Playlist second = new Playlist(\n      new Song(\"Beautiful\"), \n      new Song(\"I Will Survive\"),\n      new Song(\"Hall of Fame\"),\n      new Song(\"Stronger\"),\n      new Song(\"We Are the Champions\")\n    );\n\n    // Calls the findMatchingPlaylist() method and prints the result\n    System.out.println(inspire.findMatchingPlaylist(first) + \"\\n\");\n    System.out.println(inspire.findMatchingPlaylist(second));\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Playlist.java": {
        "text": "/*\n * Represents a playlist\n */\npublic class Playlist {\n\n  private Song s1, s2, s3, s4, s5;\n\n  /*\n   * Initializes the playlist with 5 Song objects\n   */\n  public Playlist(Song s1, Song s2, Song s3, Song s4, Song s5) {\n    this.s1 = s1;\n    this.s2 = s2;\n    this.s3 = s3;\n    this.s4 = s4;\n    this.s5 = s5;\n  }\n\n  /*\n   * Returns a String indicating whether all song titles match\n   */\n  public String findMatchingPlaylist(Playlist other) {\n    boolean allSame = true;\n\n    if (this.s1 != other.s1) {\n      allSame = false;\n    }\n    if (this.s2 != other.s2) {\n      allSame = false;\n    }\n    if (this.s3 != other.s3) {\n      allSame = false;\n    }\n    if (this.s4 != other.s4) {\n      allSame = false;\n    }\n    if (this.s5 != other.s5) {\n      allSame = false;\n    }\n\n    if (allSame) {\n      return \"All of the songs are the same!\";\n    } else {\n      return \"Not all of the songs are the same.\";\n    }\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Song.java": {
        "text": "/*\n * Represents a song\n */\npublic class Song {\n\n  private String title;\n\n  /*\n   * Sets title to the specified title\n   */\n  public Song(String title) {\n    this.title = title;\n  }\n\n  /*\n   * Returns the title of the song\n   */\n  public String getTitle() {\n    return title;\n  }\n\n  /*\n   * Returns true if the title of other is the same as this Song\n   */\n  public boolean equals(Object other) {\n    if (other == this) {\n      return true;\n    }\n\n    if (!(other instanceof Song)) {\n      return false;\n    }\n\n    Song otherSong = (Song) other;\n    return this.title.equals(otherSong.title);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      }
    }
  },
  "published": true,
  "audit_log": "[{\"changed_at\":\"2024-08-02T22:18:07.430+00:00\",\"changed\":[\"cloned from \\\"CSA U4L6-L6c_pilot-2025\\\"\"],\"cloned_from\":\"CSA U4L6-L6c_pilot-2025\"},{\"changed_at\":\"2025-05-26 01:20:12 +0000\",\"changed\":[\"long_instructions\",\"contained_level_names\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-26 01:21:02 +0000\",\"changed\":[\"start_sources\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-26 01:21:04 +0000\",\"changed\":[\"encrypted_validation\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-26 01:21:50 +0000\",\"changed\":[\"encrypted_exemplar_sources\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"}]"
