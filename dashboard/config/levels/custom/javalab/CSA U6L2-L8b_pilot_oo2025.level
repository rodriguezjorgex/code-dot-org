    "start_sources": {
      "ChatbotRunner.java": {
        "text": "public class ChatbotRunner {\n  public static void main(String[] args) {\n\n    // Creates a Chatbot object\n    Chatbot alexa = new Chatbot(\"Alexa\", \"partsofspeech.txt\");\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the tagPartsOfSpeech() method and print the result.\n     * -----------------------------------------------------------------------------\n     */\n\n\n\n    \n    \n  }\n}",
        "isVisible": true,
        "tabOrder": 0
      },
      "Chatbot.java": {
        "text": "/*\n * Represents a chatbot on a school website\n */\npublic class Chatbot {\n\n  private String name;                // The name of a chatbot\n  private String[] partsOfSpeech;     // The 1D array containing words and their parts of speech\n\n  /*\n   * Sets name to the specified name and initializes partsOfSpeech\n   * to the data in the specified text file\n   */\n  public Chatbot(String name, String filename) {\n    this.name = name;\n    this.partsOfSpeech = FileReader.toStringArray(filename);\n  }\n\n  /*\n   * Returns the 1D array containing the parts of speech\n   */\n  public String[] getPartsOfSpeech() {\n    return partsOfSpeech;\n  }\n\n  /*\n   * Returns a String containing each word in statement tagged with\n   * its part of speech from partsOfSpeech\n   */\n  public String tagPartsOfSpeech(String statement) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Search for each word in statement in the 1D array partsOfSpeech to get\n     * its part of speech. Return a String that contains each word in statement\n     * tagged with its part of speech.\n     * -----------------------------------------------------------------------------\n     */\n\n    \n    return \"\";\n  }\n\n  /*\n   * Returns a String containing currentWord and its part of speech\n   */\n  public String getWordWithPart(String currentWord) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Traverse the 1D array partsOfSpeech and check if currentWord matches a\n     * word in partsOfSpeech. If so, return a String contaiing the currentWord\n     * concatenated with the part of speech.\n     * -----------------------------------------------------------------------------\n     */\n    \n\n    return \"\";\n  }\n  \n}",
        "isVisible": true,
        "tabOrder": 1
      },
      "FileReader.java": {
        "text": "import java.util.Scanner;\nimport java.util.ArrayList;\nimport java.io.File;\nimport java.io.FileNotFoundException;\n\npublic class FileReader {\n\n  public static String[] toStringArray(String filename) {\n    ArrayList<String> temp = readDataFromFile(filename);\n    String[] data = new String[temp.size()];\n\n    for (int index = 0; index < data.length; index++) {\n      String currentValue = temp.get(index);\n      data[index] = currentValue;\n    }\n\n    return data;\n  }\n\n  public static int[] toIntArray(String filename) {\n    ArrayList<String> temp = readDataFromFile(filename);\n    int[] data = new int[temp.size()];\n\n    for (int index = 0; index < data.length; index++) {\n      String currentValue = temp.get(index);\n      data[index] = Integer.parseInt(currentValue);\n    }\n\n    return data;\n  }\n\n  public static double[] toDoubleArray(String filename) {\n    ArrayList<String> temp = readDataFromFile(filename);\n    double[] data = new double[temp.size()];\n\n    for (int index = 0; index < data.length; index++) {\n      String currentValue = temp.get(index);\n      data[index] = Double.parseDouble(currentValue);\n    }\n\n    return data;\n  }\n\n  private static Scanner createScanner(File theFile) {\n    Scanner tempScanner = null;\n\n    try {\n      tempScanner = new Scanner(theFile);\n    } catch(FileNotFoundException error) {\n      System.out.println(\"File not found.\");\n    }\n\n    return tempScanner;\n  }\n\n  private static ArrayList<String> readDataFromFile(String filename) {\n    File dataFile = new File(filename);\n    Scanner reader = createScanner(dataFile);\n    ArrayList<String> temp = new ArrayList<String>();\n\n    while (reader.hasNextLine()) {\n      String currentLine = reader.nextLine().trim();\n      temp.add(currentLine);\n    }\n\n    reader.close();\n    return temp;\n  }\n  \n}",
        "isVisible": false,
        "tabOrder": 2
      },
