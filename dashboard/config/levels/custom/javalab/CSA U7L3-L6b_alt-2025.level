      "ShoppingPlatform.java": {
        "text": "/*\n * Represents a shopping platform with two featured products\n */\npublic class ShoppingPlatform {\n\n  private Product featuredTextbook;\n  private Product featuredSmartphone;\n\n  public ShoppingPlatform() {\n    featuredTextbook = new Product(\"1\", \"AP CSA textbook\");\n    featuredSmartphone = new Product(\"10\", \"smartphone\");\n  }\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Write the search() method. This version should take a name and ID\n   * and return the featuredTextbook.\n   * -----------------------------------------------------------------------------\n   */\n  public Product search(String name, String ID) {\n    // Your code here\n    return null;\n  }\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Write the search() method. This version should take an ID only\n   * and return the featuredSmartphone.\n   * -----------------------------------------------------------------------------\n   */\n  public Product search(String ID) {\n    // Your code here\n    return null;\n  }\n\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Product.java": {
        "text": "/*\n * Represents a Product\n */\npublic class Product {\n  \n  private String ID;   // ID\n  private String name; // name\n\n  public Product(String ID, String name) {\n    this.ID = ID;\n    this.name = name;\n  }\n\n  public String getID() {\n    return ID;\n  }\n\n  public String getName() {\n    return name;\n  }\n  \n  public String toString() {\n    return \"ID: \" + ID + \" name: \" + name;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      }
    }
