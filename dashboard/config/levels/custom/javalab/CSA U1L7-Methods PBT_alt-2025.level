    "start_sources": {
      "NeighborhoodRunner.java": {
        "text": "import org.code.neighborhood.*;\n\npublic class NeighborhoodRunner {\n  public static void main(String[] args) {\n\n    PainterPlus olivia = new PainterPlus();\n\n    olivia.move();\n\n    olivia.takePaint();\n    olivia.takePaint();\n    olivia.takePaint();\n    olivia.takePaint();\n\n    olivia.paintSquare();\n    \n  }\n}",
        "isVisible": true,
        "tabOrder": 0
      },
      "PainterPlus.java": {
        "text": "import org.code.neighborhood.*;\n\npublic class PainterPlus extends Painter {\n\n  // Paints a square\n  public void paintSquare() {\n    move();\n    paint(\"blue\");\n    turnLeft();\n    turnLeft();\n    turnLeft();\n\n    move();\n    paint(\"blue\");\n    turnLeft();\n    turnLeft();\n    turnLeft();\n\n    move();\n    paint(\"blue\");\n    turnLeft();\n    turnLeft();\n    turnLeft();\n\n    move();\n    paint(\"blue\");\n    turnLeft();\n    turnLeft();\n    turnLeft();\n  }\n  \n}",
        "isVisible": true,
        "tabOrder": 1
      }
    },
