      "Job.java": {
        "text": "/*\n * Represents a job posting\n */\npublic class Job {\n  \n  private String email1;\n  private String email2;\n\n  /*\n   * Initializes email1 and email2\n   */\n  public Job(String email1, String email2) {\n    this.email1 = email1;\n    this.email2 = email2;\n  }\n\n  /*\n   * Compares the two email addresses using compareTo()\n   */\n  public int compareEmails() {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use compareTo() to compare email1 and email2.\n     * Return the result of the comparison.\n     * -----------------------------------------------------------------------------\n     */\n\n\n    \n    return 0; // placeholder\n  }\n}\n",
