      "TheaterRunner.java": {
        "text": "import org.code.theater.*;\n\npublic class TheaterRunner {\n  public static void main(String[] args) {\n\n    // Creates individual Battle objects\n    Battle b1 = new Battle(\"Batman\", \"Joker\");\n    Battle b2 = new Battle(\"Superman\", \"Lex Luthor\");\n    Battle b3 = new Battle(\"Wonder Woman\", \"Ares\");\n    Battle b4 = new Battle(\"Batman\", \"Reign\");\n    Battle b5 = new Battle(\"Batman\", \"Joker\");\n\n    // Creates a BattleScene with fixed battles\n    BattleScene scene = new BattleScene(b1, b2, b3, b4, b5);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call isMatch() on each battle. If a match, pass two matching battles\n     * into drawResults().\n     * -----------------------------------------------------------------------------\n     */\n\n\n    \n    Theater.playScenes(scene);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "BattleScene.java": {
        "text": "import org.code.theater.*;\nimport org.code.media.*;\n\npublic class BattleScene extends Scene {\n\n  private Battle b1, b2, b3, b4, b5;\n\n  public BattleScene(Battle b1, Battle b2, Battle b3, Battle b4, Battle b5) {\n    this.b1 = b1;\n    this.b2 = b2;\n    this.b3 = b3;\n    this.b4 = b4;\n    this.b5 = b5;\n  }\n\n  /*\n   * Returns true if battle matches both characters\n   */\n  public boolean isMatch(Battle battle, String firstCharacter, String secondCharacter) {\n    // TO DO: Return true only if both characters match\n    return false;\n  }\n\n  /*\n   * Draws two matched results\n   */\n  public void drawResults(Battle match1, Battle match2) {\n    setTextColor(\"white\");\n    setTextHeight(20);\n    setTextStyle(Font.SANS, FontStyle.BOLD);\n\n    drawImage(match1.getMainImage(), 0, 0, getWidth());\n    pause(0.2);\n    drawText(match1.getMainCharacter(), 150, 300);\n\n    pause(2);\n    clear(\"black\");\n    drawText(\"Another battle against\", 100, 150);\n\n    pause(0.5);\n    drawImage(match2.getEnemyImage(), 0, 0, getWidth());\n    pause(0.2);\n    drawText(match2.getEnemyCharacter(), 150, 300);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Battle.java": {
        "text": "/*\n * Represents a character battle\n */\npublic class Battle {\n\n  private String mainCharacter;\n  private String mainImage;\n  private String enemyCharacter;\n  private String enemyImage;\n\n  public Battle(String mainCharacter, String enemyCharacter) {\n    this.mainCharacter = mainCharacter;\n    this.enemyCharacter = enemyCharacter;\n    this.mainImage = getImageFile(mainCharacter);\n    this.enemyImage = getImageFile(enemyCharacter);\n  }\n\n  public String getImageFile(String characterName) {\n    String image = \"\";\n    if (characterName.equals(\"Batman\")) image = \"batman-battle.png\";\n    if (characterName.equals(\"Superman\")) image = \"superman-battle.png\";\n    if (characterName.equals(\"Wonder Woman\")) image = \"wonder-woman-battle.png\";\n    if (characterName.equals(\"Supergirl\")) image = \"supergirl.png\";\n    if (characterName.equals(\"Joker\")) image = \"joker.png\";\n    if (characterName.equals(\"Lex Luthor\")) image = \"lexluther.png\";\n    if (characterName.equals(\"Ares\")) image = \"ares.png\";\n    if (characterName.equals(\"Reign\")) image = \"reign.jpg\";\n    if (characterName.equals(\"Cyborg Superman\")) image = \"cyborg.png\";\n    return image;\n  }\n\n  public String getMainCharacter() {\n    return mainCharacter;\n  }\n\n  public String getEnemyCharacter() {\n    return enemyCharacter;\n  }\n\n  public String getMainImage() {\n    return mainImage;\n  }\n\n  public String getEnemyImage() {\n    return enemyImage;\n  }\n\n  public String toString() {\n    return mainCharacter + \" vs \" + enemyCharacter;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      }
    },
    "name_suffix": "_alt-2025",
    "ai_tutor_available": "false"
  },
