    "start_sources": {
      "NeighborhoodRunner.java": {
        "text": "import org.code.neighborhood.*;\n\npublic class NeighborhoodRunner {\n  public static void main(String[] args) {\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Instantiate a ParkPainter object and create a 1D array with at least \n   *    two paint colors to ensure consecutive pairs can be used.\n   * ✅ Call the paintPark() method with the 1D array of colors.\n   * -----------------------------------------------------------------------------\n   */\n\n    \n    \n  }\n}",
        "isVisible": true,
        "tabOrder": 0
      },
      "ParkPainter.java": {
        "text": "import org.code.neighborhood.*;\nimport java.util.Scanner;\n\n/*\n * Represents a Painter that paints in a park\n */\npublic class ParkPainter extends Painter {\n\n  /*\n   * Sets the starting x and y location, direction\n   * amount of paint to the specified values\n   */\n  public ParkPainter(int x, int y, String direction, int numPaint) {\n    super(x, y, direction, numPaint);\n  }\n\n  /*\n   * Paints a line while ParkPainter can move forward,\n   * alternating between two colors.\n   */\n  public void paintLine(String color1, String color2) {\n    boolean useFirstColor = true;\n  \n    while (canMove()) {\n      if (useFirstColor) {\n        paint(color1);\n      } else {\n        paint(color2);\n      }\n      move();\n      useFirstColor = !useFirstColor; // Toggle between the two colors\n    }\n  }\n\n  /*\n   * Paints lines around the park using consecutive pairs of colors\n   * from the paintColors array. Each line alternates between two\n   * adjacent colors in the array before turning left.\n   */\n  public void paintPark(String[] paintColors) {\n  /* --------------------------------------- TO DO ---------------------------------------\n   * ✅ Traverse the 1D array paintColors, using each consecutive pair of colors \n   *    to paint alternating colors in a line, then turn left.\n   * -------------------------------------------------------------------------------------\n   */\n    \n    \n  }\n\n}",
        "isVisible": true,
        "tabOrder": 1
      }
    },
