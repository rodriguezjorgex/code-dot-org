    "name_suffix": "_alt-2025",
    "ai_tutor_available": "false",
    "start_sources": {
      "TheaterRunner.java": {
        "text": "import org.code.theater.*;\n\npublic class TheaterRunner {\n  public static void main(String[] args) {\n    // Creates 5 individual Fire objects instead of reading from files\n    Fire f1 = new Fire(\"Woodley\", \"Lightning\");\n    Fire f2 = new Fire(\"GP 632\", \"Lightning\");\n    Fire f3 = new Fire(\"Raymond Road\", \"Motorist\");\n    Fire f4 = new Fire(\"Pengra Car Fire\", \"Lightning\");\n    Fire f5 = new Fire(\"Boomer\", \"Motorist\");\n\n    // Creates FireData object\n    FireData scene = new FireData(f1, f2, f3, f4, f5);\n\n    /* TO DO:\n     * ✅ Call countMatching on each fire, add up the results, and call drawResult.\n     */\n    \n\n    \n    // Plays the scene\n    Theater.playScenes(scene);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "FireData.java": {
        "text": "import org.code.theater.*;\n\n/*\n * Visualizes fire data using 5 separate Fire objects\n */\npublic class FireData extends Scene {\n\n  private Fire f1, f2, f3, f4, f5;\n\n  public FireData(Fire f1, Fire f2, Fire f3, Fire f4, Fire f5) {\n    this.f1 = f1;\n    this.f2 = f2;\n    this.f3 = f3;\n    this.f4 = f4;\n    this.f5 = f5;\n  }\n\n  /*\n   * Returns 1 if fire's cause matches and name is longer than 6, else 0\n   */\n  public int countMatching(Fire fire, String cause) {\n    // TO DO: Use nested ifs to check both conditions\n    return -1;\n  }\n\n  /*\n   * Draws the number of fires that matched the given cause + name length\n   */\n  public void drawResult(String cause, int count) {\n    int numFires = count;\n    while (numFires > 0) {\n      int randomX = (int)(Math.random() * getWidth());\n      int randomY = (int)(Math.random() * getHeight());\n      drawImage(\"fire.png\", randomX, randomY, 100);\n      pause(0.1);\n      numFires--;\n    }\n\n    pause(0.5);\n    drawText(\"There have been \" + count + \" fires\", 50, 100);\n    drawText(\"caused by \" + cause, 50, 125);\n    drawText(\"where the length of the name\", 50, 150);\n    drawText(\"is greater than 6.\", 50, 175);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Fire.java": {
        "text": "/*\n * Represents a fire event in a city\n */\npublic class Fire {\n\n  private String name;\n  private String cause;\n\n  public Fire(String name, String cause) {\n    this.name = name;\n    this.cause = cause;\n  }\n\n  public String getName() {\n    return name;\n  }\n\n  public String getCause() {\n    return cause;\n  }\n\n  public String toString() {\n    return name + \" - caused by \" + cause;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      }
    }
