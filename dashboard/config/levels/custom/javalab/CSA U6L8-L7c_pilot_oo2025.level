      "MarketplaceRunner.java": {
        "text": "import java.util.ArrayList;\n\npublic class MarketplaceRunner {\n  public static void main(String[] args) {\n    \n    ArrayList<String> productDescriptions = new ArrayList<String>();\n    productDescriptions.add(\"Smartphone: new\");\n    productDescriptions.add(\"Running shoes: best for marathons\");\n    productDescriptions.add(\"Chess board: easy to carry\");\n    productDescriptions.add(\"Dog food: organic\");\n    \n    ArrayList<String> relevantKeywords = new ArrayList<String>();\n    relevantKeywords.add(\"affordable\");\n    relevantKeywords.add(\"organic\");\n    relevantKeywords.add(\"best\");\n    relevantKeywords.add(\"easy\");\n\n    // Create a Marketplace object\n    Marketplace marketplace = new Marketplace(productDescriptions, relevantKeywords);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the filterSearchResults() method and print the result\n     * -----------------------------------------------------------------------------\n     */\n\n    \n    \n  }\n}",
