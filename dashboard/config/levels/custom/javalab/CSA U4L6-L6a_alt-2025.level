    "start_sources": {
      "PetRunner.java": {
        "text": "public class PetRunner {\n  public static void main(String[] args) {\n\n    // Creates Dog objects\n    Dog dog1 = new Dog(\"Max\", 3);\n    Dog dog2 = new Dog(\"Bella\", 2);\n    Dog dog3 = new Dog(\"Duke\", 5);\n    Dog dog4 = new Dog(\"Luna\", 4);\n    Dog dog5 = new Dog(\"Rocky\", 1);\n\n    // Creates a PetStore object\n    PetStore pets = new PetStore(dog1, dog2, dog3, dog4, dog5);\n\n    // Creates two Dog objects to find\n    Dog firstDog = new Dog(\"Charlie\", 4);\n    Dog secondDog = new Dog(\"Daisy\", 10);\n\n    // Calls the findMatchingDog() method and prints the result\n    System.out.println(\"Match for Charlie: \" + pets.findMatchingDog(firstDog) + \"\\n\");\n    System.out.println(\"Match for Daisy: \" + pets.findMatchingDog(secondDog));\n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Dog.java": {
        "text": "/*\n * Represents a dog\n */\npublic class Dog {\n\n  private String name;   // The name of a dog\n  private int age;       // The age of a dog\n\n  /*\n   * Sets name to the specified name and age to the specified age\n   */\n  public Dog(String name, int age) {\n    this.name = name;\n    this.age = age;\n  }\n\n  /*\n   * Returns the name of the dog\n   */\n  public String getName() {\n    return name;\n  }\n\n  /*\n   * Returns the age of the dog\n   */\n  public int getAge() {\n    return age;\n  }\n\n  /*\n   * Returns true if the ages are the same, otherwise returns false\n   */\n  public boolean equals(Object other) {\n    if (other == this) {\n      return true;\n    }\n\n    if (!(other instanceof Dog)) {\n      return false;\n    }\n\n    Dog otherDog = (Dog) other;\n    return this.age == otherDog.age;\n  }\n\n  /*\n   * Returns a String containing the dog's name and age\n   */\n  public String toString() {\n    return name + \": \" + age + \" years old\";\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      },
      "PetStore.java": {
        "text": "/*\n * Represents a pet store\n */\npublic class PetStore {\n\n  private Dog dog1;\n  private Dog dog2;\n  private Dog dog3;\n  private Dog dog4;\n  private Dog dog5;\n\n  /*\n   * Initializes the PetStore with 5 Dog objects\n   */\n  public PetStore(Dog dog1, Dog dog2, Dog dog3, Dog dog4, Dog dog5) {\n    this.dog1 = dog1;\n    this.dog2 = dog2;\n    this.dog3 = dog3;\n    this.dog4 = dog4;\n    this.dog5 = dog5;\n  }\n\n  /*\n   * Returns a String containing information about the Dog\n   * object that has the same age as the parameter dogToFind\n   */\n  public String findMatchingDog(Dog dogToFind) {\n    String result = \"\";\n\n    // Students will find and fix the bug here\n    if (dog1 == dogToFind) {\n      result += \"Matching dog found!\\n\" + dog1;\n    }\n    if (dog2 == dogToFind) {\n      result += \"Matching dog found!\\n\" + dog2;\n    }\n    if (dog3 == dogToFind) {\n      result += \"Matching dog found!\\n\" + dog3;\n    }\n    if (dog4 == dogToFind) {\n      result += \"Matching dog found!\\n\" + dog4;\n    }\n    if (dog5 == dogToFind) {\n      result += \"Matching dog found!\\n\" + dog5;\n    }\n\n    if (result.equals(\"\")) {\n      result += \"No matching dog found.\";\n    }\n\n    return result;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    }
  },
  "published": true,
