      "VideoRunner.java": {
        "text": "public class VideoRunner {\n  public static void main(String[] args) {\n\n    User amelia = new User();\n\n    Video innovators = new Video(\"The Innovators: Women in Tech\", 3360);\n    Video robotics = new Video(\"Intro to Robotics\", 1860);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the addViewing() method and print the User object.\n     * -----------------------------------------------------------------------------\n     */\n\n    \n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Video.java": {
        "text": "public class Video {\n\n  private String title;\n  private int length;\n  private int watched;\n\n  public Video(String title, int length) {\n    this.title = title;\n    this.length = length;\n  }\n\n  public String getTitle() {\n    return title;\n  }\n\n  public int getLength() {\n    return length;\n  }\n\n  public int getWatched() {\n    return watched;\n  }\n\n  public void setWatched(int numSeconds) {\n    watched = numSeconds;\n  }\n\n  public String toString() {\n    return title + \" - \" + length + \" seconds (\" + watched + \" seconds watched)\";\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      },
      "User.java": {
        "text": "public class User {\n\n  private Video video1;\n  private Video video2;\n  private Video video3;\n\n  public User() {\n    video1 = null;\n    video2 = null;\n    video3 = null;\n  }\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Write the private method hasWatchedMinimum() with a parameter for the\n   * number of seconds. Return true if greater than 30.\n   * -----------------------------------------------------------------------------\n   */\n  private boolean hasWatchedMinimum(int seconds) {\n    // your code here\n    return false;\n  }\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Write the public method addViewing with a parameter for a Video and\n   * number of seconds watched. If hasWatchedMinimum() is true, create a copy\n   * and store it in the next available slot.\n   * -----------------------------------------------------------------------------\n   */\n  public void addViewing(Video original, int seconds) {\n    // your code here\n  }\n\n  public String toString() {\n    String result = \"\";\n\n    if (video1 != null) {\n      result += video1.toString() + \"\\n\";\n    }\n\n    if (video2 != null) {\n      result += video2.toString() + \"\\n\";\n    }\n\n    if (video3 != null) {\n      result += video3.toString() + \"\\n\";\n    }\n\n    return result;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    }
  },
