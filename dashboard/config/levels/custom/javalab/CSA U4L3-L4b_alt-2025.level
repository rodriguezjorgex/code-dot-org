      "PosterRunner.java": {
        "text": "public class PosterRunner {\n  public static void main(String[] args) {\n    \n    PrintShop shop = new PrintShop();\n    System.out.println(shop.getPosterCosts());\n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "PrintShop.java": {
        "text": "/*\n * Calculates material costs for printing posters\n */\npublic class PrintShop {\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Declare and initialize a constant called COST_PER_SQ_INCH and set it to 0.02.\n   * -----------------------------------------------------------------------------\n   */\n\n  \n\n  /*\n   * Returns a string listing the total material cost of each poster\n   */\n  public String getPosterCosts() {\n    String result = \"Poster Costs\\n---------------\\n\";\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Update each line to use the constant instead of the number 0.02.\n     * -----------------------------------------------------------------------------\n     */\n\n    result += \"Small Poster (12 x 18): $\" + (12 * 18 * 0.02) + \"\\n\";\n    result += \"Large Poster (24 x 36): $\" + (24 * 36 * 0.02) + \"\\n\";\n\n    return result;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    },
