      "ShapeScene.java": {
        "text": "import org.code.theater.*;\nimport org.code.media.Color;\n\npublic class ShapeScene extends Scene {\n\n  /*\n   * Returns a new Color object with random RGB values\n   */\n  public Color makeRandomColor() {\n    // Replace with your code\n    return 0;\n  }\n\n  /*\n   * Draws a shape using the given Color\n   */\n  public void drawShape(Color color) {\n    setFillColor(color);\n    drawRectangle(200, 200, 150, 150);\n  }\n}",
