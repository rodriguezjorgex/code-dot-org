    "display_name": "The TrafficPainter",
    "bubble_choice_description": "Shifts the colors of a 1D array of paint colors and then uses a `for` loop to navigate traffic, painting a path to the food truck. ",
    "thumbnail_url": "https://images.code.org/b5a44fe6d176edebaa876da660d6565b-image-1648557517951.gif",
