    "start_sources": {
      "MenuRunner.java": {
        "text": "public class MenuRunner {\n  public static void main(String[] args) {\n\n    // Creates MenuItem objects\n    MenuItem m1 = new MenuItem(\"burger\");\n    MenuItem m2 = new MenuItem(\"curry\");\n    MenuItem m3 = new MenuItem(\"pizza\");\n    MenuItem m4 = new MenuItem(\"sushi\");\n    MenuItem m5 = new MenuItem(\"samosa\");\n\n    // Creates a Menu object\n    Menu foods = new Menu(m1, m2, m3, m4, m5);\n\n    // Creates first test Menu (same items)\n    Menu first = new Menu(\n      new MenuItem(\"burger\"),\n      new MenuItem(\"curry\"),\n      new MenuItem(\"pizza\"),\n      new MenuItem(\"sushi\"),\n      new MenuItem(\"samosa\")\n    );\n\n    // Creates second test Menu (different items)\n    Menu second = new Menu(\n      new MenuItem(\"burger\"),\n      new MenuItem(\"moussaka\"),\n      new MenuItem(\"pizza\"),\n      new MenuItem(\"sushi\"),\n      new MenuItem(\"paella\")\n    );\n\n    // Calls the findMatchingMeal() method and prints the result\n    System.out.println(foods.findMatchingMeal(first) + \"\\n\");\n    System.out.println(foods.findMatchingMeal(second));\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Menu.java": {
        "text": "/*\n * Represents a restaurant menu\n */\npublic class Menu {\n\n  private MenuItem m1, m2, m3, m4, m5;\n\n  /*\n   * Initializes the menu with 5 MenuItem objects\n   */\n  public Menu(MenuItem m1, MenuItem m2, MenuItem m3, MenuItem m4, MenuItem m5) {\n    this.m1 = m1;\n    this.m2 = m2;\n    this.m3 = m3;\n    this.m4 = m4;\n    this.m5 = m5;\n  }\n\n  /*\n   * Returns a String if all MenuItem objects have the same type\n   */\n  public String findMatchingMeal(Menu other) {\n    boolean allSame = true;\n\n    if (this.m1 != other.m1) {\n      allSame = false;\n    }\n    if (this.m2 != other.m2) {\n      allSame = false;\n    }\n    if (this.m3 != other.m3) {\n      allSame = false;\n    }\n    if (this.m4 != other.m4) {\n      allSame = false;\n    }\n    if (this.m5 != other.m5) {\n      allSame = false;\n    }\n\n    if (allSame) {\n      return \"All of the options are the same!\";\n    } else {\n      return \"Not all of the options are the same.\";\n    }\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "MenuItem.java": {
        "text": "/*\n * Represents an item on a menu\n */\npublic class MenuItem {\n\n  private String type;\n\n  /*\n   * Sets type to the specified type\n   */\n  public MenuItem(String type) {\n    this.type = type;\n  }\n\n  /*\n   * Returns the type of the menu item\n   */\n  public String getType() {\n    return type;\n  }\n\n  /*\n   * Returns true if the type of other is the same as this MenuItem\n   */\n  public boolean equals(Object other) {\n    if (other == this) {\n      return true;\n    }\n\n    if (!(other instanceof MenuItem)) {\n      return false;\n    }\n\n    MenuItem otherItem = (MenuItem) other;\n    return this.type.equals(otherItem.type);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      }
    },
