    "start_sources": {
      "JobRunner.java": {
        "text": "import java.util.ArrayList;\n\npublic class JobRunner {\n  public static void main(String[] args) {\n\n    // Creates a list of email addresses\n    ArrayList<String> emails = new ArrayList<String>();\n    emails.add(\"jane.smith@email.com\");\n    emails.add(\"sarah.johnson@email.com\");\n    emails.add(\"michael.lee@email.com\");\n    emails.add(\"lisa.chen@email.com\");\n    emails.add(\"william.kim@email.com\");\n\n    // Creates a Job object\n    Job posting = new Job(emails);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the shiftEmails() method to shift the emails by a specified amount.\n     * ✅ Print the shifted list using the resultsToString() method.\n     * -----------------------------------------------------------------------------\n     */\n\n\n    \n    \n  }\n}",
        "isVisible": true,
        "tabOrder": 0
      },
      "Job.java": {
        "text": "import java.util.ArrayList;\n\n/*\n * Represents a job posting\n */\npublic class Job {\n  \n  private ArrayList<String> emails;    // The list of email addresses\n\n  /*\n   * Initializes emails to the specified list of emails\n   */\n  public Job(ArrayList<String> emails) {\n    this.emails = emails;\n  }\n\n  /*\n   * Returns the list of emails\n   */\n  public ArrayList<String> getEmails() {\n    return emails;\n  }\n\n  /*\n   * Shifts the email addresses in the list to the left by shiftAmount positions\n   */\n  public void shiftEmails(int shiftAmount) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Shift the list of emails left by shiftAmount positions. Use a loop to\n     * move the first element to the end of the list.\n     * -----------------------------------------------------------------------------\n     */\n    \n    \n    \n  }\n\n  /*\n   * Returns a String containing each value in the specified list\n   */\n  public String resultsToString() {\n    String text = \"\";\n\n    for (int index = 0; index < emails.size(); index++) {\n      text += emails.get(index) + \"\\n\";\n    }\n\n    return text;\n  }\n  \n}",
        "isVisible": true,
        "tabOrder": 1
      }
    },
