      "EssayRunner.java": {
        "text": "public class EssayRunner {\n  public static void main(String[] args) {\n\n    // Creates an Essay object with a known dictionary word\n    Essay wordChecker = new Essay(\"reduction\");\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the compareWords() method with a test word and print the result.\n     * -----------------------------------------------------------------------------\n     */\n\n\n\n    \n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Essay.java": {
        "text": "/*\n * Analyzes the text in an essay\n */\npublic class Essay {\n\n  private String dictionaryWord;\n\n  /*\n   * Initializes dictionaryWord to the specified value\n   */\n  public Essay(String dictionaryWord) {\n    this.dictionaryWord = dictionaryWord;\n  }\n\n  /*\n   * Compares wordToCheck to dictionaryWord using compareTo() and returns result\n   */\n  public int compareWords(String wordToCheck) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use compareTo() to compare wordToCheck to dictionaryWord.\n     * Return the result of the comparison as an integer.\n     * -----------------------------------------------------------------------------\n     */\n\n    \n\n    return 0;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    }
  },
