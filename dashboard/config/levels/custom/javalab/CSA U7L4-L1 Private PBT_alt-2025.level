      "RecipeRunner.java": {
        "text": "public class RecipeRunner {\n  public static void main(String[] args) {\n\n    // Creates individual recipes\n    Recipe r1 = new Recipe(\"Vegetable lasagna\", \"vegetarian\");\n    Recipe r2 = new Recipe(\"Beef stew\", \"meat\");\n    Recipe r3 = new Recipe(\"Grilled chicken\", \"meat\");\n    Recipe r4 = new Recipe(\"Spinach quiche\", \"vegetarian\");\n\n    // Creates a RecipeBlog object\n    RecipeBlog blog = new RecipeBlog(r1, r2, r3, r4);\n    \n    System.out.println(\"Recommended vegetarian recipes:\\n\" + blog.getRecommendedVegetarianRecipes());\n\n    /* ---- 🔎 ADD YOUR CODE BELOW THIS LINE ---- */\n\n\n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "RecipeBlog.java": {
        "text": "public class RecipeBlog {\n\n  private Recipe recipe1;\n  private Recipe recipe2;\n  private Recipe recipe3;\n  private Recipe recipe4;\n\n  public RecipeBlog(Recipe r1, Recipe r2, Recipe r3, Recipe r4) {\n    recipe1 = r1;\n    recipe2 = r2;\n    recipe3 = r3;\n    recipe4 = r4;\n  }\n\n  public String getRecommendedVegetarianRecipes() {\n    return recipesToString(recipe1, recipe4);\n  }\n\n  public String getRecommendedMeatRecipes() {\n    return recipesToString(recipe2, recipe3);\n  }\n\n  private String recipesToString(Recipe a, Recipe b) {\n    return a.toString() + \"\\n\" + b.toString();\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Recipe.java": {
        "text": "public class Recipe {\n\n  private String name;\n  private String diet;\n\n  public Recipe(String name, String diet) {\n    this.name = name;\n    this.diet = diet;\n  }\n\n  public String getName() {\n    return name;\n  }\n\n  public String getDiet() {\n    return diet;\n  }\n\n  public String toString() {\n    return name + \" (\" + diet + \")\";\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      }
    },
