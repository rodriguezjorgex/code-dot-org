      "SalesRunner.java": {
        "text": "public class SalesRunner {\n  public static void main(String[] args) {\n\n    // Creates a Sales object\n    Sales business = new Sales();\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call cleanValue() on each sale value and print it using Sales.salesToString().\n     * -----------------------------------------------------------------------------\n     */\n\n    System.out.print(Sales.salesToString(business.cleanValue(-4.05)));\n    System.out.print(Sales.salesToString(business.cleanValue(5.06)));\n    System.out.print(Sales.salesToString(business.cleanValue(3.99)));\n    System.out.print(Sales.salesToString(business.cleanValue(-3.99)));\n    System.out.print(Sales.salesToString(business.cleanValue(-1.99)));\n    System.out.print(Sales.salesToString(business.cleanValue(2.05)));\n    System.out.print(Sales.salesToString(business.cleanValue(10.50)));\n    System.out.print(Sales.salesToString(business.cleanValue(-7.85)));\n    System.out.print(Sales.salesToString(business.cleanValue(6.73)));\n    System.out.print(Sales.salesToString(business.cleanValue(-8.45)));\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Sales.java": {
        "text": "/*\n * Represents sales made at a business\n */\npublic class Sales {\n\n  /*\n   * Returns the absolute value of a single sale amount\n   */\n  public double cleanValue(double value) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use Math.abs() to return the absolute value of the input\n     * -----------------------------------------------------------------------------\n     */\n    return 0;\n  }\n\n  /*\n   * Returns a formatted String containing one sale value\n   */\n  public static String salesToString(double value) {\n    return \"$\" + value + \"\\n\";\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    }
