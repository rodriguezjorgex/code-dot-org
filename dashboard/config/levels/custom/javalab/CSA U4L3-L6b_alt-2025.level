    "start_sources": {
      "PhysicianRunner.java": {
        "text": "public class PhysicianRunner {\n  public static void main(String[] args) {\n\n    // Create individual Patient objects\n    Patient p1 = new Patient(\"Olivia\", 98.2);\n    Patient p2 = new Patient(\"Liam\", 98.9);\n    Patient p3 = new Patient(\"Ava\", 102.3);\n    Patient p4 = new Patient(\"Ethan\", 98.4);\n    Patient p5 = new Patient(\"Isabella\", 99.6);\n\n    // Create a Physician object\n    Physician doctor = new Physician(\"Dr. Smith\");\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call isSick() for each patient and print whether they are sick.\n     * Use patient.getName() to get their name for the print statement.\n     * -----------------------------------------------------------------------------\n     */\n\n\n\n\n\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Physician.java": {
        "text": "/*\n * Represents a physician\n */\npublic class Physician {\n\n  private String name;\n\n  /*\n   * Sets the name of the physician\n   */\n  public Physician(String name) {\n    this.name = name;\n  }\n\n  /*\n   * Returns the name of the physician\n   */\n  public String getName() {\n    return name;\n  }\n\n  /*\n   * Returns true if the patient's temperature is more than\n   * 0.5 degrees away from 98.6, otherwise returns false\n   */\n  public boolean isSick(Patient patient) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use Math.abs() to check whether the patient's temperature is more than\n     * 0.5 degrees from 98.6. Return true if they are sick.\n     * -----------------------------------------------------------------------------\n     */\n    return false;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Patient.java": {
        "text": "/*\n * Represents a patient\n */\npublic class Patient {\n\n  private String name;    // The name of a patient\n  private double temp;    // The temperature of a patient\n\n  /*\n   * Sets name and temp to the specified values\n   */\n  public Patient(String name, double temp) {\n    this.name = name;\n    this.temp = temp;\n  }\n\n  /*\n   * Returns the name of the patient\n   */\n  public String getName() {\n    return name;\n  }\n\n  /*\n   * Returns the temperature of the patient\n   */\n  public double getTemp() {\n    return temp;\n  }\n\n  /*\n   * Returns a String containing the patient's name and temperature\n   */\n  public String toString() {\n    return name + \" - \" + temp;\n  }\n  \n}",
        "isVisible": true,
        "tabOrder": 2
      }
    },
    "name_suffix": "_alt-2025",
