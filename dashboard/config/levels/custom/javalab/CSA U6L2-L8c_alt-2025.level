      "NovelRunner.java": {
        "text": "public class NovelRunner {\n  public static void main(String[] args) {\n\n    // Creates a Novel object\n    Novel story = new Novel();\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the getWordsForPart() method and print the result.\n     * -----------------------------------------------------------------------------\n     */\n\n\n    \n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Novel.java": {
        "text": "/*\n * Represents a novel\n */\npublic class Novel {\n\n  private String data;  // A string containing parts of speech and example words\n\n  /*\n   * Initializes data with a hardcoded string of parts of speech\n   */\n  public Novel() {\n    this.data = \"noun:dog,cat\\nverb:run,jump\\nadjective:blue,quick\";\n  }\n\n  /*\n   * Returns a String containing words that match the parameter partToFind\n   */\n  public String getWordsForPart(String partToFind) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use indexOf() and substring() to find the line that starts with partToFind.\n     * Only works for input \"noun\". Return the matching words on separate lines.\n     * -----------------------------------------------------------------------------\n     */\n\n    \n\n    return \"\";\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    },
