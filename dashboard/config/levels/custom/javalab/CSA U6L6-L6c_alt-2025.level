      "TravelAgencyRunner.java": {
        "text": "public class TravelAgencyRunner {\n  public static void main(String[] args) {\n\n    // Creates two tour packages\n    TourPackage p1 = new TourPackage(\"Paris\", 5);\n    TourPackage p2 = new TourPackage(\"Rome\", 6);\n\n    // Creates a TravelAgency object\n    TravelAgency travel = new TravelAgency(p1, p2);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the comparePackages() method and print the result.\n     * -----------------------------------------------------------------------------\n     */\n\n\n\n    \n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "TravelAgency.java": {
        "text": "/*\n * Represents a travel agency\n */\npublic class TravelAgency {\n  \n  private TourPackage pkg1;\n  private TourPackage pkg2;\n\n  /*\n   * Initializes pkg1 and pkg2 with the specified packages\n   */\n  public TravelAgency(TourPackage pkg1, TourPackage pkg2) {\n    this.pkg1 = pkg1;\n    this.pkg2 = pkg2;\n  }\n\n  /*\n   * Compares the two destinations and returns the result of compareTo()\n   */\n  public int comparePackages() {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use compareTo() to compare the destination of pkg1 with the destination of pkg2.\n     * Return the result.\n     * -----------------------------------------------------------------------------\n     */\n\n    \n\n    return 0; // placeholder\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "TourPackage.java": {
        "text": "/*\n * Represents a tour package\n */\npublic class TourPackage {\n\n  private String destination;    // The destination for a tour package\n  private int numDays;           // The number of days for the tour\n\n  /*\n   * Sets destination and numDays to the specified values\n   */\n  public TourPackage(String destination, int numDays) {\n    this.destination = destination;\n    this.numDays = numDays;\n  }\n\n  /*\n   * Returns the destination\n   */\n  public String getDestination() {\n    return destination;\n  }\n\n  /*\n   * Return the number of days\n   */\n  public int getNumDays() {\n    return numDays;\n  }\n\n  /*\n   * Returns a String containing the tour package information\n   */\n  public String toString() {\n    return destination + \" - \" + numDays + \" days\";\n  }\n  \n}",
        "isVisible": true,
        "tabOrder": 2
      }
    },
