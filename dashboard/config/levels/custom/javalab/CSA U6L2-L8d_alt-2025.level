      "WordRunner.java": {
        "text": "public class WordRunner {\n  public static void main(String[] args) {\n\n    // Creates a WordProcessor object\n    WordProcessor processor = new WordProcessor();\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the getSecondEntry() method and print the result.\n     * -----------------------------------------------------------------------------\n     */\n\n\n\n    \n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "WordProcessor.java": {
        "text": "/*\n * Processes and analyzes text\n */\npublic class WordProcessor {\n\n  private String data;\n\n  /*\n   * Initializes the data string with sample entries\n   */\n  public WordProcessor() {\n    this.data = \"dog:noun,run:verb,blue:adjective\";\n  }\n\n  /*\n   * Returns the second word and part of speech, separated by a tab character\n   */\n  public String getSecondEntry() {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use indexOf() and substring() to extract the second entry from data.\n     * The second entry is \"run:verb\". Return it as \"run\\tverb\".\n     * -----------------------------------------------------------------------------\n     */\n\n    \n\n    return \"\";\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    }
