sLqjcWQRpXpGVPE\nxDWquT6If2NfpaxIDJqDDpRLdjzvkn98fbs5m1mlzoHMX9m+AvTgwkSzXL/q\nE8/vak7jwEl5sHxIqeqXADFbIsCRP1yp7SAg3+adddK/Q4E8qzIgYX8L8K2z\nSUqNB/zsbQHcA2JR7cah5vgx4vWmpqsR+3AoWGgJjOpZsVxTMWBtgkcwnns/\nUq91UiMqAaXj6FCxSYKLBpeyBPAuRUOz8lqPmTn54MWIeoXlrm9WA43iOoVy\nTU+t9nReVISkAZsLy0yO7+uHIjdcaGdge/htQxeY77rE+GUToe6HZqgL1Yea\nQ0FvL2bEWSWsesmljC4e2iBEEUiPoydvm53lofjITB5cMDJJF8QZgFe9c2yN\nU+oMjtX0Jc8PJwFvmNoXyfQK6wNh5KErYO1n+iWLVvFTC8ISYWIBFQ6g4cO0\nbVhIgy0QkVYZMaynDWOBnD9Uq+CtXaJdEt/frTskaJI60xWI0GKGKjN2Gwka\nD5SrfdUQ0/MdEcBoxnI9YGXb+IZoFTtEKqCXo5DMyYMA/boFaqMxOfhyq0EA\npqLNcISoL3Tf885VI75Hp0lpfHtt5a+soJX/hIXIMJ+Bzjg9Omv1gKQ3uJbr\nKvz4BkKnDmISuDQuAm8ve4K6PCakxsqDMOrglAzlngxxNTiqeGRiQEh5ZQVo\n2dO3OnnaYIeHONlBUHg9GT2uQW47Z7jhjCgvDzQvsLRO6NzfQKoCER2ReLr8\nadCqvhn6Cw8Rh7DvwLpOCofA8Ys/6ugU6JejqN/VjC2FAOl8vtsyjhI2wEhW\nH4xS9o5oD6UfloS2zVvZRJK2UO43MqSWqVBLdm7ux6TxaMJ9pigyZFv44bGM\nbKdw5K3xFdoAeg28tdwmVKEeiC3727t52mgX3DaylGm9mSfaRDv2r20QY+v6\nzTeGH4rObUvMTAq/72iZtA==\n",
    "name_suffix": "_alt-2025",
    "start_sources": {
      "TheaterRunner.java": {
        "text": "import org.code.theater.*;\n\npublic class TheaterRunner {\n  public static void main(String[] args) {\n\n    // Creates individual Brand objects\n    Brand b1 = new Brand(\"US Polo\", \"Women\");\n    Brand b2 = new Brand(\"US Polo\", \"Men\");\n    Brand b3 = new Brand(\"GAP\", \"Women\");\n    Brand b4 = new Brand(\"GAP\", \"Men\");\n    Brand b5 = new Brand(\"Kenneth Cole\", \"Women\");\n    Brand b6 = new Brand(\"Kenneth Cole\", \"Men\");\n    Brand b7 = new Brand(\"Puma\", \"Women\");\n    Brand b8 = new Brand(\"Puma\", \"Men\");\n\n    // Creates a Fashion object\n    Fashion scene = new Fashion(b1, b2, b3, b4, b5, b6, b7, b8);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the countByBrands() method then call the drawResults() method\n     * with the results.\n     * -----------------------------------------------------------------------------\n     */\n\n\n    // Plays the scene\n    Theater.playScenes(scene);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Fashion.java": {
        "text": "import org.code.theater.*;\n\n/*\n * Creates a visual to show popular brands\n */\npublic class Fashion extends Scene {\n\n  private Brand b1, b2, b3, b4, b5, b6, b7, b8;\n\n  public Fashion(Brand b1, Brand b2, Brand b3, Brand b4,\n                 Brand b5, Brand b6, Brand b7, Brand b8) {\n    this.b1 = b1;\n    this.b2 = b2;\n    this.b3 = b3;\n    this.b4 = b4;\n    this.b5 = b5;\n    this.b6 = b6;\n    this.b7 = b7;\n    this.b8 = b8;\n  }\n\n  /*\n   * Returns a Results object containing the number of purchases by gender and brand\n   */\n  public Results countByBrands(String gender) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Check if each brand's gender matches the parameter gender and\n     * increment the appropriate counter in a Results object based on\n     * the brand name. Return the Results object.\n     * -----------------------------------------------------------------------------\n     */\n\n\n    return null;\n  }\n\n  /*\n   * Draws the results in the scene\n   */\n  public void drawResults(String gender, Results results) {\n    drawText(\"Brands purchased by \" + gender, 55, 40);\n\n    setFillColor(\"red\");\n    drawRectangle(0, 90, results.getUSPolo() * 20, 25);\n    pause(0.2);\n\n    setFillColor(\"green\");\n    drawRectangle(0, 130, results.getGAP() * 20, 25);\n    pause(0.2);\n\n    setFillColor(\"purple\");\n    drawRectangle(0, 170, results.getKennethCole() * 20, 25);\n    pause(0.2);\n\n    setFillColor(\"orange\");\n    drawRectangle(0, 210, results.getOther() * 20, 25);\n    pause(0.2);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Brand.java": {
        "text": "/*\n * Represents a brand of clothing\n */\npublic class Brand {\n\n  private String name;\n  private String gender;\n\n  public Brand(String name, String gender) {\n    this.name = name;\n    this.gender = gender;\n  }\n\n  public String getName() {\n    return name;\n  }\n\n  public String getGender() {\n    return gender;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      },
      "Results.java": {
        "text": "/*\n * Stores counts of purchases by brand\n */\npublic class Results {\n\n  private int usPolo;\n  private int gap;\n  private int kennethCole;\n  private int other;\n\n  public Results() {\n    usPolo = 0;\n    gap = 0;\n    kennethCole = 0;\n    other = 0;\n  }\n\n  public void incrementUSPolo() {\n    usPolo++;\n  }\n\n  public void incrementGAP() {\n    gap++;\n  }\n\n  public void incrementKennethCole() {\n    kennethCole++;\n  }\n\n  public void incrementOther() {\n    other++;\n  }\n\n  public int getUSPolo() {\n    return usPolo;\n  }\n\n  public int getGAP() {\n    return gap;\n  }\n\n  public int getKennethCole() {\n    return kennethCole;\n  }\n\n  public int getOther() {\n    return other;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 3
      }
    }
  },
