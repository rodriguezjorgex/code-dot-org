c\nxXzlacx0YP55FYVepDexUHgXKeCT4I2zD65180K1OWheI6LyyIt8GGQrXQwb\niX3dgqu11W0u6NXdTn5r12x+TWNlzvAgGsR9PjAi+mrE1Bw+Tt/fx97jdcKf\n2D3uf6rHIjt+8Bbd8IVUvhSmx68JHII6Xuq6ylfp5pKQ09B1XN+e8G14grIV\n93U8jBV9WPQcBGm3GsPx9HODxokwPCtkpmqJspI3vo+SF/9Gj/aapm2hVk3G\nI1wT6L2iNeaLSW06rHHkAhXzpVOdXMdVBxv3YoEF4C1EFuOfIDaOb1kn0KGc\njVC/h0iiOTtXGO+U3YmvikdTAPCiPU5qY/uJ07o+jlVM7CejfoCUPfjVv65x\nAbQrP8Jyq8K7Yi0Si8F6xqlTOcJoLwmnt+Vkb+n9Ii14rc8ocC+OtxO6LCfh\nhwUQHCa5r3YjiAeRxXDnxDr9TvBtQiUcJvqkfGYINKqVhcjj2Q==\n",
    "start_sources": {
      "ArticleRunner.java": {
        "text": "import java.util.ArrayList;\n\npublic class ArticleRunner {\n  public static void main(String[] args) {\n\n    // Creates a list of quotes from sources\n    ArrayList<String> quotes = new ArrayList<String>();\n    quotes.add(\"The economy is growing at a record pace.\");\n    quotes.add(\"Climate change is the defining challenge of our time.\");\n    quotes.add(\"Technology is advancing faster than ever before.\");\n    quotes.add(\"The economy is growing at a record pace.\"); // Duplicate\n    quotes.add(\"Education reform is necessary for future generations.\");\n\n    // Creates an Article object\n    Article newsAnalysis = new Article(quotes);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the hasDuplicateQuotes() method and print whether duplicate quotes exist.\n     * -----------------------------------------------------------------------------\n     */\n\n    \n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Article.java": {
        "text": "import java.util.ArrayList;\n\n/*\n * Represents a news article\n */\npublic class Article {\n  \n  private ArrayList<String> quotes;    // The list of quotes\n\n  /*\n   * Initializes quotes to the specified list of quotes\n   */\n  public Article(ArrayList<String> quotes) {\n    this.quotes = quotes;\n  }\n\n  /*\n   * Returns the list of quotes\n   */\n  public ArrayList<String> getQuotes() {\n    return quotes;\n  }\n\n  /*\n   * Returns true if duplicate quotes exist, false otherwise\n   */\n  public boolean hasDuplicateQuotes() {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use nested loops to traverse the list of quotes and compare each quote \n     * to every other quote that comes after it in the list. If any two quotes match, \n     * return true immediately. If no duplicates are found after checking all quotes, \n     * return false.\n     * -----------------------------------------------------------------------------\n     */\n    \n    \n    return false;\n  }\n}",
        "isVisible": true,
        "tabOrder": 1
      }
    },
