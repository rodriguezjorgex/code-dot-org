      "TheaterRunner.java": {
        "text": "import org.code.theater.*;\n\npublic class TheaterRunner {\n  public static void main(String[] args) {\n    \n    // Creates a School object\n    School scene = new School();\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call both versions of the createCourse() method\n     * -----------------------------------------------------------------------------\n     */\n    \n\n    scene.drawResult();\n\n    Theater.playScenes(scene);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "School.java": {
        "text": "import org.code.theater.*;\n\n/*\n * Represents a school\n */\npublic class School extends Scene {\n\n  private Course course1;\n  private Course course2;\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Write the createCourse() method. This version should take a course ID and\n   * name as parameters, and assign a new Course to course1.\n   * -----------------------------------------------------------------------------\n   */\n  public void createCourse(String ID, String name) {\n    // Your code here\n  }\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Write the createCourse() method. This version should take a course ID only,\n   * and assign a new Course to course2.\n   * -----------------------------------------------------------------------------\n   */\n  public void createCourse(String ID) {\n    // Your code here\n  }\n\n  public Course getCourse1() {\n    return course1;\n  }\n  \n  public Course getCourse2() {\n    return course2;\n  }\n\n  /*\n   * Draws the result in the scene\n   */\n  public void drawResult() {\n    drawImage(\"whiteboard.png\", 0, 0, getWidth());\n  \n    drawText(\"Courses:\", 50, 80);\n  \n    drawText(\"\" + course1, 50, 120);  \n    pause(0.5);\n  \n    drawText(\"\" + course2, 50, 160);\n    pause(0.5);\n  }\n\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Course.java": {
        "text": "import org.code.theater.*;\nimport org.code.media.*;\n\n/*\n * Represents a Course\n */\npublic class Course {\n  \n  private String ID;   // ID\n  private String name; // name\n\n  public Course(String ID, String name) {\n    this.ID = ID;\n    this.name = name;\n  }\n\n  public Course(String ID) {\n    this(ID, \"\");\n  }\n\n  /*\n   * Returns a String containing the course's information\n   */\n  public String toString() {\n    return \"ID: \" + ID + \" name: \" + name;\n  }\n\n}",
        "isVisible": true,
        "tabOrder": 2
      }
    }
  },
