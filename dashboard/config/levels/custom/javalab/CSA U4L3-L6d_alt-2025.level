    "start_sources": {
      "TheaterRunner.java": {
        "text": "import org.code.theater.*;\n\npublic class TheaterRunner {\n  public static void main(String[] args) {\n\n    // Create SadBee objects\n    SadBee bee1 = new SadBee(20, 20);\n    SadBee bee2 = new SadBee(200, 20);\n    SadBee bee3 = new SadBee(80, 100);\n    SadBee bee4 = new SadBee(220, 150);\n\n    // Create scene and draw pairs\n    SadBeeScene scene = new SadBeeScene();\n\n    scene.drawResults(bee1, bee2);\n    scene.drawResults(bee2, bee3);\n    scene.drawResults(bee3, bee4);\n    scene.drawResults(bee1, bee4);\n\n    Theater.playScenes(scene);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "SadBeeScene.java": {
        "text": "import org.code.theater.*;\n\npublic class SadBeeScene extends Scene {\n\n  /*\n   * Returns the distance between the first SadBee and the second SadBee\n   */\n  public int getDistance(SadBee first, SadBee second) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use Math.abs() to return the absolute value of the difference between\n     * the x-locations of two SadBee objects.\n     * -----------------------------------------------------------------------------\n     */\n    return 0;\n  }\n\n  /*\n   * Draws pairs of bees and shows the distance between them\n   */\n  public void drawResults(SadBee bee1, SadBee bee2) {\n    drawImage(SadBee.SAD_BEE_IMAGE, bee1.getXLocation(), bee1.getYLocation(), SadBee.SIZE);\n    drawImage(SadBee.SAD_BEE_IMAGE, bee2.getXLocation(), bee2.getYLocation(), SadBee.SIZE);\n    drawText(\"Distance between the sad bees is \" + getDistance(bee1, bee2), 40, 330);\n\n    pause(1.5);\n    clear(\"white\");\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "SadBee.java": {
        "text": "import org.code.theater.*;\n\n/*\n * Represents a sad bee avatar\n */\npublic class SadBee {\n\n  private int xLocation;\n  private int yLocation;\n  public static final int SIZE = 150;\n  public static final String SAD_BEE_IMAGE = \"sadbee.png\";\n\n  /*\n   * Sets the xLocation and yLocation to the specified values\n   */\n  public SadBee(int xLocation, int yLocation) {\n    this.xLocation = xLocation;\n    this.yLocation = yLocation;\n  }\n\n  /*\n   * Returns the x location of the sad bee avatar\n   */\n  public int getXLocation() {\n    return xLocation;\n  }\n\n  /*\n   * Returns the y location of the sad bee avatar\n   */\n  public int getYLocation() {\n    return yLocation;\n  }\n\n  /*\n   * Sets the x location to the newXLocation\n   */\n  public void setXLocation(int newXLocation) {\n    xLocation = newXLocation;\n  }\n\n  /*\n   * Sets the y location to the newYLocation\n   */\n  public void setYLocation(int newYLocation) {\n    yLocation = newYLocation;\n  }\n  \n}",
        "isVisible": true,
        "tabOrder": 2
      }
    }
  },
