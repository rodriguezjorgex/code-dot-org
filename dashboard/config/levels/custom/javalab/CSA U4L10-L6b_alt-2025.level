    "name_suffix": "_alt-2025",
    "ai_tutor_available": "false",
    "start_sources": {
      "TheaterRunner.java": {
        "text": "import org.code.theater.*;\n\npublic class TheaterRunner {\n  public static void main(String[] args) {\n\n    // Manually create individual Country objects\n    Country c1 = new Country(\"Canada\", \"High income\");\n    Country c2 = new Country(\"Brazil\", \"Upper middle income\");\n    Country c3 = new Country(\"India\", \"Lower middle income\");\n    Country c4 = new Country(\"Nepal\", \"Lower middle income\");\n    Country c5 = new Country(\"Germany\", \"High income\");\n    Country c6 = new Country(\"Morocco\", \"Other\");\n    Country c7 = new Country(\"South Africa\", \"Upper middle income\");\n    Country c8 = new Country(\"Mexico\", \"Upper middle income\");\n\n    // Create an Internet scene\n    Internet scene = new Internet(c1, c2, c3, c4, c5, c6, c7, c8);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call getCountsByGroup() and then call drawResults() with the result\n     * -----------------------------------------------------------------------------\n     */\n\n\n    // Play the scene\n    Theater.playScenes(scene);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Internet.java": {
        "text": "import org.code.theater.*;\n\npublic class Internet extends Scene {\n\n  private Country c1, c2, c3, c4, c5, c6, c7, c8;\n\n  public Internet(Country c1, Country c2, Country c3, Country c4,\n                  Country c5, Country c6, Country c7, Country c8) {\n    this.c1 = c1;\n    this.c2 = c2;\n    this.c3 = c3;\n    this.c4 = c4;\n    this.c5 = c5;\n    this.c6 = c6;\n    this.c7 = c7;\n    this.c8 = c8;\n  }\n\n  /*\n   * Returns a Results object containing the number of countries in each income group\n   */\n  public Results getCountsByGroup() {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Check the group of each country and update the correct counter in\n     * a Results object. Use multi-selection statements (if/else if/else).\n     * Return the Results object.\n     * -----------------------------------------------------------------------------\n     */\n\n\n    return null;\n  }\n\n  /*\n   * Draws the result bars on screen using the results object\n   */\n  public void drawResults(Results results) {\n    drawText(\"Number of Countries by Group\", 40, 30);\n\n    setFillColor(\"red\");\n    drawRectangle(0, 60, results.getHighIncome() * 20, 25);\n    pause(0.2);\n\n    setFillColor(\"green\");\n    drawRectangle(0, 100, results.getLowerMiddleIncome() * 20, 25);\n    pause(0.2);\n\n    setFillColor(\"purple\");\n    drawRectangle(0, 140, results.getUpperMiddleIncome() * 20, 25);\n    pause(0.2);\n\n    setFillColor(\"orange\");\n    drawRectangle(0, 180, results.getOther() * 20, 25);\n    pause(0.2);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "Country.java": {
        "text": "public class Country {\n\n  private String name;\n  private String group;\n\n  public Country(String name, String group) {\n    this.name = name;\n    this.group = group;\n  }\n\n  public String getName() {\n    return name;\n  }\n\n  public String getGroup() {\n    return group;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      },
      "Results.java": {
        "text": "public class Results {\n\n  private int highIncome;\n  private int lowerMiddleIncome;\n  private int upperMiddleIncome;\n  private int other;\n\n  public Results() {\n    highIncome = 0;\n    lowerMiddleIncome = 0;\n    upperMiddleIncome = 0;\n    other = 0;\n  }\n\n  public void incrementHighIncome() {\n    highIncome++;\n  }\n\n  public void incrementLowerMiddleIncome() {\n    lowerMiddleIncome++;\n  }\n\n  public void incrementUpperMiddleIncome() {\n    upperMiddleIncome++;\n  }\n\n  public void incrementOther() {\n    other++;\n  }\n\n  public int getHighIncome() {\n    return highIncome;\n  }\n\n  public int getLowerMiddleIncome() {\n    return lowerMiddleIncome;\n  }\n\n  public int getUpperMiddleIncome() {\n    return upperMiddleIncome;\n  }\n\n  public int getOther() {\n    return other;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 3
      }
    }
  },
  "published": true,
  "audit_log": "[{\"changed_at\":\"2024-08-02T22:17:23.744+00:00\",\"changed\":[\"cloned from \\\"CSA U4L10-L6b_pilot-2025\\\"\"],\"cloned_from\":\"CSA U4L10-L6b_pilot-2025\"},{\"changed_at\":\"2025-05-27 14:34:20 +0000\",\"changed\":[\"long_instructions\",\"contained_level_names\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-27 14:44:51 +0000\",\"changed\":[\"encrypted_validation\",\"start_sources\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-27 14:44:56 +0000\",\"changed\":[\"start_sources\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-27 14:44:58 +0000\",\"changed\":[],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-27 14:50:29 +0000\",\"changed\":[\"encrypted_exemplar_sources\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"},{\"changed_at\":\"2025-05-27 14:53:57 +0000\",\"changed\":[\"encrypted_exemplar_sources\"],\"changed_by_id\":16889,\"changed_by_email\":\"jamila+lb@code.org\"}]"
