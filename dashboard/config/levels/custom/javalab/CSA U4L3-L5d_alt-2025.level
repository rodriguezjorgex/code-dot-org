    "start_sources": {
      "Creator.java": {
        "text": "import org.code.theater.*;\n\npublic class Creator extends Scene {\n\n  private int startNum;\n\n  /*\n   * Sets startNum to the specified value\n   */\n  public Creator(int startNum) {\n    this.startNum = startNum;\n  }\n\n  /*\n   * Returns the starting number of people\n   */\n  public int getStartNum() {\n    return startNum;\n  }\n\n  public double raiseToPower(double value, int power) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use Math.pow to raise the given value to the given power\n     * -----------------------------------------------------------------------------\n     */\n    return 0;\n  }\n\n  public void drawResult(double value) {\n    int x = 50;\n    int y = getNextY();\n    drawImage(\"message.png\", x, y, 50);\n    drawText(value + \" people reached\", x + 60, y + 30);\n    pause(0.1);\n  }\n\n  private int currentY = 50;\n\n  private int getNextY() {\n    int y = currentY;\n    currentY += 50;\n    return y;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "TheaterRunner.java": {
        "text": "import org.code.theater.*;\n\npublic class TheaterRunner {\n  public static void main(String[] args) {\n    Creator reach = new Creator(10);\n\n    double level1 = reach.getStartNum();\n    double level2 = reach.raiseToPower(level1, 2);\n    double level3 = reach.raiseToPower(level2, 3);\n\n    reach.drawResult(level1);\n    reach.drawResult(level2);\n    reach.drawResult(level3);\n\n    Theater.playScenes(reach);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      }
    }
  },
