    "start_sources": {
      "ChatbotRunner.java": {
        "text": "public class ChatbotRunner {\n  public static void main(String[] args) {\n\n    // Creates a Chatbot object\n    Chatbot alexa = new Chatbot(\"Alexa\");\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the getDogPart() method and print the result.\n     * -----------------------------------------------------------------------------\n     */\n\n\n\n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Chatbot.java": {
        "text": "/*\n * Represents a chatbot on a school website\n */\npublic class Chatbot {\n\n  private String name;           // The name of the chatbot\n  private String data;           // A string containing parts of speech entries\n\n  /*\n   * Sets name to the specified name and initializes data with a hardcoded set of entries\n   */\n  public Chatbot(String name) {\n    this.name = name;\n    this.data = \"dog:noun,blue:adjective,run:verb\";\n  }\n\n  /*\n   * Returns the part of speech for \"dog\" using indexOf() and substring()\n   */\n  public String getDogPart() {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use indexOf() and substring() to extract the word and part of speech\n     * for \"dog\" from the data string. Return the result in the format:\n     * \"dog: noun\"\n     * -----------------------------------------------------------------------------\n     */\n\n    \n\n    return \"\";\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    },
