    "start_sources": {
      "TheaterRunner.java": {
        "text": "import org.code.theater.*;\n\npublic class TheaterRunner {\n  public static void main(String[] args) {\n    BasketballScene scene = new BasketballScene();\n\n    // Example game scores\n    int h1 = 75, v1 = 64;\n    int h2 = 82, v2 = 87;\n    int h3 = 90, v3 = 90;\n    int h4 = 68, v4 = 83;\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call getScoreDiff() for each set of scores, and pass the result along\n     * with the scores to drawResult().\n     * -----------------------------------------------------------------------------\n     */\n\n\n\n\n\n\n    Theater.playScenes(scene);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "BasketballScene.java": {
        "text": "import org.code.theater.*;\n\n/*\n * Creates a visualization to show the difference\n * between home and visiting team scores\n */\npublic class BasketballScene extends Scene {\n\n  /*\n   * Returns the absolute difference between home and visitor scores\n   */\n  public int getScoreDiff(int home, int visitor) {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Use Math.abs() to return the difference between home and visitor scores\n     * -----------------------------------------------------------------------------\n     */\n    return 0;\n  }\n\n  /*\n   * Draws the result in the scene\n   */\n  public void drawResult(int home, int visitor, int diff) {\n    int winner = getWinner(home, visitor);\n\n    drawHomeText(home);\n    drawVisitingText(visitor);\n    drawWinnerText(winner, diff);\n\n    int size = 150;\n    int xLocation = (getWidth() / 2) - (size / 2);\n    drawImage(\"basketball.png\", xLocation, 120, size);\n\n    pause(1.5);\n    clear(\"white\");\n  }\n\n  public int getWinner(int homeScore, int visitingScore) {\n    if (homeScore > visitingScore) {\n      return 0;\n    } else {\n      return 1;\n    }\n  }\n\n  public void drawHomeText(int score) {\n    drawText(\"Home\", 75, 75);\n    drawText(score + \"\", 75, 100);\n  }\n\n  public void drawVisitingText(int score) {\n    drawText(\"Visitor\", 250, 75);\n    drawText(score + \"\", 250, 100);\n  }\n\n  public void drawWinnerText(int winner, int difference) {\n    String winnerText = (winner == 0) ? \"Home\" : \"Visiting\";\n    drawText(winnerText + \" team won by \" + difference + \" points\", 50, 325);\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    }
  },
