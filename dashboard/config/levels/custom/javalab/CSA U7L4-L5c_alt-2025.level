      "RecipeRunner.java": {
        "text": "public class RecipeRunner {\n  public static void main(String[] args) {\n\n    // Creates a Website object with 5 hardcoded recipes\n    Website recipeWebsite = new Website();\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the getRecommendedRecipes() method and print the results.\n     * -----------------------------------------------------------------------------\n     */\n\n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      },
      "Recipe.java": {
        "text": "/*\n * Represents a recipe\n */\npublic class Recipe {\n\n  private String name;\n  private String ingredient1;\n  private String ingredient2;\n  private String ingredient3;\n\n  public Recipe(String name, String i1, String i2, String i3) {\n    this.name = name;\n    this.ingredient1 = i1;\n    this.ingredient2 = i2;\n    this.ingredient3 = i3;\n  }\n\n  public String getName() {\n    return name;\n  }\n\n  public String getIngredient1() {\n    return ingredient1;\n  }\n\n  public String getIngredient2() {\n    return ingredient2;\n  }\n\n  public String getIngredient3() {\n    return ingredient3;\n  }\n\n  public String toString() {\n    return name + \"\\n----------\\n\" + ingredient1 + \"\\n\" + ingredient2 + \"\\n\" + ingredient3;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 2
      },
      "Website.java": {
        "text": "/*\n * Represents a recipe website\n */\npublic class Website {\n\n  private Recipe r1;\n  private Recipe r2;\n  private Recipe r3;\n  private Recipe r4;\n  private Recipe r5;\n\n  public Website() {\n    r1 = new Recipe(\"Spaghetti Bolognese\", \"ground beef\", \"onion\", \"tomato\");\n    r2 = new Recipe(\"Chicken Curry\", \"chicken\", \"curry powder\", \"coconut milk\");\n    r3 = new Recipe(\"Beef Stroganoff\", \"beef\", \"mushrooms\", \"sour cream\");\n    r4 = new Recipe(\"Vegetable Stir-Fry\", \"broccoli\", \"carrots\", \"soy sauce\");\n    r5 = new Recipe(\"Salmon with Asparagus\", \"salmon\", \"asparagus\", \"lemon\");\n  }\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Write a private method resultsToString that takes three Recipe parameters\n   * and returns a String with each recipe's info on separate lines.\n   * -----------------------------------------------------------------------------\n   */\n  private String resultsToString(Recipe a, Recipe b, Recipe c) {\n    // your code here\n    return \"\";\n  }\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Write a public method getRecommendedRecipes that takes three ingredients\n   * and returns a String using the resultsToString method with any 3 recipes.\n   * -----------------------------------------------------------------------------\n   */\n  public String getRecommendedRecipes(String i1, String i2, String i3) {\n    // your code here\n    return \"\";\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      }
    }
