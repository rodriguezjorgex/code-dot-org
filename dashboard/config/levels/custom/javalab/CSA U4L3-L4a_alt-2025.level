    "start_sources": {
      "TravelAgency.java": {
        "text": "/*\n * Manages data about vacation packages\n */\npublic class TravelAgency {\n\n  /* ----------------------------------- TO DO -----------------------------------\n   * ✅ Declare and initialize a constant called DAILY_RATE to 250.\n   * -----------------------------------------------------------------------------\n   */\n\n  \n\n  /*\n   * Returns a String with the total prices of all vacation packages\n   */\n  public String getPrices() {\n    String result = \"Vacation Packages\\n---------------\\n\";\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Update each line to use the constant instead of the number 250.\n     * -----------------------------------------------------------------------------\n     */\n\n    result += \"Beach Bonanza (5 days): $\" + (5 * 250) + \"\\n\";\n    result += \"Mountain Retreat (3 days): $\" + (3 * 250) + \"\\n\";\n    result += \"City Explorer (7 days): $\" + (7 * 250) + \"\\n\";\n\n    return result;\n  }\n}\n",
        "isVisible": true,
        "tabOrder": 1
      },
      "AgencyRunner.java": {
        "text": "public class AgencyRunner {\n  public static void main(String[] args) {\n    \n    TravelAgency agency = new TravelAgency();\n    \n    System.out.println(agency.getPrices());\n    \n  }\n}\n",
        "isVisible": true,
        "tabOrder": 0
      }
    },
