    "start_sources": {
      "StoreRunner.java": {
        "text": "import java.util.ArrayList;\n\npublic class StoreRunner {\n  public static void main(String[] args) {\n\n    // Creates an ArrayList of items\n    ArrayList<Item> items = new ArrayList<Item>();\n    items.add(new Item(\"Sneakers\", 59.99));\n    items.add(new Item(\"Backpack\", 29.99));\n    items.add(new Item(\"Backpack\", 35.75));\n    items.add(new Item(\"Water Bottle\", 9.99));\n    items.add(new Item(\"Backpack\", 25.67));\n\n    // Creates a Store object\n    Store supplies = new Store(items);\n\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Call the findMostExpensive() method and print the result.\n     * -----------------------------------------------------------------------------\n     */\n\n\n    \n    \n  }\n}",
        "isVisible": true,
        "tabOrder": 0
      },
      "Store.java": {
        "text": "import java.util.ArrayList;\n\n/*\n * Represents a store\n */\npublic class Store {\n\n  private ArrayList<Item> inventory;    // The list of items at a store\n\n  /*\n   * Initializes inventory to the specified list of items\n   */\n  public Store(ArrayList<Item> inventory) {\n    this.inventory = inventory;\n  }\n\n  /*\n   * Returns the list of items\n   */\n  public ArrayList<Item> getInventory() {\n    return inventory;\n  }\n\n  /*\n   * Returns the most expensive Item in inventory\n   */\n  public Item findMostExpensive() {\n    /* ----------------------------------- TO DO -----------------------------------\n     * ✅ Traverse the inventory list and find the Item with the highest price.\n     * -----------------------------------------------------------------------------\n     */\n    Item mostExpensive = null;\n\n    \n    return mostExpensive;\n  }\n  \n}",
        "isVisible": true,
        "tabOrder": 1
      },
      "Item.java": {
        "text": "/*\n * Represents an item in a store\n */\npublic class Item {\n\n  private String type;    // The type of item\n  private double price;   // The price of an item\n\n  /*\n   * Sets type and price to the specified values\n   */\n  public Item(String type, double price) {\n    this.type = type;\n    this.price = price;\n  }\n\n  /*\n   * Returns the type of the item\n   */\n  public String getType() {\n    return type;\n  }\n\n  /*\n   * Returns the price of the item\n   */\n  public double getPrice() {\n    return price;\n  }\n\n  /*\n   * Returns a String containing the type and price of the item\n   */\n  public String toString() {\n    return type + \" - \" + price;\n  }\n  \n}",
        "isVisible": true,
        "tabOrder": 2
      }
    },
