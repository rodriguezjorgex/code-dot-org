  "properties": {
    "encrypted": "false",
    "long_instructions": "## Do This\r\n\r\nHover over the different sections of the webpage to locate:\r\n- Nav (Navigation) Bar\r\n- Hero section\r\n- Cards\r\n- Footer\r\n\r\nLabel these four features in your activity guide. Then choose one to describe in detail.",
    "submittable": "false",
    "disable_edit_run_for_submission": "false",
    "hide_share_and_remix": "false",
    "widget_view": "false",
    "initial_view_mode": "preview",
    "ai_tutor_mode": "suggest",
    "predict_settings": {
      "isPredictLevel": false,
      "solution": "",
      "questionType": "freeResponse",
