      "files": {
        "2": {
          "id": "2",
          "name": "styles.css",
          "language": "css",
          "contents": "* {\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  font-family: Arial, Helvetica, sans-serif;\n  font-size: 14px;\n  color: #222;\n}\n\n.site {\n  display: flex;\n  flex-direction: column;\n  min-height: 100vh;\n}\n\n.header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 12px 16px;\n  background: #f0f0f0;\n}\n\n.title {\n  font-weight: 700;\n}\n\n.nav-link {\n  color: #6b6bb8; /* Low-ish contrast on light gray */\n  text-decoration: underline;\n  padding: 2px 4px; /* Tiny tap target */\n  font-size: 12px;\n}\n\n/* Intentionally remove visible focus outline (bad) */\n.nav-link:focus,\n.tiny-btn:focus,\n.input:focus,\n.primary:focus {\n  outline: none;\n  box-shadow: none;\n}\n\n.hero {\n  padding: 16px;\n  background: #f5f5f5; /* Light gray background */\n}\n\n.hero-img {\n  width: 100%;\n  height: 180px;\n  object-fit: cover;\n  display: block;\n}\n\n.muted {\n  color: #b5b5b5; /* Low contrast on #f5f5f5 background */\n}\n\n.tiny-btn {\n  font-size: 10px; /* Too small */\n  padding: 2px 6px; /* Too small click target */\n}\n\n.content {\n  padding: 16px;\n}\n\n.section {\n  margin-bottom: 24px;\n}\n\n/* Styled like a heading but not semantic (still a div) */\n.section-title {\n  font-weight: 700;\n  font-size: 18px;\n  margin-bottom: 8px;\n}\n\n.input {\n  padding: 6px 8px;\n  font-size: 12px; /* Small text */\n  width: 240px;\n  margin-right: 8px;\n}\n\n.primary {\n  background: #005fcc;\n  color: white;\n  border: none;\n  padding: 6px 10px;\n  font-size: 12px;\n  cursor: pointer;\n}\n\n.footer {\n  margin-top: auto;\n  padding: 12px 16px;\n  background: #f0f0f0;\n}\n\n/* Product cards (simple layout, keeps intentional a11y issues) */\n.cards {\n  display: grid;\n  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));\n  gap: 12px;\n  margin-top: 8px;\n}\n\n.card {\n  background: #ffffff;\n  border: 1px solid #e0e0e0;\n  padding: 12px;\n}\n\n.card-img {\n  width: 100%;\n  height: 140px;\n  object-fit: cover;\n  display: block;\n}\n\n/* Styled like a heading but still not semantic */\n.card-title {\n  font-weight: 700;\n  font-size: 16px;\n  margin: 8px 0;\n}\n",
          "folderId": "0",
          "active": false
        },
