        "7": {
          "id": "7",
          "name": "index.html",
          "language": "html",
          "contents": "<!doctype html>\n<html>\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>Umbrella Shop</title>\n  <link rel=\"stylesheet\" href=\"styles.css\">\n</head>\n<body>\n  <div class=\"site\">\n    <div class=\"header\">\n      <div class=\"title\">RainReady Umbrellas</div>\n      <a href=\"#\" class=\"nav-link\">Click here</a>\n    </div>\n\n    <div class=\"hero\">\n      <img src=\"umbrellaHeader.png\" class=\"hero-img\">\n      <p class=\"muted\">Stay dry in style with our lightweight, wind-tested umbrellas.</p>\n      <button class=\"tiny-btn\">Shop</button>\n    </div>\n\n    <div class=\"content\">\n      <div class=\"section\">\n        <div class=\"section-title\">Products</div>\n        <p>\n          Discover durable classics and ultra-compact travel umbrellas. Limited colors available today.\n        </p>\n        <div class=\"cards\">\n          <div class=\"card\">\n            <img src=\"umbrella1.png\" class=\"card-img\">\n            <div class=\"card-title\">Classic Umbrella</div>\n            <p>Sturdy steel frame with ergonomic handle.</p>\n            <button class=\"tiny-btn\">Add</button>\n          </div>\n          <div class=\"card\">\n            <img src=\"umbrella2.png\" class=\"card-img\">\n            <div class=\"card-title\">Travel Mini</div>\n            <p>Pocket-size design for on-the-go coverage.</p>\n            <button class=\"tiny-btn\">Add</button>\n          </div>\n          <div class=\"card\">\n            <img src=\"umbrella3.png\" class=\"card-img\">\n            <div class=\"card-title\">WindGuard Pro</div>\n            <p>Reinforced canopy built for gusty days.</p>\n            <button class=\"tiny-btn\">Add</button>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <div class=\"section-title\">Order</div>\n        <input type=\"text\" class=\"input\" placeholder=\"Your name\">\n        <button class=\"primary\">Buy Now</button>\n      </div>\n    </div>\n\n    <div class=\"footer\">\n      <div>© 2025 RainReady Co</div>\n    </div>\n  </div>\n</body>\n</html>\n",
          "folderId": "0",
          "active": true
        }
      },
