          "id": "2",
          "name": "style.css",
          "language": "css",
          "contents": "body {\n  font-family: Arial, sans-serif;\n  text-align: center;\n  margin-top: 50px;\n}\n\nbutton {\n  padding: 10px 20px;\n  font-size: 16px;\n  cursor: pointer;\n}\n\n#message {\n  margin-top: 20px;\n  font-size: 18px;\n  color: darkblue;\n}\n",
          "folderId": "0",
          "active": false
        },
        "3": {
          "id": "3",
          "name": "script.js",
          "language": "js",
          "contents": "document.getElementById(\"clickButton\").addEventListener(\"click\", function() {\n  document.getElementById(\"message\").textContent = \"button clicked!\";\n});\n",
