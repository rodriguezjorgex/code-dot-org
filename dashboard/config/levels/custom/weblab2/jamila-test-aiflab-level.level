          "language": "html",
          "contents": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Button Click Example</title>\n  <link rel=\"stylesheet\" href=\"style.css\">\n</head>\n<body>\n\n  <h1>Click the Button!</h1>\n  <button id=\"clickButton\">Click Me</button>\n  <p id=\"message\"></p>\n\n  <script src=\"script.js\"></script>\n</body>\n</html>\n",
          "active": false,
          "folderId": "0"
        },
