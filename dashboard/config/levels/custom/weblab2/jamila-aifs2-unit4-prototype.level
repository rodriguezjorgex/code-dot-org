        "2": {
          "id": "2",
          "name": "style.css",
          "language": "css",
          "contents": "/* style.css */\n\n/* General body styling for a dark arcade background */\nbody {\n    font-family: 'Press Start 2P', cursive; /* Retro arcade font */\n    display: flex;\n    justify-content: center;\n    align-items: flex-start;\n    min-height: 100vh;\n    margin: 0;\n    background-color: #1a1a2e; /* Dark blue-purple background */\n    padding: 20px;\n    color: #00ff00; /* Neon green text */\n    text-shadow: 0 0 5px #00ff00; /* Neon glow effect */\n}\n\n/* Main container for the dashboard */\n.container {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    width: 100%;\n    max-width: 960px;\n    background-color: rgba(0, 0, 0, 0.7); /* Slightly transparent dark background */\n    padding: 20px;\n    border-radius: 8px;\n    box-shadow: 0 0 15px #ff00ff; /* Neon pink shadow */\n    border: 2px solid #00ffff; /* Neon blue border */\n}\n\n/* Title of the application */\n.app-title {\n    font-family: 'Press Start 2P', cursive;\n    font-size: 3rem;\n    margin-bottom: 30px;\n    color: #ffea00; /* Neon yellow title */\n    text-shadow: 0 0 10px #ffea00, 0 0 20px #ffea00; /* Stronger neon glow */\n    text-align: center;\n}\n\n/* Section containing the filter dropdowns and song count */\n.filter-section {\n    display: flex;\n    align-items: center;\n    gap: 15px;\n    margin-bottom: 40px;\n    width: 100%;\n    justify-content: center;\n    flex-wrap: wrap;\n}\n\n/* Styling for the dropdown container */\n.dropdown {\n    position: relative;\n    display: inline-block;\n}\n\n/* Styling for the select element (the actual dropdown) */\n.filter-dropdown {\n    font-family: 'Press Start 2P', cursive;\n    padding: 10px 20px;\n    border: 2px solid #00ffff; /* Neon blue border */\n    border-radius: 5px; /* Slightly rounded corners for a pixelated look */\n    background-color: #333; /* Darker background for dropdown */\n    color: #00ff00; /* Neon green text */\n    font-size: 0.9rem;\n    cursor: pointer;\n    appearance: none;\n    -webkit-appearance: none;\n    -moz-appearance: none;\n    background-image: url('data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%22292.4%22%20height%3D%22292.4%22%3E%3Cpath%20fill%3D%22%2300FF00%22%20d%3D%22M287%2069.4a17.6%2017.6%200%200%200-13-5.4H18.4c-6.5%200-12.3%203.2-16.1%208.1-3.8%204.9-4.9%2011.6-3.1%2017.9L139.6%20275.4a17.6%2017.6%200%200%200%2029.2%200L300.7%2090.8c1.8-6.3.7-13-3.1-17.9z%22%2F%3E%3C%2Fsvg%3E'); /* Custom neon green dropdown arrow */\n    background-repeat: no-repeat;\n    background-position: right 10px center;\n    background-size: 10px;\n    padding-right: 30px;\n    box-shadow: 0 0 8px #00ff00; /* Neon green shadow */\n}\n\n.filter-dropdown:hover {\n    background-color: #555; /* Slightly lighter on hover */\n    box-shadow: 0 0 12px #00ff00;\n}\n\n.filter-dropdown:focus {\n    outline: none;\n    border-color: #ff00ff; /* Neon pink focus border */\n    box-shadow: 0 0 15px #ff00ff;\n}\n\n/* Reduces motion for users who prefer it */\n@media (prefers-reduced-motion: reduce) {\n    .filter-dropdown {\n        transition: none;\n    }\n}\n\n/* Styling for the song count display */\n.song-count {\n    font-family: 'Press Start 2P', cursive;\n    font-size: 1rem;\n    color: #ff00ff; /* Neon pink for the count */\n    margin-left: 10px;\n    text-shadow: 0 0 5px #ff00ff;\n}\n\n/* Container for displaying the song cards */\n.song-display {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); /* Responsive columns */\n    gap: 30px;\n    width: 100%;\n    justify-items: center;\n}\n\n/* Styling for individual song cards */\n.song-card {\n    width: 180px;\n    height: 180px;\n    border: 2px solid #00ffff; /* Neon blue border */\n    border-radius: 50%;\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    text-align: center;\n    background-color: rgba(0, 0, 0, 0.5); /* Semi-transparent dark background */\n    box-shadow: 0 0 10px #00ff00; /* Neon green shadow */\n    cursor: pointer;\n    transition: transform 0.3s ease, box-shadow 0.3s ease;\n    color: #00ff00; /* Neon green text */\n    text-shadow: 0 0 5px #00ff00;\n}\n\n.song-card:hover {\n    transform: scale(1.05);\n    box-shadow: 0 0 20px #ff00ff; /* Neon pink shadow on hover */\n}\n\n/* Reduces motion for users who prefer it */\n@media (prefers-reduced-motion: reduce) {\n    .song-card {\n        transition: none;\n    }\n}\n\n/* Styling for the song title within the card */\n.song-title {\n    font-family: 'Press Start 2P', cursive;\n    font-size: 1rem;\n    font-weight: bold;\n    margin: 0;\n    color: #ffea00; /* Neon yellow title */\n    text-shadow: 0 0 5px #ffea00;\n}\n\n/* Styling for the artist name within the card */\n.artist-name {\n    font-family: 'Press Start 2P', cursive;\n    font-size: 0.8rem;\n    color: #00ffff; /* Neon blue artist name */\n    margin: 5px 0 0;\n    text-shadow: 0 0 3px #00ffff;\n}\n\n/* Styling for the genre and mood within the card */\n.genre-mood {\n    font-family: 'Press Start 2P', cursive;\n    font-size: 0.7rem;\n    color: #ff00ff; /* Neon pink genre/mood */\n    margin: 5px 0 0;\n    text-shadow: 0 0 3px #ff00ff;\n}\n\n/* Media queries for responsiveness */\n@media (max-width: 768px) {\n    .app-title {\n        font-size: 2.5rem;\n    }\n\n    .filter-section {\n        flex-direction: column;\n        gap: 10px;\n    }\n\n    .filter-dropdown {\n        width: 100%; /* Full width dropdowns on smaller screens */\n    }\n\n    .song-display {\n        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); /* Smaller cards */\n        gap: 20px;\n    }\n\n    .song-card {\n        width: 150px;\n        height: 150px;\n    }\n}\n\n@media (max-width: 480px) {\n    .app-title {\n        font-size: 2rem;\n    }\n\n    .song-display {\n        grid-template-columns: 1fr; /* Single column on very small screens */\n    }\n\n    .song-card {\n        width: 100%; /* Full width cards */\n        height: auto;\n        min-height: 150px;\n        border-radius: 10px; /* More rectangular cards for readability */\n    }\n}\n\n\n",
          "folderId": "0",
          "active": false
