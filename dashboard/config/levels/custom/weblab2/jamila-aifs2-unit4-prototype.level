        "1": {
          "id": "1",
          "name": "index.html",
          "language": "html",
          "contents": "<!-- index.html -->\n<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>SongSurfer Dashboard</title>\n    <link rel=\"stylesheet\" href=\"style.css\">\n</head>\n<body>\n    <div class=\"container\">\n        <!-- Main title for the application -->\n        <h1 class=\"app-title\">SongSurfer</h1>\n\n        <div class=\"filter-section\">\n            <!-- Artist Filter Dropdown -->\n            <div class=\"dropdown\">\n                <select id=\"artist-filter\" class=\"filter-dropdown\">\n                    <option value=\"\">All Artists</option>\n                    <option value=\"Ramones\">Ramones</option>\n                    <option value=\"The Runaways\">The Runaways</option>\n                    <option value=\"Lo-fi Fruits Music\">Lo-fi Fruits Music</option>\n                    <option value=\"Chillhop Music\">Chillhop Music</option>\n                </select>\n            </div>\n\n            <!-- Genre Filter Dropdown -->\n            <div class=\"dropdown\">\n                <select id=\"genre-filter\" class=\"filter-dropdown\">\n                    <option value=\"\">All Genres</option>\n                    <option value=\"Punk\">Punk</option>\n                    <option value=\"Lo-fi\">Lo-fi</option>\n                </select>\n            </div>\n\n            <!-- Mood Filter Dropdown -->\n            <div class=\"dropdown\">\n                <select id=\"mood-filter\" class=\"filter-dropdown\">\n                    <option value=\"\">All Moods</option>\n                    <option value=\"Energetic\">Energetic</option>\n                    <option value=\"Rebellious\">Rebellious</option>\n                    <option value=\"Relaxing\">Relaxing</option>\n                    <option value=\"Calm\">Calm</option>\n                </select>\n            </div>\n\n            <!-- Display for the number of songs -->\n            <span class=\"song-count\">6 songs</span>\n        </div>\n\n        <div class=\"song-display\">\n            <!-- Placeholder song cards -->\n            <div class=\"song-card\">\n                <p class=\"song-title\">song title</p>\n                <p class=\"artist-name\">artist name</p>\n                <p class=\"genre-mood\">genre | mood</p>\n            </div>\n            <div class=\"song-card\">\n                <p class=\"song-title\">song title</p>\n                <p class=\"artist-name\">artist name</p>\n                <p class=\"genre-mood\">genre | mood</p>\n            </div>\n            <div class=\"song-card\">\n                <p class=\"song-title\">song title</p>\n                <p class=\"artist-name\">artist name</p>\n                <p class=\"genre-mood\">genre | mood</p>\n            </div>\n            <div class=\"song-card\">\n                <p class=\"song-title\">song title</p>\n                <p class=\"artist-name\">artist name</p>\n                <p class=\"genre-mood\">genre | mood</p>\n            </div>\n            <div class=\"song-card\">\n                <p class=\"song-title\">song title</p>\n                <p class=\"artist-name\">artist name</p>\n                <p class=\"genre-mood\">genre | mood</p>\n            </div>\n            <div class=\"song-card\">\n                <p class=\"song-title\">song title</p>\n                <p class=\"artist-name\">artist name</p>\n                <p class=\"genre-mood\">genre | mood</p>\n            </div>\n        </div>\n    </div>\n    <!-- Link to your data file -->\n    <script src=\"music_data.js\"></script>\n    <!-- Link to your main script file -->\n    <script src=\"script.js\"></script>\n</body>\n</html>\n\n\n",
          "folderId": "0",
