      "files": {
        "1": {
          "id": "1",
          "name": "index.html",
          "language": "html",
          "contents": "<!DOCTYPE html>\n<html>\n<head>\n  <title>Color Toggle App</title>\n  <link rel=\"stylesheet\" href=\"styles.css\">\n</head>\n<body>\n  <h1>Page Color Toggle</h1>\n\n  <label class=\"switch\">\n    <input type=\"checkbox\" id=\"colorToggle\">\n    <span class=\"slider round\"></span>\n  </label>\n\n  <script src=\"script.js\"></script>\n</body>\n</html>\n",
          "active": true,
          "folderId": "0"
        },
        "2": {
          "id": "2",
          "name": "script.js",
          "language": "js",
          "contents": "// script.js\nconst colorToggle = document.getElementById('colorToggle');\n\ncolorToggle.addEventListener(\"change\", ()=> {\n  if (document.body.style.backgroundColor == \"purple\"){\n    document.body.style.backgroundColor = \"white\";\n  } else {\n    document.body.style.backgroundColor = \"purple\";\n  }\n})",
          "folderId": "0",
          "active": false
        },
        "3": {
          "id": "3",
          "name": "styles.css",
          "language": "css",
          "contents": "/* style.css */\n\n.switch {\n  position: relative;\n  display: inline-block;\n  width: 60px; /* Width of the entire toggle */\n  height: 34px; /* Height of the entire toggle */\n}\n\n/* Hide default HTML checkbox */\n.switch input {\n  opacity: 0;\n  width: 0;\n  height: 0;\n}\n\n/* The slider part of the toggle */\n.slider {\n  position: absolute;\n  cursor: pointer;\n  top: 0;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  background-color: #ccc; /* Default background color when off */\n  -webkit-transition: .4s; /* Smooth transition for color change */\n  transition: .4s; /* Smooth transition for color change */\n}\n\n/* The \"round\" part for rounded corners */\n.slider.round {\n  border-radius: 34px; /* Makes the overall slider rounded */\n}\n\n/* The \"knob\" or \"thumb\" of the toggle */\n.slider::before {\n  position: absolute;\n  content: \"\"; /* Essential for pseudo-elements to display */\n  height: 26px; /* Size of the knob */\n  width: 26px; /* Size of the knob */\n  left: 4px; /* Starting position from the left */\n  bottom: 4px; /* Starting position from the bottom */\n  background-color: white; /* Color of the knob */\n  -webkit-transition: .4s; /* Smooth transition for movement */\n  transition: .4s; /* Smooth transition for movement */\n  border-radius: 50%; /* Makes the knob perfectly round */\n}\n\n/* style.css (add these rules) */\n\n/* When the checkbox is checked, change the background color of the slider */\n.switch input:checked + .slider {\n  background-color: #2196F3; /* A nice blue color */\n}\n\n/* When the checkbox is checked, move the knob to the right */\n.switch input:checked + .slider::before {\n  -webkit-transform: translateX(26px); /* Move the knob by 26px */\n  -ms-transform: translateX(26px);\n  transform: translateX(26px);\n}\n\n\n\n",
          "folderId": "0",
          "active": false
        },
        "4": {
          "id": "4",
          "name": "prompt.md",
          "language": "md",
          "contents": "Update the page to put a box around the title and toggle. \nGive that box a black background and make the text white.\nUpdate the toggle to change the page to yellow instead of purple.",
          "folderId": "0",
          "active": false
        }
