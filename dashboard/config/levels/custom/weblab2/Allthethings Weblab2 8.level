    "start_sources": {
      "folders": {
      },
      "files": {
        "1": {
          "id": "1",
          "name": "index.html",
          "language": "html",
          "contents": "<!DOCTYPE html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <title>Predict: Click me</title>\n  </head>\n  <body>\n    <h1>Web Lab 2 Predict Level</h1>\n\n    <button id=\"clickMe\">Click me</button>\n    <p id=\"output\" aria-live=\"polite\"></p>\n\n    <script src=\"script.js\"></script>\n  </body>\n</html>\n  ",
          "active": false,
          "folderId": "0"
        },
        "2": {
          "id": "2",
          "name": "script.js",
          "language": "js",
          "contents": "document.addEventListener('DOMContentLoaded', () => {\n  const button = document.getElementById('clickMe');\n  const output = document.getElementById('output');\n    \n  if (!button || !output) return;\n\n  button.addEventListener('click', () => {\n    output.textContent = 'Good night!';\n  });\n});",
          "folderId": "0",
          "active": true
        }
      },
