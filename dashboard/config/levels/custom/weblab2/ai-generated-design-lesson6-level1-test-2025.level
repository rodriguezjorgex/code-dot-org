          "name": "index.html",
          "language": "html",
          "contents": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Homepage</title>\n</head>\n<body>\n  <header>\n    <h1>Welcome to My Website</h1>\n    <nav>\n      <a href=\"index.html\">Home</a> |\n      <a href=\"contact.html\">Contact</a>\n    </nav>\n  </header>\n\n  <main>\n    <section>\n      <h2>About Us</h2>\n      <p>We are a small team dedicated to building simple, elegant web experiences using modern web technologies.</p>\n    </section>\n\n    <section>\n      <h2>Our Services</h2>\n      <ul>\n        <li>Web Design</li>\n        <li>Web Development</li>\n        <li>Consulting</li>\n      </ul>\n    </section>\n\n    <section>\n      <h2>Latest News</h2>\n      <p>Check out our latest updates and projects on our blog. We regularly post about technology and design trends.</p>\n    </section>\n  </main>\n\n  <footer>\n    <p>&copy; 2025 My Website. All rights reserved.</p>\n  </footer>\n</body>\n</html>\n  ",
          "active": true,
          "folderId": "0"
        },
        "2": {
          "id": "2",
          "name": "contact.html",
          "language": "html",
          "contents": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Contact Us</title>\n</head>\n<body>\n  <header>\n    <h1>Contact Us</h1>\n    <nav>\n      <a href=\"index.html\">Home</a> |\n      <a href=\"contact.html\">Contact</a>\n    </nav>\n  </header>\n\n  <main>\n    <section>\n      <h2>Get in Touch</h2>\n      <p>We’d love to hear from you! Please use the form below to send us a message.</p>\n      <form action=\"#\" method=\"post\">\n        <label for=\"name\">Name:</label><br>\n        <input type=\"text\" id=\"name\" name=\"name\"><br><br>\n\n        <label for=\"email\">Email:</label><br>\n        <input type=\"email\" id=\"email\" name=\"email\"><br><br>\n\n        <label for=\"message\">Message:</label><br>\n        <textarea id=\"message\" name=\"message\" rows=\"5\" cols=\"30\"></textarea><br><br>\n\n        <input type=\"submit\" value=\"Send Message\">\n      </form>\n    </section>\n\n    <section>\n      <h2>Our Location</h2>\n      <p>123 Main Street<br>\n      Hometown, USA 12345</p>\n    </section>\n  </main>\n\n  <footer>\n    <p>&copy; 2025 My Website. All rights reserved.</p>\n  </footer>\n</body>\n</html>",
          "folderId": "0",
          "active": false
        }
