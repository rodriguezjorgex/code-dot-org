    "encrypted": "false",
    "long_instructions": "Use a loop to heal villagers with a fixed number of potions.\r\n\r\n## Do This: \r\n- Run the code to see how many villagers you heal with 6 potions.\r\n- Modify the code so that healing a villager costs 2 potions instead of 1.",
    "ai_tutor_available": "false",
    "submittable": "false",
    "hide_share_and_remix": "false",
    "enable_micro_bit": "false",
    "predict_settings": {
