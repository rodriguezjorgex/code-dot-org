    },
    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "potions = 6  # You start with 6 potions\nvillagers_healed = 0  # Start with 0 villagers healed\n\n# Heal a villager for each potion\nwhile potions > 0:\n    villagers_healed += 1\n    potions -= 1\n    print(\"You healed a villager! Total villagers healed:\", villagers_healed)\n\nprint(\"You ran out of potions!\")\n",
          "folderId": "0",
          "active": true,
          "open": true
        }
      },
      "folders": {
      },
      "openFiles": [
        "0"
      ]
    },
    "validation_file": {
      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\n\nclass TestVillagerHealingCost(unittest.TestCase):\n\n    def test_modify_healing_cost(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Check if the potion cost for healing is updated to 2 in the while loop\n            if 'potions -= 2' not in content:\n                self.fail(\n                    \"The potion cost for healing a villager has not been updated to 2 potions. \"\n                    \"Please change the line `potions -= 1` to `potions -= 2` so that healing a villager costs 2 potions.\"\n                )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
