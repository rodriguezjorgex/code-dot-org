    "thumbnail_url": "https://images.code.org/9850d5503be9c5bac7b953cea642ffc4-choiceB.gif",
    "display_name": "Paint Until You're Stuck",
    "bubble_choice_description": "The `Painter` just picked up some paint and is ready to go! The `Painter` wants to paint every space it passes, but only if it still has paint. If the `Painter` runs out of room to move forward, it should turn right to find a new path. Write a function that helps the `Painter` do both.",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPaintOrTurnHasPaint(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (4, 5) after painting and turning\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (4, 5),\n            \"The Painter didn't stop at (4, 5). Make sure your function paints and moves when possible and turns when blocked.\"\n        )\n\n    def test_painted_spaces(self):\n        \"\"\"Painter paints (6,4), (6,5), and (5,5)\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n        expected_output[4][6] = True  # (6,4)\n        expected_output[5][6] = True  # (6,5)\n        expected_output[5][5] = True  # (5,5)\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"The expected spaces (6,4), (6,5), and (5,5) weren't all painted. Make sure your loop continues while the Painter has paint.\"\n        )\n\n    def test_turns_when_blocked(self):\n        \"\"\"Painter turns right when it can't move\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            3,\n            \"The Painter didn't turn right when blocked. Make sure your paint_or_turn() turns right when the Painter can’t move.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
