      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestEmergencyProtocolFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_full_emergency_sequence(self):\n        \"\"\"emergency_protocol() should call all safety functions in order\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertGreaterEqual(\n            len(printed_messages),\n            4,\n            \"Make sure your emergency_protocol() function calls sound_alarm() twice, then lock_doors(), then secure_server_room().\"\n        )\n\n        alarm_count = sum(1 for line in printed_messages if \"alarm\" in line.lower())\n        doors_locked = any(\"lock\" in line.lower() for line in printed_messages)\n        server_secured = any(\"server\" in line.lower() for line in printed_messages)\n\n        self.assertGreaterEqual(\n            alarm_count,\n            2,\n            \"Make sure sound_alarm() is called twice at the beginning of emergency_protocol().\"\n        )\n\n        self.assertTrue(\n            doors_locked,\n            \"It looks like lock_doors() wasn't called. Make sure you call it after sounding the alarms.\"\n        )\n\n        self.assertTrue(\n            server_secured,\n            \"It looks like secure_server_room() wasn't called. Make sure you call it at the end of emergency_protocol().\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
