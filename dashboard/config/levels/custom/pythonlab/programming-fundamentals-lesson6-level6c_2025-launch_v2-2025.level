          "name": "main.py",
          "language": "py",
          "contents": "def sound_alarm():\n  # Prints a message to notify that the alarm is sounding\n  print(\"🔊 Alarm sounding! Please evacuate.\")\n\ndef lock_doors():\n  # Prints a message to notify that the doors are locked\n  print(\"🔒 All doors are now locked.\")\n\ndef secure_server_room():\n  # Prints a message to notify that the server room is secured\n  print(\"🖥️ Server room secured.\")\n\n# TODO - Write the emergency_protocol() function\n\n\n\n# TODO - Call the emergency_protocol() function\n\n",
