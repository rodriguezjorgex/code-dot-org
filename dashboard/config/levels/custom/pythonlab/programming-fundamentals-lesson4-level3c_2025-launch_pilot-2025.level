      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestFavoriteArtist(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get the printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_favorite_artist_variable_exists_and_is_string(self):\n        \"\"\"A variable called favorite_artist should exist and be a string\"\"\"\n        try:\n            from main import favorite_artist\n        except ImportError:\n            self.fail(\"Make sure you create a variable called favorite_artist!\")\n\n        self.assertIsInstance(\n            favorite_artist,\n            str,\n            \"The favorite_artist variable should be a string (inside quotes)!\"\n        )\n\n    def test_favorite_artist_in_output(self):\n        \"\"\"Printed message should include the favorite artist\"\"\"\n        try:\n            from main import favorite_artist\n        except ImportError:\n            self.fail(\"Make sure you create a variable called favorite_artist!\")\n\n        printed_lines = [line.strip() for line in self.log if line.strip()]\n\n        found = any(favorite_artist in line for line in printed_lines)\n\n        self.assertTrue(\n            found,\n            \"Make sure your printed message includes the favorite artist!\"\n        )\n",
