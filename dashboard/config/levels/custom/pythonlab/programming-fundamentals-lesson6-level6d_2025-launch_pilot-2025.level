      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestCreateArtFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_full_art_sequence(self):\n        \"\"\"create_art() should call all drawing functions in order\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()] \n\n        self.assertGreaterEqual(\n            len(printed_messages),\n            4,\n            \"Make sure your create_art() function draws two circles, one triangle, and adds a shadow effect!\"\n        )\n\n        circle_count = sum(1 for line in printed_messages if \"circle\" in line.lower())\n        triangle_drawn = any(\"triangle\" in line.lower() for line in printed_messages)\n        shadow_added = any(\"shadow\" in line.lower() for line in printed_messages)\n\n        self.assertGreaterEqual(\n            circle_count,\n            2,\n            \"Make sure draw_circle() is called twice at the start of create_art().\"\n        )\n\n        self.assertTrue(\n            triangle_drawn,\n            \"It looks like draw_triangle() wasn't called. Make sure you draw a triangle after the circles.\"\n        )\n\n        self.assertTrue(\n            shadow_added,\n            \"It looks like add_shadow_effect() wasn't called. Make sure you finish by adding a shadow effect.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
