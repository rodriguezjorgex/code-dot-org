          "name": "main.py",
          "language": "py",
          "contents": "def draw_circle():\n  # Prints a message that a circle has been drawn\n  print(\"🟠 Drawing a circle\")\n\ndef draw_triangle():\n  # Prints a message that a triangle has been drawn\n  print(\"🔺 Drawing a triangle\")\n\ndef add_shadow_effect():\n  # Prints a message that a shadow effect has been added\n  print(\"🌫️ Adding a shadow effect\")\n\n# TODO - Write the create_art() function\n\n\n\n# TODO - Call the create_art() function\n\n",
