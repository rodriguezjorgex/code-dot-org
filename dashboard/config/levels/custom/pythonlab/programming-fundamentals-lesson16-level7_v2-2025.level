      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\nimport ast\n\nclass TestGreetUserColor(unittest.TestCase):\n\n    def test_function_call_has_color_argument(self):\n        \"\"\"Add a color to the parameter in the function call.\"\"\"\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Parse the file into an AST (Abstract Syntax Tree)\n            tree = ast.parse(content)\n\n            # Look for function call to `greet_user`\n            function_calls = [\n                node for node in ast.walk(tree)\n                if isinstance(node, ast.Call) and\n                isinstance(node.func, ast.Name) and node.func.id == \"greet_user\"\n            ]\n\n            if not function_calls:\n                self.fail(\"The function `greet_user()` was not called in `main.py`. Ensure it is properly used.\")\n\n            for call in function_calls:\n                # Ensure the function call has at least 3 arguments (name, age, color)\n                if len(call.args) < 3:\n                    self.fail(\n                        \"The function `greet_user()` is missing the third parameter. \"\n                        \"Please pass a color as the third argument.\"\n                    )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n    def test_third_print_statement_not_empty(self):\n        \"\"\"Add a statement that checks for the user's favorite color.\"\"\"\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Parse the file into an AST (Abstract Syntax Tree)\n            tree = ast.parse(content)\n\n            # Find all print statements\n            print_statements = [\n                node for node in ast.walk(tree)\n                if isinstance(node, ast.Expr) and isinstance(node.value, ast.Call) and\n                isinstance(node.value.func, ast.Name) and node.value.func.id == \"print\"\n            ]\n\n            if len(print_statements) < 3:\n                self.fail(\n                    \"The third `print()` statement is missing. \"\n                    \"Please add a statement that checks for the user's favorite color.\"\n                )\n\n            # Ensure the third print statement is not empty\n            third_print = print_statements[2]  # Get the third print statement\n            if not third_print.value.args:\n                self.fail(\n                    \"The third `print()` statement is empty. \"\n                    \"Please ensure it prints something related to the user's favorite color.\"\n                )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
