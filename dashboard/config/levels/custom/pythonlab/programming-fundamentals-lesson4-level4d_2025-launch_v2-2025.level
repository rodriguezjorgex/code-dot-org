      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestCurrentPeriodUpdate(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get the printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_current_period_updated(self):\n        \"\"\"current_period should change from original to a new value\"\"\"\n        try:\n            from main import current_period\n        except ImportError:\n            self.fail(\"Make sure you create a variable called current_period!\")\n\n        printed_lines = [line.strip() for line in self.log if line.strip()]\n\n        # Find original and updated printed lines\n        original_line = next((line for line in printed_lines if \"Current class period:\" in line), None)\n        updated_line = next((line for line in printed_lines if \"Updated class period:\" in line), None)\n\n        self.assertIsNotNone(original_line, \"Make sure you print the original class period!\")\n        self.assertIsNotNone(updated_line, \"Make sure you print the updated class period!\")\n\n        # Extract just the period numbers\n        original_period = original_line.split(\":\")[-1].strip()\n        updated_period = updated_line.split(\":\")[-1].strip()\n\n        self.assertNotEqual(\n            original_period,\n            updated_period,\n            \"Make sure you actually update the current_period to a new value!\"\n        )\n",
