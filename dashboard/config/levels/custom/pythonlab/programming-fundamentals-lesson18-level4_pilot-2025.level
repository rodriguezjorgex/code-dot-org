        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from support import rare_magical_herb, uncommon_herb, common_herb\nimport random\n\n# Roll the dice\ndice_roll = random.randint(1, 6)\nprint(\"You rolled a\", dice_roll)\n\nif dice_roll == 6:\n    rare_magical_herb()\nelif dice_roll >= 4: # Modify this code so uncommon_herb is triggered if the dice lands on 5\n    uncommon_herb()\nelse:\n    common_herb()",
          "folderId": "0",
          "active": true,
          "open": true
        },
        "1": {
          "id": "1",
          "name": "support.py",
          "language": "py",
          "contents": "# Support file with accessible ASCII art and emojis\n\ndef rare_magical_herb():\n    art = \"\"\"\n    🌟 🌸 🌟\n    You found a rare magical herb!\n    \"\"\"\n    print(art)\n\ndef uncommon_herb():\n    art = \"\"\"\n    🌱 🍄 🌱\n    You found an uncommon herb.\n    \"\"\"\n    print(art)\n\ndef common_herb():\n    art = \"\"\"\n    🌱 ☘️ 🌱\n    You found a common herb.\n    \"\"\"\n    print(art)\n",
          "folderId": "0",
