      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\n\nclass TestIngredientCollection(unittest.TestCase):\n\n    def test_modify_ingredient_goal(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Check if the while loop condition is updated to `ingredients < 15`\n            if 'while ingredients < 15' not in content:\n                self.fail(\n                    \"The while loop condition has not been updated to `ingredients < 15`. \"\n                    \"Please change the loop condition to stop rolling once you have at least 15 ingredients.\"\n                )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
