        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "import random\n\ningredients = 0\nrolls = 0\n\n# Keep rolling the dice until you collect 10 ingredients\nwhile ingredients < 10:\n    dice_roll = random.randint(1, 6)\n    ingredients += dice_roll\n    rolls += 1\n    print(\"You rolled a\", dice_roll, \"and now have\", ingredients, \"ingredients.\")\n\nprint(\"It took\", rolls, \"rolls to collect 10 ingredients!\")\n\n",
          "folderId": "0",
          "active": true,
          "open": true
        }
