    "display_name": "Around the Food Trucks",
    "bubble_choice_description": "Modify the program so the `Painter` goes the other way to get around the food trucks.",
    "thumbnail_url": "https://images.code.org/ebf7ee568c28d07b194a9b50a7bf6f5a-choiceA.gif",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPainterGoesAroundFoodTrucks(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter named anika = Painter()!\")\n\n    def test_correct_sequence_of_moves(self):\n        \"\"\"Painter should move five times, turn, and move five more times\"\"\"\n        events = self.painter.get_events()\n\n        # Extract just the action types\n        action_sequence = [event.neighborhood_action_type for event in events]\n\n        # Find indexes of all the moves\n        move_indexes = [i for i, action in enumerate(action_sequence) if action == \"MOVE\"]\n\n        # Check that moves happen in two groups, separated by a TURN_LEFT\n        first_turn_index = action_sequence.index(\"TURN_LEFT\")\n        moves_before_turn = sum(1 for action in action_sequence[:first_turn_index] if action == \"MOVE\")\n        moves_after_turn = sum(1 for action in action_sequence[first_turn_index+1:] if action == \"MOVE\")\n\n        self.assertGreaterEqual(\n            moves_before_turn,\n            5,\n            \"Make sure your Painter moves forward five times BEFORE turning left!\"\n        )\n\n        self.assertGreaterEqual(\n            moves_after_turn,\n            5,\n            \"Make sure your Painter moves forward five times AFTER turning left!\"\n        )\n\n    def test_painter_ends_at_correct_position(self):\n        \"\"\"Painter should end at (5, 5)\"\"\"\n        final_x = self.painter.ending_position.x\n        final_y = self.painter.ending_position.y\n\n        self.assertEqual(\n            (final_x, final_y),\n            (5, 5),\n            \"The Painter should end at (5, 5) after navigating correctly around the food trucks.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
