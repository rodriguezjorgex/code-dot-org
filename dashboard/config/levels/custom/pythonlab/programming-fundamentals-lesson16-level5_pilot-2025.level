          "name": "main.py",
          "language": "py",
          "contents": "def create_message():\n    # Ask for the user's name\n    name = input(\"\")\n\n    # Ask for the user's favorite animal\n    animal = input(\"\")\n\n    # Print a personalized message\n    print(name + \" loves \" + animal + \"s!\")\n\ncreate_message()\n",
