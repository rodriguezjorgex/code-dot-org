      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\nimport ast\n\nclass TestCreateMessage(unittest.TestCase):\n\n    def test_input_prompts_filled(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Parse the file into an AST (Abstract Syntax Tree)\n            tree = ast.parse(content)\n\n            # Find all function calls to input()\n            input_statements = [\n                node for node in ast.walk(tree)\n                if isinstance(node, ast.Call) and isinstance(node.func, ast.Name) and node.func.id == \"input\"\n            ]\n\n            # Ensure there are at least two input() calls (one for name, one for animal)\n            if len(input_statements) < 2:\n                self.fail(\n                    \"The function `create_message()` must contain two `input()` statements. \"\n                    \"Ensure one asks for the user's name and the other asks for their favorite animal.\"\n                )\n\n            # Check that both input() statements have non-empty prompt strings\n            for i, statement in enumerate(input_statements):\n                if not statement.args or not isinstance(statement.args[0], ast.Str) or statement.args[0].s.strip() == \"\":\n                    self.fail(\n                        f\"The prompt for input() statement {i+1} is empty. \"\n                        \"Please modify both input statements to ask a meaningful question.\"\n                    )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
