          "name": "main.py",
          "language": "py",
          "contents": "# Compare two numbers. Keep changing the numbers and running the code. What happens? \nnum1 = 10\nnum2 = 5\n\nprint(\"Is num1 equal to num2? \" + str(num1 == num2))\nprint(\"Is num1 greater than num2? \" + str(num1 > num2))\nprint(\"Is num1 less than or equal to num2? \" + str(num1 <= num2))\n",
