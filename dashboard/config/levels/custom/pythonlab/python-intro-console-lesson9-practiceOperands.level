      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\n\nclass TestNumValues(unittest.TestCase):\n\n    def test_change_num_values(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Check if num1 is not 10 and num2 is not 5\n            if 'num1 = 10' in content and 'num2 = 5' in content:\n                self.fail(\n                    \"The variables 'num1' and 'num2' have not been changed from their original values. \"\n                    \"Please update 'num1' to a value other than 10 and 'num2' to a value other than 5.\"\n                )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
      "folderId": "0",
