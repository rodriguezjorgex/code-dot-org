      "name": "test.py",
      "language": "py",
      "contents": "import inspect\nfrom unittest import TestCase\nfrom unittest_runner import ValidationProtocol\nfrom main import send_text\n\nclass TestSendTextFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up validation and get stdout logs\"\"\"\n        cls.validation = ValidationProtocol()\n        cls.stdout_logs = cls.validation.get_stdout_logs()\n\n    def test_function_has_one_parameter(self):\n        \"\"\"send_text should accept exactly one parameter\"\"\"\n        params = inspect.signature(send_text).parameters\n        self.assertEqual(\n            len(params),\n            1,\n            \"The function send_text should have exactly one parameter for the name.\"\n        )\n\n    def test_output_uses_passed_name(self):\n        \"\"\"Printed output should dynamically use the name argument\"\"\"\n        self.assertGreaterEqual(\n            len(self.stdout_logs),\n            1,\n            \"No output was found. Make sure send_text() is called and prints a message.\"\n        )\n",
