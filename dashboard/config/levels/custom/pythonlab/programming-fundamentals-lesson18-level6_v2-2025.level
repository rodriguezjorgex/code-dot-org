        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from support import herb_choice, root_choice, berry_choice, flower_choice \nimport random\n\n# This asks the  user what they want to choose. \ningredient = input(\"What ingredient do you want to gather (herb, root, berry)? \").lower()\n\nif ingredient == \"herb\":\n    herb_choice()\nelif ingredient == \"root\":\n    root_choice()\nelif ingredient == \"berry\":\n    berry_choice()\n# Add code here that will execute a flower_choice()\n\n\nelse:\n    print(\"That ingredient doesn't exist!\")\n",
          "folderId": "0",
          "active": true,
          "open": true
        },
        "1": {
          "id": "1",
          "name": "support.py",
          "language": "py",
          "contents": "# Support file for critter capture messages\n\ndef herb_choice():\n    art = \"\"\"\n    🌿🌱🌿\n    You found a **fresh herb**!\n    \"\"\"\n    print(art)\n\ndef root_choice():\n    art = \"\"\"\n    🌳🌳🌳\n    You found a **sturdy root**!\n    \"\"\"\n    print(art)\n\ndef berry_choice():\n    art = \"\"\"\n    🍓🫐🍓\n    You picked some **fresh berries**! \n    \"\"\"\n    print(art)\n\ndef flower_choice():\n    art = \"\"\"\n    🌼💐🌼\n    You picked some **beautiful flowers**!\n    \"\"\"\n    print(art)\n",
