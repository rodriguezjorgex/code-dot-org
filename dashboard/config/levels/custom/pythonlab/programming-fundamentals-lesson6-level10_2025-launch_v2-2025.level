      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestMorningPlaylistFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_both_songs_played(self):\n        \"\"\"morning_playlist() should call both song functions\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertGreaterEqual(\n            len(printed_messages),\n            2,\n            \"Make sure your morning_playlist() function calls both play_hype_song() and play_chill_song()!\"\n        )\n\n        hype_song_played = any(\"hype\" in line.lower() for line in printed_messages)\n        chill_song_played = any(\"chill\" in line.lower() for line in printed_messages)\n\n        self.assertTrue(\n            hype_song_played,\n            \"It looks like play_hype_song() wasn't called. Make sure you include it (with parentheses!) inside morning_playlist().\"\n        )\n\n        self.assertTrue(\n            chill_song_played,\n            \"It looks like play_chill_song() wasn't called. Double-check that you spelled it correctly and used parentheses inside morning_playlist().\"\n        )\n",
