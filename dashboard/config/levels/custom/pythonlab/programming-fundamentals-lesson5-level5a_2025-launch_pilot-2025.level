          "contents": "from neighborhood import Painter\n\nyara = Painter()\n\n# TODO - Create a second Painter\n\n\n# Move yara\nyara.move()\nyara.move()\nyara.move()\n\nyara.turn_left()\nyara.turn_left()\nyara.turn_left()\n\nyara.move()\n\n# Move imani\nimani.move()\nimani.move()\nimani.move()\nimani.move()\nimani.move()\nimani.move()\nimani.move()\n\nimani.turn_left()\nimani.turn_left()\nimani.turn_left()\n\nimani.move()",
