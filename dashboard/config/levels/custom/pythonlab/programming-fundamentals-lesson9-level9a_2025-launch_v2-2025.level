    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPaintLines(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (6, 0)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (6, 0),\n            \"The Painter didn't stop at (6, 0). Check your paint_lines() logic for direction and movement.\"\n        )\n\n    def test_correct_spaces_are_painted(self):\n        \"\"\"Painter paints expected traffic line spaces\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n\n        painted_tiles = [\n            (3, 0), (3, 1), (3, 2), (3, 4), (3, 5), (3, 6),\n            (6, 1), (6, 2), (6, 3), (6, 5), (6, 6), (6, 7)\n        ]\n\n        for x, y in painted_tiles:\n            expected_output[y][x] = True\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"The expected spaces weren't all painted. Make sure the Painter is moving and painting as specified in the loop.\"\n        )\n\n    def test_moves_and_paints(self):\n        \"\"\"Painter moves and paints multiple times\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"MOVE\"),\n            10,\n            \"The Painter didn't move enough. Make sure your loop logic supports alternating movement and painting.\"\n        )\n        self.assertGreaterEqual(\n            self.painter.action_count(\"PAINT\"),\n            10,\n            \"The Painter didn't paint enough spaces. Check that the paint_lines() loop is working while the Painter has paint.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
