    "validation_file": {
      "id": "4",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestMoveOrTurn(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_turns_left_when_blocked(self):\n        \"\"\"Painter turns left when facing an obstacle (move_or_left)\"\"\"\n        left_turns = self.painter.action_count(\"TURN_LEFT\")\n        self.assertGreaterEqual(\n            left_turns,\n            3,\n            \"The Painter didn't turn left enough times. Make sure they turn left when they can't move forward in move_or_left().\"\n        )\n\n    def test_turns_right_when_blocked(self):\n        \"\"\"Painter turns right when facing an obstacle (move_or_right)\"\"\"\n        total_turns = self.painter.action_count(\"TURN_LEFT\")\n        self.assertGreaterEqual(\n            total_turns,\n            11,\n            \"The Painter didn't turn right enough times. Make sure they turn right when they can't move forward in move_or_right().\"\n        )\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (6, 7) after navigating all turns\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (6, 7),\n            \"The Painter didn't stop at (6, 7). Make sure the Painter turns correctly when blocked and continues along the intended path.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
