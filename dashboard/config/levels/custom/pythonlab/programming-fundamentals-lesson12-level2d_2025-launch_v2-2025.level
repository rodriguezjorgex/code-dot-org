    "mini_app": "neighborhood",
    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\nfrom custom import turn_right, keep_moving, move_or_left, move_or_right\n\nelsa = Painter()\n\nturn_right(elsa)\n\nwhile elsa.is_facing_south():\n  move_or_left(elsa)\n\nwhile elsa.is_facing_east():\n  move_or_left(elsa)\n\nwhile elsa.is_facing_north():\n  move_or_right(elsa)\n\nwhile elsa.is_facing_east():\n  move_or_right(elsa)\n\nkeep_moving(elsa)\n",
          "folderId": "0",
          "active": false,
          "open": true,
          "type": "locked_starter"
        },
        "2": {
          "id": "2",
          "name": "custom.py",
          "language": "py",
          "contents": "def turn_right(this_painter):\n  this_painter.turn_left()\n  this_painter.turn_left()\n  this_painter.turn_left()\n\ndef keep_moving(this_painter):\n  while this_painter.can_move():\n    this_painter.move()\n\ndef move_or_left(this_painter):\n  if this_painter.can_move():\n    this_painter.move()\n  # TODO - Add an else statement to turn left if the Painter can't move forward\n  this_painter.turn_left()\n\ndef move_or_right(this_painter):\n  if this_painter.can_move():\n    this_painter.move()\n  # TODO - Add an else statement to turn right if the Painter can't move forward\n  turn_right(this_painter)\n",
          "folderId": "0",
          "active": false,
          "open": true
        }
      },
      "folders": {
      },
