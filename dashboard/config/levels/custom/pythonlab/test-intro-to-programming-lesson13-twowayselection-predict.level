          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\n\n# Create a new Painter object\nnathan = Painter()\n\n# Declare variables for user input\ncolor = input(\"What color would you like to paint with?\")\n \n# Predict what this code will do\nnathan.set_paint(1)\n\nif nathan.has_paint():\n   if nathan.is_facing_east():\n\t   nathan.paint(color)\n\t   nathan.move()\n   else:\n\t   nathan.turn_left()\n\n\n",
