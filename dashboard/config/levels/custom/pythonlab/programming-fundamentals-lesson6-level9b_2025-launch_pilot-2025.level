      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\n# Try importing the student's function\ntry:\n    from main import look_both_ways\n    function_exists = True\nexcept ImportError:\n    function_exists = False\n\nclass TestLookBothWaysFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_look_both_ways_function_exists(self):\n        \"\"\"look_both_ways() should exist and be callable\"\"\"\n        if not function_exists:\n            self.fail(\"Make sure you define a function called look_both_ways()!\")\n\n    def test_four_safety_reminders_printed(self):\n        \"\"\"Four crossing reminders should be printed\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertEqual(\n            len(printed_messages),\n            4,\n            \"Make sure you call your look_both_ways() function four times to print four reminders!\"\n        )\n\n        all_contain_crossing = all(\n            \"cross\" in line.lower() or \"look\" in line.lower() for line in printed_messages\n        )\n\n        self.assertTrue(\n            all_contain_crossing,\n            \"Each reminder should encourage looking both ways or crossing safely! Make sure your look_both_ways() function mentions crossing or looking.\"\n        )\n",
