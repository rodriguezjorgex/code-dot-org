    "display_name": "Taxi Lane Trek",
    "bubble_choice_description": "The `Painter` needs to make it across a line of parked taxis to reach the traffic cone at the far edge of The Neighborhood. Write a `keep_moving()` function to move safely past the row and arrive at the goal.",
    "thumbnail_url": "https://images.code.org/c6922684367f5b82411ebc7e4764e2b7-choiceC.gif",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestKeepMovingFinalChallenge(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (11, 11)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (11, 10),\n            \"The Painter didn't stop at (11, 11). Make sure you're using keep_moving() and turning at the right places to reach the traffic cone.\"\n        )\n\n    def test_used_can_move(self):\n        \"\"\"Painter called can_move() (used in keep_moving)\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"CAN_MOVE\"),\n            1,\n            \"The Painter never checked can_move(). Ensure keep_moving() uses a while loop with can_move() as the condition.\"\n        )\n\n    def test_made_enough_moves(self):\n        \"\"\"Painter moved multiple times to reach the cone\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"MOVE\"),\n            10,\n            \"The Painter didn't move enough. Make sure to navigate using keep_moving().\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
