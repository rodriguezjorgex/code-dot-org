    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "import unittest\nimport ast\nfrom io import StringIO\nimport sys\n\nclass TestDebuggingStrategies(unittest.TestCase):\n    def setUp(self):\n        \"\"\"Setup function to capture stdout for print statement validation.\"\"\"\n        self.held_output = StringIO()\n        sys.stdout = self.held_output\n\n    def tearDown(self):\n        \"\"\"Restore stdout after tests.\"\"\"\n        sys.stdout = sys.__stdout__\n    \n    def test_3_final_paint_correction(self):\n        \"\"\"Ensure that both Susan and Joe objects finish painting their lines without errors.\"\"\"\n        with open(\"main.py\", \"r\") as f:\n            content = f.read()\n        \n        susan_fix = \"susan.take_paint()\" in content and \"susan.paint(\" in content\n        joe_fix = \"joe.take_paint()\" in content and \"joe.paint(\" in content\n        \n        self.assertTrue(susan_fix, \"Susan must call take_paint() and paint() manually after the final move.\")\n        self.assertTrue(joe_fix, \"Joe must call take_paint() and paint() manually after the final move.\")\n    \n    def test_2_paint_line_is_called_correct_number_of_times(self):\n        \"\"\"Ensure paint_line() is called the correct number of times for both Susan and Joe.\"\"\"\n        with open(\"main.py\", \"r\") as f:\n            lines = f.readlines()\n        \n        susan_calls = 0\n        joe_calls = 0\n        \n        for line in lines:\n            stripped_line = line.strip()\n            if stripped_line.startswith(\"paint_line(susan)\"):\n                susan_calls += 1\n            if stripped_line.startswith(\"paint_line(joe)\"):\n                joe_calls += 1\n        \n        self.assertEqual(susan_calls, 7, \"Susan must call paint_line() 7 times to complete the top horizontal line.\")\n        self.assertEqual(joe_calls, 7, \"Joe must call paint_line() 7 times to complete the left vertical line.\")\n    \n    def test_1_paint_line_moves_after_taking_paint(self):\n        \"\"\"Ensure that the paint object gets paint before moving inside paint_line function.\"\"\"\n        with open(\"main.py\", \"r\") as f:\n            lines = f.readlines()\n        \n        inside_function = False\n        take_paint_before_move = False\n        take_paint_found = False\n        \n        for line in lines:\n            stripped_line = line.strip()\n            \n            if stripped_line.startswith(\"def paint_line\"):\n                inside_function = True\n                continue\n            if inside_function and stripped_line.startswith(\"painter.take_paint()\"):\n                take_paint_found = True\n            if inside_function and stripped_line.startswith(\"painter.move()\"):\n                if take_paint_found:\n                    take_paint_before_move = True\n                break\n        \n        self.assertTrue(take_paint_before_move, \"Inside paint_line, you must call painter.take_paint() before painter.move().\")\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
