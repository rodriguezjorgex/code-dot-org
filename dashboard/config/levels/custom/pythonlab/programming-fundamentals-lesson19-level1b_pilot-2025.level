    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "def space_mission():\n    print(\"Welcome to the Space Escape Mission!\")\n    name = input(\"Astronaut, what's your name? \")\n    print(f\"{name}, your mission is to escape the malfunctioning space station.\")\n\n    decision1 = input(\"Do you fix the oxygen generator or head to the escape pod? (fix/pod) \").lower()\n    if decision1 == \"fix\":\n        print(\"You successfully fix the oxygen generator, buying more time.\")\n    elif decision1 == \"pod\":\n        print(\"The escape pod is damaged! You need to find another way.\")\n    else:\n        print(\"Hmm... that's not an option. Try again.\")\n\n    decision2 = input(\"Do you trust the AI system or override it manually? (trust/override) \").lower()\n    if decision2 == \"trust\":\n        print(\"The AI safely guides you to the escape route.\")\n    elif decision2 == \"override\":\n        print(\"You manually override the controls and narrowly avoid disaster.\")\n    else:\n        print(\"Hmm... that's not an option. Try again.\")\n\n    print(\"🎉 Congratulations! You've won the game! 🎉\")\n\nspace_mission()\n",
