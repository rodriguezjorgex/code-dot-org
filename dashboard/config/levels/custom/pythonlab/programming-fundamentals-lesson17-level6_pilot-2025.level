          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "ingredients = 0  # Start with 0 ingredients\n\n# Keep gathering ingredients until you have 5\nwhile ingredients < 5:\n    ingredients += 1\n    print(\"You collected an ingredient! Total ingredients:\", ingredients)\n\nprint(\"You have enough ingredients!\")",
          "folderId": "0",
          "active": true,
          "open": true
        }
