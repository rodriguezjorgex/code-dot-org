      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\nimport ast\n\nclass TestClimbStairs(unittest.TestCase):\n\n    def test_if_statement_has_body(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Parse the file into an AST (Abstract Syntax Tree)\n            tree = ast.parse(content)\n\n            # Find the function definition\n            for node in ast.walk(tree):\n                if isinstance(node, ast.FunctionDef) and node.name == \"climb_stairs\":\n                    for stmt in node.body:\n                        if isinstance(stmt, ast.If):\n                            # Ensure the if statement has a body that is not empty\n                            if not stmt.body:\n                                self.fail(\n                                    \"The if-statement inside `climb_stairs()` does not have any code. \"\n                                    \"Make sure to complete the conditional with a valid action.\"\n                                )\n                            return  # Test passes if the if-statement has a body\n\n            self.fail(\"Could not find an if-statement inside `climb_stairs()`. Please add one.\")\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
