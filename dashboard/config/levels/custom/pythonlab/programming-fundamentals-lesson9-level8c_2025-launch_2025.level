    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestDeliverPizza(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (5, 5)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (5, 5),\n            \"The Painter didn't stop at (5, 5). Make sure move_until_turn() and deliver_pizza() are implemented correctly.\"\n        )\n\n    def test_turns_right(self):\n        \"\"\"Painter turns right at least once\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            3,\n            \"The Painter didn't turn right. Make sure to call turn_right() when needed in both functions.\"\n        )\n\n    def test_moves_occurred(self):\n        \"\"\"Painter moved multiple times\"\"\"\n        self.assertGreater(\n            self.painter.action_count(\"MOVE\"),\n            5,\n            \"The Painter didn’t move enough. Check that both loops are functioning and that turns are not preventing forward progress.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    },
