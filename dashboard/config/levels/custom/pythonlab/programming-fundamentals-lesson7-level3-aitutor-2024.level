        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\n\n# turn right by turning left 3x\ndef turn_right():\n  painter.turn_left()\n  painter.turn_left()\n  painter.turn_left()\n\n# function to move and paint a step-like pattern\ndef paint_step():\n  painter.take_paint()\n  painter.paint(\"blue\")\n  painter.mov()\n  turn_right()\n  painter.move()\n  painter.take_paint()\n  painter.paint(\"rainbow\")\n  painter.turn_left()\n  painter.move()\n\n\npaint_step()\npaint_step()\nleo = Painter()\n\n\n\n\n",
