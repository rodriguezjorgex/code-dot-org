    "validation_file": {
      "id": "2",
      "name": "main_test.py",
      "language": "py",
      "contents": "import unittest\nfrom unittest_runner import ValidationProtocol\n\nclass TestDebugPaintStep(unittest.TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"\n        Retrieve the NeighborhoodLog once for all tests.\n        \"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        painter_logs = cls.log.painter_logs if cls.log else []\n        cls.painter_logs = painter_logs\n\n    def test_step1_two_painters(self):\n        \"\"\"\n        Create two Painter objects.\n        \"\"\"\n        self.assertEqual(\n            len(self.painter_logs), \n            2,\n            f\"We expected exactly two Painter objects). \"\n            f\"Found {len(self.painter_logs)} instead.\"\n        )\n\n    def test_step2_total_paint_actions(self):\n        \"\"\"\n        Paint four times.\n        \"\"\"\n        if len(self.painter_logs) < 2:\n            self.skipTest(\"We don't have two Painter objects yet.\")\n\n        total_paint = 0\n        for log in self.painter_logs:\n            total_paint += log.action_count(\"PAINT\")\n\n        self.assertEqual(\n            total_paint,\n            4,\n            f\"We expected 4 total paint actions (2 per paint_step() call), found {total_paint}. \"\n            \"Check that each paint_step() does two paints, and paint_step() is called twice.\"\n        )\n\n    def test_step3_blue_and_green_only(self):\n        \"\"\"\n        Paint two spaces blue and green.\n        \"\"\"\n        if len(self.painter_logs) < 2:\n            self.skipTest(\"We don't have two Painter objects yet.\")\n\n        final_output = self.log.final_output\n        grid_size = len(final_output)\n\n        blue_count = 0\n        green_count = 0\n        other_paint = 0\n\n        for y in range(grid_size):\n            for x in range(grid_size):\n                color = final_output[y][x]\n                if color == \"blue\":\n                    blue_count += 1\n                elif color == \"green\":\n                    green_count += 1\n                elif color is not None:\n                    other_paint += 1\n\n        self.assertEqual(\n            blue_count, \n            2, \n            f\"Found {blue_count} squares painted 'blue', but expected 2.\"\n        )\n        self.assertEqual(\n            green_count, \n            2, \n            f\"Found {green_count} squares painted 'green', but expected 2.\"\n        )\n        self.assertEqual(\n            other_paint, \n            0, \n            f\"Found {other_paint} squares painted with a color other than 'blue' or 'green'. \"\n            \"We expected no extra colors.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
