      "id": "1",
      "name": "test.py",
      "language": "py",
      "contents": "import ast\nimport io\nimport runpy\nimport builtins\nfrom contextlib import redirect_stdout\nfrom unittest import TestCase\n\nMAIN_FILE = \"main.py\"\n\n\nclass TestFreeChoiceProgram(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Load output and variables\"\"\"\n        cls.stdout_lines = []\n        cls.ns = None\n\n        # Parse source to AST for structural checks (no import/subprocess needed)\n        with open(MAIN_FILE, \"r\", encoding=\"utf-8\") as f:\n            cls.source = f.read()\n        cls.tree = ast.parse(cls.source, filename=MAIN_FILE)\n\n        # Prevent blocking if students used input()\n        original_input = getattr(builtins, \"input\", None)\n        buf = io.StringIO()\n        try:\n            builtins.input = (lambda *args, **kwargs: \"\")\n            with redirect_stdout(buf):\n                # Execute main.py as a script (no import), capture its globals and stdout\n                cls.ns = runpy.run_path(MAIN_FILE, run_name=\"__main__\")\n        except SystemExit:\n            # Allow scripts that call exit() to continue\n            pass\n        except Exception:\n            # If execution fails, leave ns as None; tests below will surface the original messages\n            cls.ns = None\n        finally:\n            cls.stdout_lines = [line.strip() for line in buf.getvalue().splitlines() if line.strip()]\n            if original_input is not None:\n                builtins.input = original_input\n\n    def test_variables_created(self):\n        \"\"\"Create at least int, str, and bool variables\"\"\"\n        # Mirror original behavior/message on import failure\n        if self.ns is None:\n            self.fail(\"Something went wrong importing your program. Double-check your code!\")\n\n        has_int = False\n        has_str = False\n        has_bool = False\n\n        for var_name, var in self.ns.items():\n            if var_name.startswith(\"_\"):\n                continue\n            # Order matters: bool is a subclass of int\n            if isinstance(var, bool):\n                has_bool = True\n            elif isinstance(var, int):\n                has_int = True\n            elif isinstance(var, str):\n                has_str = True\n\n        self.assertTrue(has_int, \"Make sure you create at least one int variable!\")\n        self.assertTrue(has_str, \"Make sure you create at least one string variable!\")\n        self.assertTrue(has_bool, \"Make sure you create at least one bool variable!\")\n\n    def test_operation_used(self):\n        \"\"\"At least one operation should be used in the code\"\"\"\n        # Mirror original behavior/message on import failure\n        if self.ns is None:\n            self.fail(\"Something went wrong importing your program.\")\n\n        # Require that a numeric operation is actually USED to create/store a new value.\n        # Accept Assign or AugAssign with numeric ops: +, -, *, /, //, %, **\n        numeric_ops = (ast.Add, ast.Sub, ast.Mult, ast.Div, ast.FloorDiv, ast.Mod, ast.Pow)\n\n        def has_numeric_operation_assignment(tree: ast.AST) -> bool:\n            for node in ast.walk(tree):\n                # x = a + b, x = -y  (ensure it's *assigned*)\n                if isinstance(node, ast.Assign):\n                    val = node.value\n                    if isinstance(val, ast.BinOp) and isinstance(val.op, numeric_ops):\n                        return True\n                    if isinstance(val, ast.UnaryOp) and isinstance(val.op, (ast.UAdd, ast.USub)):\n                        return True\n                # x += 1, y *= 2, etc.\n                if isinstance(node, ast.AugAssign) and isinstance(node.op, numeric_ops):\n                    return True\n            return False\n\n        self.assertTrue(\n            has_numeric_operation_assignment(self.tree),\n            \"Make sure you use some math operation (+, -, *, /) to create a new value!\"\n        )\n\n    def test_printed_output(self):\n        \"\"\"Use print() at least once\"\"\"\n        printed_lines = self.stdout_lines\n        self.assertGreaterEqual(\n            len(printed_lines),\n            1,\n            \"Make sure you print something to show your variables or results!\"\n        )\n",
