      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\n# Try importing the student's functions\ntry:\n    from main import take_break\n    take_break_exists = True\nexcept ImportError:\n    take_break_exists = False\n\ntry:\n    from main import check_todo\n    check_todo_exists = True\nexcept ImportError:\n    check_todo_exists = False\n\nclass TestStudySessionFunctions(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_take_break_function_exists(self):\n        \"\"\"take_break() should exist and be callable\"\"\"\n        if not take_break_exists:\n            self.fail(\"Make sure you define a function called take_break()!\")\n\n    def test_check_todo_function_exists(self):\n        \"\"\"check_todo() should exist and be callable\"\"\"\n        if not check_todo_exists:\n            self.fail(\"Make sure you define a function called check_todo()!\")\n\n    def test_eight_lines_printed(self):\n        \"\"\"Eight total lines should be printed (four blocks of two lines)\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertEqual(\n            len(printed_messages),\n            8,\n            \"Make sure your program prints eight lines total by calling take_break() and check_todo() twice each!\"\n        )\n\n        # Check for at least one break reminder and one to-do reminder\n        has_break_reminder = any(\"break\" in line.lower() or \"stretch\" in line.lower() for line in printed_messages)\n        has_todo_reminder = any(\"to-do\" in line.lower() or \"task\" in line.lower() for line in printed_messages)\n\n        self.assertTrue(\n            has_break_reminder,\n            \"Make sure your take_break() function reminds about taking breaks!\"\n        )\n\n        self.assertTrue(\n            has_todo_reminder,\n            \"Make sure your check_todo() function reminds about checking your to-do list!\"\n        )\n",
      "folderId": "0",
