    "thumbnail_url": "https://images.code.org/1b470f0274249949ad72de44bec94914-choiceD.gif",
    "display_name": "Turn When the Road Ends",
    "bubble_choice_description": "The `Painter` is trying to drive its donut truck through a tight alley, but there's a row of taxis blocking the way. The `Painter` needs to follow the path, turn around the corner, and then head west. Write a function that helps the `Painter` decide whether to move forward or turn when its going west.",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestMoveOrTurnFacingWest(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (3, 8) after navigating westward path\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (3, 8),\n            \"The Painter didn't stop at (3, 8). Make sure move_or_turn() correctly handles movement and turning while facing west.\"\n        )\n\n    def test_turns_left_when_blocked(self):\n        \"\"\"Painter turns left at least once if blocked\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            1,\n            \"The Painter didn't turn left. Make sure to call turn_left() when the Painter can't move forward while facing west.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
