      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\n# Try importing the student's function\ntry:\n    from main import stay_quiet\n    function_exists = True\nexcept ImportError:\n    function_exists = False\n\nclass TestSurpriseCountdown(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_stay_quiet_function_exists(self):\n        \"\"\"stay_quiet() should exist and be callable\"\"\"\n        if not function_exists:\n            self.fail(\"Make sure you define a function called stay_quiet()!\")\n\n    def test_correct_countdown_printed(self):\n        \"\"\"Three suspense messages, then surprise\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertEqual(\n            len(printed_messages),\n            4,\n            \"Make sure you call stay_quiet() three times, then print 'SURPRISE!' once. There should be four total lines.\"\n        )\n\n        # First three lines must contain 'Shhh' or similar\n        suspense_lines = printed_messages[:3]\n        all_suspense = all(\n            \"shhh\" in line.lower() or \"quiet\" in line.lower() for line in suspense_lines\n        )\n\n        self.assertTrue(\n            all_suspense,\n            \"The first three messages should build suspense! Make sure stay_quiet() prints something like 'Shhh... they're coming!'\"\n        )\n\n        # Fourth line must say surprise\n        surprise_line = printed_messages[3]\n        self.assertIn(\n            \"surprise\",\n            surprise_line.lower(),\n            \"The final message should be 'SURPRISE!' Make sure you print the final surprise after the countdown.\"\n        )\n",
      "folderId": "0",
