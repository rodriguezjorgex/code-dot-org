          "name": "main.py",
          "language": "py",
          "contents": "def plant_garden(): # Use a parameter in this function\n    print(\"Dash plants beanstalk\") # Change every instance of \"beanstalk\" to the parameter name\n    print(\"Dash moves to the next spot.\")\n    print(\"Dash plants beanstalk\")\n    print(\"Dash moves to the next spot.\")\n    print(\"Dash plants beanstalk\")\n    print(\"Dash moves to the next spot.\")\n    print(\"Dash plants beanstalk\")\n    print(\"Dash moves to the next spot.\")\n\n# Call your function here\n",
