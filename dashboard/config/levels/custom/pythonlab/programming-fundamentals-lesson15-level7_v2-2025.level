      "name": "test.py",
      "language": "py",
      "contents": "import unittest\nimport re\n\nclass TestPlantGardenFunction(unittest.TestCase):\n\n    def test_add_parameter(self):\n        \"\"\"Check if the function 'plant_garden' has a parameter.\"\"\"\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Check for function definition with at least one parameter\n            function_pattern = re.search(r'def\\s+plant_garden\\s*\\(\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\)\\s*:', content)\n\n            if not function_pattern:\n                self.fail(\"You haven't added a parameter to the 'plant_garden' function. Please update the function definition to include one.\")\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n    def test_call_function_with_argument(self):\n        \"\"\"Check if 'plant_garden' is called with an argument.\"\"\"\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Look for any call to plant_garden() with an argument inside parentheses\n            function_call_pattern = re.search(r'plant_garden\\s*\\(\\s*[\"\\'][a-zA-Z0-9_\\s]+[\"\\']\\s*\\)', content)\n\n            if not function_call_pattern:\n                self.fail(\"You haven't called the 'plant_garden' function with an argument. Make sure to pass an item name when calling the function.\")\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
