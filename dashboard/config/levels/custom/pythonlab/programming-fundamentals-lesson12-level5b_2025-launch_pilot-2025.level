    "display_name": "Go or Turn",
    "bubble_choice_description": "The `Painter` is working its way through a twisty neighborhood street. It needs to keep moving when the path is clear, but if there's a wall in front, it needs to turn left to stay on the path. Help the `Painter` do this by writing a function that uses an `if/else` statement to decide what to do next.",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestMoveOrTurnLeft(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_turns_left_when_blocked(self):\n        \"\"\"Painter turns left when blocked by an obstacle\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            3,\n            \"The Painter didn't turn left when needed. Add an else statement to turn left if the Painter can't move forward.\"\n        )\n\n    def test_final_position_is_correct(self):\n        \"\"\"Painter ends at (8, 8) after following the path\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (8, 8),\n            \"The Painter didn't stop at (8, 8). Make sure they’re following the path and turning left when needed.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
