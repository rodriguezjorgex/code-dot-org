      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestStartingLevel(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get the printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_starting_level_variable_exists_and_is_integer(self):\n        \"\"\"A variable called starting_level should exist and be an integer\"\"\"\n        try:\n            from main import starting_level\n        except ImportError:\n            self.fail(\"Make sure you create a variable called starting_level!\")\n\n        self.assertIsInstance(\n            starting_level,\n            int,\n            \"The starting_level variable should be a number (integer)!\"\n        )\n\n    def test_starting_level_in_output(self):\n        \"\"\"Printed message should include the starting level\"\"\"\n        try:\n            from main import starting_level\n        except ImportError:\n            self.fail(\"Make sure you create a variable called starting_level!\")\n\n        printed_lines = [line.strip() for line in self.log if line.strip()]\n\n        found = any(str(starting_level) in line for line in printed_lines)\n\n        self.assertTrue(\n            found,\n            \"Make sure your printed message includes the starting level!\"\n        )\n",
