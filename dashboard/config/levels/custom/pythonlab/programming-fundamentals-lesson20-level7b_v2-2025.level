        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "def solve_riddle():\n    print(\"A wise old owl asks: 'The more you take, the more you leave behind. What am I?'\")\n    answer = input(\"Your answer: \").lower()\n\n    if answer == \"footsteps\":\n        print(\"✅ Correct! You move forward through the mysterious door.\")\n    else:\n        hint = input(\"❓ Incorrect! Would you like a hint? (yes/no) \").lower()\n        # Add the nested conditional here. Ask if they want a hint. If \"yes\", give hint, if \"no\" print \"Try again.\"\n\n\nsolve_riddle()\n",
