      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\nimport ast\n\nclass TestSolveRiddle(unittest.TestCase):\n\n    def test_nested_conditional_present(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Parse the file into an AST (Abstract Syntax Tree)\n            tree = ast.parse(content)\n\n            # Find the function definition\n            for node in ast.walk(tree):\n                if isinstance(node, ast.FunctionDef) and node.name == \"solve_riddle\":\n                    for stmt in node.body:\n                        if isinstance(stmt, ast.If) and isinstance(stmt.orelse, list):\n                            # Look for a second nested if-statement inside the else block\n                            for nested_stmt in stmt.orelse:\n                                if isinstance(nested_stmt, ast.If):\n                                    return  # Test passes if a nested if-statement is found inside the else block\n\n            self.fail(\n                \"The `else` block in `solve_riddle()` is missing a nested conditional. \"\n                \"Please add an if-statement to check if the user wants a hint.\"\n            )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
