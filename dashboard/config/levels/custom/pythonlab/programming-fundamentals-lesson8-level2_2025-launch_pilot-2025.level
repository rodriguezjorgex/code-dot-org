    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestHasPaintLoop(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (4, 0)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (4, 0),\n            \"The Painter didn't stop at (4, 0). Make sure your loop uses has_paint() to control painting and movement.\"\n        )\n\n    def test_painted_correct_spaces(self):\n        \"\"\"Spaces (1,0), (2,0), and (3,0) are painted\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n        expected_output[0][1] = True  # (1,0)\n        expected_output[0][2] = True  # (2,0)\n        expected_output[0][3] = True  # (3,0)\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"Spaces (1,0), (2,0), and (3,0) should be painted. Make sure your loop paints each space while the Painter has paint.\"\n        )\n\n    def test_painted_three_times(self):\n        \"\"\"Painter painted three times\"\"\"\n        self.assertEqual(\n            self.painter.action_count(\"PAINT\"),\n            3,\n            \"The Painter should paint exactly three times. Check that your loop only runs while the Painter has paint.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
