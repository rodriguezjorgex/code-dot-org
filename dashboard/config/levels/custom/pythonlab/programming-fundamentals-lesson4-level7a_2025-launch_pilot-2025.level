      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestBookRecommendation(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_book_title_printed(self):\n        \"\"\"The correct book title should be printed\"\"\"\n        printed_lines = [line.strip() for line in self.log if line.strip()]\n\n        self.assertTrue(\n            any(\"The House on Mango Street\" in line for line in printed_lines),\n            \"Make sure you correctly assign and print the book title 'The House on Mango Street'!\"\n        )\n",
