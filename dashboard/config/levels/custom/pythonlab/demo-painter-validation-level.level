    "validation_file": {
      "id": "2",
      "name": "test_main.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPainterMoveOnce(TestCase):\n  @classmethod\n  def setUpClass(cls):\n    \"\"\"Run the student's code once and save the results\"\"\"\n    cls.log = ValidationProtocol().get_neighborhood_log()\n    if not cls.log.painter_logs:\n      cls.painter = None\n    else:\n      cls.painter = cls.log.painter_logs[0]\n  \n  def test_painter_created(self):\n    \"\"\"Check if a Painter was created\"\"\"\n    self.assertIsNotNone(self.painter, \"Make sure to create a Painter!\")\n\n  def setUp(self):\n    if self.painter is None:\n      self.skipTest(\"No Painter was created yet! Make sure to make one.\")\n  \n  def test_painter_moved_once(self):\n    \"\"\"The Painter should move forward exactly once\"\"\"\n    move_count = self.painter.action_count(\"MOVE\")\n    self.assertEqual(\n      move_count,\n      1,\n      \"The Painter should move exactly once. Did you use the move() function?\"\n    )",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
