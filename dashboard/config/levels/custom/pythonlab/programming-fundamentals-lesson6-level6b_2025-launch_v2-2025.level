      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestDailyReminderFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_both_reminders_printed(self):\n        \"\"\"daily_reminder() should call both reminder functions\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertGreaterEqual(\n            len(printed_messages),\n            2,\n            \"Make sure your daily_reminder() function calls both turn_off_lights() and use_reusable_bottle()!\"\n        )\n\n        lights_reminder = any(\"light\" in line.lower() for line in printed_messages)\n        bottle_reminder = any(\"bottle\" in line.lower() for line in printed_messages)\n\n        self.assertTrue(\n            lights_reminder,\n            \"It looks like the lights reminder was missing. Make sure you call turn_off_lights() inside daily_reminder().\"\n        )\n\n        self.assertTrue(\n            bottle_reminder,\n            \"It looks like the water bottle reminder was missing. Make sure you call use_reusable_bottle() inside daily_reminder().\"\n        )\n",
      "folderId": "0",
