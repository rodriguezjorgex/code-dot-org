        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\n\nzoe = Painter()\n\nzoe.move()\nzoe.move()\nzoe.move()\nzoe.turn_left()\nzoe.turn_left()\nzoe.turn_left()\nzoe.move()\n\n#zoe.take_paint()\n#zoe.take_paint()\n#zoe.take_paint()\n\nzoe.move()\n#zoe.paint(\"white\")\nzoe.move()\n#zoe.paint(\"white\")\nzoe.move()\n#zoe.paint(\"white\")",
