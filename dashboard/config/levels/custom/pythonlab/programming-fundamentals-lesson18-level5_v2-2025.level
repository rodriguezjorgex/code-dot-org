        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from support import legendary_critter, rare_critter, common_critter, critter_escaped\nimport random\n\n# Attempt to capture a critter\nprint(\"🎲 You throw a magic capture orb...\")\ndice_roll = random.randint(1, 6)\nprint(\"The orb shakes... You rolled a\", dice_roll)\n\nif dice_roll == 6:\n    legendary_critter()\nelif dice_roll >= 4:\n    rare_critter()\n# Add another condition that captures a common_critter if the dice rolls a 2 or higher. \n    \n\nelse:\n    critter_escaped()\n",
          "folderId": "0",
          "active": false,
          "open": true
        },
        "1": {
          "id": "1",
          "name": "support.py",
          "language": "py",
          "contents": "# Support file for critter capture messages\n\ndef legendary_critter():\n    art = \"\"\"\n    ✨🐉 LEGENDARY CAPTURED 🐉✨\n    Incredible! You captured a **legendary critter**! \n    The villagers will speak of this moment forever!\n    \"\"\"\n    print(art)\n\ndef rare_critter():\n    art = \"\"\"\n    ✨🦑 Rare Critter Caught! 🦑✨\n    Amazing! You captured a **rare critter**.\n    Not everyone is lucky enough to find one!\n    \"\"\"\n    print(art)\n\ndef common_critter():\n    art = \"\"\"\n    🐾🐕 Common Critter Captured! 🐕🐾\n    Great job! You caught a **common critter**.\n    This one will make a friendly companion!\n    \"\"\"\n    print(art)\n\ndef critter_escaped():\n    art = \"\"\"\n    ❌ The Critter Escaped! ❌\n    Oh no! The critter broke free and ran away.\n    Try again next time!\n    \"\"\"\n    print(art)\n",
