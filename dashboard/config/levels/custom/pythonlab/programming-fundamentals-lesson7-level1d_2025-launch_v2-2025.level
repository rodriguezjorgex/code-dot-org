      "name": "test.py",
      "language": "py",
      "contents": "import inspect\nfrom unittest import TestCase\nfrom unittest_runner import ValidationProtocol\nfrom main import send_registration_reminder\n\nclass TestSendRegistrationReminder(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up validation and get stdout logs\"\"\"\n        cls.validation = ValidationProtocol()\n        cls.stdout_logs = cls.validation.get_stdout_logs()\n\n    def test_function_has_two_parameters(self):\n        \"\"\"send_registration_reminder should accept exactly two parameters\"\"\"\n        params = inspect.signature(send_registration_reminder).parameters\n        self.assertEqual(\n            len(params),\n            2,\n            \"The function send_registration_reminder should have exactly two parameters: one for the name and one for the deadline.\"\n        )\n\n    def test_output_uses_name_and_deadline(self):\n        \"\"\"Printed output should dynamically use the name and deadline\"\"\"\n        self.assertGreaterEqual(\n            len(self.stdout_logs),\n            1,\n            \"No output was found. Make sure send_registration_reminder() is called and prints a message.\"\n        )\n\n        last_output = self.stdout_logs[-1]\n\n        # Make sure it doesn't use the hardcoded \"Alex\"\n        self.assertNotIn(\n            \"Alex\",\n            last_output,\n            \"The output still uses the hardcoded name 'Alex'. Make sure you use the parameters passed to the function.\"\n        )\n",
