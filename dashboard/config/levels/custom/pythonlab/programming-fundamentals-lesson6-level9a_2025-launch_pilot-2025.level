      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\n# Try importing the student's function\ntry:\n    from main import remind_to_drink\n    function_exists = True\nexcept ImportError:\n    function_exists = False\n\nclass TestRemindToDrinkFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_remind_to_drink_function_exists(self):\n        \"\"\"remind_to_drink() should exist and be callable\"\"\"\n        if not function_exists:\n            self.fail(\"Make sure you define a function called remind_to_drink()!\")\n\n    def test_five_reminders_printed(self):\n        \"\"\"Five hydration reminders should be printed\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertEqual(\n            len(printed_messages),\n            5,\n            \"Make sure you call your remind_to_drink() function five times to print five reminders!\"\n        )\n\n        all_contain_hydration = all(\n            \"water\" in line.lower() or \"drink\" in line.lower() or \"hydration\" in line.lower()\n            for line in printed_messages\n        )\n\n        self.assertTrue(\n            all_contain_hydration,\n            \"Each reminder should encourage hydration! Make sure your remind_to_drink() function mentions drinking water.\"\n        )\n",
