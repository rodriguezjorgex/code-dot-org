    "thumbnail_url": "https://images.code.org/aa35e13e7400fcff961fb1b95e07e45b-choiceC.gif",
    "display_name": "Find a Way Around",
    "bubble_choice_description": "The `Painter` is heading east, but there's a taxi blocking the way! Write a function that helps the `Painter` keep moving if the path is clear, or turn right when blocked. Once the `Painter` gets past the obstacle, it should continue moving until the path ends.",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestMoveOrTurnFacingEast(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (7, 8) after move_or_turn and keep_moving\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (7, 8),\n            \"The Painter didn't stop at (7, 8). Make sure move_or_turn() and keep_moving() are used correctly to finish the path.\"\n        )\n\n    def test_turns_when_blocked(self):\n        \"\"\"Painter turns right at least once if blocked\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            3,\n            \"The Painter didn’t turn right. Make sure to call turn_right() when the Painter can’t move while facing east.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
