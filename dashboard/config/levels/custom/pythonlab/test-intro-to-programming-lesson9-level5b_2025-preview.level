    "validation_file": {
      "id": "2",
      "name": "main_test.py",
      "language": "py",
      "contents": "import unittest\nfrom unittest_runner import ValidationProtocol\n\nclass TestPaintAndMove(unittest.TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"\n        Retrieve the NeighborhoodLog once for all tests.\n        \"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        cls.painter_logs = cls.log.painter_logs if cls.log else []\n\n    def test_step1_single_painter_named_keith(self):\n        \"\"\"\n        Create a Painter object.\n        \"\"\"\n        self.assertEqual(\n            len(self.painter_logs),\n            1,\n            f\"We expected exactly one Painter object, but found {len(self.painter_logs)}.\"\n        )\n\n    def test_step2_is_on_bucket_used(self):\n        \"\"\"\n        Check that the Painter is on a paint bucket.\n        \"\"\"\n        if not self.painter_logs:\n            self.skipTest(\"No Painter found.\")\n\n        painter_log = self.painter_logs[0]\n        self.assertTrue(\n            painter_log.did_action_at_least(\"IS_ON_BUCKET\", 1),\n            \"It doesn't look like you used is_on_bucket().\"\n            \"Remember to collect multiple buckets if you're on them.\"\n        )\n\n    def test_step3_has_paint_used(self):\n        \"\"\"\n        Check that the Painter has paint at least once.\n        \"\"\"\n        if not self.painter_logs:\n            self.skipTest(\"No Painter found.\")\n\n        painter_log = self.painter_logs[0]\n        self.assertTrue(\n            painter_log.did_action_at_least(\"HAS_PAINT\", 1),\n            \"It doesn't look like you used has_paint().\"\n            \"Use has_paint() to keep painting until you're out!\"\n        )\n\n    def test_step4_paint_actions(self):\n        \"\"\"\n        Paint at least five times.\n        \"\"\"\n        if not self.painter_logs:\n            self.skipTest(\"No Painter found.\")\n\n        painter_log = self.painter_logs[0]\n        self.assertTrue(\n            painter_log.did_action_at_least(\"PAINT\", 5),\n            \"We expected at least 5 paint actions, but didn't see that many. \"\n            \"Make sure you're painting repeatedly as you move.\"\n        )\n\n    def test_step5_move_actions(self):\n        \"\"\"\n        Move at least five times.\n        \"\"\"\n        if not self.painter_logs:\n            self.skipTest(\"No Painter found.\")\n\n        painter_log = self.painter_logs[0]\n        self.assertTrue(\n            painter_log.did_action_at_least(\"MOVE\", 5),\n            \"We expected at least 5 moves, but didn't see that many. \"\n            \"Ensure you're traveling around the grid while painting.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    },
