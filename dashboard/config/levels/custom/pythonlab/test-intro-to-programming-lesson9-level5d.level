    "validation_file": {
      "id": "2",
      "name": "main_test.py",
      "language": "py",
      "contents": "import unittest\nfrom unittest_runner import ValidationProtocol\n\nclass TestThreeFunctions(unittest.TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"\n        Retrieve the NeighborhoodLog a single time for all tests.\n        \"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        cls.painter_logs = cls.log.painter_logs if cls.log else []\n\n    def test_step1_single_painter_named_natalia(self):\n        \"\"\"\n        Create a Painter object.\n        \"\"\"\n        self.assertEqual(\n            len(self.painter_logs),\n            1,\n            f\"We expected exactly one Painter. Found {len(self.painter_logs)}.\"\n        )\n\n    def test_step2_is_on_bucket_usage(self):\n        \"\"\"\n        Check if the Painter is on a paint bucket at least once.\n        \"\"\"\n        if not self.painter_logs:\n            self.skipTest(\"No Painter found.\")\n\n        painter_log = self.painter_logs[0]\n        self.assertTrue(\n            painter_log.did_action_at_least(\"IS_ON_BUCKET\", 1),\n            \"It doesn't look like you used is_on_bucket().\"\n            \"Use a while loop to collect all paint from a bucket.\"\n        )\n\n    def test_step3_can_move_usage(self):\n        \"\"\"\n        Check that the Painter can move at least once.\n        \"\"\"\n        if not self.painter_logs:\n            self.skipTest(\"No Painter found.\")\n\n        painter_log = self.painter_logs[0]\n        self.assertTrue(\n            painter_log.did_action_at_least(\"CAN_MOVE\", 1),\n            \"It doesn't look like you used can_move().\"\n            \"Use a while loop to move to a new location in the Neighborhood.\"\n        )\n\n    def test_step4_paint_usage(self):\n        \"\"\"\n        Paint at least once.\n        \"\"\"\n        if not self.painter_logs:\n            self.skipTest(\"No Painter found.\")\n\n        painter_log = self.painter_logs[0]\n        self.assertTrue(\n            painter_log.did_action_at_least(\"PAINT\", 1),\n            \"We expected you to paint at least once.\"\n        )\n\n    def test_step5_moves_enough(self):\n        \"\"\"\n        Move at least once.\n        \"\"\"\n        if not self.painter_logs:\n            self.skipTest(\"No Painter found.\")\n\n        painter_log = self.painter_logs[0]\n        self.assertTrue(\n            painter_log.did_action_at_least(\"MOVE\", 1),\n            \"It looks like you never moved. Make sure you navigate the neighborhood.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
