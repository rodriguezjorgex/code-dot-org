    "display_name": "Turn When Trapped",
    "bubble_choice_description": "The `Painter` is exploring a winding path full of twists and turns. It needs your help deciding what to do when the road ahead is blocked. Write a function that helps the `Painter` move forward when it can and turn right when it can't.",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestMoveOrTurn(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_turns_right_when_blocked(self):\n        \"\"\"Painter turns right when it can't move forward\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            3,\n            \"The Painter didn't turn right when blocked. Make sure you're calling turn_right() when the Painter can’t move.\"\n        )\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (7, 3) after navigating The Neighborhood\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (7, 3),\n            \"The Painter didn't stop at (7, 3). Check that they're navigating the full path and turning right when blocked.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
