      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestForecastUpdate(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get the printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_forecast_updated(self):\n        \"\"\"forecast should change from original to a new value\"\"\"\n        try:\n            from main import forecast\n        except ImportError:\n            self.fail(\"Make sure you create a variable called forecast!\")\n\n        printed_lines = [line.strip() for line in self.log if line.strip()]\n\n        # Find original and updated printed lines\n        original_line = next((line for line in printed_lines if \"Today's forecast:\" in line), None)\n        updated_line = next((line for line in printed_lines if \"Updated forecast:\" in line), None)\n\n        self.assertIsNotNone(original_line, \"Make sure you print the original forecast!\")\n        self.assertIsNotNone(updated_line, \"Make sure you print the updated forecast!\")\n\n        # Extract just the forecast words\n        original_forecast = original_line.split(\":\")[-1].strip()\n        updated_forecast = updated_line.split(\":\")[-1].strip()\n\n        self.assertNotEqual(\n            original_forecast,\n            updated_forecast,\n            \"Make sure you actually update the forecast to a new value!\"\n        )\n",
