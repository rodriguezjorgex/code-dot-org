      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\n# Try importing the student's function\ntry:\n    from main import intro_line\n    function_exists = True\nexcept ImportError:\n    function_exists = False\n\nclass TestIntroLineFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_intro_line_function_exists(self):\n        \"\"\"intro_line() should exist and be callable\"\"\"\n        if not function_exists:\n            self.fail(\"Make sure you define a function called intro_line()!\")\n\n    def test_three_intro_lines_printed(self):\n        \"\"\"Three intro lines should be printed\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertEqual(\n            len(printed_messages),\n            3,\n            \"Make sure you call your intro_line() function three times to print three intro messages!\"\n        )\n\n        all_contain_intro = all(\n            \"welcome\" in line.lower() or \"what's up\" in line.lower() for line in printed_messages\n        )\n\n        self.assertTrue(\n            all_contain_intro,\n            \"Each message should sound like a video intro! Make sure your intro_line() function prints the catchphrase correctly.\"\n        )\n",
