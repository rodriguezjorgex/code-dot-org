      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestMakePlaylistFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up validation and get stdout logs\"\"\"\n        cls.validation = ValidationProtocol()\n        cls.stdout_logs = cls.validation.get_stdout_logs()\n\n    def test_function_prints_message(self):\n        \"\"\"Printed output should include a playlist message\"\"\"\n        self.assertGreaterEqual(\n            len(self.stdout_logs),\n            1,\n            \"No output was found. Make sure your program prints a message about the playlist.\"\n        )\n\n        output_text = \" \".join(self.stdout_logs).lower()\n\n        expected_keywords = [\"playlist\", \"for\"]\n        for word in expected_keywords:\n            self.assertIn(\n                word,\n                output_text,\n                f\"The output should include the word '{word}'. Make sure your playlist message uses the username!\"\n            )\n",
