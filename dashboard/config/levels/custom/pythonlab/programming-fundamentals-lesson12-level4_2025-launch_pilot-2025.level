      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\nfrom custom import turn_right, move_or_turn\n\ntaylor = Painter()\n\nturn_right(taylor)\n\nwhile taylor.is_facing_south():\n  move_or_turn(taylor)\n\nwhile taylor.is_facing_east():\n  move_or_turn(taylor)\n",
          "folderId": "0",
          "active": false,
          "open": true,
          "type": "locked_starter"
        },
        "2": {
          "id": "2",
          "name": "custom.py",
          "language": "py",
          "contents": "def turn_right(this_painter):\n  this_painter.turn_left()\n  this_painter.turn_left()\n  this_painter.turn_left()\n\ndef move_or_turn(this_painter):\n  if this_painter.can_move():\n    this_painter.move()\n  this_painter.turn_left()",
          "folderId": "0",
          "active": false,
          "open": true
        }
