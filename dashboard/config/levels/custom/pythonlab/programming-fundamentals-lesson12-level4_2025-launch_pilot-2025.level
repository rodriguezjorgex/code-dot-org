    "validation_file": {
      "id": "4",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPainterPath(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run student code once and cache the log\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_painter_follows_winding_path(self):\n        \"\"\"Painter follows the path without veering off\"\"\"\n        left_turns = self.painter.action_count(\"TURN_LEFT\")\n        moves = self.painter.action_count(\"MOVE\")\n\n        self.assertLess(\n            left_turns,\n            moves,\n            \"Hmm, it seems like the Painter is still turning left too often. Try adding an else statement so turning only happens when the Painter can't move.\"\n        )\n\n    def test_path_completion_position(self):\n        \"\"\"Painter ends at the expected position\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y, self.painter.ending_position.direction),\n            (3, 3, \"north\"),\n            \"The Painter didn't end up at the expected location. Did they follow the path correctly?\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
