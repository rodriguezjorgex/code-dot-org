    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "def start_game():\n    print(\"Welcome to the Enchanted Forest Adventure!\")\n    name = input(\"What's your name, adventurer? \")\n    print(f\"Greetings, {name}! Your quest begins now.\")\n    \n    path = input(\"Do you choose the left path or the right path? (left/right) \").lower()\n    if path == \"left\":\n        print(\"You encounter a friendly elf who gives you a magical key.\")\n    elif path == \"right\":\n        print(\"A wild troll blocks your way! You have to run back.\")\n    else:\n        print(\"Hmm... that's not an option. Try again.\")\n\n    action = input(\"Do you fight the dragon or sneak past it? (fight/sneak) \").lower()\n    if action == \"fight\":\n        print(\"You bravely fight the dragon and win with the magical key's help!\")\n    elif action == \"sneak\":\n        print(\"You sneak past the dragon quietly and find a hidden treasure.\")\n    else:\n        print(\"Hmm... that's not an option. Try again.\")\n\n    print(\"🎉 Congratulations! You've won the game! 🎉\")\n\nstart_game()",
