    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestMoveToSouthAndEast(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (11, 0)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (11, 0),\n            \"The Painter didn't stop at (11, 0). Double-check your move_to_south and move_to_east logic.\"\n        )\n\n    def test_turns_right_multiple_times(self):\n        \"\"\"Painter turns right multiple times\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            9,\n            \"The Painter didn't turn right enough times. Make sure you're calling turn_right() inside both move_to_south and move_to_east when appropriate.\"\n        )\n\n    def test_moves_multiple_steps(self):\n        \"\"\"Painter moves enough to complete the full maze\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"MOVE\"),\n            15,\n            \"The Painter didn't move far enough. Make sure all loops are executing correctly and the path continues to the cone.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
