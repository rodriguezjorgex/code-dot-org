    "display_name": "Go the Other Way",
    "bubble_choice_description": "Modify the program so the `Painter` goes the other way to get around the park.",
    "thumbnail_url": "https://images.code.org/2e3bf1182591f9eead94ce90209f7868-choiceB.gif",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPainterAroundPark(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter named ethan = Painter()!\")\n\n    def test_correct_sequence_of_moves_and_turns(self):\n        \"\"\"Painter should move 7, turn, move 7, turn, move 2\"\"\"\n        events = self.painter.get_events()\n        action_sequence = [event.neighborhood_action_type for event in events]\n\n        # Break action sequence into groups of moves between turns\n        move_groups = []\n        current_moves = 0\n\n        for action in action_sequence:\n            if action == \"MOVE\":\n                current_moves += 1\n            elif action == \"TURN_LEFT\":\n                if current_moves > 0:\n                    move_groups.append(current_moves)\n                    current_moves = 0\n        if current_moves > 0:\n            move_groups.append(current_moves)\n\n        self.assertGreaterEqual(\n            len(move_groups),\n            3,\n            \"Make sure your Painter moves, turns, moves again, turns, and finishes moving!\"\n        )\n\n        expected_move_counts = [7, 7, 2]\n        self.assertEqual(\n            move_groups[:3],\n            expected_move_counts,\n            f\"The pattern of moves is incorrect. Expected {expected_move_counts} but got {move_groups[:3]}. Make sure the Painter moves 7 spaces, turns, moves 7 spaces, turns, then moves 2 spaces.\"\n        )\n\n    def test_painter_ends_at_correct_position(self):\n        \"\"\"Painter should end at (5, 7)\"\"\"\n        final_x = self.painter.ending_position.x\n        final_y = self.painter.ending_position.y\n\n        self.assertEqual(\n            (final_x, final_y),\n            (5, 7),\n            \"The Painter should end at (5, 7) after navigating correctly around the park.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
