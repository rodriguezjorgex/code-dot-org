      "name": "main_test.py",
      "language": "py",
      "contents": "import unittest\nfrom unittest_runner import ValidationProtocol\n\nclass TestVariableTypes(unittest.TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Retrieve the program output once for all tests.\"\"\"\n        cls.lines = ValidationProtocol().get_stdout_logs()\n\n    def test_string_variable(self):\n        \"\"\"Check that the string variable is correctly printed.\"\"\"\n        self.assertEqual(self.lines[0], \"My string variable is hello\", \"The string variable output is incorrect.\")\n\n    def test_integer_variable(self):\n        \"\"\"Check that the integer variable is correctly printed.\"\"\"\n        self.assertEqual(self.lines[1], \"My integer variable is 1\", \"The integer variable output is incorrect.\")\n\n    def test_boolean_variable(self):\n        \"\"\"Check that the boolean variable is correctly printed.\"\"\"\n        self.assertEqual(self.lines[2], \"My boolean variable is True\", \"The boolean variable output is incorrect.\")\n\n    def test_float_variable(self):\n        \"\"\"Check that the float variable is correctly printed.\"\"\"\n        self.assertEqual(self.lines[3], \"My float variable is 95.1\", \"The float variable output is incorrect.\")\n\nif __name__ == '__main__':\n    unittest.main()\n",
