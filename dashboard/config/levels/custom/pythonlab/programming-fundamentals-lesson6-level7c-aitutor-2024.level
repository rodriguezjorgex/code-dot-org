    "display_name": "Diagonal Line",
    "bubble_choice_description": "Write a program to paint a diagonal line.",
    "thumbnail_url": "https://images.code.org/ba55a63c300ee519f966a56805c33b07-Screenshot 2025-01-22 142943.png",
    "validation_file": {
      "id": "2",
      "name": "main_test.py",
      "language": "py",
      "contents": "import unittest\nfrom unittest_runner import ValidationProtocol\n\nclass TestDiagonalPaint(unittest.TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"\n        Retrieve the NeighborhoodLog once for all tests.\n        \"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        painter_logs = cls.log.painter_logs\n        cls.painter_log = painter_logs[0] if painter_logs else None\n\n    def test_step1_create_painter(self):\n        \"\"\"\n        A Painter object is created.\n        \"\"\"\n        self.assertIsNotNone(\n            self.painter_log,\n            \"No Painter object found. Make sure to create one!\"\n        )\n\n    def test_step2_diagonal_only(self):\n        \"\"\"\n        Paint a diagonal line.\n        \"\"\"\n        if self.painter_log is None:\n            self.skipTest(\"No Painter created; skipping diagonal paint check.\")\n\n        # We'll build a 12×12 grid (rows/cols indexed 0..11).\n        # True => must be painted (non-None)\n        # False => must be unpainted (None)\n        grid_size = 12\n        expected_paint = [[False for _ in range(grid_size)] for _ in range(grid_size)]\n\n        # Mark diagonal squares (x, x) from x=0..11 as True\n        for x in range(grid_size):\n            y = x\n            expected_paint[y][x] = True\n\n        # Now use final_output_contains_paint. This will fail if any cell\n        # not on the diagonal is painted, or if any diagonal cell is missing paint.\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_paint),\n            \"One or more diagonal squares aren't painted, or you've painted extra squares.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
