    "thumbnail_url": "https://images.code.org/e025b324ee29d7dab8fd6c5c911729ac-choiceC.gif",
    "validation_file": {
      "id": "4",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestTakeOrTurn(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_turns_right_when_not_on_bucket(self):\n        \"\"\"Painter makes a right turn\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            3,\n            \"The Painter didn't turn right when not on a bucket. Add an else statement that turns right when the Painter is not on a bucket.\"\n        )\n\n    def test_final_position_is_correct(self):\n        \"\"\"Painter ends at (2, 6) after collecting and turning\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (2, 6),\n            \"The Painter didn't stop at (2, 6). Make sure the Painter turns correctly when not on a paint bucket.\"\n        )\n\n    def test_painter_has_four_units_of_paint(self):\n        \"\"\"Painter ends with exactly 4 units of paint\"\"\"\n        self.assertEqual(\n            self.painter.ending_paint_count,\n            4,\n            \"The Painter should end with 4 units of paint. Make sure the Painter is collecting paint correctly from the buckets.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
