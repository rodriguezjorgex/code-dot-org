    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\nfrom custom import keep_moving, take_or_turn\n\nmisty = Painter()\n\ntake_or_turn(misty)\nkeep_moving(misty)\n",
          "folderId": "0",
          "active": false,
          "open": true,
          "type": "locked_starter"
        },
        "2": {
          "id": "2",
          "name": "custom.py",
          "language": "py",
          "contents": "def turn_right(this_painter):\n  this_painter.turn_left()\n  this_painter.turn_left()\n  this_painter.turn_left()\n\ndef keep_moving(this_painter):\n  while this_painter.can_move():\n    this_painter.move()\n\ndef take_all_paint(this_painter):\n  while this_painter.is_on_bucket():\n    this_painter.take_paint()\n\ndef take_or_turn(this_painter):\n  while this_painter.is_facing_east():\n    this_painter.move()\n    if this_painter.is_on_bucket():\n      take_all_paint(this_painter)\n    # TODO - Add an else statement to turn right if the Painter is not on a paint bucket\n\n    ",
          "folderId": "0",
          "active": false,
          "open": true
        }
      },
