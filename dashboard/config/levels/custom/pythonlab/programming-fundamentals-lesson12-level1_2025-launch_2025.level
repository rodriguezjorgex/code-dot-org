    "mini_app": "neighborhood",
    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\nfrom custom import turn_right, collect_paint, turn_south, paint_to_empty\n\nsierra = Painter()\n\ncollect_paint(sierra)\nturn_south(sierra)\ncollect_paint(sierra)\npaint_to_empty(sierra, \"purple\")\ncollect_paint(sierra)\npaint_to_empty(sierra, \"purple\")\ncollect_paint(sierra)\npaint_to_empty(sierra, \"purple\")\ncollect_paint(sierra)\npaint_to_empty(sierra, \"purple\")\n",
          "folderId": "0",
          "active": true,
          "open": true
        },
        "2": {
          "id": "2",
          "name": "custom.py",
          "language": "py",
          "contents": "def turn_right(this_painter):\n  this_painter.turn_left()\n  this_painter.turn_left()\n  this_painter.turn_left()\n\ndef take_all_paint(this_painter):\n  while this_painter.is_on_bucket():\n    this_painter.take_paint()\n\ndef collect_paint(this_painter):\n  this_painter.move()\n  take_all_paint(this_painter)\n\ndef turn_south(this_painter):\n  while this_painter.is_facing_east():\n    if this_painter.can_move(\"south\"):\n      turn_right(this_painter)\n    this_painter.move()\n\ndef paint_to_empty(this_painter, color):\n  while this_painter.has_paint():\n    this_painter.paint(color)\n    if this_painter.can_move():\n      this_painter.move()\n    else:\n      this_painter.turn_left()",
          "folderId": "0",
          "active": false,
          "open": true
        }
      },
      "folders": {
      },
      "openFiles": [
        "0",
        "2"
      ]
    }
