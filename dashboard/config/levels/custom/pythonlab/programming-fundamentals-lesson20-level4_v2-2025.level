      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\n\nclass TestKeyMessageModification(unittest.TestCase):\n\n    def test_modify_key_message(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Ensure that the original print statement has been modified\n            if \"print(\\\"🔑 The key glows! A hidden passage appears!\\\")\" in content:\n                self.fail(\n                    \"The message for when the player has the key has not been modified. \"\n                    \"Please change this print statement to something new.\"\n                )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
