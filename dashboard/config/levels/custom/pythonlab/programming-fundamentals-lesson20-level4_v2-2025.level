          "name": "main.py",
          "language": "py",
          "contents": "print(\"A statue speaks: 'I will open the door if you can answer my question.'\")\nanswer = input(\"What comes once in a minute, twice in a moment, but never in a thousand years? \").lower()\n\nif answer == \"m\":\n    print(\"✅ The statue nods, and the door creaks open.\")\n    has_key = input(\"Do you have the golden key? (yes/no) \").lower()\n    if has_key == \"yes\":\n        print(\"🔑 The key glows! A hidden passage appears!\") # Change what happens if the play has the key\n    else:\n        print(\"You proceed through the regular entrance.\")\nelse:\n    print(\"❌ Incorrect! The statue remains silent.\")\n\n",
