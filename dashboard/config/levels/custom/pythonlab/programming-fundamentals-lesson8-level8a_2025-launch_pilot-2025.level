    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestTakeAllPaint(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (2, 0)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (2, 0),\n            \"The Painter didn't stop at (2, 0). Make sure you move to the bucket before calling take_all_paint().\"\n        )\n\n    def test_paint_collected(self):\n        \"\"\"Painter has 20 units of paint\"\"\"\n        self.assertEqual(\n            self.painter.ending_paint_count,\n            20,\n            \"The Painter should end with 20 units of paint. Make sure your take_all_paint() loop keeps collecting until the bucket is empty.\"\n        )\n\n    def test_used_is_on_bucket(self):\n        \"\"\"Painter checked if it was on a bucket\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"IS_ON_BUCKET\"),\n            1,\n            \"The Painter never checked if it was on a bucket. Make sure take_all_paint() uses a while loop with is_on_bucket().\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
