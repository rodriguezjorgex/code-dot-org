        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "def feed_villager():\n    meal = input(\"What meal will you give the villager? (bread/soup/meat): \").lower()\n\n    if meal == \"bread\":\n        print(\"🍞 The villager smiles and thanks you for the bread.\")\n    elif meal == \"soup\":\n        print(\"🥣 The villager enjoys the warm soup and feels refreshed.\")\n    elif meal == \"meat\":\n        print(\"🍖 The villager gains strength from the hearty meal!\")\n    else:\n        print(\"❌ The villager refuses the unfamiliar meal.\")\n\nfeed_villager()\n",
