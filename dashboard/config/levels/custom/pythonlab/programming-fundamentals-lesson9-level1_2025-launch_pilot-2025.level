          "contents": "from neighborhood import Painter\n\nangie = Painter()\n\nangie.move()\nangie.take_paint()\nangie.take_paint()\nangie.move()\n\n# TODO - Add an if statement and move this paint command inside it\nangie.paint(\"blue\")\n\nangie.turn_left()\nangie.turn_left()\nangie.turn_left()\nangie.move()\nangie.turn_left()\nangie.turn_left()\nangie.turn_left()\n\nangie.paint(\"green\")",
