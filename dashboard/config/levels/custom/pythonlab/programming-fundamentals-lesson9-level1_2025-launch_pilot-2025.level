    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestConditionalPaint(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_only_one_tile_is_painted(self):\n        \"\"\"Only one tile is painted (no blue)\"\"\"\n        painted_count = sum(\n            1 for row in self.log.final_output for cell in row if cell is not None\n        )\n        self.assertEqual(\n            painted_count,\n            1,\n            \"Only one space should be painted. Make sure the blue paint only runs if the Painter is facing west.\"\n        )\n\n    def test_correct_tile_is_painted(self):\n        \"\"\"Only (2, 1) is painted\"\"\"\n        final = self.log.final_output\n        grid_size = len(final)\n\n        # Create an expected output grid with only (2, 1) painted green\n        expected_output = [[None for _ in range(grid_size)] for _ in range(grid_size)]\n        expected_output[1][2] = \"Green\"  # (2, 1) coordinates\n\n        self.assertTrue(\n            self.log.final_output_matches(expected_output),\n            \"The space (2, 1) should be painted green, and no other spaces should be painted. Make sure the Painter correctly checks the direction before painting.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
