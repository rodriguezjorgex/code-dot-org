          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\n\nkatie = Painter()\n\nkatie.move()\n\nwhile katie.is_on_bucket():\n  katie.take_paint()\n\nwhile katie.has_paint():\n  katie.paint(\"green\")\nkatie.move()\n\nkatie.turn_left()\nkatie.turn_left()\nkatie.turn_left()\n\nwhile katie.can_move():\nkatie.move()",
          "folderId": "0",
          "active": true,
          "open": true
        }
      },
