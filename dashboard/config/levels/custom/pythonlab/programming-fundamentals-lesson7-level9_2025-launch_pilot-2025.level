        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\nfrom custom import take_three_paint, paint_spaces\n\nzuri = Painter()\n\nzuri.move()\n\ntake_three_paint(zuri)\n\nzuri.move()\n\nzuri.turn_left()\nzuri.turn_left()\nzuri.turn_left()\n\nzuri.move()\nzuri.move()\n\nzuri.turn_left()\n\npaint_spaces(zuri)",
          "folderId": "0",
          "active": false,
          "open": true,
          "type": "locked_starter"
        },
        "2": {
          "id": "2",
          "name": "custom.py",
          "language": "py",
          "contents": "def take_three_paint(this_painter):\n  this_painter.take_paint()\n  this_painter.take_paint()\n  this_painter.take_paint()\n\ndef paint_three_spaces(this_painter):\n  this_painter.paint(\"Navy\")\n  this_painter.paint(\"Navy\")\n  this_painter.move()\n",
          "folderId": "0",
          "active": false,
          "open": true
        }
