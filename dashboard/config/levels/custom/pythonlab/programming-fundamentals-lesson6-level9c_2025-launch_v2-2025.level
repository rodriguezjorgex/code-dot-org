      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\n# Try importing the student's function\ntry:\n    from main import wake_up_response\n    function_exists = True\nexcept ImportError:\n    function_exists = False\n\nclass TestWakeUpResponseFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_wake_up_response_function_exists(self):\n        \"\"\"wake_up_response() should exist and be callable\"\"\"\n        if not function_exists:\n            self.fail(\"Make sure you define a function called wake_up_response()!\")\n\n    def test_three_wake_up_messages_printed(self):\n        \"\"\"Three wake-up messages should be printed\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertEqual(\n            len(printed_messages),\n            3,\n            \"Make sure you call your wake_up_response() function three times to simulate the assistant being triggered three times!\"\n        )\n\n        all_contain_listening = all(\n            \"listen\" in line.lower() or \"ready\" in line.lower() for line in printed_messages\n        )\n\n        self.assertTrue(\n            all_contain_listening,\n            \"Each wake-up response should sound like the assistant is ready or listening! Make sure your wake_up_response() function prints a listening message.\"\n        )\n",
      "folderId": "0",
