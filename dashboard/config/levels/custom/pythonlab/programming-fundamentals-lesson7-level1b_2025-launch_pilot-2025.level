      "name": "test.py",
      "language": "py",
      "contents": "import inspect\nfrom unittest import TestCase\nfrom unittest_runner import ValidationProtocol\nfrom main import fan_shoutout\n\nclass TestFanShoutout(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up validation and get stdout logs\"\"\"\n        cls.validation = ValidationProtocol()\n        cls.stdout_logs = cls.validation.get_stdout_logs()\n\n    def test_function_has_one_parameter(self):\n        \"\"\"fan_shoutout should accept exactly one parameter\"\"\"\n        params = inspect.signature(fan_shoutout).parameters\n        self.assertEqual(\n            len(params),\n            1,\n            \"The function fan_shoutout should have exactly one parameter for the fan's name.\"\n        )\n\n    def test_output_uses_dynamic_name(self):\n        \"\"\"Printed output should use a dynamic fan name (not hardcoded 'Jamie')\"\"\"\n        self.assertGreaterEqual(\n            len(self.stdout_logs),\n            1,\n            \"No output was found. Make sure fan_shoutout() is called and prints a message.\"\n        )\n\n        last_output = self.stdout_logs[-1]\n\n        # Make sure it doesn't still print \"Jamie\"\n        self.assertNotIn(\n            \"Jamie\",\n            last_output,\n            \"The output still uses the hardcoded name 'Jamie'. Make sure you print the dynamic fan name passed as a parameter.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
