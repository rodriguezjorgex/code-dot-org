    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\nfrom custom import turn_right, keep_moving\n\npaige = Painter()\n\nkeep_moving(paige)\nturn_right(paige)\n\nwhile paige.is_facing_south():\n  # TODO - Modify the if statement to turn and move only if the Painter can move east\n  if paige.can_move(\"east\"):\n    paige.turn_left()\n    keep_moving(paige)\n  # TODO - Add an else statement so the Painter only moves forward if it can't move east\n  paige.move()\n",
          "folderId": "0",
          "active": false,
          "open": true,
          "type": "locked_starter"
        },
        "2": {
          "id": "2",
          "name": "custom.py",
          "language": "py",
          "contents": "def turn_right(this_painter):\n  this_painter.turn_left()\n  this_painter.turn_left()\n  this_painter.turn_left()\n\ndef keep_moving(this_painter):\n  while this_painter.can_move():\n    this_painter.move()",
          "folderId": "0",
          "active": false,
          "open": true
        }
      },
