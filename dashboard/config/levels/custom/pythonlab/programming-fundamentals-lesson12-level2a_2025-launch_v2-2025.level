    "thumbnail_url": "https://images.code.org/a98abc56e7669d2eac95b47cb3d67c3c-choiceA.gif",
    "validation_file": {
      "id": "4",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPainterAvoidsTaxis(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_painter_moves_around_taxis(self):\n        \"\"\"Painter moves down the street and turns left\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            4,\n            \"It looks like the Painter isn't turning left to get past the taxis. Make sure you added the else statement so they only move forward when they can't go east.\"\n        )\n\n    def test_painter_stops_at_correct_position(self):\n        \"\"\"Painter ends at (6, 7) after passing the taxis\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (7, 6),\n            \"The Painter didn't stop at the correct location. Check that they're moving past the taxis and continuing to the sidewalk.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
