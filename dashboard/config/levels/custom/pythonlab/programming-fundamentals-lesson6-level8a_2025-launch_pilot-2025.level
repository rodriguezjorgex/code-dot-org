      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\n# Try importing the student's function\ntry:\n    from main import give_compliment\n    function_exists = True\nexcept ImportError:\n    function_exists = False\n\nclass TestGiveComplimentFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_give_compliment_function_runs(self):\n        \"\"\"give_compliment() should exist and be callable\"\"\"\n        if not function_exists:\n            self.fail(\"Make sure you define a function called give_compliment()!\")\n\n    def test_three_compliments_given(self):\n        \"\"\"Three compliments should be printed\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertEqual(\n            len(printed_messages),\n            3,\n            \"Make sure you call your give_compliment() function three times to print three compliments!\"\n        )\n\n        all_contain_compliment = all(\n            \"great\" in line.lower() or \"good\" in line.lower() or \"awesome\" in line.lower() for line in printed_messages\n        )\n\n        self.assertTrue(\n            all_contain_compliment,\n            \"Each message should be a compliment! Make sure your give_compliment() function prints something positive.\"\n        )\n",
