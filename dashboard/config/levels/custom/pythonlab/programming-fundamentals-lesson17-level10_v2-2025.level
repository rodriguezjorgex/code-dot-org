    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "import random\n\npotions = 5\nvillagers_healed = 0\n\n# Use a potion to heal 1 to 3 villagers (random)\nwhile potions > 0:\n    heal = random.randint(1, 3)  # Randomly heal 1 to 3 villagers\n    villagers_healed += heal\n    potions -= 1\n    print(\"You healed\", heal, \"villagers! Total villagers healed:\", villagers_healed)\n\nprint(\"You ran out of potions!\")\n",
          "folderId": "0",
          "active": true,
          "open": true
        }
      },
