    "validation_file": {
      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\n\nclass TestPotionHealing(unittest.TestCase):\n\n    def test_modify_healing_range(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Check if the random range is updated to `random.randint(2, 5)`\n            if 'random.randint(2, 5)' not in content:\n                self.fail(\n                    \"The healing range has not been updated to 2 to 5 villagers. \"\n                    \"Please change the line `random.randint(1, 3)` to `random.randint(2, 5)` \"\n                    \"so that each potion heals between 2 and 5 villagers.\"\n                )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
