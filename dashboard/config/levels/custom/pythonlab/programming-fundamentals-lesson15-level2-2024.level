      "language": "py",
      "contents": "import unittest\n\nclass TestStudentCode(unittest.TestCase):\n\n    def test_hello_world_change(self):\n        \"\"\"Change the text in the print statement.\"\"\"\n        try:\n            with open('main.py', 'r') as f:\n                lines = f.readlines()\n\n            # Check if the first line matches the original code exactly\n            original_code = 'print(\"Hello, world!\")\\n'\n            if len(lines) > 0 and lines[0].strip() == 'print(\"Hello, world!\")':\n                self.fail(\"You haven't changed the string! Please modify the 'Hello, world!' message to something else.\")\n            else:\n                print(\"Success! You've changed the string.\")\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
