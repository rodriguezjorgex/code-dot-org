          "name": "main.py",
          "language": "py",
          "contents": "print(\"A statue speaks: 'I will open the door if you can answer my question.'\")\nanswer = input(\"What comes once in a minute, twice in a moment, but never in a thousand years? \").lower()\n\nif answer == \"m\":\n    print(\"✅ The statue nods, and the door creaks open.\")\nelse:\n    # Modify this line to add a hint instead of just printing 'Incorrect'\n    print(\"❌ Incorrect! Try again.\")\n",
