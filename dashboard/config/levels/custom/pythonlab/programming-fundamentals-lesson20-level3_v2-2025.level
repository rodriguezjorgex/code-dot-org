      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\n\nclass TestRiddleModification(unittest.TestCase):\n\n    def test_modify_else_statement(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Ensure that the else statement has been modified\n            if \"print(\\\"❌ Incorrect! Try again.\\\")\" in content:\n                self.fail(\n                    \"The else statement has not been modified. \"\n                    \"Please change it to provide a hint instead of just saying 'Incorrect!'.\"\n                )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
