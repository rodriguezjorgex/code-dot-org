    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestFixPaintPathBug(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (3, 4)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (3, 4),\n            \"The Painter didn't stop at (3, 4). Make sure the loop to paint with has_paint() runs after collecting paint.\"\n        )\n\n    def test_correct_spaces_are_painted(self):\n        \"\"\"Painter paints (3, 0) to (3, 3)\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n        for y in range(0, 4):\n            expected_output[y][3] = True\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"Spaces (3, 0) to (3, 3) should be painted. Make sure the Painter collects paint before using has_paint().\"\n        )\n\n    def test_painting_logic_runs_after_paint_collection(self):\n        \"\"\"Painter paints only after reaching the bucket and taking paint\"\"\"\n        self.assertGreaterEqual(\n            self.painter.ending_paint_count,\n            0,\n            \"Make sure the Painter collects paint from the bucket before entering the paint loop.\"\n        )\n        self.assertGreaterEqual(\n            self.painter.action_count(\"PAINT\"),\n            4,\n            \"The Painter didn't paint the expected number of spaces. Check your while loop using has_paint().\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
