      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\n# Try importing the student's function\ntry:\n    from main import ai_reminder\n    function_exists = True\nexcept ImportError:\n    function_exists = False\n\nclass TestAIReminderFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_ai_reminder_function_exists(self):\n        \"\"\"ai_reminder() should exist and be callable\"\"\"\n        if not function_exists:\n            self.fail(\"Make sure you define a function called ai_reminder()!\")\n\n    def test_six_ai_reminder_lines_printed(self):\n        \"\"\"Six reminder lines should be printed (two lines per call, three calls)\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertEqual(\n            len(printed_messages),\n            6,\n            \"Make sure you call your ai_reminder() function three times! Each call should print two lines, for a total of six lines.\"\n        )\n\n        # Check that at least one message mentions AI and one mentions critical thinking\n        has_ai_message = any(\"ai\" in line.lower() for line in printed_messages)\n        has_critical_thinking_message = any(\"think\" in line.lower() or \"check\" in line.lower() for line in printed_messages)\n\n        self.assertTrue(\n            has_ai_message,\n            \"Make sure your reminder talks about AI tools!\"\n        )\n\n        self.assertTrue(\n            has_critical_thinking_message,\n            \"Make sure your reminder encourages critical thinking or double-checking information!\"\n        )\n",
      "folderId": "0",
