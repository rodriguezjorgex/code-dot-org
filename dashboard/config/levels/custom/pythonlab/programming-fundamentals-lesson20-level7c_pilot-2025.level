      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\nimport ast\n\nclass TestUnlockDoor(unittest.TestCase):\n\n    def test_print_message_after_has_key(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Parse the file into an AST (Abstract Syntax Tree)\n            tree = ast.parse(content)\n\n            # Locate the `unlock_door` function\n            for node in ast.walk(tree):\n                if isinstance(node, ast.FunctionDef) and node.name == \"unlock_door\":\n                    for stmt in node.body:\n                        # Check for the if-statement (if has_key == \"yes\")\n                        if isinstance(stmt, ast.If) and isinstance(stmt.test, ast.Compare):\n                            if hasattr(stmt.test.left, \"id\") and stmt.test.left.id == \"has_key\":\n                                # Ensure there's a print statement inside this if block\n                                if not any(isinstance(s, ast.Expr) and isinstance(s.value, ast.Call) and isinstance(s.value.func, ast.Name) and s.value.func.id == \"print\" for s in stmt.body):\n                                    self.fail(\n                                        \"Missing a print statement inside `if has_key == \\\"yes\\\"`. \"\n                                        \"Please add a success message after the condition.\"\n                                    )\n\n                        # Check for the else-statement\n                        if isinstance(stmt, ast.If) and stmt.orelse:\n                            for else_stmt in stmt.orelse:\n                                if isinstance(else_stmt, ast.Assign) and hasattr(else_stmt.targets[0], \"id\") and else_stmt.targets[0].id == \"search\":\n                                    # Ensure there's a nested if-else under `search = input(...)`\n                                    if not any(isinstance(nested_stmt, ast.If) for nested_stmt in stmt.orelse):\n                                        self.fail(\n                                            \"The `else` block is missing a nested conditional. \"\n                                            \"Please add an if-statement to check if the player wants to search for the key.\"\n                                        )\n                    return  # Test passes if both checks pass\n\n            self.fail(\"Could not find the required `if` statement and nested conditional inside `unlock_door()`.\")\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
