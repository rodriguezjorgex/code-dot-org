          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "def unlock_door():\n    has_key = input(\"Do you have the golden key? (yes/no) \").lower()\n\n    if has_key == \"yes\":\n       # Add the success message here\n\n    else:\n        search = input(\"Would you like to search for the key? (yes/no) \").lower()\n        # Add nested conditional statement here\n\n\nunlock_door()\n\n",
