    "mini_app": "neighborhood",
    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\nfrom custom import turn_right, take_all_paint, move_and_paint, paint_south\n\nyoda = Painter()\n\nyoda.move()\ntake_all_paint(yoda)\nmove_and_paint(yoda, \"gold\")\nmove_and_paint(yoda, \"gold\")\nturn_right(yoda)\npaint_south(yoda, \"gold\")\nyoda.turn_left()\nmove_and_paint(yoda, \"gold\")\nmove_and_pint(yoda, \"gold\")\nturn_right(yoda)\npaint_south(yoda, \"gold\")\n",
          "folderId": "0",
          "active": false,
          "open": true,
          "type": "locked_starter"
        },
        "2": {
          "id": "2",
          "name": "custom.py",
          "language": "py",
          "contents": "def turn_right(this_painter):\nthis_painter.turn_left()\nthis_painter.turn_left()\nthis_painter.turn_left()\n\ndef take_all_paint(this_painter):\n  while this_painter.is_on_bucket():\n  this_painter.take_paint()\n\ndef move_and_paint(this_painter, color):\n  this_painter.move()\n  this_painter.paint(color)\n\ndef paint_south(this_painter, color):\n  while this_painter.can_move(\"south\"):\n    this_painter.move()\n    if this_painter.has_paint()\n      this_painter.paint(color)\n",
          "folderId": "0",
          "active": false,
          "open": true
        }
      },
      "folders": {
      },
      "openFiles": [
        "0",
        "2"
      ]
    },
