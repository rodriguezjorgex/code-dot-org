      "name": "test.py",
      "language": "py",
      "contents": "import inspect\nfrom unittest import TestCase\nfrom unittest_runner import ValidationProtocol\nfrom main import send_reminder\n\nclass TestSendReminder(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up validation and get stdout logs\"\"\"\n        cls.validation = ValidationProtocol()\n        cls.stdout_logs = cls.validation.get_stdout_logs()\n\n    def test_function_has_two_parameters(self):\n        \"\"\"send_reminder should accept exactly two parameters\"\"\"\n        params = inspect.signature(send_reminder).parameters\n        self.assertEqual(\n            len(params),\n            2,\n            \"The function send_reminder should have exactly two parameters: one for the name and one for the task.\"\n        )\n\n    def test_output_uses_name_and_task(self):\n        \"\"\"Printed output should dynamically use the name and the task\"\"\"\n        self.assertGreaterEqual(\n            len(self.stdout_logs),\n            1,\n            \"No output was found. Make sure send_reminder() is called and prints a message.\"\n        )\n\n        last_output = self.stdout_logs[-1]\n\n        # Check that the old hardcoded name is not used\n        self.assertNotIn(\n            \"Chris\",\n            last_output,\n            \"The output still uses the hardcoded name 'Chris'. Make sure you use the dynamic parameters instead.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
