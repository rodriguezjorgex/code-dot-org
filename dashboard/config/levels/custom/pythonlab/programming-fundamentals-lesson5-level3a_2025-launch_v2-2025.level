    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPainterReachCone(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_painter_moved_three_times(self):\n        \"\"\"Painter should move forward three times\"\"\"\n        move_count = self.painter.action_count(\"MOVE\")\n\n        self.assertEqual(\n            move_count,\n            3,\n            \"Make sure your Painter moves forward three times to reach the traffic cone!\"\n        )\n\n    def test_painter_ends_at_correct_position(self):\n        \"\"\"Painter should end at (3, 0)\"\"\"\n        final_x = self.painter.ending_position.x\n        final_y = self.painter.ending_position.y\n\n        self.assertEqual(\n            (final_x, final_y),\n            (3, 0),\n            \"The Painter should end at (3, 0) after reaching the traffic cone.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
