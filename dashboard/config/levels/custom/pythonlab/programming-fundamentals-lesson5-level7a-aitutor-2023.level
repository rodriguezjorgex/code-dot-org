      "id": "2",
      "name": "main_test.py",
      "language": "py",
      "contents": "import unittest\nfrom unittest_runner import ValidationProtocol\n\nclass TestPainterEndsAt30(unittest.TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"\n        Retrieve the NeighborhoodLog once for all tests.\n        \"\"\"\n        cls.neighborhood_log = ValidationProtocol().get_neighborhood_log()\n        painter_logs = cls.neighborhood_log.painter_logs\n        cls.painter_log = painter_logs[0] if painter_logs else None\n\n    def test_step1_create_painter(self):\n        \"\"\"\n        Create a Painter object.\n        \"\"\"\n        self.assertIsNotNone(\n            self.painter_log,\n            \"We couldn't find a Painter object. Make sure you create one!\"\n        )\n\n    def test_step2_final_position(self):\n        \"\"\"\n        Painter reaches the cone.\n        \"\"\"\n        if self.painter_log is None:\n            self.skipTest(\"No Painter found!\")\n\n        final_pos = self.painter_log.ending_position\n        if final_pos.x != 3 or final_pos.y != 0:\n            self.fail(\n                \"Your Painter didn't reach the cone.\"\n            )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
