    "validation_file": {
      "id": "2",
      "name": "main_test.py",
      "language": "py",
      "contents": "import unittest\nfrom unittest_runner import ValidationProtocol\n\nclass TestPaintLineToCone(unittest.TestCase):\n\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Retrieve the NeighborhoodLog once for all tests.\"\"\"\n        cls.neighborhood_log = ValidationProtocol().get_neighborhood_log()\n        logs = cls.neighborhood_log.painter_logs\n        cls.painter_log = logs[0] if logs else None\n\n    def test_step1_create_painter(self):\n        \"\"\"\n        A Painter object is created.\n        \"\"\"\n        self.assertIsNotNone(\n            self.painter_log,\n            \"No Painter object found. Did you create one?\"\n        )\n\n    def test_step2_paint_line(self):\n        \"\"\"\n        The path to the traffic cone is painted.\n        Skip if no Painter object exists.\n        \"\"\"\n        if self.painter_log is None:\n            self.skipTest(\"No Painter created. Cannot check painted cells.\")\n\n        grid_size = 8\n        # Build a boolean 2D array: True => must be painted (non-None), False => must remain None\n        expected_paint = [[False]*grid_size for _ in range(grid_size)]\n\n        expected_paint[1][3] = True\n        # (3,2) => y=2, x=3\n        expected_paint[2][3] = True\n        # (3,3) => y=3, x=3\n        expected_paint[3][3] = True\n        # (3,4) => y=4, x=3\n        expected_paint[4][3] = True\n        # (3,5) => y=5, x=3\n        expected_paint[5][3] = True\n        # (3,6) => y=6, x=3\n        expected_paint[6][3] = True\n        # (3,7) => y=7, x=3\n        expected_paint[7][3] = True\n        # (2,7) => y=7, x=2\n        expected_paint[7][2] = True\n\n        # final_output_contains_paint ensures ONLY those cells are painted\n        self.assertTrue(\n            self.neighborhood_log.final_output_contains_paint(expected_paint),\n            \"One or more required cells aren't painted correctly, or extra cells have paint. \"\n            \"Review which squares you paint along the line to the cone.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
