          "name": "main.py",
          "language": "py",
          "contents": "from support import blue_potion, red_potion, yellow_potion \n\n\n# This asks the user what they want to choose. \npotion = input(\"Which potion do you want to use (blue, red, yellow)? \").lower()\n\nif potion == \"blue\":\n    blue_potion()\n# Add code here to write your elif statements for the red potion and the yellow potion.\n\n\nelse:\n    print(\"That potion doesn't exist!\")\n",
          "folderId": "0",
