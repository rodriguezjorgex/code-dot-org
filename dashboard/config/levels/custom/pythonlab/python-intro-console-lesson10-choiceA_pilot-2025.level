          "name": "support.py",
          "language": "py",
          "contents": "# Support file for critter capture messages\n\ndef blue_potion():\n    art = \"\"\"\n    💙💊💙\n    The blue potion healed you. Your health is back to 100%!\n    \"\"\"\n    print(art)\n\ndef red_potion():\n    art = \"\"\"\n    🔥❤️‍🔥🔥\n    The red potion shoots out fireballs! Use it on your enemies. \n    \"\"\"\n    print(art)\n\ndef yellow_potion():\n    art = \"\"\"\n    🌟💪🌟\n    The yellow potion makes you invincible for 5 minutes. Power up!  \n    \"\"\"\n    print(art)\n\n",
