          "language": "py",
          "contents": "from neighborhood import Painter\n\n# TODO - Create the missing Painters\n\n\n\n\n# Move zola\nzola.move()\nzola.move()\nzola.move()\nzola.move()\n\nzola.turn_left()\nzola.turn_left()\nzola.turn_left()\n\nzola.move()\nzola.move()\n\n# Move kenji\nkenji.move()\nkenji.move()\nkenji.move()\nkenji.move()\n\nkenji.turn_left()\nkenji.turn_left()\nkenji.turn_left()\n\nkenji.move()\nkenji.move()\n\n# Move britney\nbritney.move()\nbritney.move()\nbritney.move()\nbritney.move()\n\nbritney.turn_left()\nbritney.turn_left()\nbritney.turn_left()\n\nbritney.move()\nbritney.move()\n",
