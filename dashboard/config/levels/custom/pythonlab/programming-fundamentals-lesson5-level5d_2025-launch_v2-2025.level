    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestThreePaintersGoToHouseParty(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs or len(cls.log.painter_logs) < 3:\n            cls.painter1 = None\n            cls.painter2 = None\n            cls.painter3 = None\n        else:\n            cls.painter1 = cls.log.painter_logs[0]\n            cls.painter2 = cls.log.painter_logs[1]\n            cls.painter3 = cls.log.painter_logs[2]\n\n    def setUp(self):\n        if self.painter1 is None or self.painter2 is None or self.painter3 is None:\n            self.skipTest(\"Three Painters were not created. Make sure you create three Painters!\")\n\n    def test_first_painter_final_position(self):\n        \"\"\"First Painter should end at (4, 2)\"\"\"\n        final_x = self.painter1.ending_position.x\n        final_y = self.painter1.ending_position.y\n\n        self.assertEqual(\n            (final_x, final_y),\n            (4, 2),\n            \"The first Painter should end at (4, 2) after completing its moves.\"\n        )\n\n    def test_second_painter_final_position(self):\n        \"\"\"Second Painter should end at (4, 2)\"\"\"\n        final_x = self.painter2.ending_position.x\n        final_y = self.painter2.ending_position.y\n\n        self.assertEqual(\n            (final_x, final_y),\n            (4, 2),\n            \"The second Painter should end at (4, 2) after completing its moves.\"\n        )\n\n    def test_third_painter_final_position(self):\n        \"\"\"Third Painter should end at (4, 2)\"\"\"\n        final_x = self.painter3.ending_position.x\n        final_y = self.painter3.ending_position.y\n\n        self.assertEqual(\n            (final_x, final_y),\n            (4, 2),\n            \"The third Painter should end at (4, 2) after completing its moves.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
