          "language": "py",
          "contents": "from neighborhood import Painter\n\nchloe = Painter()\n\n# TODO - Create a second Painter\n\n\n# Move chloe\nchloe.turn_left()\nchloe.turn_left()\nchloe.turn_left()\n\nchloe.move()\nchloe.move()\nchloe.move()\n\nchloe.turn_left()\nchloe.move()\nchloe.move()\n\n# Move mei\nmei.turn_left()\nmei.turn_left()\nmei.turn_left()\n\nmei.move()\nmei.move()\nmei.move()\nmei.move()\nmei.move()\nmei.move()\nmei.move()\n\nmei.turn_left()\nmei.move()\nmei.move()\n",
