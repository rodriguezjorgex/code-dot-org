          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\n\n# TODO - Add a parameter for this_painter\ndef take_three_paint():\n  # TODO - Modify the function to use this_painter\n  sally.take_paint()\n  sally.take_paint()\n  sally.take_paint()\n\n# TODO - Add a parameter for this_painter\ndef paint_then_move():\n  # TODO - Modify the function to use this_painter\n  helen.paint(\"Thistle\")\n  helen.move()\n  helen.paint(\"Thistle\")\n  helen.move()\n  helen.paint(\"Thistle\")\n\nsally = Painter()\nhelen = Painter()\n\nsally.move()\nsally.move()\nsally.move()\n\n# TODO - Call the take_three_paint() function with sally\ntake_three_paint()\n\nsally.turn_left()\nsally.turn_left()\nsally.turn_left()\n\n# TODO - Call the paint_then_move() function with sally\nsally.paint(\"Thistle\")\nsally.move()\nsally.paint(\"Thistle\")\nsally.move()\nsally.paint(\"Thistle\")\n\nhelen.move()\nhelen.move()\nhelen.move()\nhelen.move()\n\n# TODO - Call the take_three_paint() function with helen\nhelen.take_paint()\nhelen.take_paint()\nhelen.take_paint()\n\nhelen.turn_left()\nhelen.turn_left()\nhelen.turn_left()\n\n# TODO - Call the paint_then_move() function with helen\npaint_then_move()",
