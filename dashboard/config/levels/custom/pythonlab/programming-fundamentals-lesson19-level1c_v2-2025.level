          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "def cupcake_mystery():\n    print(\"Welcome to The Mystery of the Missing Cupcake!\")\n    detective = input(\"What's your detective name? \")\n    print(f\"Detective {detective}, you have a case to solve!\")\n\n    suspect = input(\"Do you want to question Alex or Jordan first? (Alex/Jordan) \").lower()\n    if suspect == \"alex\":\n        print(\"Alex says they were at the library during the time of the theft.\")\n    elif suspect == \"jordan\":\n        print(\"Jordan claims they were baking cookies at home.\")\n    else:\n        print(\"Hmm... that's not an option. Try again.\")\n\n    clue = input(\"Do you check the kitchen for clues or the library? (kitchen/library) \").lower()\n    if clue == \"kitchen\":\n        print(\"You find crumbs leading to Jordan's backpack!\")\n    elif clue == \"library\":\n        print(\"At the library, you find Alex's signed logbook proving they were present.\")\n    else:\n        print(\"Hmm... that's not an option. Try again.\")\n\n    print(\"🎉 Congratulations! You've solved the mystery! 🎉\")\n\ncupcake_mystery()\n",
