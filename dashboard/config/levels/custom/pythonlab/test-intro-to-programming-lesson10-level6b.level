    "enable_micro_bit": "false",
    "mini_app": "neighborhood",
    "predict_settings": {
      "isPredictLevel": false
    },
    "long_instructions": "# Do This:\r\n1. Write a program to get the Painter to the traffic cone based on the direction it can move:\r\n\t- Define one function to have the Painter move east while it can move and to turn right when it is able to move south.\r\n    - Define a second function to have the Painter move north while it can move and to turn right when it is able to move east.\r\n\r\n<details style=\"background-color: #e0d1ec; padding: 10px; margin-bottom: 10px; border: 1px solid transparent; border-radius: 5px;\">\r\n    <summary style=\"font-size: 1.2em; font-weight: bold; color: black;\">Need help with your algorithms?</summary>\r\n    <div style=\"margin-top: 20px; margin-left: 20px; margin-right: 20px;\">\r\n    \t<p style=\"color: black;\">Here is one approach to solving this problem.</p>\r\n        <pre style=\"background-color: #333333; color: white;\">\r\n#first function\r\nwhile the Painter can move east\r\n   move\r\n   if the Painter can move south\r\n      turn right\r\n#second function\r\nwhile the Painter can move north\r\n   if the Painter can move east\r\n      turn right\r\n   move\r\n\t  </pre>\r\n    </div>\r\n</details>",
    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\n\n# Create Painter object\ntrinity = Painter()\n\n# Function definition for turn right\ndef turn_right():\n  trinity.turn_left()\n  trinity.turn_left()\n  trinity.turn_left()\n\n# Function defintion for turn around\ndef turn_around():\n  trinity.turn_left()\n  trinity.turn_left()\n\n# Function definition to move while painter can move\ndef move_while_can():\n  while trinity.can_move():\n    trinity.move()\n\n# ADD TWO NEW FUNCTION DEFINTIONS HERE\ndef move_east_then_turn_if_south():\n  while trinity.can_move('east'):\n    trinity.move()\n    if trinity.can_move('south'):\n      turn_right()\n\ndef move_north_turn_if_east():\n  while trinity.can_move('north'):\n    if trinity.can_move('east'):\n      turn_right()\n    trinity.move()\n\n# ADD FUNCTION CALLS TO GET THE PAINTER TO THE TRAFFIC CONE\n",
          "folderId": "0",
          "active": true,
          "open": true
        }
      },
      "folders": {
      }
