    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestCollectPaint(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (2, 9)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (2, 9),\n            \"The Painter didn't stop at (2, 9). Make sure collect_paint() completes the full path.\"\n        )\n\n    def test_paint_count(self):\n        \"\"\"Painter ends with 23 units of paint\"\"\"\n        self.assertEqual(\n            self.painter.ending_paint_count,\n            23,\n            \"The Painter should end with 23 units of paint. Make sure take_all_paint() is called whenever the Painter is on a bucket.\"\n        )\n\n    def test_movement_and_bucket_checks(self):\n        \"\"\"Painter moved enough and checked for buckets\"\"\"\n        self.assertGreater(\n            self.painter.action_count(\"MOVE\"),\n            10,\n            \"The Painter didn't move enough. Check your collect_paint() loop.\"\n        )\n        self.assertGreaterEqual(\n            self.painter.action_count(\"IS_ON_BUCKET\"),\n            1,\n            \"It looks like the Painter never checked for buckets. Make sure you use is_on_bucket() before calling take_all_paint().\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
