    "display_name": "Take Three Paint",
    "bubble_choice_description": "You're helping two `Painter`s collect paint for their next masterpiece. But right now, the `take_three_paint()` function only works for one `Painter`.",
    "thumbnail_url": "https://images.code.org/eb0121e000a412190cb6ce05b38196f0-choiceA.gif",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "import inspect\nfrom unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestTakeThreePaintGeneric(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up validation and get logs\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs or len(cls.log.painter_logs) < 2:\n            cls.first_painter = None\n            cls.second_painter = None\n        else:\n            cls.first_painter = cls.log.painter_logs[0]\n            cls.second_painter = cls.log.painter_logs[1]\n\n    def setUp(self):\n        if self.first_painter is None or self.second_painter is None:\n            self.skipTest(\"Two Painters should be created and used in this program.\")\n\n    def test_function_has_one_parameter(self):\n        \"\"\"take_three_paint should accept exactly one parameter\"\"\"\n        from main import take_three_paint\n        params = inspect.signature(take_three_paint).parameters\n        self.assertEqual(\n            len(params),\n            1,\n            \"The function take_three_paint should have exactly one parameter (this_painter).\"\n        )\n\n    def test_first_painter_final_position(self):\n        \"\"\"First Painter ends at (1, 4)\"\"\"\n        self.assertEqual(\n            (self.first_painter.ending_position.x, self.first_painter.ending_position.y),\n            (1, 4),\n            \"The first Painter didn't end at (1, 4). Double-check their movement and painting path.\"\n        )\n\n    def test_second_painter_final_position(self):\n        \"\"\"Second Painter ends at (5, 0)\"\"\"\n        self.assertEqual(\n            (self.second_painter.ending_position.x, self.second_painter.ending_position.y),\n            (5, 0),\n            \"The second Painter didn't end at (5, 0). Double-check their movement and painting path.\"\n        )\n\n    def test_correct_spaces_are_painted(self):\n        \"\"\"Painters paint the expected spaces\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n\n        painted_spaces = [\n            (3, 0), (4, 0), (5, 0),\n            (1, 2), (1, 3), (1, 4)\n        ]\n\n        for x, y in painted_spaces:\n            expected_output[y][x] = True\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"Not all expected spaces were painted. Make sure both Painters collected paint and painted correctly.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
