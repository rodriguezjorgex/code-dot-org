          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\n\n# TODO - Add a parameter for this_painter\ndef take_three_paint():\n  # TODO - Modify the function to use this_painter\n  sofia.take_paint()\n  sofia.take_paint()\n  sofia.take_paint()\n\nsofia = Painter()\ncaleb = Painter()\n\nsofia.move()\nsofia.turn_left()\nsofia.turn_left()\nsofia.turn_left()\nsofia.move()\n\n# TODO - Call the take_three_paint() function with sofia\ntake_three_paint()\n\nsofia.move()\nsofia.paint(\"PowderBlue\")\nsofia.move()\nsofia.paint(\"PowderBlue\")\nsofia.move()\nsofia.paint(\"PowderBlue\")\n\ncaleb.move()\ncaleb.move()\n\n# TODO - Call the take_three_paint() function with caleb\ncaleb.take_paint()\ncaleb.take_paint()\ncaleb.take_paint()\n\ncaleb.move()\ncaleb.paint(\"SeaGreen\")\ncaleb.move()\ncaleb.paint(\"SeaGreen\")\ncaleb.move()\ncaleb.paint(\"SeaGreen\")",
