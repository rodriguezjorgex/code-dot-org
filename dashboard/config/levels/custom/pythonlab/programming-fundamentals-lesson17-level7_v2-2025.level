    "validation_file": {
      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\n\nclass TestPotionCost(unittest.TestCase):\n\n    def test_modify_potion_cost(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Check if the potion cost is updated to 3 in the while loop\n            if 'ingredients -= 3' not in content:\n                self.fail(\n                    \"The potion cost has not been updated to 3 ingredients. \"\n                    \"Please change the line `ingredients -= 2` to `ingredients -= 3` so that each potion costs 3 ingredients.\"\n                )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
