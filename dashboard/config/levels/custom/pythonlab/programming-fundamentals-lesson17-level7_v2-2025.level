    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "ingredients = 12  # You start with 12 ingredients\npotions = 0       # Start with 0 potions\n\n# Each potion costs 2 ingredients\nwhile ingredients >= 2:\n    potions += 1\n    ingredients -= 2\n    print(\"You made a potion! Total potions:\", potions)\n\nprint(\"You ran out of ingredients!\")",
          "folderId": "0",
          "active": true,
          "open": true
        }
      },
