          "name": "main.py",
          "language": "py",
          "contents": "# Modify the code below to create a new companion for your main character\ndef create_companion(name, type):\n    print(\"✨ You have a new companion!\")\n    print(\"🐾 Meet \" + name + \", a loyal \" + type + \" who will join you on your adventure!\")\n\n# Example Calls:\ncreate_companion(\"Luna\", \"magical cat\")\ncreate_companion(\"Sparky\", \"robotic dog\")\n",
