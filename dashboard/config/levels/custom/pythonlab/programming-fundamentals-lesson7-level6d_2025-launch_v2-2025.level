          "language": "py",
          "contents": "from neighborhood import Painter\n\n# TODO - Add a parameter for this_painter\ndef take_four_paint():\n  # TODO - Modify the function to use this_painter\n  mika.take_paint()\n  mika.take_paint()\n  mika.take_paint()\n  mika.take_paint()\n\n# TODO - Add a parameter for this_painter\ndef paint_then_move():\n  # TODO - Modify the function to use this_painter\n  luca.paint(\"CadetBlue\")\n  luca.move()\n  luca.paint(\"CadetBlue\")\n  luca.move()\n  luca.paint(\"CadetBlue\")\n  luca.move()\n  luca.paint(\"CadetBlue\")\n\nmika = Painter()\nluca = Painter()\n\nmika.turn_left()\nmika.turn_left()\nmika.turn_left()\n\nmika.move()\n\n# TODO - Call the take_four_paint() function with mika\ntake_four_paint()\n\n# TODO - Call the paint_then_move() function with mika\nmika.paint(\"CadetBlue\")\nmika.move()\nmika.paint(\"CadetBlue\")\nmika.move()\nmika.paint(\"CadetBlue\")\nmika.move()\nmika.paint(\"CadetBlue\")\n\nmika.move()\n\nmika.turn_left()\n\nmika.move()\nmika.move()\nmika.move()\nmika.move()\n\n# TODO - Call the take_four_paint() function with mika\ntake_four_paint()\n\nmika.paint(\"CadetBlue\")\nmika.move()\nmika.paint(\"CadetBlue\")\n\nmika.turn_left()\n\nmika.move()\nmika.paint(\"CadetBlue\")\nmika.move()\nmika.paint(\"CadetBlue\")\n\nluca.turn_left()\nluca.turn_left()\nluca.turn_left()\n\nluca.move()\nluca.move()\nluca.move()\nluca.move()\nluca.move()\n\n# TODO - Call the take_four_paint() function with luca\nluca.take_paint()\nluca.take_paint()\nluca.take_paint()\nluca.take_paint()\n\nluca.turn_left()\n\n# TODO - Call the paint_then_move() function with luca\npaint_then_move()",
