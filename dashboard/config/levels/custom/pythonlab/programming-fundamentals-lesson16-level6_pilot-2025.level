      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\nimport ast\n\nclass TestGreetUserCall(unittest.TestCase):\n\n    def test_function_called(self):\n        \"\"\"Call the function greet_user() at the end of your program.\"\"\"\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Parse the file into an AST (Abstract Syntax Tree)\n            tree = ast.parse(content)\n\n            # Look for function call `greet_user()`\n            function_called = any(\n                isinstance(node, ast.Expr) and\n                isinstance(node.value, ast.Call) and\n                isinstance(node.value.func, ast.Name) and\n                node.value.func.id == \"greet_user\"\n                for node in ast.walk(tree)\n            )\n\n            if not function_called:\n                self.fail(\"The function `greet_user()` was not called in `main.py`. \"\n                          \"Please ensure you call it at the end of your script.\")\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
