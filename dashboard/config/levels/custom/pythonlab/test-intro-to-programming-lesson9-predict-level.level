          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\n\nella = Painter()\n\nwhile ella.can_move(\"East\"):\n  ella.move()\n  ella.paint(\"yellow\")\nella.turn_left()\nella.turn_left()\nella.turn_left()\nella.move()\nella.paint(\"blue\")\n",
