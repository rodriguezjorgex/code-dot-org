VYtYLjm23vyP2nNDmuDfGfFnoF4Dac=\n",
    "display_name": "Same Moves, New Painter",
    "bubble_choice_description": "Update the functions to use a `this_painter` parameter so the `Painter`s can share the same instructions without repeating code.",
    "thumbnail_url": "https://images.code.org/f496b9310f332da74d1ccf289cf0f220-choiceC.gif",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "import inspect\nfrom unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPainterTakeAndPaintThree(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Set up validation and get logs\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs or len(cls.log.painter_logs) < 2:\n            cls.first_painter = None\n            cls.second_painter = None\n        else:\n            cls.first_painter = cls.log.painter_logs[0]\n            cls.second_painter = cls.log.painter_logs[1]\n\n    def setUp(self):\n        if self.first_painter is None or self.second_painter is None:\n            self.skipTest(\"Two Painters should be created and used in this program.\")\n\n    def test_take_three_paint_has_one_parameter(self):\n        \"\"\"take_three_paint should accept exactly one parameter\"\"\"\n        from main import take_three_paint\n        params = inspect.signature(take_three_paint).parameters\n        self.assertEqual(\n            len(params),\n            1,\n            \"The function take_three_paint should have exactly one parameter (this_painter).\"\n        )\n\n    def test_paint_three_has_one_parameter(self):\n        \"\"\"paint_three should accept exactly one parameter\"\"\"\n        from main import paint_three\n        params = inspect.signature(paint_three).parameters\n        self.assertEqual(\n            len(params),\n            1,\n            \"The function paint_three should have exactly one parameter (this_painter).\"\n        )\n\n    def test_first_painter_final_position(self):\n        \"\"\"First Painter ends at (5, 4)\"\"\"\n        self.assertEqual(\n            (self.first_painter.ending_position.x, self.first_painter.ending_position.y),\n            (5, 4),\n            \"The first Painter didn't stop at (5, 4). Check your function calls and path logic.\"\n        )\n\n    def test_second_painter_final_position(self):\n        \"\"\"Second Painter ends at (6, 4)\"\"\"\n        self.assertEqual(\n            (self.second_painter.ending_position.x, self.second_painter.ending_position.y),\n            (6, 4),\n            \"The second Painter didn't stop at (6, 4). Check your function calls and path logic.\"\n        )\n\n    def test_correct_spaces_are_painted(self):\n        \"\"\"Painters painted the expected spaces\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n\n        painted_spaces = [\n            (1, 0), (2, 0), (3, 0),\n            (3, 1), (3, 2), (3, 3), (3, 4),\n            (4, 4), (5, 4),\n            (6, 4), (6, 3), (6, 2)\n        ]\n\n        for x, y in painted_spaces:\n            expected_output[y][x] = True\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"Not all expected spaces were painted. Make sure the Painters correctly painted the full path using the reusable functions.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
