          "language": "py",
          "contents": "from neighborhood import Painter\n\n# TODO - Add a parameter for this_painter\ndef take_three_paint():\n  # TODO - Modify the function to use this_painter\n  fiona.take_paint()\n  fiona.take_paint()\n  fiona.take_paint()\n\n# TODO - Add a parameter for this_painter\ndef paint_three():\n  # TODO - Modify the function to use this_painter\n  selena.paint(\"SteelBlue\")\n  selena.move()\n  selena.paint(\"SteelBlue\")\n  selena.move()\n  selena.paint(\"SteelBlue\")\n\nfiona = Painter()\nselena = Painter()\n\nfiona.move()\n\n# TODO - Call the take_three_paint() function with fiona\ntake_three_paint()\n\n# TODO - Call the paint_three() function with fiona\nfiona.paint(\"SteelBlue\")\nfiona.move()\nfiona.paint(\"SteelBlue\")\nfiona.move()\nfiona.paint(\"SteelBlue\")\n\nfiona.turn_left()\nfiona.turn_left()\nfiona.turn_left()\n\nfiona.move()\nfiona.move()\nfiona.move()\nfiona.move()\n\n# TODO - Call the take_three_paint() function with fiona\ntake_three_paint()\n\nfiona.turn_left()\n\n# TODO - Call the paint_three() function with fiona\nfiona.paint(\"SteelBlue\")\nfiona.move()\nfiona.paint(\"SteelBlue\")\nfiona.move()\nfiona.paint(\"SteelBlue\")\n\nselena.move()\nselena.move()\nselena.move()\n\nselena.turn_left()\nselena.turn_left()\nselena.turn_left()\n\nselena.move()\n\n# TODO - Call the take_three_paint() function with selena\nselena.take_paint()\nselena.take_paint()\nselena.take_paint()\n\n# TODO - Call the paint_three() function with selena\npaint_three()\n\nselena.move()\n\nselena.turn_left()\n\nselena.move()\nselena.move()\nselena.move()\n\nselena.turn_left()\n\nselena.move()\nselena.move()\n\n# TODO - Call the take_three_paint() function with selena\nselena.take_paint()\nselena.take_paint()\nselena.take_paint()\n\nselena.turn_left()\nselena.turn_left()\n\n# TODO - Call the paint_three() function with selena\npaint_three()",
