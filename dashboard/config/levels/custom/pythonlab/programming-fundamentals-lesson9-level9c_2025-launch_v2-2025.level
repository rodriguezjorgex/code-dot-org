    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestKeepPaintingAndNextRow(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (3, 7)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (3, 7),\n            \"The Painter didn't stop at (3, 7). Check that keep_painting() and move_to_next_row() worked together correctly.\"\n        )\n\n    def test_correct_spaces_are_painted(self):\n        \"\"\"Painter painted expected spaces\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n\n        painted_tiles = [\n            (8, 3), (9, 3), (10, 3),\n            (8, 4), (9, 4), (10, 4),\n            (3, 7), (3, 8), (3, 9),\n            (4, 7), (4, 8), (4, 9)\n        ]\n\n        for x, y in painted_tiles:\n            expected_output[y][x] = True\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"The expected spaces weren't all painted. Make sure the Painter is painting and transitioning rows correctly.\"\n        )\n\n    def test_moves_and_turns(self):\n        \"\"\"Painter moved and turned multiple times\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"MOVE\"),\n            15,\n            \"The Painter didn’t move enough. Make sure loops and transitions are fully executed.\"\n        )\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            4,\n            \"The Painter didn't turn enough times. Make sure turn_left() and turn_right() are used in move_to_next_row().\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
