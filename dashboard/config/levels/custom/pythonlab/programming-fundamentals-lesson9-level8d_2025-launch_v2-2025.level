    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPaintDiagonal(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (11, 11)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (11, 11),\n            \"The Painter didn't stop at (11, 11). Make sure your paint_diagonal() logic completes the full path.\"\n        )\n\n    def test_painted_diagonal_tiles(self):\n        \"\"\"Painter paints diagonal from (0,0) to (11,11)\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n        for i in range(12):  # From (0,0) to (11,11)\n            expected_output[i][i] = True\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"The diagonal spaces (0,0) to (11,11) weren't all painted. Make sure paint_diagonal() works for both east and south directions.\"\n        )\n\n    def test_movement_and_turns(self):\n        \"\"\"Painter moves and turns enough to complete the diagonal\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"MOVE\"),\n            12,\n            \"The Painter didn't move enough to reach the end of the diagonal.\"\n        )\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            10,\n            \"The Painter didn't turn often enough. Make sure you're changing direction after each diagonal step.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
