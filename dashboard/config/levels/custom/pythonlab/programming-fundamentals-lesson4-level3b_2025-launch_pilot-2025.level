      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestStepGoalTracker(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get the printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_step_goal_exists_and_is_integer(self):\n      \"\"\"A variable called step_goal should exist and be an integer\"\"\"\n      namespace = {}\n      with open(\"main.py\", \"r\") as f:\n          code = f.read()\n          exec(code, namespace)\n  \n      self.assertIn('step_goal', namespace, \"Make sure you define step_goal!\")\n  \n      self.assertIsInstance(\n          namespace['step_goal'],\n          int,\n          \"step_goal should be an integer!\"\n      )\n\n    def test_step_goal_in_output(self):\n        \"\"\"Printed message should include the step_goal\"\"\"\n        try:\n            from main import step_goal\n        except ImportError:\n            self.fail(\"Make sure you create a variable called step_goal!\")\n\n        printed_lines = [line.strip() for line in self.log if line.strip()]\n\n        found = any(str(step_goal) in line for line in printed_lines)\n\n        self.assertTrue(\n            found,\n            \"Make sure your printed message includes the step goal number!\"\n        )\n",
