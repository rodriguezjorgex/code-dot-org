    "display_name": "Stop and Scoop",
    "bubble_choice_description": "The `Painter` is cruising down the street, but it doesn't know when to stop for paint! Help the `Painter` make smart decisions by writing a function that checks if it's on a paint bucket. If it is, it should take the paint; if not, it should keep moving.",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestTakeOrMove(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter object was created. Make sure to create a Painter in your code.\")\n\n    def test_checks_if_on_bucket(self):\n        \"\"\"Painter calls is_on_bucket() at least once\"\"\"\n        self.assertGreater(\n            self.painter.action_count(\"IS_ON_BUCKET\"),\n            0,\n            \"The Painter never checked if it was on a bucket. Make sure you're calling is_on_bucket() in your take_or_move() function.\"\n        )\n\n    def test_final_position_is_correct(self):\n        \"\"\"Painter ends at (7, 0) after collecting and moving\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (7, 0),\n            \"The Painter didn't stop at (7, 0). Make sure they keep moving until they can’t anymore.\"\n        )\n\n    def test_painter_collected_all_paint(self):\n        \"\"\"Painter ends with exactly 13 units of paint\"\"\"\n        self.assertEqual(\n            self.painter.ending_paint_count,\n            13,\n            \"The Painter should end with 13 units of paint. Make sure you're checking for buckets and taking paint correctly in take_or_move().\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
