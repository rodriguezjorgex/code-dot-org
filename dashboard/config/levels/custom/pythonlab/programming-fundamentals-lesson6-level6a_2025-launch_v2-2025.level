      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPrepareStreamFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_camera_and_streaming_tool_started(self):\n        \"\"\"prepare_stream() should call both setup functions\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertGreaterEqual(\n            len(printed_messages),\n            2,\n            \"Make sure your prepare_stream() function calls both activate_camera() and open_streaming_tool()!\"\n        )\n\n        camera_started = any(\"Camera is now on\" in line for line in printed_messages)\n        streaming_tool_ready = any(\"Streaming tool is ready\" in line for line in printed_messages)\n\n        self.assertTrue(\n            camera_started,\n            \"It looks like activate_camera() wasn't called. Make sure your prepare_stream() function calls activate_camera().\"\n        )\n\n        self.assertTrue(\n            streaming_tool_ready,\n            \"It looks like open_streaming_tool() wasn't called. Make sure your prepare_stream() function calls open_streaming_tool().\"\n        )\n",
