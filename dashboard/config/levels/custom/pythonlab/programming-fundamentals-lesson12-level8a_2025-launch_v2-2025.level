    "thumbnail_url": "https://images.code.org/6d30c7e89f38fcd0e3b926e7ae6d71ac-choiceA.gif",
    "display_name": "Paint or Pivot",
    "bubble_choice_description": "The `Painter` is making its way through The Neighborhood and wants to leave a trail behind, but only when it has paint! If the `Painter` runs out, it needs to turn right to find the next paint bucket. Write a function that helps the `Painter` decide what to do each time its facing east.",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPaintOrTurn(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position_is_correct(self):\n        \"\"\"Painter ends at (6, 1) after painting and turning\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (6, 1),\n            \"The Painter didn't stop at (6, 1). Make sure your paint_or_turn() function turns the Painter when it runs out of paint.\"\n        )\n\n    def test_expected_spaces_are_painted(self):\n        \"\"\"Painter paints (1,0), (2,0), (3,0), (4,1), and (5,1)\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n        expected_output[0][1] = True  # (1, 0)\n        expected_output[0][2] = True  # (2, 0)\n        expected_output[0][3] = True  # (3, 0)\n        expected_output[1][4] = True  # (4, 1)\n        expected_output[1][5] = True  # (5, 1)\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"The expected spaces weren't all painted. Make sure your function paints when it has paint and turns otherwise.\"\n        )\n\n    def test_turns_right_when_out_of_paint(self):\n        \"\"\"Painter turns right when it can't paint anymore\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            3,\n            \"The Painter didn't turn right after running out of paint. Make sure to call turn_right() when paint runs out.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
