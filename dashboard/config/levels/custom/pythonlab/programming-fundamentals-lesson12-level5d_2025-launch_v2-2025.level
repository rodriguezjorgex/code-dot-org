    "display_name": "Paint It or Pass It",
    "bubble_choice_description": "The `Painter` is following a path and wants to leave a trail of paint, but only if it has paint! If the `Painter` is out of paint, it should just keep moving.",
    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPaintOrMove(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position_is_correct(self):\n        \"\"\"Painter ends at (7, 7) after painting and moving\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (7, 7),\n            \"The Painter didn't stop at (7, 7). Make sure they navigate all paths using paint_or_move().\"\n        )\n\n    def test_specific_spaces_are_painted(self):\n        \"\"\"Painter paints spaces (2,0), (2,5), and (7,5)\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n        expected_output[0][2] = True  # (2,0)\n        expected_output[5][2] = True  # (2,5)\n        expected_output[5][7] = True  # (7,5)\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"The expected spaces (2,0), (2,5), and (7,5) weren't all painted. Make sure you're using paint_or_move() correctly with the paint color.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
