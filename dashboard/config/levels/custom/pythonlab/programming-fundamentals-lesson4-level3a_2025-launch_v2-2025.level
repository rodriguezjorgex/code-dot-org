      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestUsernameWelcome(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get the printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_username_variable_exists_and_is_string(self):\n        \"\"\"A variable called username should exist and be a string\"\"\"\n        try:\n            from main import username\n        except ImportError:\n            self.fail(\"Make sure you create a variable called username!\")\n\n        self.assertIsInstance(\n            username,\n            str,\n            \"The username variable should be a string (inside quotes)!\"\n        )\n\n    def test_username_in_welcome_message(self):\n        \"\"\"Printed message should include the username\"\"\"\n        try:\n            from main import username\n        except ImportError:\n            self.fail(\"Make sure you create a variable called username!\")\n\n        printed_lines = [line.strip() for line in self.log if line.strip()]\n\n        # Check if any printed line contains the username\n        found = any(username in line for line in printed_lines)\n\n        self.assertTrue(\n            found,\n            \"Make sure your printed message includes the username!\"\n        )\n",
