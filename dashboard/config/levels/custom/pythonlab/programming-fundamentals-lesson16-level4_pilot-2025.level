    "validation_file": {
      "id": "1",
      "name": "test_main.py",
      "language": "py",
      "contents": "import unittest\nimport ast\n\nclass TestCollectUserData(unittest.TestCase):\n\n    def test_input_prompt_modified(self):\n        try:\n            with open('main.py', 'r') as f:\n                content = f.read()\n\n            # Parse the file into an AST (Abstract Syntax Tree)\n            tree = ast.parse(content)\n\n            # Find all function calls\n            input_statements = [\n                node for node in ast.walk(tree)\n                if isinstance(node, ast.Call) and\n                isinstance(node.func, ast.Name) and node.func.id == \"input\"\n            ]\n\n            # Ensure there are at least two input() calls (one for name, one for color)\n            if len(input_statements) < 2:\n                self.fail(\n                    \"The function `collect_user_data()` must contain two `input()` statements. \"\n                    \"Ensure one asks for the user's name and the other for their favorite color.\"\n                )\n\n            # Extract the second input() function's argument (color prompt)\n            second_input_prompt = input_statements[1].args[0] if input_statements[1].args else None\n\n            # Ensure the prompt is a non-empty string\n            if not isinstance(second_input_prompt, ast.Str) or second_input_prompt.s.strip() == \"\":\n                self.fail(\n                    \"The second `input()` prompt is still empty. \"\n                    \"Please modify it to ask for the user's favorite color.\"\n                )\n\n        except FileNotFoundError:\n            self.fail(\"The file 'main.py' was not found. Please make sure it exists in the same directory.\")\n        except Exception as e:\n            self.fail(f\"Error running the test: {e}\")\n\nif __name__ == \"__main__\":\n    unittest.main()\n",
