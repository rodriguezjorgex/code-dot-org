          "contents": "def collect_user_data():\n    name = input(\"What is your name? \")\n    color = input(\"\") # Change this prompt to ask for the user's favorite color\n    print(\"Hello, \" + name + \"! Your favorite color is \" + age + \".\")\n    \ncollect_user_data()",
