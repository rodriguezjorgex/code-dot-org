    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestIsOnBucketLoop(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (6, 0)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (6, 0),\n            \"The Painter didn't stop at (6, 0). Make sure the loop to collect paint works before painting the path.\"\n        )\n\n    def test_painted_expected_spaces(self):\n        \"\"\"Spaces (1,0) to (5,0) are painted\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n        for x in range(1, 6):\n            expected_output[0][x] = True\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"The expected spaces (1,0) to (5,0) should be painted. Make sure paint and move commands follow the paint collection.\"\n        )\n\n    def test_used_is_on_bucket(self):\n        \"\"\"Painter checked if it was on a bucket\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"IS_ON_BUCKET\"),\n            1,\n            \"The Painter never checked if it was on a bucket. Make sure you're using a while loop with is_on_bucket() as the condition.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
