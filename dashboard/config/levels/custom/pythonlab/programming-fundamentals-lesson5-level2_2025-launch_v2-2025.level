    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestBasicPainterMove(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter using painter_name = Painter()!\")\n\n    def test_painter_moved_once(self):\n        \"\"\"The Painter should move forward once\"\"\"\n        move_count = self.painter.action_count(\"MOVE\")\n\n        self.assertEqual(\n            move_count,\n            1,\n            \"Make sure your Painter moves exactly once using move().\"\n        )\n",
      "folderId": "0",
      "active": false,
