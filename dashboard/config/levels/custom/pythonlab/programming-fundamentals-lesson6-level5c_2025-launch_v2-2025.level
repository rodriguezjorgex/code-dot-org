      "name": "test.py",
      "language": "py",
      "contents": "import re\nfrom unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestSnackSplitterFunction(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Get printed output log\"\"\"\n        cls.log = ValidationProtocol().get_stdout_logs()\n\n    def test_cookies_divided_reasonably(self):\n        \"\"\"snack_splitter() should print a reasonable cookies-per-person number\"\"\"\n        printed_messages = [line.strip() for line in self.log if line.strip()]\n\n        self.assertGreaterEqual(\n            len(printed_messages),\n            1,\n            \"Make sure your snack_splitter() function prints a message showing how cookies are shared!\"\n        )\n\n        # Try to find a number in the printed text\n        number_found = False\n        for line in printed_messages:\n            numbers = re.findall(r'\\d+\\.?\\d*', line)\n            for num in numbers:\n                value = float(num)\n                if 0 < value < 12:\n                    number_found = True\n                    break\n            if number_found:\n                break\n\n        self.assertTrue(\n            number_found,\n            \"Make sure your calculation makes sense: each person should get some cookies, but not more than 12!\"\n        )\n",
