        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\nfrom custom import turn_right, take_all_paint, paint_until_empty\n\ntifa = Painter()\n\nturn_right(tifa)\ntifa.move()\ntake_all_paint(tifa)\ntifa.turn_left()\npaint_until_empty(tifa, \"blue\")\n\n# TODO - Write an if statement to turn right and move forward if on paint\n\n\n",
          "folderId": "0",
          "active": false,
          "open": true,
          "type": "locked_starter"
        },
        "2": {
          "id": "2",
          "name": "custom.py",
          "language": "py",
          "contents": "def turn_right(this_painter):\n  this_painter.turn_left()\n  this_painter.turn_left()\n  this_painter.turn_left()\n\ndef take_all_paint(this_painter):\n  while this_painter.is_on_bucket():\n    this_painter.take_paint()\n\ndef paint_until_empty(this_painter, color):\n  while this_painter.has_paint():\n    this_painter.move()\n    this_painter.paint(color)",
          "folderId": "0",
          "active": false,
          "open": true
