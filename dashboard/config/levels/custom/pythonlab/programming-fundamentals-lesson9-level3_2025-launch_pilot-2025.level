    "validation_file": {
      "id": "4",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestOnPaintTurn(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position_and_direction(self):\n        \"\"\"Painter ends at (5, 2) facing south\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y, self.painter.ending_position.direction),\n            (5, 2, \"south\"),\n            \"The Painter should end at (5, 2) facing south. Make sure your if statement checks is_on_paint() before turning and moving.\"\n        )\n\n    def test_expected_path_is_painted(self):\n        \"\"\"Painter paints tiles (1,1) through (5,1)\"\"\"\n        final = self.log.final_output\n        expected_output = [[False for _ in range(len(final[0]))] for _ in range(len(final))]\n        for x in range(1, 6):\n            expected_output[1][x] = True  # row 1, columns 1 to 5\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"The tiles (1,1) to (5,1) should be painted. Make sure your paint_until_empty() loop works as expected.\"\n        )\n\n    def test_turns_right_if_on_paint(self):\n        \"\"\"Painter makes a right turn if on paint (inferred from turn_left calls)\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            3,\n            \"The Painter didn't turn right. Make sure the if statement runs only if the Painter is on paint.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
