    "validation_file": {
      "id": "2",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestTurnAroundIfFacingEast(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and cache the results\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (6, 6)\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (6, 6),\n            \"The Painter didn't stop at (6, 6). Make sure the movement and turn_around() logic are correct.\"\n        )\n\n    def test_direction_changed(self):\n        \"\"\"Painter is no longer facing east after turning around\"\"\"\n        self.assertNotEqual(\n            self.painter.ending_position.direction,\n            \"east\",\n            \"The Painter is still facing east. Make sure you use two left turns when the Painter is facing east.\"\n        )\n\n    def test_turns_at_least_two_left(self):\n        \"\"\"Painter made at least two left turns\"\"\"\n        self.assertGreaterEqual(\n            self.painter.action_count(\"TURN_LEFT\"),\n            2,\n            \"The Painter didn’t turn around. Make sure to use two left turns when facing east.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
