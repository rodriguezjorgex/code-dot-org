    "thumbnail_url": "https://images.code.org/ae25db1a5ea932bf0ebc4b3a94fc7ee7-choiceB.gif",
    "validation_file": {
      "id": "4",
      "name": "test.py",
      "language": "py",
      "contents": "from unittest import TestCase\nfrom unittest_runner import ValidationProtocol\n\nclass TestPainterPaintsCorrectSpaces(TestCase):\n    @classmethod\n    def setUpClass(cls):\n        \"\"\"Run the student's code once and save the log for all tests\"\"\"\n        cls.log = ValidationProtocol().get_neighborhood_log()\n        if not cls.log.painter_logs:\n            cls.painter = None\n        else:\n            cls.painter = cls.log.painter_logs[0]\n\n    def setUp(self):\n        if self.painter is None:\n            self.skipTest(\"No Painter was created. Make sure to create a Painter in your code.\")\n\n    def test_specific_spaces_have_paint(self):\n        \"\"\"Spaces (1,1), (2,1), and (3,1) are painted\"\"\"\n        grid_size = 10\n        expected_output = [[False for _ in range(grid_size)] for _ in range(grid_size)]\n        expected_output[1][1] = True\n        expected_output[1][2] = True\n        expected_output[1][3] = True\n\n        self.assertTrue(\n            self.log.final_output_contains_paint(expected_output),\n            \"The expected spaces (1,1), (2,1), and (3,1) weren't all painted. Make sure you're painting while the Painter still has paint.\"\n        )\n\n    def test_moves_beyond_paint(self):\n        \"\"\"Painter continues moving after running out of paint\"\"\"\n        self.assertGreater(\n            self.painter.action_count(\"MOVE\"),\n            3,\n            \"The Painter seems to stop after using up all paint. Add an else so they keep moving even without paint.\"\n        )\n\n    def test_final_position(self):\n        \"\"\"Painter ends at (9,1) after completing all moves\"\"\"\n        self.assertEqual(\n            (self.painter.ending_position.x, self.painter.ending_position.y),\n            (9, 1),\n            \"The Painter didn't stop at (9,1). Check your loop logic to ensure they move until they can't anymore.\"\n        )\n",
      "folderId": "0",
      "active": false,
      "open": false,
      "type": "validation"
    }
  },
