    "start_sources": {
      "files": {
        "0": {
          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\nfrom custom import turn_right, take_all_paint\n\nellie = Painter()\n\nellie.move()\nturn_right(ellie)\nellie.move()\ntake_all_paint(ellie)\nellie.turn_left()\n\nwhile ellie.can_move():\n  if ellie.has_paint():\n    ellie.paint(\"green\")\n    ellie.move()\n  # TODO - Add an else statement so the Painter moves forward if it doesn't have paint\n  ellie.move()",
          "folderId": "0",
          "active": false,
          "open": true,
          "type": "locked_starter"
        },
        "2": {
          "id": "2",
          "name": "custom.py",
          "language": "py",
          "contents": "def turn_right(this_painter):\n  this_painter.turn_left()\n  this_painter.turn_left()\n  this_painter.turn_left()\n\ndef take_all_paint(this_painter):\n  while this_painter.is_on_bucket():\n    this_painter.take_paint()",
          "folderId": "0",
          "active": false,
          "open": true
        }
      },
