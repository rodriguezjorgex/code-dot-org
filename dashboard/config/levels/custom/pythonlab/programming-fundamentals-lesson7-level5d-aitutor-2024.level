          "id": "0",
          "name": "main.py",
          "language": "py",
          "contents": "from neighborhood import Painter\n\njoy = Painter()\n\ndef paint_step():\n    joy.painter(\"red\")\n    joy.move()\n    joy.pant(\"green\")  \n\npaint_step()\n",
          "folderId": "0",
          "active": false,
