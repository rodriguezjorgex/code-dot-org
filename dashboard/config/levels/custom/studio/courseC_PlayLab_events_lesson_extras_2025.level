    "authored_hints": "[{\"hint_class\":\"content\",\"hint_markdown\":\"You can use this block to move actors to different places on the game space.\\n\\n<xml> <block type=\\\"studio_setSpritePosition\\\">\\n    <title name=\\\"SPRITE\\\">0</title>\\n    <title name=\\\"VALUE\\\">12</title>\\n  </block></xml>\\n\",\"hint_id\":\"courseC_PlayLab_events_challenge_a\",\"hint_type\":\"general\",\"tts_url\":\"https://tts.code.org/sharon22k/180/100/e04de3d99bd4414762944ae365b63c98/courseC_PlayLab_events_challenge1_2018.mp3\"},{\"hint_class\":\"content\",\"hint_markdown\":\"Try using `set actor 1 to the middle left position` when it touches either of the other actors. This will reset the game so the player can keep trying!\",\"hint_id\":\"courseC_PlayLab_events_challenge_b\",\"hint_type\":\"general\",\"tts_url\":\"https://tts.code.org/sharon22k/180/100/0f406cffbbf52c91d941af46cb56967b/courseC_PlayLab_events_challenge1_2018.mp3\"},{\"hint_class\":\"content\",\"hint_markdown\":\"You might also want to try changing the speed of the different actors to make the game easier or more challenging!\\n\\n<xml>  <block type=\\\"studio_setSpriteSpeed\\\">\\n    <title name=\\\"SPRITE\\\">0</title>\\n    <title name=\\\"VALUE\\\">Studio.SpriteSpeed.FAST</title>\\n  </block></xml>\",\"hint_id\":\"courseC_PlayLab_events_challenge_c\",\"hint_type\":\"general\",\"tts_url\":\"https://tts.code.org/sharon22k/180/100/b1032e6d0b69ef884ce1184c0a2261a8/courseC_PlayLab_events_challenge1_2018.mp3\"}]",
    "instructions_important": "false",
