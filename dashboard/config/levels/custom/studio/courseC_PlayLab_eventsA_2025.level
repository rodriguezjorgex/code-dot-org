  <blocks>
    <start_blocks>
      <xml xmlns="https://developers.google.com/blockly/xml">
        <block type="when_run" deletable="false" movable="false" x="16" y="16"/>
        <block type="studio_whenUp" deletable="false" x="16" y="120">
          <next>
            <block type="studio_move">
              <field name="SPRITE">0</field>
              <field name="DIR">1</field>
            </block>
          </next>
        </block>
        <block type="studio_whenLeft" deletable="false" x="240" y="120">
          <next>
            <block type="studio_move">
              <field name="SPRITE">0</field>
              <field name="DIR">8</field>
            </block>
          </next>
        </block>
        <block type="studio_whenDown" deletable="false" x="16" y="200">
          <next>
            <block type="studio_move">
              <field name="SPRITE">0</field>
              <field name="DIR">4</field>
            </block>
          </next>
        </block>
        <block type="studio_whenRight" deletable="false" x="240" y="200">
          <next>
            <block type="studio_move">
              <field name="SPRITE">0</field>
              <field name="DIR">2</field>
            </block>
          </next>
        </block>
        <block type="studio_repeatForever" x="16" y="296">
          <statement name="DO">
            <block type="studio_moveDistance">
              <field name="SPRITE">1</field>
              <field name="DIR">1</field>
              <field name="DISTANCE">400</field>
              <next>
                <block type="studio_moveDistance">
                  <field name="SPRITE">1</field>
                  <field name="DIR">4</field>
                  <field name="DISTANCE">400</field>
                </block>
              </next>
            </block>
          </statement>
        </block>
        <block type="studio_whenSpriteCollided" x="16" y="420">
          <field name="SPRITE1">0</field>
          <field name="SPRITE2">1</field>
          <next>
            <block type="studio_saySpriteChoices">
              <field name="SPRITE">0</field>
              <field name="VALUE">Ouch!</field>
              <next>
                <block type="studio_playSound">
                  <field name="SOUND">hit</field>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="studio_whenSpriteCollided" x="300" y="420">
          <field name="SPRITE1">0</field>
          <field name="SPRITE2">2</field>
          <next>
            <block type="studio_changeScore">
              <field name="VALUE">1</field>
            </block>
          </next>
        </block>
      </xml>
