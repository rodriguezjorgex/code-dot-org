  "properties": {
    "encrypted": "false",
    "long_instructions": "#### Wherever, Whenever\r\n\r\nThis is an example of an \"Only What You Gave Me\" remix, where tracks from the original song are used in new and interesting ways to change how the song sounds and feels. As you listen, consider the following:\r\n\r\n- Notice how the song uses vocals as the \"background\" instead of more traditional instruments. How does this make the song \"feel\"?\r\n- Notice how the same chorus vocals are used as the song continues, but they overlap or the order changes. How does this change how the song \"feels\"?",
    "offer_browser_tts": "true",
    "use_secondary_finish_button": "false",
    "hide_share_and_remix": "true",
