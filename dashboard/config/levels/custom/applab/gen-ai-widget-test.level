    "start_blocks": "// Character Quiz App Lab logic (ES5 only)\n\nvar DEBUG = true;\n\n//MODEL\nvar predefined = [\n  [\"Good\", \"Evil\"],\n  [\"Funny\", \"Serious\"],\n  [\"Brave\", \"Timid\"],\n  [\"Outgoing\", \"Shy\"],\n  [\"Stubborn\", \"Quitter\"]\n];\n\n// ratings[0] = predefined (5), ratings[1] = custom (2)\nvar ratings = [\n  [-1, -1, -1, -1, -1],\n  [-1, -1]\n];\n\nvar characterObject = {};\ncharacterObject.myCharacter = {};\ncharacterObject.comparisonCharacters = [];\nvar STATE = 0;\n\nvar DESCRIPTIONTEXT = {\n  0: \"Choose a character you are familiar with and enter their name below. For each trait pair, click a number (1 = left trait, 10 = right trait). Then add two traits of your own and rate them.\",\n  1: \"Now it's time for someone else in the class to enter their character information! Have them type in their character name and select all of the traits that match their character. When they're done, they can press the 'Next Character' button and another class member can try. When at least 3 characters have been entered, press the 'Ready For Part 3' Button!\",\n  2: \"Now we can compare characters! Which ones are most similar? Which are most different?\"\n};\n\nvar TITLETEXT = {\n  0: \"Character Quiz - Part 1\",\n  1: \"Character Quiz - Part 2\",\n  2: \"Character Quiz - Part 3\"\n};\n\nvar BUTTONTEXT = {\n  0: \"Ready For Part 2!\",\n  1: \"Ready for Part 3!\",\n  2: \"Finished!\"\n};\n\nvar CHARACTERVISIBILITY = {\n  0: false,\n  1: true,\n  2: false\n};\n\nvar BACKVISIBILITY = {\n  0: false,\n  1: true,\n  2: true\n};\n\nvar BLOCKVISIBILITY = {\n  0: false,\n  1: true,\n  2: true\n};\n\nupdateView();\n\n//SETUP FUNCTIONS - STATE INDEPENDENT\n\n// Helper to color-code selected buttons in a row\nfunction markSelected(prefix, choice) {\n  for (var i = 1; i <= 10; i++) {\n    var id = prefix + i;\n    var color = i === choice ? \"#4caf50\" : \"#f8f8f8\";\n    setProperty(id, \"background-color\", color);\n    setProperty(id, \"text-color\", \"black\");\n  }\n}\n\n// Attach handlers for predefined trait buttons\nfor (var r = 0; r < 5; r++) {\n  for (var n = 1; n <= 10; n++) {\n    (function(row, num) {\n      onEvent(\"btn\" + row + \"_\" + num, \"click\", function() {\n        ratings[0][row] = num;\n        markSelected(\"btn\" + row + \"_\", num);\n      });\n    })(r, n);\n  }\n}\n\n// Attach handlers for custom trait buttons\nfor (var c = 1; c <= 2; c++) {\n  for (var m = 1; m <= 10; m++) {\n    (function(row, num) {\n      onEvent(\"btnC\" + row + \"_\" + num, \"click\", function() {\n        ratings[1][row - 1] = num;\n        markSelected(\"btnC\" + row + \"_\", num);\n      });\n    })(c, m);\n  }\n}\n\n\n\nfunction saveCharacter() {\n  var charName = getText(\"characterNameInput\").trim();\n  /*\n  if (getText(\"characterNameInput\").trim() === \"\") {\n    console.log(\"Please enter a character name.\");\n    return;\n  }\n  */\n\n  var result = { character: charName };\n\n  // Predefined\n  for (var i = 0; i < 5; i++) {\n    result[predefined[i][0] + \"-\" + predefined[i][1]] = ratings[0][i];\n  }\n\n  // Custom traits\n  for (var j = 1; j <= 2; j++) {\n    var leftText = getText(\"customLeft\" + j).trim() || (\"CustomLeft\" + j);\n    var rightText = getText(\"customRight\" + j).trim() || (\"CustomRight\" + j);\n    result[leftText + \"-\" + rightText] = ratings[1][j - 1];\n  }\n  \n  //State 0: saving original character\n  //State 1: saving a new comparison character\n  if(STATE == 0) {\n    characterObject.myCharacter = result;\n  }\n  if(STATE == 1) {\n    characterObject.comparisonCharacters.push(result);\n  }\n  if(DEBUG) {\n    console.log(characterObject);\n  }\n}\n \nfunction updateState(elt) {\n  if(elt == \"mainButton\") {\n    if(STATE != 2) {\n      STATE++;\n    }\n  }\n  if(elt == \"backButton\") {\n    if(STATE != 0) {\n      STATE--;\n    }\n  }\n  \n  //no action for characterButton\n  \n  updateView();\n}\n\n\nfunction updateView() {\n  setText(\"titleLabel\", TITLETEXT[STATE]);\n  setText(\"descriptionLabel\", DESCRIPTIONTEXT[STATE]);\n  setText(\"mainButton\", BUTTONTEXT[STATE]);\n  if(CHARACTERVISIBILITY[STATE]) {\n    showElement(\"characterButton\");\n  } else {\n    hideElement(\"characterButton\");\n  }\n  if(BACKVISIBILITY[STATE]) {\n    showElement(\"backButton\");\n  } else {\n    hideElement(\"backButton\");\n  }\n  if(BLOCKVISIBILITY[STATE]) {\n    showElement(\"leftBlockLabel\");\n    showElement(\"rightBlockLabel\");\n  } else {\n    hideElement(\"leftBlockLabel\");\n    hideElement(\"rightBlockLabel\");\n  }\n  resetButtons();\n  setText(\"characterNameInput\", \"\");\n}\n\n\nfunction resetButtons() {\n  for (var r = 0; r < 5; r++) {\n    for (var n = 1; n <= 10; n++) {\n      (function(row, num) {\n        setProperty(\"btn\" + row + \"_\" + num, \"background-color\", rgb(248, 248, 248));\n        setProperty(\"btn\" + row + \"_\" + num, \"text-color\", rgb(0, 0, 0));\n      })(r, n);\n    }\n  }\n  \n  // Attach handlers for custom trait buttons\n  for (var c = 1; c <= 2; c++) {\n    for (var m = 1; m <= 10; m++) {\n      (function(row, num) {\n        setProperty(\"btnC\" + row + \"_\" + num, \"background-color\", rgb(248, 248, 248));\n        setProperty(\"btnC\" + row + \"_\" + num, \"text-color\", rgb(0, 0, 0));\n      })(c, m);\n    }\n  }\n}\n\nonEvent(\"backButton\", \"click\", function() {\n  updateState(\"backButton\");\n});\n\n\n// Save / output JSON\nonEvent(\"mainButton\", \"click\", function() {\n\n  saveCharacter();\n  updateState(\"mainButton\");\n});\n\nonEvent(\"characterButton\", \"click\", function() {\n  saveCharacter();\n  updateState(\"characterButton\");\n});\n\n",
    "name_suffix": "_2024",
    "start_libraries": "[{\"name\":\"I18n_GENAIU124L9\",\"description\":\"Translation library for Gen AI Unit 1 Lesson 9 levels\",\"functions\":[\"translate\",\"getTranslations\",\"testTranslatability\"],\"dropletConfig\":[{\"func\":\"I18n_GENAIU124L9.translate\",\"category\":\"Functions\",\"comment\":\"Returns the i18n string for a given key\",\"type\":\"either\",\"params\":[\"key\"],\"paletteParams\":[\"key\"]},{\"func\":\"I18n_GENAIU124L9.getTranslations\",\"category\":\"Functions\",\"comment\":\"returns the TRANSLATIONTEXT JSON object\",\"type\":\"either\"},{\"func\":\"I18n_GENAIU124L9.testTranslatability\",\"category\":\"Functions\",\"comment\":\"This function adds \\\"!!\\\" to the start of every string in TRANSLATIONTEXT.\\nThis function is for DEBUGGING PURPOSES ONLY.\\nWhen debugging: A levelbuilder should call this at the very beginning of the level in order to\\nsee that all of the places where they expect a translation are getting a transaltion\\n(because the !! will show for translated texts)\",\"type\":\"either\"}],\"source\":\"var TRANSLATIONTEXT = {\\n  \\\"titleLabel_0\\\": \\\"Mad Lib Widget\\\",\\n  \\\"probabilityTitle2Label_1\\\": \\\"Start Here!\\\",\\n  \\\"probabilityTitle_2\\\": \\\"Generate Probability Mad Lib\\\",\\n  \\\"probabilityLockedNoun1_3\\\": \\\"Noun 1: ?????\\\",\\n  \\\"probabilityLockedNoun2_4\\\": \\\"Noun 2: ?????\\\",\\n  \\\"probabilityLockedNoun3_5\\\": \\\"Noun 3: ?????\\\",\\n  \\\"probabilityLockedNoun4_6\\\": \\\"Noun 4: ?????\\\",\\n  \\\"probabilityLockedNoun5_7\\\": \\\"Noun 5: ?????\\\",\\n  \\\"probabilityLockedNoun6_8\\\": \\\"Noun 6: ?????\\\",\\n  \\\"probabilityNoun2Score_9\\\": \\\"100\\\",\\n  \\\"probabilityNoun3Score_10\\\": \\\"100\\\",\\n  \\\"probabilityNoun4Score_11\\\": \\\"100\\\",\\n  \\\"probabilityNoun5Score_12\\\": \\\"100\\\",\\n  \\\"probabilityNoun6Score_13\\\": \\\"100\\\",\\n  \\\"probabilityNoun1Score_14\\\": \\\"100\\\",\\n  \\\"probabilityNounLabel_15\\\": \\\"set with PROBABILITYLABEL\\\",\\n  \\\"dataTitle_16\\\": \\\"View Data\\\",\\n  \\\"generateTitleLabel_17\\\": \\\"Generate a Mad Lib\\\",\\n  \\\"homeGenerateButton_18\\\": \\\"Generate a Mad Lib\\\",\\n  \\\"homeDataButton_19\\\": \\\"View Data + Random Mad Lib\\\",\\n  \\\"homeProbabilityButton_20\\\": \\\"Probability Mad Lib\\\",\\n  \\\"probabilityGenerateButton_21\\\": \\\"Generate Mad Lib\\\",\\n  \\\"probabilityRestartButton_22\\\": \\\"Restart This Screen\\\",\\n  \\\"probabilityCalculateButton_23\\\": \\\"Calculate Scores\\\",\\n  \\\"probabilityContinueButton_24\\\": \\\"Continue\\\",\\n  \\\"dataViewButton_25\\\": \\\"View Data\\\",\\n  \\\"dataRandomButton_26\\\": \\\"Random Mad Lib From the Data\\\",\\n  \\\"generateGenerateButton_27\\\": \\\"Generate Mad Lib\\\",\\n  \\\"probabilityMadlibText_28\\\": \\\"Set with PROBABILITYMADLIBSTRING\\\",\\n  \\\"dataTextArea_29\\\": \\\"use DATATEXTSTRING variable to fill this box\\\",\\n  \\\"generateMadLibText_30\\\": \\\"use GENERATETEXTSTRING variable to fill this box\\\",\\n  \\\"detailsLabelMouseover\\\": \\\"Generate a Mad Lib - this will let you enter 6 words to generate a mad lib that matches the example used in class.\\\",\\n  \\\"dataLabelMouseover\\\": \\\"View Data + Random Mad Lib - this will let you view the raw data from 1000 people who also completed this mad lib. You can also randomly view one of the mad libs from this dataset\\\",\\n  \\\"probabilityLabelMouseover\\\": \\\"Probability Mad Lib - this will let you enter multiple possibilities for a single blank, and then the program will choose the word most popular amongst the answers from the 1000 people who completed this same mad lib.\\\",\\n  \\\"madlibsentence1\\\": \\\"Once upon a time, in a vast and mystical \\\",\\n  \\\"madlibsentence2\\\": \\\", there lived a small yet adventurous \\\",\\n  \\\"madlibsentence3\\\": \\\". Every morning, it would set out to explore the \\\",\\n  \\\"madlibsentence4\\\": \\\", searching for hidden treasures and secret \\\",\\n  \\\"madlibsentence5\\\": \\\". One day, during its travels, it stumbled upon an ancient \\\",\\n  \\\"madlibsentence6\\\": \\\", covered in vines and mystery. Inside, there was a magical \\\",\\n  \\\"madlibsentence7\\\": \\\" that promised to grant the finder their heart's deepest desire.\\\",\\n  \\\"madlibnumber\\\": \\\"Mad Lib #\\\",\\n  \\\"nounLabel\\\": \\\"Noun\\\",\\n  \\\"noun1\\\": \\\"forest\\\",\\n  \\\"noun2\\\": \\\"passageways\\\",\\n  \\\"noun3\\\": \\\"pancake\\\",\\n  \\\"noun4\\\": \\\"toothbrush\\\",\\n  \\\"noun5\\\": \\\"fox\\\",\\n  \\\"noun6\\\": \\\"map\\\",\\n  \\\"noun7\\\": \\\"spatula\\\",\\n  \\\"noun8\\\": \\\"sandwich\\\",\\n  \\\"noun9\\\": \\\"cave\\\",\\n  \\\"noun10\\\": \\\"sword\\\",\\n  \\\"noun11\\\": \\\"pencil\\\",\\n  \\\"noun12\\\": \\\"glitter\\\",\\n  \\\"noun13\\\": \\\"kingdom\\\",\\n  \\\"noun14\\\": \\\"chambers\\\",\\n  \\\"noun15\\\": \\\"refrigerator\\\",\\n  \\\"noun16\\\": \\\"stapler\\\",\\n  \\\"noun17\\\": \\\"knight\\\",\\n  \\\"noun18\\\": \\\"door\\\",\\n  \\\"noun19\\\": \\\"encyclopedia\\\",\\n  \\\"noun20\\\": \\\"elevator\\\",\\n  \\\"noun21\\\": \\\"castle\\\",\\n  \\\"noun22\\\": \\\"lamp\\\",\\n  \\\"noun23\\\": \\\"headphone\\\",\\n  \\\"noun24\\\": \\\"microwave\\\",\\n  \\\"noun25\\\": \\\"desert\\\",\\n  \\\"noun26\\\": \\\"books\\\",\\n  \\\"noun27\\\": \\\"telescope\\\",\\n  \\\"noun28\\\": \\\"candle\\\",\\n  \\\"noun29\\\": \\\"robot\\\",\\n  \\\"noun30\\\": \\\"book\\\",\\n  \\\"noun31\\\": \\\"flashlight\\\",\\n  \\\"noun32\\\": \\\"sticker\\\",\\n  \\\"noun33\\\": \\\"garden\\\",\\n  \\\"noun34\\\": \\\"mirror\\\",\\n  \\\"noun35\\\": \\\"skateboard\\\",\\n  \\\"noun36\\\": \\\"feather\\\",\\n  \\\"noun37\\\": \\\"ocean\\\",\\n  \\\"noun38\\\": \\\"artifacts\\\",\\n  \\\"noun39\\\": \\\"notebook\\\",\\n  \\\"noun40\\\": \\\"harmonica\\\",\\n  \\\"noun41\\\": \\\"fairy\\\",\\n  \\\"noun42\\\": \\\"crystal\\\",\\n  \\\"noun43\\\": \\\"cactus\\\",\\n  \\\"noun44\\\": \\\"marble\\\",\\n  \\\"noun45\\\": \\\"stone\\\",\\n  \\\"noun46\\\": \\\"pineapple\\\",\\n  \\\"noun47\\\": \\\"cookie\\\",\\n  \\\"noun48\\\": \\\"valley\\\",\\n  \\\"noun49\\\": \\\"ruins\\\",\\n  \\\"noun50\\\": \\\"umbrella\\\",\\n  \\\"noun51\\\": \\\"snowglobe\\\",\\n  \\\"noun52\\\": \\\"dragon\\\",\\n  \\\"noun53\\\": \\\"locket\\\",\\n  \\\"noun54\\\": \\\"blanket\\\",\\n  \\\"noun55\\\": \\\"pillow\\\",\\n  \\\"noun56\\\": \\\"mountain\\\",\\n  \\\"noun57\\\": \\\"amulet\\\",\\n  \\\"noun58\\\": \\\"thermostat\\\",\\n  \\\"noun59\\\": \\\"sneaker\\\",\\n  \\\"noun60\\\": \\\"island\\\",\\n  \\\"noun61\\\": \\\"scrolls\\\",\\n  \\\"noun62\\\": \\\"balloon\\\",\\n  \\\"noun63\\\": \\\"keyboard\\\",\\n  \\\"noun64\\\": \\\"pirate\\\",\\n  \\\"noun65\\\": \\\"chest\\\",\\n  \\\"noun66\\\": \\\"teapot\\\",\\n  \\\"noun67\\\": \\\"sunglasses\\\",\\n  \\\"noun68\\\": \\\"river\\\",\\n  \\\"noun69\\\": \\\"potion\\\",\\n  \\\"noun70\\\": \\\"bookmark\\\",\\n  \\\"noun71\\\": \\\"bubble\\\",\\n  \\n  \\\"DATATEXTSTRING\\\": \\\"You can do two things on this screen:\\\\n\\\\n1) View the data from 1000 peolple who completed the same mad lib, so  you can see all of the different choices they made for filling in the blanks\\\\n\\\\n2) Randomly view one of those mad-libs\\\\n\\\\nThe results will appear in this box!\\\",\\n  \\\"GENERATETEXTSTRING\\\": \\\"Type in each noun into the screen above, then click Generate Mad Lib. The resulting mad lib will show up here!\\\",\\n  \\\"PROBABILITYMADLIBSTRING\\\": \\\"1) On the left, enter all of the possible responses the class generated for Noun 1\\\\n\\\\n2) Click \\\\\\\"Calculate Scores\\\\\\\" button. This will compare the list of class possibilities to the dataset representing what 1000 other people submitted for their madlib. The scores will appear next to each word. After reviewing, press the Continue button\\\\n\\\\n3) The highest score will be chosen, and the top of the screen will update. Then the side-panel will refresh and you can now enter the class possibilities for Noun 2.\\\\n\\\\n4) Follow the same steps until all of the most popular nouns have been chosen\\\\n\\\\n5) Once all the nouns have been selected, A Generate Mad Lib button will appear. Press it to generate the mad lib!\\\\n\\\\nAt any time, press the \\\\\\\"Restart This Screen\\\\\\\" button to start this process over\\\",\\n  \\\"DETAILSLABELSTRING\\\": \\\"Hover over a button to see what it does\\\",\\n  \\\"PROBABILITYLABEL\\\": \\\"Enter possibilities for Noun \\\"\\n};\\n\\n\\n\\n//Returns the i18n string for a given key\\nfunction translate(key) {\\n  return TRANSLATIONTEXT[key];\\n}\\n\\n//returns the TRANSLATIONTEXT JSON object\\nfunction getTranslations() {\\n  return TRANSLATIONTEXT;\\n}\\n\\n/*\\nThis function adds \\\"!!\\\" to the start of every string in TRANSLATIONTEXT.\\nThis function is for DEBUGGING PURPOSES ONLY.\\nWhen debugging: A levelbuilder should call this at the very beginning of the level in order to\\nsee that all of the places where they expect a translation are getting a transaltion\\n(because the !! will show for translated texts)\\n*/\\nfunction testTranslatability() {\\n  var keys = Object.keys(TRANSLATIONTEXT);\\n  for(var i = 0; i < keys.length; i++) {\\n    var key = keys[i];\\n    TRANSLATIONTEXT[key] = \\\"!!\\\" + TRANSLATIONTEXT[key];\\n  }\\n}\\n\",\"originalName\":\"I18n_GENAIU124L9\",\"versionId\":\"2CpXMruQav9lMGQ6W3qXzQ6zqX2rNM0H\",\"channelId\":\"ExlOHqgjqe6ouXxkA1gjnA\",\"fromLevelbuilder\":true}]",
    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: none;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"default\" id=\"screen1\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 255, 255);\"><label id=\"titleLabel\" style=\"position: absolute; left: -5px; top: 0px; width: 600px; height: 30px; text-align: center; font-size: 24px; background-color: rgba(0, 0, 0, 0); text-rendering: optimizespeed; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; font-family: Tahoma, Geneva, sans-serif; color: rgb(77, 87, 95); padding: 2px 15px;\" data-mod-bordercolor=\"1\" data-mod-fontfamily=\"1\" data-mod-fontsize=\"1\">Character Quiz: Part 1</label>\n<label id=\"descriptionLabel\" style=\"position: absolute; left: 15px; top: 40px; width: 565px; height: 55px; font-size: 12px; background-color: rgba(0, 0, 0, 0); text-rendering: optimizespeed; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; font-family: Tahoma, Geneva, sans-serif; color: rgb(77, 87, 95); padding: 2px 15px; text-align: center;\" data-mod-bordercolor=\"1\" data-mod-fontfamily=\"1\" data-mod-fontsize=\"1\">Choose a character you are familiar with and enter their name below. For each trait pair, click a number (1 = left trait, 10 = right trait). Then add two traits of your own and rate them.</label>\n<input id=\"characterNameInput\" type=\"text\" placeholder=\"Character name...\" style=\"position: absolute; left: 175px; top: 105px; width: 260px; height: 30px; border-style: solid; border-width: 1px; border-color: rgb(77, 87, 95); border-radius: 4px; font-family: Arial, Helvetica, sans-serif; padding: 5px; background-color: rgb(242, 242, 242); color: rgb(0, 0, 0); font-size: 12px;\" data-mod-textcolor=\"1\" data-mod-backgroundcolor=\"1\" data-mod-bordercolor=\"1\" data-mod-borderradius=\"1\" data-mod-fontsize=\"1\" data-mod-padding=\"1\">\n<label id=\"traitLeft0\" style=\"position: absolute; left: 20px; top: 145px; width: 110px; height: 25px; margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; text-align: right;\">Good</label>\n<button id=\"btn0_1\" style=\"position: absolute; left: 160px; top: 145px; width: 24px; height: 24px; padding: 0px; margin: 0px; border-style: solid; background-color: rgb(248, 248, 248); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px;\">1</button>\n<button id=\"btn0_2\" style=\"position: absolute; left: 190px; top: 145px; width: 24px; height: 24px; padding: 0px; margin: 0px; border-style: solid; background-color: rgb(248, 248, 248); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px;\">2</button>\n<button id=\"btn0_3\" style=\"position: absolute; left: 220px; top: 145px; width: 24px; height: 24px; padding: 0px; margin: 0px; border-style: solid; background-color: rgb(248, 248, 248); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px;\">3</button>\n<button id=\"btn0_4\" style=\"position: absolute; left: 250px; top: 145px; width: 24px; height: 24px; padding: 0px; margin: 0px; border-style: solid; background-color: rgb(248, 248, 248); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px;\">4</button>\n<button id=\"btn0_5\" style=\"position: absolute; left: 280px; top: 145px; width: 24px; height: 24px; padding: 0px; margin: 0px; border-style: solid; background-color: rgb(248, 248, 248); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px;\" data-mod-backgroundcolor=\"1\" data-mod-textcolor=\"1\">5</button>\n<button id=\"btn0_6\" style=\"position: absolute; left: 310px; top: 145px; width: 24px; height: 24px; padding: 0px; margin: 0px; border-style: solid; background-color: rgb(248, 248, 248); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px;\">6</button>\n<button id=\"btn0_7\" style=\"position: absolute; left: 340px; top: 145px; width: 24px; height: 24px; padding: 0px; margin: 0px; border-style: solid; background-color: rgb(248, 248, 248); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px;\">7</button>\n<button id=\"btn0_8\" style=\"position: absolute; left: 370px; top: 145px; width: 24px; height: 24px; padding: 0px; margin: 0px; border-style: solid; background-color: rgb(248, 248, 248); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px;\">8</button>\n<button id=\"btn0_9\" style=\"position: absolute; left: 400px; top: 145px; width: 24px; height: 24px; padding: 0px; margin: 0px; border-style: solid; background-color: rgb(248, 248, 248); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px;\">9</button>\n<button id=\"btn0_10\" style=\"position: absolute;