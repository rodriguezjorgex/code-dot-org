    "start_blocks": "// Password to detect\r\nvar actualPassword = \"Hank2009Eilish\";\r\n\r\n// Password guessing logic\r\nonEvent(\"password_button\", \"click\", function() {\r\n  var k1 = getText(\"keyword1_input\");\r\n  var k2 = getText(\"keyword2_input\");\r\n  var k3 = getText(\"keyword3_input\");\r\n\r\n  var combos = [\r\n    k1 + k2 + k3,\r\n    k1 + k3 + k2,\r\n    k2 + k1 + k3,\r\n    k2 + k3 + k1,\r\n    k3 + k1 + k2,\r\n    k3 + k2 + k1,\r\n    k1 + \"_\" + k2 + \"_\" + k3,\r\n    k1 + \"_\" + k3 + \"_\" + k2,\r\n    k2 + \"_\" + k1 + \"_\" + k3,\r\n    k2 + \"_\" + k3 + \"_\" + k1,\r\n    k3 + \"_\" + k1 + \"_\" + k2,\r\n    k3 + \"_\" + k2 + \"_\" + k1,\r\n    k1 + \"_\" + k2 + k3,\r\n    k2 + \"_\" + k1 + k3,\r\n    k1 + k2 + \"_\" + k3\r\n  ];\r\n\r\n  var output = \"Possible password guesses:\\n\";\r\n  var passwordFound = false;\r\n\r\n  for (var i = 0; i < combos.length; i++) {\r\n    output += combos[i] + \"\\n\";\r\n\r\n    if (combos[i] == actualPassword) {\r\n      passwordFound = true;\r\n    }\r\n  }\r\n\r\n  setText(\"password_guesses\", output);\r\n\r\n  if (passwordFound) {\r\n    setText(\"password_detected\", \r\n      \"Password Detected!\\nusername: jasminejogger\\npassword: \" + actualPassword);\r\n    showElement(\"password_detected\");\r\n  }\r\n});\r\n\r\n// Submit button logic\r\nonEvent(\"submit_button\", \"click\", function() {\r\n  var user = getText(\"username_input\");\r\n  var pass = getText(\"password_input\");\r\n\r\n  if (user == \"jasminejogger\" && pass == actualPassword) {\r\n    hideElement(\"submit_button\");\r\n    hideElement(\"keyword1_input\");\r\n    hideElement(\"keyword2_input\");\r\n    hideElement(\"keyword3_input\");\r\n    hideElement(\"text_area1\");\r\n    hideElement(\"password_button\");\r\n    hideElement(\"password_guesses\");\r\n    hideElement(\"incorrect_guess\");\r\n\r\n    showElement(\"guessing_explanation\");\r\n    showElement(\"access_granted\");\r\n  } else {\r\n    showElement(\"incorrect_guess\");\r\n  }\r\n});\r\n",
    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: block;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"robot\" id=\"screen1\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(216, 224, 227);\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson3-level6/logo5.png?t=1752765079000\" data-canonical-image-url=\"image://logo5.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image1\" style=\"height: 100px; width: 100px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 20px; top: 30px; margin: 0px;\"><button id=\"submit_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 100px; background-color: rgb(178, 217, 235); color: rgb(53, 60, 66); border-color: rgb(128, 167, 185); border-radius: 0px; border-width: 2px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 20px; top: 250px;\">Submit</button><input id=\"username_input\" style=\"margin: 0px; width: 255px; height: 35px; border-style: solid; color: rgb(53, 60, 66); background-color: rgb(255, 255, 255); border-color: rgb(53, 60, 66); border-radius: 0px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 20px; top: 160px;\" placeholder=\"username\"><input id=\"password_input\" style=\"margin: 0px; width: 255px; height: 35px; border-style: solid; color: rgb(53, 60, 66); background-color: rgb(255, 255, 255); border-color: rgb(53, 60, 66); border-radius: 0px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 20px; top: 205px;\" placeholder=\"password\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson3-level6/QuikCash_text.png?t=1752765294000\" data-canonical-image-url=\"image://QuikCash_text.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image2\" style=\"height: 105px; width: 130px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 140px; top: 30px; margin: 0px;\"><div contenteditable=\"true\" class=\"textArea\" id=\"password_guesses\" style=\"width: 265px; height: 250px; border-style: solid; background-color: rgb(245, 245, 246); color: rgb(53, 60, 66); border-color: rgb(128, 167, 185); border-radius: 0px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 320px; top: 190px; margin: 0px;\">Possible password guesses:<div><br></div></div><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson3-level6/divider.png?t=1752765358000\" data-canonical-image-url=\"image://divider.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image3\" style=\"height: 450px; width: 20px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 285px; top: 0px; margin: 0px;\"><input id=\"keyword1_input\" style=\"margin: 0px; width: 145px; height: 35px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(247, 208, 208); border-color: rgb(53, 60, 66); border-radius: 0px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 320px; top: 65px;\" placeholder=\"keyword 1\"><input id=\"keyword2_input\" style=\"margin: 0px; width: 145px; height: 35px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(247, 208, 208); border-color: rgb(53, 60, 66); border-radius: 0px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 320px; top: 105px;\" placeholder=\"keyword 2\"><input id=\"keyword3_input\" style=\"margin: 0px; width: 145px; height: 35px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(247, 208, 208); border-color: rgb(53, 60, 66); border-radius: 0px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 320px; top: 145px;\" placeholder=\"keyword 3\"><div contenteditable=\"true\" class=\"textArea\" id=\"text_area1\" style=\"width: 295px; height: 60px; border-style: solid; background-color: rgba(245, 245, 246, 0); color: rgb(53, 60, 66); border-color: rgba(128, 167, 185, 0); border-radius: 0px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 305px; top: 0px; margin: 0px;\">Based on the social media post that you see to the left, pick three keywords that might combine into a password.</div><div contenteditable=\"true\" class=\"textArea design-mode-hidden\" id=\"password_detected\" style=\"width: 255px; height: 75px; border-style: solid; background-color: rgb(247, 208, 208); color: rgb(53, 60, 66); border-color: rgb(128, 167, 185); border-radius: 29px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 20px; top: 330px; margin: 0px;\">Password Detected!<div>username: </div><div>password: </div></div><button id=\"password_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 65px; width: 100px; background-color: rgb(178, 217, 235); color: rgb(53, 60, 66); border-color: rgb(128, 167, 185); border-radius: 0px; border-width: 2px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 485px; top: 85px;\">Password Guess</button><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson3-level6/access_granted.png?t=1752766319000\" data-canonical-image-url=\"image://access_granted.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"access_granted\" style=\"height: 75px; width: 265px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 320px; top: 90px; margin: 0px;\" class=\"design-mode-hidden\"><div contenteditable=\"true\" class=\"textArea design-mode-hidden\" id=\"guessing_explanation\" style=\"width: 290px; height: 270px; border-style: solid; background-color: rgba(245, 245, 246, 0); color: rgb(53, 60, 66); border-color: rgba(128, 167, 185, 0); border-radius: 0px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 16px; padding: 5px 15px; position: absolute; left: 310px; top: 150px; margin: 0px;\">Password Guessing is an attack where someone uses personal details—like your pet’s name, birth year, or favorite band—often found on social media, to guess your password. <div><br></div><div>Attackers combine these clues into common patterns to try and break into your account.</div></div><div contenteditable=\"true\" class=\"textArea design-mode-hidden\" id=\"incorrect_guess\" style=\"width: 140px; height: 70px; border-style: solid; background-color: rgba(245, 245, 246, 0); color: rgb(243, 18, 18); border-color: rgba(128, 167, 185, 0); border-radius: 0px; border-width: 1px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 125px; top: 250px; margin: 0px;\">The username and/or password are incorrect!</div></div></div>",
    "preload_asset_list": null,
    "encrypted_examples": [

    ],
    "long_instructions": "## Do This:\r\n\r\n1. Examine the social media post below for *keywords* that might be contained within this user's password\r\n\r\n2. Enter three different keywords into the red boxes within the application and press `Password Guess` to scramble them\r\n\r\n3. Once the system confirms that the correct password was found, enter both the `username` and `password` and press the `Submit` button to gain access.\r\n\r\n---\r\n\r\n\r\n![](https://images.code.org/d4a6debad60f3b7bd81359304a751302-image-1752766950884.gif)"
  },
  "audit_log": "[{\"changed_at\":\"2025-07-16 21:44:36 +0000\",\"changed\":[\"validation_enabled\",\"code_functions\",\"preload_asset_list\"],\"changed_by_id\":18603,\"changed_by_email\":\"erik+levelbuilder@code.org\"},{\"changed_at\":\"2025-07-16 21:47:11 +0000\",\"changed\":[\"code_functions\",\"preload_asset_list\",\"encrypted_examples\"],\"changed_by_id\":18603,\"changed_by_email\":\"erik+levelbuilder@code.org\"},{\"changed_at\":\"2025-07-16 21:48:31 +0000\",\"changed\":[],\"changed_by_id\":18603,\"changed_by_email\":\"erik+levelbuilder@code.org\"},{\"changed_at\":\"2025-07-17 15:22:53 +0000\",\"changed\":[\"start_html\"],\"changed_by_id\":18603,\"changed_by_email\":\"erik+levelbuilder@code.org\"},{\"changed_at\":\"2025-07-17 15:35:08 +0000\",\"changed\":[\"start_html\"],\"changed_by_id\":18603,\"changed_by_email\":\"erik+levelbuilder@code.org\"},{\"changed_at\":\"2025-07-17 15:37:40 +0000\",\"changed\":[\"start_blocks\",\"start_html\"],\"changed_by_id\":18603,\"changed_by_email\":\"erik+levelbuilder@code.org\"},{\"changed_at\":\"2025-07-17 15:37:49 +0000\",\"changed\":[\"start_html\"],\"changed_by_id\":18603,\"changed_by_email\":\"erik+levelbuilder@code.org\"},{\"changed_at\":\"2025-07-17 15:40:04 +0000\",\"changed\":[\"start_html\"],\"changed_by_id\":18603,\"changed_by_email\":\"erik+levelbuilder@code.org\"},{\"changed_at\":\"2025-07-17 15:47:53 +0000\",\"changed\":[\"code_functions\",\"preload_asset_list\"],\"changed_by_id\":18603,\"changed_by_email\":\"erik+levelbuilder@code.org\"}]"
