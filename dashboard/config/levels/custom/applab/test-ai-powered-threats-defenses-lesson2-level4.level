    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: block;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"default\" id=\"screen1\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 255, 255); background-size: 600px 450px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/test-ai-powered-threats-defenses-lesson2-level4/stylish-soft-blue-curve-lines-abstract-background.jpg&quot;);\" data-canonical-image-url=\"image://stylish-soft-blue-curve-lines-abstract-background.jpg\" data-image-type=\"file\"><button id=\"bin_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 75px; width: 80px; background-color: rgba(255, 164, 0, 0); color: rgb(255, 255, 255); border-color: rgba(77, 87, 95, 0); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 515px; top: 365px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/test-ai-powered-threats-defenses-lesson2-level4/recycle-bin-icon-18.png&quot;); background-size: contain; background-position: 50% 50%; background-repeat: no-repeat;\" data-canonical-image-url=\"image://recycle-bin-icon-18.png\" data-image-type=\"file\"></button><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson2-level4/home.png\" data-canonical-image-url=\"image://home.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image1\" style=\"height: 30px; width: 25px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 5px; top: 420px; margin: 0px;\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(255, 255, 255); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 12px; padding: 2px 15px; width: 53px; height: 17px; position: absolute; left: 531px; top: 385px; text-align: center;\" id=\"bin_label\">Bin</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(0, 0, 0); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 12px; padding: 2px 15px; width: 90px; height: 20px; position: absolute; left: 500px; top: 175px; text-align: center;\" id=\"chrome_label\" class=\"\">Chrome</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(0, 0, 0); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 12px; padding: 2px 15px; width: 90px; height: 20px; position: absolute; left: 500px; top: 70px; text-align: center;\" id=\"files_label\">Files</label><button id=\"chrome_window_x\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 20px; width: 20px; background-color: rgb(255, 0, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 10px; position: absolute; left: 530px; top: 37px;\" class=\"design-mode-hidden\">X</button><button id=\"chrome_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 60px; width: 90px; background-color: rgba(255, 164, 0, 0); color: rgb(255, 255, 255); border-color: rgba(77, 87, 95, 0); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 500px; top: 110px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/test-ai-powered-threats-defenses-lesson2-level4/chrome.png&quot;); background-size: contain; background-position: 50% 50%; background-repeat: no-repeat;\" data-canonical-image-url=\"image://chrome.png\" data-image-type=\"file\"></button><button id=\"files_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 60px; width: 60px; background-color: rgba(255, 164, 0, 0); color: rgb(255, 255, 255); border-color: rgba(77, 87, 95, 0); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 515px; top: 5px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/test-ai-powered-threats-defenses-lesson2-level4/folder.png&quot;); background-size: contain; background-position: 50% 50%; background-repeat: no-repeat;\" data-canonical-image-url=\"image://folder.png\" data-image-type=\"file\"></button><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson2-level4/Pasted Graphic 5 2.png\" data-canonical-image-url=\"image://Pasted Graphic 5 2.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"chrome_window\" style=\"height: 335px; width: 530px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; top: 45px; margin: 0px; left: 35px;\" class=\"design-mode-hidden\"></div><div class=\"screen\" tabindex=\"1\" data-theme=\"default\" id=\"screen2\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(0, 0, 0); display: none;\"><div contenteditable=\"true\" class=\"textArea\" id=\"text_area1\" style=\"width: 365px; height: 200px; border-style: solid; background-color: rgba(242, 242, 242, 0); color: rgb(113, 255, 0); border-color: rgba(255, 255, 255, 0); border-radius: 2px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 18px; padding: 5px 15px; position: absolute; left: 130px; top: 215px; margin: 0px; text-align: center;\">YOUR FILES ARE ENCRYPTED!!!<div><br></div><div>All your school files, photos, and saved games are locked. </div><div><br></div><div>To unlock them, you must pay $300 in Bitcoin within 10 minutes. If you don’t pay in time, your files will be deleted forever!</div></div><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson2-level4/clock-wait-till-the-end.gif\" data-canonical-image-url=\"image://clock-wait-till-the-end.gif\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image4\" style=\"height: 205px; width: 345px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 125px; top: 5px; margin: 0px;\"></div></div>",
