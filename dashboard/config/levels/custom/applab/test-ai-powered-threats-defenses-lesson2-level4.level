    "start_blocks": "// Opens Chrome window\nonEvent(\"chrome_button\", \"click\", function( ) {\n\tshowElement(\"chrome_window\");\n\tshowElement(\"chrome_window_x\");\n\tshowElement(\"chrome_text_input\");\n});\n\n// Closes Chrome window\nonEvent(\"chrome_window_x\", \"click\", function( ) {\n\thideElement(\"chrome_window\");\n\thideElement(\"chrome_window_x\");\n\thideElement(\"chrome_text_input\");\n});\n\n// Opens Email window\nonEvent(\"email_button\", \"click\", function( ) {\n\tshowElement(\"email_inbox_window\");\n\tshowElement(\"email_new_email_button\");\n\tshowElement(\"email_inbox_button\");\n\tshowElement(\"email_sent_button\");\n\tshowElement(\"email_spam_trash\");\n\tshowElement(\"email_trash_button\");\n\tshowElement(\"email_x_button\");\n\tshowElement(\"email_coach\");\n\tshowElement(\"email_jon\");\n\tshowElement(\"email_haley\")\n});\n\n// Closes Chrome window\nonEvent(\"email_x_button\", \"click\", function( ) {\n\thideElement(\"email_inbox_window\");\n\thideElement(\"email_new_email_button\");\n\thideElement(\"email_inbox_button\");\n\thideElement(\"email_sent_button\");\n\thideElement(\"email_spam_trash\");\n\thideElement(\"email_trash_button\");\n\thideElement(\"email_x_button\");\n\t\n\thideElement(\"email_from_coach\");\n\thideElement(\"email_from_jon\");\n\thideElement(\"email_from_haley\");\n\thideElement(\"email_coach\");\n\thideElement(\"email_jon\");\n\thideElement(\"email_haley\");\n});\n\n\nonEvent(\"chrome_window_x\", \"click\", function( ) {\n\thideElement(\"chrome_window\");\n\thideElement(\"chrome_window_x\");\n\thideElement(\"chrome_text_input\");\n});\n\n// Shows email\nonEvent(\"email_coach\", \"click\", function( ) {\n\tshowElement(\"email_from_coach\");\n\thideElement(\"email_from_jon\");\n\thideElement(\"email_from_haley\");\t\n});\n\nonEvent(\"email_jon\", \"click\", function( ) {\n\tshowElement(\"email_from_jon\");\n\thideElement(\"email_from_coach\");\n\thideElement(\"email_from_haley\");\t\n});\n\nonEvent(\"email_haley\", \"click\", function( ) {\n\tshowElement(\"email_from_haley\");\n\thideElement(\"email_from_coach\");\n\thideElement(\"email_from_jon\");\t\n});\n\n\n// Shows files winIdow\nonEvent(\"files_button\", \"click\", function( ) {\n\tshowElement(\"files_x_button\");\n\tshowElement(\"files_window\");\n\tshowElement(\"pdf\");\n\tshowElement(\"pdf_label\");\n\tshowElement(\"doc\");\n\tshowElement(\"doc_label\");\n\tshowElement(\"zip_button\");\n\tshowElement(\"zip_label\");\n\n});\n\nonEvent(\"files_x_button\", \"click\", function( ) {\n\thideElement(\"files_x_button\");\n\thideElement(\"files_window\");\n\thideElement(\"pdf\");\n\thideElement(\"pdf_label\");\n\thideElement(\"doc\");\n\thideElement(\"doc_label\");\n\thideElement(\"zip_button\");\n\thideElement(\"zip_label\");\n\thideElement(\"ransomware\");\n\thideElement(\"ransomware_label\");\n\n});\n\n\nonEvent(\"zip_button\", \"click\", function( ) {\n\tshowElement(\"ransomware\");\n\tshowElement(\"ransomware_label\");\n});\n\nonEvent(\"ransomware\", \"click\", function( ) {\n\tsetScreen(\"screen2\");\n});",
