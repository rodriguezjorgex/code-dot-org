    "start_blocks": "// ---------- Global Variables ----------\nvar username = \"\";\nvar email = \"\";\nvar favoriteGame = \"\";\nvar fakePhone = \"555-0134\";\nvar fakeIP = \"192.168.42.87\";\n\nvar leaderboard = [\n  { name: \"SkyRunner\", score: 9580, email: \"sky@example.com\" },\n  { name: \"PixelQueen\", score: 9020, email: \"pixelq@domain.com\" },\n  { name: \"SkyRunner\", score: 8700, email: \"skyrun23@game.net\" }, // duplicated username\n  { name: \"\", score: 0, email: \"\" } // Will be replaced by student\n];\n\n// ---------- SCREEN 1 ----------\nonEvent(\"submit_profile\", \"click\", function() {\n  username = getText(\"username_input\");\n  email = getText(\"email_input\");\n  favoriteGame = getText(\"favgame_dropdown\");\n\n  var consoleOutput = \"Developer Console\\n-------------------------\\n\";\n\n  if (username === \"\" || email === \"\") {\n    consoleOutput += \"⚠️ Username and email required.\";\n    setProperty(\"leaderboard_button\", \"hidden\", true);\n  } else if (!email.includes(\"@\") || !email.includes(\".\")) {\n    consoleOutput += \"⚠️ Email is not valid.\";\n    setProperty(\"leaderboard_button\", \"hidden\", true);\n  } else {\n    consoleOutput += \"✅ Profile submitted.\\n\";\n    consoleOutput += \"✅ Checking email against existing accounts... Email unique!\\n\";\n    consoleOutput += \"⚠️ Username could not be verified as unique.\";\n\n    leaderboard[3] = { name: username, score: 55, email: email };\n    setProperty(\"leaderboard_button\", \"hidden\", false);\n  }\n\n  setText(\"profile_console\", consoleOutput);\n});\n\n\nonEvent(\"leaderboard_button\", \"click\", function() {\n  setScreen(\"screen2\");\n  displayLeaderboard();\n});\n\n\n// ---------- SCREEN 2 ----------\nonEvent(\"refresh_button\", \"click\", function() {\n  var rawText = getText(\"leaderboard_console\").split(\"\\n\");\n  var integrityCompromised = false;\n\n  // Skip header: \"Developer Console\", divider, and any trailing warnings\n  for (var i = 0; i < leaderboard.length; i++) {\n    // Expect lines 2–5 to be leaderboard entries\n    var lineIndex = i + 2; // Skip lines 0 and 1 (header + divider)\n\n    if (lineIndex < rawText.length) {\n      var parts = rawText[lineIndex].split(\" | \");\n      if (parts.length === 3) {\n        var newName = parts[0];\n        var newScore = Number(parts[1]);\n        var newEmail = parts[2];\n\n        var original = leaderboard[i];\n        if (\n          original.name !== newName ||\n          original.score !== newScore ||\n          original.email !== newEmail\n        ) {\n          integrityCompromised = true;\n          leaderboard[i] = {\n            name: newName,\n            score: newScore,\n            email: newEmail\n          };\n        }\n      }\n    }\n  }\n\n  displayLeaderboard(integrityCompromised);\n});\n\nfunction displayLeaderboard(showWarning) {\n  var header = \"Developer Console\\n-------------------------\\n\";\n  var consoleOutput = \"\";\n  var labelOutput = \"\";\n\n  for (var i = 0; i < leaderboard.length; i++) {\n    consoleOutput += leaderboard[i].name + \" | \" + leaderboard[i].score + \" | \" + leaderboard[i].email + \"\\n\";\n    labelOutput += leaderboard[i].name + \" - \" + leaderboard[i].score + \"\\n\";\n  }\n\n  if (showWarning) {\n    consoleOutput += \"\\n⚠️ Leaderboard has been edited manually. Integrity may be compromised.\";\n  } else {\n    consoleOutput += \"\\n⚠️ This data is editable.\";\n  }\n\n  setText(\"leaderboard_console\", header + consoleOutput);\n  setText(\"leaderboard_output\", labelOutput);\n}\n\nonEvent(\"share_button\", \"click\", function() {\n  setScreen(\"screen3\");\n});\n\nonEvent(\"profile_button\", \"click\", function() {\n  setScreen(\"screen1\");\n});\n\n\n// ---------- SCREEN 3 ----------\nonEvent(\"back_button\", \"click\", function() {\n  setScreen(\"screen2\");\n  displayLeaderboard();\n});\n\nonEvent(\"share_button2\", \"click\", function() {\n  var recipient = getText(\"share_username_input\");\n  var message = getText(\"share_msg_input\");\n\n  var payload = {\n    from: username,\n    email: email,\n    favoriteGame: favoriteGame,\n    message: message,\n    score: leaderboard[3].score,\n    phone: fakePhone,\n    ipAddress: fakeIP\n  };\n\n  var pretty = JSON.stringify(payload, null, 2);\n  var consoleOutput = \"Developer Console\\n-------------------------\\n\";\n  consoleOutput += \"📤 Sending Message Payload:\\n\" + pretty;\n  consoleOutput += \"\\n\\n⚠️ Payload includes sensitive sender data.\";\n\n  setText(\"share_console\", consoleOutput);\n});\n\n",
    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: block;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"classic\" id=\"screen1\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(226, 236, 229); display: block;\"><div contenteditable=\"false\" class=\"textArea\" id=\"profile_console\" style=\"width: 240px; height: 450px; border-style: solid; background-color: rgb(84, 84, 84); color: rgb(253, 253, 253); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 1px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px; position: absolute; left: 325px; top: 0px; margin: 0px;\" data-mod-backgroundcolor=\"1\" data-mod-textcolor=\"1\" data-mod-fontfamily=\"1\">Developer Console<div>-------------------------</div></div><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1c/cellphone_wireframe.png\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"phone_BG\" style=\"height: 450px; width: 235px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 50px; top: 0px; margin: 0px;\"><input id=\"username_input\" style=\"margin: 0px; width: 180px; height: 30px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(255, 255, 255); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px; position: absolute; left: 77px; top: 85px;\" placeholder=\"username\"><input id=\"email_input\" style=\"margin: 0px; width: 180px; height: 30px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(255, 255, 255); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px; position: absolute; left: 77px; top: 135px;\" placeholder=\"email\"><select id=\"favgame_dropdown\" style=\"width: 175px; height: 30px; margin: 0px; border-style: solid; background-color: rgb(26, 188, 156); color: rgb(255, 255, 255); background-image: url(&quot;data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%20256%20448%22%20enable-background%3D%22new%200%200%20256%20448%22%3E%3Cstyle%20type%3D%22text%2Fcss%22%3E.arrow%7Bfill%3A%23ffffff%3B%7D%3C%2Fstyle%3E%3Cpath%20class%3D%22arrow%22%20d%3D%22M255.9%20168c0-4.2-1.6-7.9-4.8-11.2-3.2-3.2-6.9-4.8-11.2-4.8H16c-4.2%200-7.9%201.6-11.2%204.8S0%20163.8%200%20168c0%204.4%201.6%208.2%204.8%2011.4l112%20112c3.1%203.1%206.8%204.6%2011.2%204.6%204.4%200%208.2-1.5%2011.4-4.6l112-112c3-3.2%204.5-7%204.5-11.4z%22%2F%3E%3C%2Fsvg%3E&quot;); border-color: rgb(0, 0, 0); border-radius: 0px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 0px 30px 0px 10px; position: absolute; left: 80px; top: 210px;\"><option>-----------------------------</option><option>Tears of the Kingdom</option><option>Monster Hunter Wilds</option><option>Baldur's Gate 3</option><option>Mario Kart</option><option>Madden 2035</option><option>Fortnite</option><option>Apex Legends</option><option>Clair Obscur</option><option>Split Fiction</option><option>Elden Ring</option></select><div contenteditable=\"true\" class=\"textArea\" id=\"text_area4\" style=\"width: 165px; height: 25px; border-style: solid; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border-color: rgb(255, 255, 255); border-radius: 0px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px; position: absolute; left: 90px; top: 180px; margin: 0px;\">Choose your game!</div><button id=\"submit_profile\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 90px; background-color: rgb(26, 188, 156); color: rgb(255, 255, 255); border-color: rgb(0, 0, 0); border-radius: 12px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; position: absolute; left: 120px; top: 260px;\">Save Profile</button><button id=\"leaderboard_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 35px; width: 135px; background-color: rgb(26, 188, 156); color: rgb(255, 255, 255); border-color: rgb(0, 0, 0); border-radius: 12px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 18px; position: absolute; left: 100px; top: 370px;\" class=\"design-mode-hidden\">Leaderboard!</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(51, 51, 51); background-color: rgba(0, 0, 0, 0); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 29px; padding: 2px; width: 165px; height: 35px; position: absolute; left: 85px; top: 39px; text-align: center;\" id=\"label3\" data-mod-fontsize=\"1\">ScoreStack</label></div><div class=\"screen\" tabindex=\"1\" data-theme=\"classic\" id=\"screen3\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(226, 236, 229); display: none;\"><div contenteditable=\"false\" class=\"textArea\" id=\"share_console\" style=\"width: 240px; height: 450px; border-style: solid; background-color: rgb(84, 84, 84); color: rgb(253, 253, 253); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 1px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px; position: absolute; left: 325px; top: 0px; margin: 0px;\" data-mod-backgroundcolor=\"1\" data-mod-textcolor=\"1\" data-mod-fontfamily=\"1\">Developer Console<div>-------------------------</div></div><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1c/cellphone_wireframe.png\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"phone_BG3\" style=\"height: 450px; width: 235px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 50px; top: 0px; margin: 0px;\"><input id=\"share_username_input\" style=\"margin: 0px; width: 185px; height: 30px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(255, 255, 255); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px; position: absolute; left: 75px; top: 75px;\" placeholder=\"friend's username\"><button id=\"share_button2\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 80px; background-color: rgb(26, 188, 156); color: rgb(255, 255, 255); border-color: rgb(0, 0, 0); border-radius: 0px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; position: absolute; left: 175px; top: 280px;\">Share</button><button id=\"back_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 80px; background-color: rgb(26, 188, 156); color: rgb(255, 255, 255); border-color: rgb(0, 0, 0); border-radius: 0px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; position: absolute; left: 80px; top: 280px;\">Back</button><input id=\"share_msg_input\" style=\"margin: 0px; width: 185px; height: 150px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(255, 255, 255); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px; position: absolute; left: 75px; top: 115px;\" placeholder=\"optional message\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(51, 51, 51); background-color: rgba(0, 0, 0, 0); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 29px; padding: 2px; width: 165px; height: 35px; position: absolute; left: 85px; top: 39px; text-align: center;\" id=\"label1\">ScoreStack</label></div><div class=\"screen\" tabindex=\"1\" data-theme=\"classic\" id=\"screen2\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(226, 236, 229); background-size: 600px 450px; background-image: url(&quot;https://levelbuilder-studio.code.org/blockly/media/1x1.gif&quot;); display: none;\" data-canonical-image-url=\"\" data-image-type=\"default\"><div contenteditable=\"true\" class=\"textArea\" id=\"leaderboard_console\" style=\"width: 240px; height: 450px; border-style: solid; background-color: rgb(84, 84, 84); color: rgb(253, 253, 253); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 1px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px; position: absolute; left: 325px; top: 0px; margin: 0px;\" data-mod-backgroundcolor=\"1\" data-mod-textcolor=\"1\" data-mod-fontfamily=\"1\">Developer Console<div>-------------------------</div></div><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1c/cellphone_wireframe.png\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"phone_BG2\" style=\"height: 450px; width: 235px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 50px; top: 0px; margin: 0px;\"><div contenteditable=\"false\" class=\"textArea\" id=\"leaderboard_output\" style=\"width: 185px; height: 280px; border-style: solid; background-color: rgb(241, 197, 197); color: rgb(0, 0, 0); border-color: rgb(153, 153, 153); border-radius: 12px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px; position: absolute; left: 75px; top: 80px; margin: 0px;\" data-mod-borderradius=\"1\">leaderboard</div><button id=\"refresh_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 25px; width: 55px; background-color: rgb(26, 188, 156); color: rgb(255, 255, 255); border-color: rgb(0, 0, 0); border-radius: 9px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 11px; position: absolute; left: 75px; top: 370px;\">Refresh</button><button id=\"share_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 25px; width: 55px; background-color: rgb(26, 188, 156); color: rgb(255, 255, 255); border-color: rgb(0, 0, 0); border-radius: 9px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 11px; position: absolute; left: 140px; top: 370px;\">Share</button><button id=\"profile_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 25px; width: 55px; background-color: rgb(26, 188, 156); color: rgb(255, 255, 255); border-color: rgb(0, 0, 0); border-radius: 9px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 11px; position: absolute; left: 205px; top: 370px;\">Profile</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(51, 51, 51); background-color: rgba(0, 0, 0, 0); border-color: rgb(153, 153, 153); border-radius: 0px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 29px; padding: 2px; width: 165px; height: 35px; position: absolute; left: 85px; top: 39px; text-align: center;\" id=\"label2\" data-mod-fontsize=\"1\">ScoreStack</label></div></div>",
    "bubble_choice_description": "An app designed to display and share your high scores on a variety of popular games!",
