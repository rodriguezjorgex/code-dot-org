    "start_blocks": "var pageIndex = 0;\r\nvar riskScore = 0;\r\nvar previousRiskScore = 0;\r\n\r\n// Define your categories\r\nvar selectedOptions = [\r\n  \"\", \"\", \"\", \"\",  // Page 0\r\n  \"\", \"\", \"\", \"\",  // Page 1\r\n  \"\", \"\", \"\", \"\"   // Page 2\r\n];\r\n\r\nvar pages = [\r\n  {\r\n    header: \"🔄 User Behavior & History\",\r\n    variables: [\r\n      {\r\n        label: \"Login Frequency\",\r\n        options: {\r\n          \"Multiple times per day\": 0,\r\n          \"Once per day\": 2,\r\n          \"Once a week\": 4,\r\n          \"First login in over a month\": 6,\r\n          \"First ever login\": 7\r\n        }\r\n      },\r\n      {\r\n        label: \"Previous Failed Logins\",\r\n        options: {\r\n          \"0 (clean record)\": 0,\r\n          \"1–2 failed attempts\": 3,\r\n          \"3–5 failed attempts\": 6,\r\n          \"More than 5\": 10\r\n        }\r\n      },\r\n      {\r\n        label: \"Password Strength\",\r\n        options: {\r\n          \"Strong (16+ chars, symbols)\": 0,\r\n          \"Medium (8–15 chars)\": 3,\r\n          \"Weak (short or common)\": 7,\r\n          \"Reused password\": 10\r\n        }\r\n      },\r\n      {\r\n        label: \"Change in Device\",\r\n        options: {\r\n          \"Trusted device\": 0,\r\n          \"New but similar device\": 4,\r\n          \"New device, different OS\": 7,\r\n          \"Flagged or suspicious device\": 10\r\n        }\r\n      }\r\n    ]\r\n  },\r\n  {\r\n    header: \"🌍 Environmental Context\",\r\n    variables: [\r\n      {\r\n        label: \"Geographic Location\",\r\n        options: {\r\n          \"Usual city/country\": 0,\r\n          \"Nearby city\": 2,\r\n          \"Foreign but seen before\": 5,\r\n          \"New foreign location\": 8,\r\n          \"High-risk country\": 10\r\n        }\r\n      },\r\n      {\r\n        label: \"Language Settings\",\r\n        options: {\r\n          \"Same as usual\": 0,\r\n          \"Recently changed\": 2,\r\n          \"Unfamiliar language\": 4,\r\n          \"Mismatch between system and browser\": 5\r\n        }\r\n      },\r\n      {\r\n        label: \"Time of Day\",\r\n        options: {\r\n          \"Normal login hours\": 0,\r\n          \"Slightly outside usual\": 1,\r\n          \"Middle of the night\": 3,\r\n          \"Drastically abnormal\": 4\r\n        }\r\n      },\r\n      {\r\n        label: \"Network Type\",\r\n        options: {\r\n          \"Home Wi-Fi\": 0,\r\n          \"Work/school network\": 1,\r\n          \"Mobile hotspot\": 4,\r\n          \"Public Wi-Fi\": 6,\r\n          \"Flagged ISP\": 10\r\n        }\r\n      }\r\n    ]\r\n  },\r\n  {\r\n    header: \"📈 Behavioral Patterns\",\r\n    variables: [\r\n      {\r\n        label: \"Typing Speed\",\r\n        options: {\r\n          \"Matches usual behavior\": 0,\r\n          \"Slightly slower/faster\": 1,\r\n          \"Robotic or exact timing\": 3,\r\n          \"Pasted instead of typed\": 4\r\n        }\r\n      },\r\n      {\r\n        label: \"Mouse Movement\",\r\n        options: {\r\n          \"Natural motion\": 0,\r\n          \"Erratic but human-like\": 2,\r\n          \"Sharp or jumpy\": 4,\r\n          \"Repetitive or bot-like\": 6\r\n        }\r\n      },\r\n      {\r\n        label: \"Autofill Usage\",\r\n        options: {\r\n          \"Typed manually\": 0,\r\n          \"Autofill from trusted device\": 1,\r\n          \"Autofill from unknown source\": 3,\r\n          \"Autofill + new device\": 4\r\n        }\r\n      },\r\n      {\r\n        label: \"Use of VPN/Proxy\",\r\n        options: {\r\n          \"No VPN\": 0,\r\n          \"Trusted VPN\": 4,\r\n          \"Proxy or Tor\": 8,\r\n          \"VPN + new device/location\": 10\r\n        }\r\n      }\r\n    ]\r\n  }\r\n];\r\n\r\n\r\nfunction populatePage(index) {\r\n  var page = pages[index];\r\n  setText(\"page_header_text\", page.header);\r\n\r\n  for (var i = 0; i < 4; i++) {\r\n    var dropdownId = \"option_dropdown\" + (i + 1);\r\n    var labelId = \"option_text\" + (i + 1);\r\n    var globalIndex = index * 4 + i;\r\n\r\n    setText(labelId, page.variables[i].label);\r\n    setProperty(dropdownId, \"options\", Object.keys(page.variables[i].options));\r\n    setText(dropdownId, selectedOptions[globalIndex]);\r\n  }\r\n\r\n  setProperty(\"back_button\", \"hidden\", index === 0);\r\n  setProperty(\"forward_button\", \"hidden\", index === pages.length - 1);\r\n}\r\n\r\n\r\nonEvent(\"forward_button\", \"click\", function() {\r\n  pageIndex++;\r\n  populatePage(pageIndex);\r\n  calculateRiskScore();\r\n});\r\n\r\nonEvent(\"back_button\", \"click\", function() {\r\n  pageIndex--;\r\n  populatePage(pageIndex);\r\n  calculateRiskScore();\r\n});\r\n\r\nfunction calculateRiskScore() {\r\n  // Calculate raw score from all selections\r\n  riskScore = 0;\r\n  for (var page = 0; page < pages.length; page++) {\r\n    for (var i = 0; i < 4; i++) {\r\n      var selection = selectedOptions[page * 4 + i];\r\n      if (selection !== \"\") {\r\n        var value = pages[page].variables[i].options[selection];\r\n        riskScore += value;\r\n      }\r\n    }\r\n  }\r\n  \r\n  // Clamp score between 0 and 90\r\n  riskScore = Math.max(0, Math.min(90, riskScore));\r\n  \r\n  // Update overlay position\r\n  var xPos = (riskScore / 90) * 460;\r\n  setPosition(\"risk_score_overlay\", xPos, getYPosition(\"risk_score_overlay\"));\r\n  \r\n  // Show visual delta if score changed\r\n  var delta = riskScore - previousRiskScore;\r\n  if (delta !== 0) {\r\n    animateScoreChange(delta);\r\n  }\r\n  previousRiskScore = riskScore;\r\n  \r\n  updateFooterText();\r\n\r\n}\r\n\r\nfunction animateScoreChange(delta) {\r\n  var text = (delta > 0 ? \"+\" : \"\") + delta;\r\n  var color = (delta > 0 ? \"red\" : \"green\");  \r\n  var startY = 135;\r\n  var endY = (delta > 0 ? 205 : 60);         \r\n  var duration = 1000;\r\n  var steps = 60;\r\n  var interval = duration / steps;\r\n  var deltaY = (endY - startY) / steps;\r\n\r\n  setText(\"score_visual\", text);\r\n  setProperty(\"score_visual\", \"text-color\", color);\r\n  setPosition(\"score_visual\", 255, startY);\r\n  setProperty(\"score_visual\", \"hidden\", false);\r\n\r\n  var step = 0;\r\n  var animation = setInterval(function() {\r\n    step++;\r\n    setPosition(\"score_visual\", 255, startY + deltaY * step);\r\n\r\n    if (step >= steps) {\r\n      clearInterval(animation);\r\n      setProperty(\"score_visual\", \"hidden\", true);\r\n      setPosition(\"score_visual\", 240, 145); // Reset position\r\n    }\r\n  }, interval);\r\n}\r\n\r\n\r\n\r\nfunction updateFooterText() {\r\n  var riskLabel = \"\";\r\n  var securityMessage = \"\";\r\n\r\n  if (riskScore <= 5) {\r\n    riskLabel = \"Low Risk\";\r\n    securityMessage = \"Password only required.\";\r\n  } else if (riskScore <= 20) {\r\n    riskLabel = \"Moderate Risk\";\r\n    securityMessage = \"Backup email verification required.\";\r\n  } else if (riskScore <= 40) {\r\n    riskLabel = \"High Risk\";\r\n    securityMessage = \"Email + SMS code required.\";\r\n  } else if (riskScore <= 60) {\r\n    riskLabel = \"Severe Risk\";\r\n    securityMessage = \"Biometric authentication required.\";\r\n  } else {\r\n    riskLabel = \"Critical Risk\";\r\n    securityMessage = \"Account temporarily locked. Admin review required.\";\r\n  }\r\n\r\n  // Update score text (label under the bar)\r\n  setText(\"score_text\", \"Risk Score: \" + riskScore + \" — \" + riskLabel);\r\n\r\n  // Update footer with recommended security protocols\r\n  setText(\"page_footer_text\", securityMessage);\r\n}\r\n\r\n\r\n\r\n// Recalculate score whenever a dropdown is changed\r\n// Dropdown 1\r\nonEvent(\"option_dropdown1\", \"change\", function() {\r\n  selectedOptions[pageIndex * 4 + 0] = getText(\"option_dropdown1\");\r\n  calculateRiskScore();\r\n});\r\n\r\n// Dropdown 2\r\nonEvent(\"option_dropdown2\", \"change\", function() {\r\n  selectedOptions[pageIndex * 4 + 1] = getText(\"option_dropdown2\");\r\n  calculateRiskScore();\r\n});\r\n\r\n// Dropdown 3\r\nonEvent(\"option_dropdown3\", \"change\", function() {\r\n  selectedOptions[pageIndex * 4 + 2] = getText(\"option_dropdown3\");\r\n  calculateRiskScore();\r\n});\r\n\r\n// Dropdown 4\r\nonEvent(\"option_dropdown4\", \"change\", function() {\r\n  selectedOptions[pageIndex * 4 + 3] = getText(\"option_dropdown4\");\r\n  calculateRiskScore();\r\n});\r\n\r\npopulatePage(0);\r\ncalculateRiskScore();\r\n\r\n\r\n",
    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: none;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"polar\" id=\"screen1\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(174, 226, 244);\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson8-level4/risk_score_thermometer.png?t=1753903568000\" data-canonical-image-url=\"image://risk_score_thermometer.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"risk_score_calculator\" style=\"height: 100px; width: 600px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 0px; top: 365px; margin: 0px;\"><div contenteditable=\"true\" class=\"textArea\" id=\"page_header_text\" style=\"width: 550px; height: 40px; border-style: solid; background-color: rgb(55, 157, 241); color: rgb(239, 250, 255); border-color: rgba(255, 255, 255, 0); border-radius: 8px; border-width: 2px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 22px; padding: 5px 15px; position: absolute; left: 25px; top: 5px; margin: 0px; text-align: center;\">page_header_text</div><button id=\"forward_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 60px; width: 65px; background-color: rgba(239, 250, 255, 0); color: rgb(0, 148, 202); border-color: rgba(172, 207, 222, 0); border-radius: 20px; border-width: 2px; font-family: &quot;Comic Sans MS&quot;, cursive, sans-serif; font-size: 54px; position: absolute; left: 520px; top: 280px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/test-ai-powered-threats-defenses-lesson8-level4/next.png?t=1753902137000&quot;); background-size: contain; background-position: 50% 50%; background-repeat: no-repeat;\" data-canonical-image-url=\"image://next.png\" data-image-type=\"file\"></