    "start_libraries": "[{\"name\":\"I18n_GENAIU124L9\",\"description\":\"Translation library for Gen AI Unit 1 Lesson 9 levels\",\"functions\":[\"translate\",\"getTranslations\",\"testTranslatability\"],\"dropletConfig\":[{\"func\":\"I18n_GENAIU124L9.translate\",\"category\":\"Functions\",\"comment\":\"Returns the i18n string for a given key\",\"type\":\"either\",\"params\":[\"key\"],\"paletteParams\":[\"key\"]},{\"func\":\"I18n_GENAIU124L9.getTranslations\",\"category\":\"Functions\",\"comment\":\"returns the TRANSLATIONTEXT JSON object\",\"type\":\"either\"},{\"func\":\"I18n_GENAIU124L9.testTranslatability\",\"category\":\"Functions\",\"comment\":\"This function adds \\\"!!\\\" to the start of every string in TRANSLATIONTEXT.\\nThis function is for DEBUGGING PURPOSES ONLY.\\nWhen debugging: A levelbuilder should call this at the very beginning of the level in order to\\nsee that all of the places where they expect a translation are getting a transaltion\\n(because the !! will show for translated texts)\",\"type\":\"either\"}],\"source\":\"var TRANSLATIONTEXT = {\\n  \\\"titleLabel_0\\\": \\\"Mad Lib Widget\\\",\\n  \\\"probabilityTitle2Label_1\\\": \\\"Start Here!\\\",\\n  \\\"probabilityTitle_2\\\": \\\"Generate Probability Mad Lib\\\",\\n  \\\"probabilityLockedNoun1_3\\\": \\\"Noun 1: ?????\\\",\\n  \\\"probabilityLockedNoun2_4\\\": \\\"Noun 2: ?????\\\",\\n  \\\"probabilityLockedNoun3_5\\\": \\\"Noun 3: ?????\\\",\\n  \\\"probabilityLockedNoun4_6\\\": \\\"Noun 4: ?????\\\",\\n  \\\"probabilityLockedNoun5_7\\\": \\\"Noun 5: ?????\\\",\\n  \\\"probabilityLockedNoun6_8\\\": \\\"Noun 6: ?????\\\",\\n  \\\"probabilityNoun2Score_9\\\": \\\"100\\\",\\n  \\\"probabilityNoun3Score_10\\\": \\\"100\\\",\\n  \\\"probabilityNoun4Score_11\\\": \\\"100\\\",\\n  \\\"probabilityNoun5Score_12\\\": \\\"100\\\",\\n  \\\"probabilityNoun6Score_13\\\": \\\"100\\\",\\n  \\\"probabilityNoun1Score_14\\\": \\\"100\\\",\\n  \\\"probabilityNounLabel_15\\\": \\\"set with PROBABILITYLABEL\\\",\\n  \\\"dataTitle_16\\\": \\\"View Data\\\",\\n  \\\"generateTitleLabel_17\\\": \\\"Generate a Mad Lib\\\",\\n  \\\"homeGenerateButton_18\\\": \\\"Generate a Mad Lib\\\",\\n  \\\"homeDataButton_19\\\": \\\"View Data + Random Mad Lib\\\",\\n  \\\"homeProbabilityButton_20\\\": \\\"Probability Mad Lib\\\",\\n  \\\"probabilityGenerateButton_21\\\": \\\"Generate Mad Lib\\\",\\n  \\\"probabilityRestartButton_22\\\": \\\"Restart This Screen\\\",\\n  \\\"probabilityCalculateButton_23\\\": \\\"Calculate Scores\\\",\\n  \\\"probabilityContinueButton_24\\\": \\\"Continue\\\",\\n  \\\"dataViewButton_25\\\": \\\"View Data\\\",\\n  \\\"dataRandomButton_26\\\": \\\"Random Mad Lib From the Data\\\",\\n  \\\"generateGenerateButton_27\\\": \\\"Generate Mad Lib\\\",\\n  \\\"probabilityMadlibText_28\\\": \\\"Set with PROBABILITYMADLIBSTRING\\\",\\n  \\\"dataTextArea_29\\\": \\\"use DATATEXTSTRING variable to fill this box\\\",\\n  \\\"generateMadLibText_30\\\": \\\"use GENERATETEXTSTRING variable to fill this box\\\",\\n  \\\"detailsLabelMouseover\\\": \\\"Generate a Mad Lib - this will let you enter 6 words to generate a mad lib that matches the example used in class.\\\",\\n  \\\"dataLabelMouseover\\\": \\\"View Data + Random Mad Lib - this will let you view the raw data from 1000 people who also completed this mad lib. You can also randomly view one of the mad libs from this dataset\\\",\\n  \\\"probabilityLabelMouseover\\\": \\\"Probability Mad Lib - this will let you enter multiple possibilities for a single blank, and then the program will choose the word most popular amongst the answers from the 1000 people who completed this same mad lib.\\\",\\n  \\\"madlibsentence1\\\": \\\"Once upon a time, in a vast and mystical \\\",\\n  \\\"madlibsentence2\\\": \\\", there lived a small yet adventurous \\\",\\n  \\\"madlibsentence3\\\": \\\". Every morning, it would set out to explore the \\\",\\n  \\\"madlibsentence4\\\": \\\", searching for hidden treasures and secret \\\",\\n  \\\"madlibsentence5\\\": \\\". One day, during its travels, it stumbled upon an ancient \\\",\\n  \\\"madlibsentence6\\\": \\\", covered in vines and mystery. Inside, there was a magical \\\",\\n  \\\"madlibsentence7\\\": \\\" that promised to grant the finder their heart's deepest desire.\\\",\\n  \\\"madlibnumber\\\": \\\"Mad Lib #\\\",\\n  \\\"nounLabel\\\": \\\"Noun\\\",\\n  \\\"noun1\\\": \\\"forest\\\",\\n  \\\"noun2\\\": \\\"passageways\\\",\\n  \\\"noun3\\\": \\\"pancake\\\",\\n  \\\"noun4\\\": \\\"toothbrush\\\",\\n  \\\"noun5\\\": \\\"fox\\\",\\n  \\\"noun6\\\": \\\"map\\\",\\n  \\\"noun7\\\": \\\"spatula\\\",\\n  \\\"noun8\\\": \\\"sandwich\\\",\\n  \\\"noun9\\\": \\\"cave\\\",\\n  \\\"noun10\\\": \\\"sword\\\",\\n  \\\"noun11\\\": \\\"pencil\\\",\\n  \\\"noun12\\\": \\\"glitter\\\",\\n  \\\"noun13\\\": \\\"kingdom\\\",\\n  \\\"noun14\\\": \\\"chambers\\\",\\n  \\\"noun15\\\": \\\"refrigerator\\\",\\n  \\\"noun16\\\": \\\"stapler\\\",\\n  \\\"noun17\\\": \\\"knight\\\",\\n  \\\"noun18\\\": \\\"door\\\",\\n  \\\"noun19\\\": \\\"encyclopedia\\\",\\n  \\\"noun20\\\": \\\"elevator\\\",\\n  \\\"noun21\\\": \\\"castle\\\",\\n  \\\"noun22\\\": \\\"lamp\\\",\\n  \\\"noun23\\\": \\\"headphone\\\",\\n  \\\"noun24\\\": \\\"microwave\\\",\\n  \\\"noun25\\\": \\\"desert\\\",\\n  \\\"noun26\\\": \\\"books\\\",\\n  \\\"noun27\\\": \\\"telescope\\\",\\n  \\\"noun28\\\": \\\"candle\\\",\\n  \\\"noun29\\\": \\\"robot\\\",\\n  \\\"noun30\\\": \\\"book\\\",\\n  \\\"noun31\\\": \\\"flashlight\\\",\\n  \\\"noun32\\\": \\\"sticker\\\",\\n  \\\"noun33\\\": \\\"garden\\\",\\n  \\\"noun34\\\": \\\"mirror\\\",\\n  \\\"noun35\\\": \\\"skateboard\\\",\\n  \\\"noun36\\\": \\\"feather\\\",\\n  \\\"noun37\\\": \\\"ocean\\\",\\n  \\\"noun38\\\": \\\"artifacts\\\",\\n  \\\"noun39\\\": \\\"notebook\\\",\\n  \\\"noun40\\\": \\\"harmonica\\\",\\n  \\\"noun41\\\": \\\"fairy\\\",\\n  \\\"noun42\\\": \\\"crystal\\\",\\n  \\\"noun43\\\": \\\"cactus\\\",\\n  \\\"noun44\\\": \\\"marble\\\",\\n  \\\"noun45\\\": \\\"stone\\\",\\n  \\\"noun46\\\": \\\"pineapple\\\",\\n  \\\"noun47\\\": \\\"cookie\\\",\\n  \\\"noun48\\\": \\\"valley\\\",\\n  \\\"noun49\\\": \\\"ruins\\\",\\n  \\\"noun50\\\": \\\"umbrella\\\",\\n  \\\"noun51\\\": \\\"snowglobe\\\",\\n  \\\"noun52\\\": \\\"dragon\\\",\\n  \\\"noun53\\\": \\\"locket\\\",\\n  \\\"noun54\\\": \\\"blanket\\\",\\n  \\\"noun55\\\": \\\"pillow\\\",\\n  \\\"noun56\\\": \\\"mountain\\\",\\n  \\\"noun57\\\": \\\"amulet\\\",\\n  \\\"noun58\\\": \\\"thermostat\\\",\\n  \\\"noun59\\\": \\\"sneaker\\\",\\n  \\\"noun60\\\": \\\"island\\\",\\n  \\\"noun61\\\": \\\"scrolls\\\",\\n  \\\"noun62\\\": \\\"balloon\\\",\\n  \\\"noun63\\\": \\\"keyboard\\\",\\n  \\\"noun64\\\": \\\"pirate\\\",\\n  \\\"noun65\\\": \\\"chest\\\",\\n  \\\"noun66\\\": \\\"teapot\\\",\\n  \\\"noun67\\\": \\\"sunglasses\\\",\\n  \\\"noun68\\\": \\\"river\\\",\\n  \\\"noun69\\\": \\\"potion\\\",\\n  \\\"noun70\\\": \\\"bookmark\\\",\\n  \\\"noun71\\\": \\\"bubble\\\",\\n  \\n  \\\"DATATEXTSTRING\\\": \\\"You can do two things on this screen:\\\\n\\\\n1) View the data from 1000 peolple who completed the same mad lib, so  you can see all of the different choices they made for filling in the blanks\\\\n\\\\n2) Randomly view one of those mad-libs\\\\n\\\\nThe results will appear in this box!\\\",\\n  \\\"GENERATETEXTSTRING\\\": \\\"Type in each noun into the screen above, then click Generate Mad Lib. The resulting mad lib will show up here!\\\",\\n  \\\"PROBABILITYMADLIBSTRING\\\": \\\"1) On the left, enter all of the possible responses the class generated for Noun 1\\\\n\\\\n2) Click \\\\\\\"Calculate Scores\\\\\\\" button. This will compare the list of class possibilities to the dataset representing what 1000 other people submitted for their madlib. The scores will appear next to each word. After reviewing, press the Continue button\\\\n\\\\n3) The highest score will be chosen, and the top of the screen will update. Then the side-panel will refresh and you can now enter the class possibilities for Noun 2.\\\\n\\\\n4) Follow the same steps until all of the most popular nouns have been chosen\\\\n\\\\n5) Once all the nouns have been selected, A Generate Mad Lib button will appear. Press it to generate the mad lib!\\\\n\\\\nAt any time, press the \\\\\\\"Restart This Screen\\\\\\\" button to start this process over\\\",\\n  \\\"DETAILSLABELSTRING\\\": \\\"Hover over a button to see what it does\\\",\\n  \\\"PROBABILITYLABEL\\\": \\\"Enter possibilities for Noun \\\"\\n};\\n\\n\\n\\n//Returns the i18n string for a given key\\nfunction translate(key) {\\n  return TRANSLATIONTEXT[key];\\n}\\n\\n//returns the TRANSLATIONTEXT JSON object\\nfunction getTranslations() {\\n  return TRANSLATIONTEXT;\\n}\\n\\n/*\\nThis function adds \\\"!!\\\" to the start of every string in TRANSLATIONTEXT.\\nThis function is for DEBUGGING PURPOSES ONLY.\\nWhen debugging: A levelbuilder should call this at the very beginning of the level in order to\\nsee that all of the places where they expect a translation are getting a transaltion\\n(because the !! will show for translated texts)\\n*/\\nfunction testTranslatability() {\\n  var keys = Object.keys(TRANSLATIONTEXT);\\n  for(var i = 0; i < keys.length; i++) {\\n    var key = keys[i];\\n    TRANSLATIONTEXT[key] = \\\"!!\\\" + TRANSLATIONTEXT[key];\\n  }\\n}\\n\",\"originalName\":\"I18n_GENAIU124L9\",\"versionId\":\"2CpXMruQav9lMGQ6W3qXzQ6zqX2rNM0H\",\"channelId\":\"ExlOHqgjqe6ouXxkA1gjnA\",\"fromLevelbuilder\":true}]",
    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: none;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"default\" id=\"wordScreen\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 255, 255); display: block;\"><label id=\"title-label\" style=\"position: absolute; top: 0px; left: 0px; width: 600px; height: 30px; margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgb(244, 236, 82); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 26px; padding: 2px 15px; text-align: center;\">\n  First Word\n</label>\n\n<label id=\"label-word\" style=\"position: absolute; top: 50px; left: 20px; width: 100px; height: 30px; margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; text-align: right;\">Word</label>\n<input id=\"input-word\" type=\"text\" style=\"margin: 0px; border-style: solid; color: rgb(77, 87, 95); background-color: rgb(242, 242, 242); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; top: 50px; left: 130px; width: 400px; height: 30px;\">\n\n<label id=\"label-meaning-1\" style=\"position: absolute; top: 90px; left: 10px; width: 120px; height: 30px; margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; text-align: right;\">Meaning A</label>\n<input id=\"input-meaning-1\" type=\"text\" style=\"margin: 0px; border-style: solid; color: rgb(77, 87, 95); background-color: rgb(242, 242, 242); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; top: 90px; left: 130px; width: 400px; height: 30px;\">\n\n<label id=\"label-meaning-2\" style=\"position: absolute; top: 130px; left: 20px; width: 110px; height: 30px; margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; text-align: right;\">Meaning B</label>\n<input id=\"input-meaning-2\" type=\"text\" style=\"margin: 0px; border-style: solid; color: rgb(77, 87, 95); background-color: rgb(242, 242, 242); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; top: 130px; left: 130px; width: 400px; height: 30px;\">\n\n<label id=\"label-meaning-3\" style=\"position: absolute; top: 170px; left: 20px; width: 110px; height: 30px; margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; text-align: right;\">Meaning C</label>\n<input id=\"input-meaning-3\" type=\"text\" style=\"margin: 0px; border-style: solid; color: rgb(77, 87, 95); background-color: rgb(242, 242, 242); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; top: 170px; left: 130px; width: 400px; height: 30px;\">\n\n<label id=\"label-sentence\" style=\"position: absolute; top: 210px; left: 20px; width: 110px; height: 30px; margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; text-align: right;\">Sentence</label>\n\n<button id=\"button-back\" style=\"padding: 0px; margin: 0px; border-style: solid; background-color: rgb(255, 164, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; top: 350px; left: 130px; width: 100px; height: 40px;\">Back</button>\n<button id=\"button-continue\" style=\"padding: 0px; margin: 0px; border-style: solid; background-color: rgb(255, 164, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; top: 350px; left: 430px; width: 100px; height: 40px;\" class=\"design-mode-hidden\">Continue</button><div contenteditable=\"true\" class=\"textArea\" id=\"input-sentence\" style=\"width: 400px; height: 105px; border-style: solid; background-color: rgb(242, 242, 242); color: rgb(77, 87, 95); border-color: rgb(255, 255, 255); border-radius: 2px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 130px; top: 205px; margin: 0px;\"></div></div><div class=\"screen\" tabindex=\"1\" data-theme=\"default\" id=\"drawScreen\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 255, 255); display: none;\"><canvas width=\"600px\" height=\"210px\" id=\"canvas1\" style=\"position: absolute; left: 0px; top: 110px; margin: 0px; width: 600px; height: 210px;\"></canvas><div contenteditable=\"false\" class=\"textArea\" id=\"sentenceTextArea\" style=\"width: 495px; height: 210px; border-style: solid; background-color: rgb(242, 242, 242); color: rgb(77, 87, 95); border-color: rgb(255, 255, 255); border-radius: 2px; border-width: 1px; font-family: &quot;Lucida Console&quot;, Monaco, monospace; font-size: 19px; padding: 5px 15px; position: absolute; left: 50px; top: 110px; margin: 0px; line-height: 45px;\"></div><div contenteditable=\"false\" class=\"textArea\" id=\"directions\" style=\"width: 600px; height: 75px; border-style: solid; background-color: rgb(242, 242, 242); color: rgb(77, 87, 95); border-color: rgb(255, 255, 255); border-radius: 2px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 0px; top: 0px; margin: 0px;\">1) Read the sentence below, paying attention to the word in the yellow box<div>2) Click-and-drag your mouse over the sentence to draw on the screen. Draw a circle around the word, then draw arrows from other words that help you determine it's definition</div><div>3) Choose which definition matches the word in this sentence.</div></div><label id=\"wordLabel\" style=\"position: absolute; top: 75px; left: 0px; width: 600px; height: 35px; margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgb(244, 236, 82); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 26px; padding: 2px 15px; text-align: center;\" data-mod-backgroundcolor=\"1\" data-mod-fontsize=\"1\"></label><button id=\"resetButtonDraw\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 195px; background-color: rgb(255, 164, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 200px; top: 420px;\">Reset</button><button id=\"nextButtonDraw\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 185px; background-color: rgb(255, 164, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 405px; top: 420px;\">Next</button><button id=\"previousButtonDraw\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 180px; background-color: rgb(255, 164, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 10px; top: 420px;\">Previous</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; width: 570px; height: 30px; position: absolute; left: 0px; top: 320px; text-align: right;\" id=\"meaningA-label-draw\"></label><input type=\"radio\" name=\"meaning\" id=\"meaningA-radio-draw\" style=\"width: 25px; height: 25px; margin: 0px; position: absolute; left: 570px; top: 320px;\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; width: 570px; height: 30px; position: absolute; left: 0px; top: 350px; text-align: right;\" id=\"meaningB-label-draw\"></label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; width: 570px; height: 30px; position: absolute; left: 0px; top: 380px; text-align: right;\" id=\"meaningC-label-draw\"></label><input type=\"radio\" name=\"meaning\" id=\"meaningB-radio-draw\" style=\"width: 25px; height: 25px; margin: 0px; position: absolute; left: 570px; top: 350px;\"><input type=\"radio\" name=\"meaning\" id=\"meaningC-radio-draw\" style=\"width: 25px; height: 25px; margin: 0px; position: absolute; left: 570px; top: 380px;\"></div><div class=\"screen\" tabindex=\"1\" data-theme=\"default\" id=\"transitionScreen\" style=\"display: none; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 255, 255);\"><div contenteditable=\"false\" class=\"textArea\" id=\"text_area1\" style=\"width: 555px; height: 375px; border-style: solid; background-color: rgb(255, 255, 255); color: rgb(77, 87, 95); border-color: rgb(175, 165, 165); border-radius: 8px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 21px; padding: 5px 15px; position: absolute; left: 20px; top: 15px; margin: 0px; text-align: center;\">Great Work!<div><br></div><div>For the next step, a different person will need to sit at this screen</div><div><br></div><div>They are going to attempt to guess which meaning you meant using only context-clues from the sentence you created.</div><div><br></div><div>When you've passed this screen to someone else, press continue!</div></div><button id=\"transitionContinue\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 100px; background-color: rgb(255, 164, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 245px; top: 395px;\">Continue</button></div></div>",
    "start_blocks": "var TEST = false;\n\n//------------------WORD SCREEN----------------------\n\n// Data array\nvar entries = [];\nvar currentIndex = 0;\n\n// Get all necessary elements\nvar inputA = \"input-word\";\nvar inputB = \"input-meaning-1\";\nvar inputC = \"input-meaning-2\";\nvar inputD = \"input-meaning-3\";\nvar sentenceInput = \"input-sentence\";\nvar title = \"title-label\";\nvar btnBack = \"button-back\";\nvar btnContinue = \"button-continue\";\n\nfor(var i = 0; i < 3; i++) {\n  var temp = {\n    word: getText(inputA),\n    meaningA: getText(inputB),\n    meaningB: getText(inputC),\n    meaningC: getText(inputD),\n    sentence: getText(sentenceInput)\n  };\n  entries.push(temp);\n}\n\nif(TEST) {\n  entries = [\n      {\n          \"word\": \"Spring\",\n          \"meaningA\": \"A mechanical coil\",\n          \"meaningB\": \"To jump lightly into action\",\n          \"meaningC\": \"A Season\",\n          \"sentence\": \"As the flowers bloomed, Chris could feel that Spring was here\"\n      },\n      {\n          \"word\": \"Fly\",\n          \"meaningA\": \"An annoying insect\",\n          \"meaningB\": \"To soar or levitate through the air\",\n          \"meaningC\": \"A good looking outfit\",\n          \"sentence\": \"The glitter vest and crimson jeans made him look fly.\"\n      },\n      {\n          \"word\": \"Date\",\n          \"meaningA\": \"A fruit from desert trees\",\n          \"meaningB\": \"Go out with someone, like having dinner or a movie\",\n          \"meaningC\": \"A certain day on the calendar\",\n          \"sentence\": \"Andy and Micah both wanted to see the new Star Wars movie together, so they set a date to go out\"\n      }\n  ];\n  loadInputs(entries[0]);\n  loadDrawScreen(entries[0]);\n  showElement(\"button-continue\");\n}\n\n// Placeholder \"word\" titles\nvar words = [\"First Word\", \"Second Word\", \"Third Word\"];\n\n// Function to check if all inputs are filled\nfunction checkInputs() {\n  if (\n    getText(inputA).trim() &&\n    getText(inputB).trim() &&\n    getText(inputC).trim() &&\n    getText(inputD).trim() &&\n    getText(sentenceInput).trim()\n  ) {\n    showElement(btnContinue);\n  } else {\n    hideElement(btnContinue);\n  }\n}\n\n// Function to clear inputs\nfunction clearInputs() {\n  setText(inputA, \"\");\n  setText(inputB, \"\");\n  setText(inputC, \"\");\n  setText(inputD, \"\");\n  setText(sentenceInput, \"\");\n}\n\n// Function to load data into inputs\nfunction loadInputs(obj) {\n  setText(inputA, obj.word);\n  setText(inputB, obj.meaningA);\n  setText(inputC, obj.meaningB);\n  setText(inputD, obj.meaningC);\n  setText(sentenceInput, obj.sentence);\n}\n\n// Function to update the title\nfunction updateTitle() {\n  var word = words[currentIndex] || \"Word \" + (currentIndex + 1);\n  setText(title, word);\n}\n\n// Event listeners\n\nonEvent(inputA, \"input\", function() {\n checkInputs(); \n});\nonEvent(inputB, \"input\", function() {\n checkInputs(); \n});\nonEvent(inputC, \"input\", function() {\n checkInputs(); \n});\nonEvent(inputD, \"input\", function() {\n checkInputs(); \n});\nonEvent(sentenceInput, \"input\", function() {\n checkInputs(); \n});\n\nonEvent(btnContinue, \"click\", function () {\n  var obj = {\n    word: getText(inputA),\n    meaningA: getText(inputB),\n    meaningB: getText(inputC),\n    meaningC: getText(inputD),\n    sentence: getText(sentenceInput)\n  };\n  \n  // Store current entry\n  entries[currentIndex] = obj;\n  currentIndex++;\n  \n  if (currentIndex >= entries.length) {\n    setScreen(\"transitionScreen\"); // Only called once, after 3 entries\n    loadDrawScreen(entries[0]);\n    currentIndex = 0;\n    return;\n  }\n  \n  // Clear inputs for new entry\n  loadInputs(entries[currentIndex]);\n  updateTitle();\n  checkInputs(); // Hides button again\n});\n\n// Back button click handler\nonEvent(btnBack, \"click\", function () {\n  if (currentIndex > 0) {\n    currentIndex--;\n    loadInputs(entries[currentIndex]);\n    updateTitle();\n    checkInputs();\n  }\n});\n\n\n\n//--------------------DRAWING SCREEN---------------\n\n// Set in Design mode\n// setStyle(\"sentenceTextArea\", \"line-height: 45px\");\n\nsetStyle(\"canvas1\", \"z-index: 2\");\n\nsetActiveCanvas(\"canvas1\");\n\nvar DRAGGING = false;\n\nfunction loadDrawScreen(obj) {\n  setText(\"wordLabel\", obj.word);\n  setText(\"sentenceTextArea\", obj.sentence);\n  setText(\"meaningA-label-draw\", obj.meaningA);\n  setText(\"meaningB-label-draw\", obj.meaningB);\n  setText(\"meaningC-label-draw\", obj.meaningC);\n  if(obj.canvasData) {\n    putImageData(obj.canvasData, 0, 0);\n  }\n  if(obj.selected) {\n    setChecked(\"meaning\" + obj.selected + \"-radio-draw\", true);\n  } else {\n    setChecked(\"meaningA-radio-draw\", false);\n    setChecked(\"meaningB-radio-draw\", false);\n    setChecked(\"meaningC-radio-draw\", false);\n  }\n}\n\nonEvent(\"canvas1\", \"mousedown\", function() {\n\tDRAGGING = true;\n});\n\nonEvent(\"canvas1\", \"mouseup\", function() {\n\tDRAGGING = false;\n});\n\nonEvent(\"canvas1\", \"mousemove\", function(event) {\n\tif(DRAGGING) {\n\t  circle(event.offsetX, event.offsetY, 2);\n\t}\n});\n\nonEvent(\"resetButtonDraw\", \"click\", function( ) {\n\tclearCanvas();\n});\n\nvar CANVASTEMP;\n\nonEvent(\"previousButtonDraw\", \"click\", function( ) {\n\tif((currentIndex - 1) < 0) {\n\t  //if about to go under: return;\n\t  return;\n\t}\n\tentries[currentIndex].canvasData = getImageData(0, 0, 600, 210);\n\tclearCanvas();\n\tcurrentIndex--;\n\tloadDrawScreen(entries[currentIndex]);\n});\n\nonEvent(\"nextButtonDraw\", \"click\", function( ) {\n\tif((currentIndex + 1) >= entries.length) {\n\t  //if about to go over: return;\n\t  return;\n\t}\n\tentries[currentIndex].canvasData = getImageData(0, 0, 600, 210);\n\tclearCanvas();\n\tcurrentIndex++;\n\tloadDrawScreen(entries[currentIndex]);\n});\n\nonEvent(\"meaningA-radio-draw\", \"change\", function( ) {\n\tif(getChecked(\"meaningA-radio-draw\")) {\n\t  entries[currentIndex].selected = \"A\";\n\t}\n});\n\nonEvent(\"meaningB-radio-draw\", \"change\", function( ) {\n\tif(getChecked(\"meaningB-radio-draw\")) {\n\t  entries[currentIndex].selected = \"B\";\n\t}\n});\n\nonEvent(\"meaningC-radio-draw\", \"change\", function( ) {\n\tif(getChecked(\"meaningC-radio-draw\")) {\n\t  entries[currentIndex].selected = \"C\";\n\t}\n});\nonEvent(\"transitionContinue\", \"click\", function( ) {\n\tsetScreen(\"drawScreen\");\n});",
    "preload_asset_list": null
  },
  "published": true,
  "audit_log": "[{\"changed_at\":\"2025-05-06T18:47:53.785+00:00\",\"changed\":[\"cloned from \\\"genai-embeddings-widget_2025\\\"\"],\"cloned_from\":\"genai-embeddings-widget_2025\"},{\"changed_at\":\"2025-05-06 18:48:14 +0000\",\"changed\":[\"code_functions\",\"long_instructions\",\"start_blocks\",\"start_html\",\"preload_asset_list\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:49:11 +0000\",\"changed\":[],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:50:35 +0000\",\"changed\":[\"start_html\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:50:50 +0000\",\"changed\":[\"start_html\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:51:23 +0000\",\"changed\":[\"start_html\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:51:49 +0000\",\"changed\":[\"start_blocks\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:52:20 +0000\",\"changed\":[\"start_html\",\"start_blocks\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:52:55 +0000\",\"changed\":[\"code_functions\",\"start_html\",\"preload_asset_list\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:53:10 +0000\",\"changed\":[\"start_html\",\"start_blocks\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:53:51 +0000\",\"changed\":[\"start_html\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:54:39 +0000\",\"changed\":[\"start_html\",\"start_blocks\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-05-06 18:54:50 +0000\",\"