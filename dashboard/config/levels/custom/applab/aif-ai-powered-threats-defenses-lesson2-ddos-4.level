    "start_blocks": "// Initial Visitor Count\r\nvar visitorCount = 1000000;\r\n\r\n// Start visitor count increment\r\nsetInterval(function() {\r\n  visitorCount += randomNumber(30000, 100000); // simulate real-time increase\r\n  setText(\"visitor_count_label\", visitorCount);\r\n}, 500); // updates every half second\r\n\r\n// Click \"get tickets\" to show join queue screen\r\nonEvent(\"get_tickets_btn\", \"click\", function() {\r\n  showElement(\"join_queue_window\");\r\n  showElement(\"join_queue_btn\");\r\n  showElement(\"visitor_count_label\");\r\n});\r\n\r\n// Click \"join the queue\" to show waiting room, then auto-advance\r\nonEvent(\"join_queue_btn\", \"click\", function() {\r\n  showElement(\"waiting_room_window\");\r\n\r\n  // After 10 seconds, move to queue\r\n  setTimeout(function() {\r\n    showElement(\"queue_window\");\r\n\r\n    // After another 10 seconds, move to ticketmaster error\r\n    setTimeout(function() {\r\n      showElement(\"ticketmaster_error_window\");\r\n\r\n      // After another 10 seconds, move to 503 error\r\n      setTimeout(function() {\r\n        showElement(\"503_error\");\r\n      }, 20000);\r\n\r\n    }, 20000);\r\n\r\n  }, 10000);\r\n});\r\n",
