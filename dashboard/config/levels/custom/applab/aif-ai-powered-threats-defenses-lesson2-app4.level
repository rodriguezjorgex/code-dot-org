al Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 15px; top: 20px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/folder.png&quot;); background-size: contain; background-position: 50% 50%; background-repeat: no-repeat;\" data-canonical-image-url=\"image://folder.png\" data-image-type=\"file\"></button><button id=\"email_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 80px; width: 60px; background-color: rgba(255, 164, 0, 0); color: rgb(255, 255, 255); border-color: rgba(77, 87, 95, 0.05); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 15px; top: 215px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/email.png&quot;); background-size: contain; background-position: 50% 50%; background-repeat: no-repeat;\" data-canonical-image-url=\"image://email.png\" data-image-type=\"file\"></button><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/Pasted Graphic 7 2.png\" data-canonical-image-url=\"image://Pasted Graphic 7 2.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"email_inbox_window\" style=\"height: 350px; width: 540px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; top: 55px; margin: 0px; left: 50px;\" class=\"design-mode-hidden\"><button id=\"email_x_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 20px; width: 20px; background-color: rgb(255, 0, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 10px; position: absolute; left: 549px; top: 58px;\" class=\"design-mode-hidden\">X</button><button id=\"email_new_email_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 100px; background-color: rgb(255, 111, 12); color: rgb(255, 255, 255); border-color: rgba(77, 87, 95, 0); border-radius: 8px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 12px; position: absolute; left: 85px; top: 100px;\" class=\"design-mode-hidden\">+ New Email</button><button id=\"email_inbox_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 100px; background-color: rgba(100, 93, 87, 0); color: rgb(30, 1, 1); border-color: rgba(77, 87, 95, 0); border-radius: 8px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 12px; position: absolute; left: 85px; top: 140px; text-align: left;\" class=\"design-mode-hidden\">Inbox (3)</button><button id=\"email_sent_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 100px; background-color: rgba(100, 93, 87, 0); color: rgb(30, 1, 1); border-color: rgba(77, 87, 95, 0); border-radius: 8px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 12px; position: absolute; left: 85px; top: 170px; text-align: left;\" class=\"design-mode-hidden\">Sent</button><button id=\"email_spam_trash\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 100px; background-color: rgba(100, 93, 87, 0); color: rgb(30, 1, 1); border-color: rgba(77, 87, 95, 0); border-radius: 8px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 12px; position: absolute; left: 85px; top: 200px; text-align: left;\" class=\"design-mode-hidden\">Spam</button><button id=\"email_trash_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 100px; background-color: rgba(100, 93, 87, 0); color: rgb(30, 1, 1); border-color: rgba(77, 87, 95, 0); border-radius: 8px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 12px; position: absolute; left: 85px; top: 230px; text-align: left;\" class=\"design-mode-hidden\">Trash</button><button id=\"email_coach\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 50px; width: 125px; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Lucida Sans Unicode&quot;, &quot;Lucida Grande&quot;, sans-serif; font-size: 12px; position: absolute; left: 200px; top: 100px; text-align: left;\" class=\"design-mode-hidden\">From: headcoach@...</button><button id=\"email_jon\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 50px; width: 124px; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Lucida Sans Unicode&quot;, &quot;Lucida Grande&quot;, sans-serif; font-size: 12px; position: absolute; left: 200px; top: 155px; text-align: left;\" class=\"design-mode-hidden\">From: jon.carlo@...</button><button id=\"email_haley\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 50px; width: 124px; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Lucida Sans Unicode&quot;, &quot;Lucida Grande&quot;, sans-serif; font-size: 12px; position: absolute; left: 200px; top: 210px; text-align: left;\" class=\"design-mode-hidden\">From: haley.smith@..</button><div contenteditable=\"true\" class=\"textArea design-mode-hidden\" id=\"email_from_coach\" style=\"width: 225px; height: 300px; border-style: solid; background-color: rgba(242, 242, 242, 0); color: rgb(77, 87, 95); border-color: rgb(255, 255, 255); border-radius: 2px; border-width: 1px; font-family: &quot;Lucida Sans Unicode&quot;, &quot;Lucida Grande&quot;, sans-serif; font-size: 12px; padding: 5px 15px; position: absolute; left: 335px; top: 95px; margin: 0px;\">Subject: No Practice Today<div><br></div><div>From: headcoach@whs.edu</div><div><br></div><div>Hello,</div><div><br></div><div>Today's practice is cancelled. We will meet next Wednesday.</div><div><br></div><div>Thanks,</div><div>Coach</div></div><div contenteditable=\"true\" class=\"textArea design-mode-hidden\" id=\"email_from_jon\" style=\"width: 225px; height: 300px; border-style: solid; background-color: rgba(255, 255, 255, 0); color: rgb(77, 87, 95); border-color: rgb(255, 255, 255); border-radius: 2px; border-width: 1px; font-family: &quot;Lucida Sans Unicode&quot;, &quot;Lucida Grande&quot;, sans-serif; font-size: 12px; padding: 5px 15px; position: absolute; left: 335px; top: 95px; margin: 0px;\">Subject: No Practice Today<div><br></div><div>From: jon.carlo@whs.edu</div><div><br></div><div>Hello,</div><div><br></div><div>Can we be partners for the upcoming project?</div><div><br></div><div>Thanks,</div><div>Jon</div></div><div contenteditable=\"true\" class=\"textArea design-mode-hidden\" id=\"email_from_haley\" style=\"width: 225px; height: 300px; border-style: solid; background-color: rgba(255, 255, 255, 0); color: rgb(0, 0, 0); border-color: rgb(255, 255, 255); border-radius: 2px; font-family: &quot;Lucida Sans Unicode&quot;, &quot;Lucida Grande&quot;, sans-serif; font-size: 12px; padding: 5px 15px; position: absolute; left: 335px; top: 95px; margin: 0px; border-width: 1px;\">Subject: Homework<div><br></div><div>From: haley.smith@whs.edu</div><div><br></div><div>Hello,</div><div><br></div><div>Can you share today's homework with me? I forgot to bring home my binder.</div><div><br></div><div>Haley</div></div><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/Pasted Graphic 8 2.png\" data-canonical-image-url=\"image://Pasted Graphic 8 2.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"files_window\" style=\"height: 425px; width: 435px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 55px; top: 50px; margin: 0px;\" class=\"design-mode-hidden\"><button id=\"files_x_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 16px; width: 16px; background-color: rgb(255, 0, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 8px; position: absolute; left: 470px; top: 113px;\" class=\"design-mode-hidden\">X</button><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/pdf.png\" data-canonical-image-url=\"image://pdf.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"pdf\" style=\"height: 60px; width: 55px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 90px; top: 150px; margin: 0px;\" class=\"design-mode-hidden\"><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/doc.png\" data-canonical-image-url=\"image://doc.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"doc\" style=\"height: 60px; width: 60px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 205px; top: 150px; margin: 0px;\" class=\"design-mode-hidden\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: Tahoma, Geneva, sans-serif; font-size: 13px; padding: 2px 15px; width: 92px; height: 18px; position: absolute; left: 70px; top: 220px; text-align: center;\" id=\"pdf_label\" class=\"design-mode-hidden\">grades.pdf</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0,