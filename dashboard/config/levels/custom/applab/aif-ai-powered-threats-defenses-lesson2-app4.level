    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: none;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"default\" id=\"screen1\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 255, 255); background-size: 600px 450px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/Pasted%20Graphic%205.png&quot;);\" data-canonical-image-url=\"image://Pasted Graphic 5.png\" data-image-type=\"file\"><button id=\"bin_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 75px; width: 80px; background-color: rgba(255, 164, 0, 0); color: rgb(255, 255, 255); border-color: rgba(77, 87, 95, 0); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 510px; top: 305px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/recycle-bin-icon-18.png&quot;); background-size: contain; background-position: 50% 50%; background-repeat: no-repeat;\" data-canonical-image-url=\"image://recycle-bin-icon-18.png\" data-image-type=\"file\"></button><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/home.png\" data-canonical-image-url=\"image://home.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image1\" style=\"height: 30px; width: 25px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 5px; top: 420px; margin: 0px;\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(255, 255, 255); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 12px; padding: 2px 15px; width: 53px; height: 17px; position: absolute; left: 531px; top: 385px; text-align: center;\" id=\"bin_label\">Bin</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(255, 255, 255); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 12px; padding: 2px 15px; width: 90px; height: 20px; position: absolute; left: 0px; top: 195px; text-align: center;\" id=\"chrome_label\">Chrome</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(255, 255, 255); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 12px; padding: 2px 15px; width: 90px; height: 20px; position: absolute; left: 0px; top: 85px; text-align: center;\" id=\"files_label\">Files</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(255, 255, 255); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 12px; padding: 2px 15px; height: 20px; position: absolute; left: 0px; top: 285px; text-align: center; width: 90px;\" id=\"email_label\">Email</label><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-app4/Pasted Graphic 5 2.png\" data-canonical-image-url=\"image://Pasted Graphic 5 2.png\" data-image-type=\"file\" data-object-fit=\"conta