    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: block;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"lemonade\" id=\"screen1\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 224, 73);\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1b/cellphone_wireframe.png\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"cellphone_BG\" style=\"height: 450px; width: 225px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 35px; top: 0px; margin: 0px;\"><div contenteditable=\"false\" class=\"textArea\" id=\"quiz_console\" style=\"width: 260px; height: 450px; border-style: solid; background-color: rgb(88, 84, 84); color: rgb(255, 255, 255); border-color: rgb(25, 58, 85); border-radius: 6px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px 15px; position: absolute; left: 300px; top: 0px; margin: 0px;\">Developer Console<div>---------------------------</div><div><br></div></div><input id=\"full_name_input\" style=\"margin: 0px; width: 175px; height: 30px; border-style: solid; color: rgb(8, 94, 140); background-color: rgb(255, 255, 255); border-color: rgb(25, 58, 85); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 60px; top: 135px;\" placeholder=\"Full name\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(8, 94, 140); background-color: rgba(0, 0, 0, 0); border-color: rgb(25, 58, 85); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 20px; padding: 2px 15px; width: 180px; height: 25px; position: absolute; left: 60px; top: 40px; text-align: center;\" id=\"label1\">FutureForm</label><input id=\"zip_input\" style=\"margin: 0px; width: 175px; height: 30px; border-style: solid; color: rgb(8, 94, 140); background-color: rgb(255, 255, 255); border-color: rgb(25, 58, 85); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 60px; top: 175px;\" placeholder=\"Zip code\"><input id=\"birthday_input\" style=\"margin: 0px; width: 175px; height: 30px; border-style: solid; color: rgb(8, 94, 140); background-color: rgb(255, 255, 255); border-color: rgb(25, 58, 85); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 60px; top: 215px;\" placeholder=\"Birthdate MM/DD/YYYY\"><input id=\"salary_input\" style=\"margin: 0px; width: 175px; height: 30px; border-style: solid; color: rgb(8, 94, 140); background-color: rgb(255, 255, 255); border-color: rgb(25, 58, 85); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 60px; top: 255px;\" placeholder=\"Desired Salary\"><button id=\"submit_quiz\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 100px; background-color: rgb(8, 94, 140); color: rgb(255, 255, 255); border-color: rgb(172, 207, 222); border-radius: 6px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 15px; position: absolute; left: 100px; top: 360px;\">Submit</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(8, 94, 140); background-color: rgba(0, 0, 0, 0); border-color: rgb(25, 58, 85); border-radius: 0px; border-width: 0px; font-family: Tahoma, Geneva, sans-serif; font-size: 14px; padding: 2px 15px; width: 185px; height: 65px; position: absolute; left: 55px; top: 75px;\" id=\"label2\">With just a little personal information, predict your future career path:</label></div><div class=\"screen\" tabindex=\"1\" data-theme=\"lemonade\" id=\"screen2\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 224, 73); display: none;\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1b/cellphone_wireframe.png\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"cellphone_BG2\" style=\"height: 450px; width: 225px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 35px; top: 0px; margin: 0px;\"><div contenteditable=\"true\" class=\"textArea\" id=\"result_console\" style=\"width: 260px; height: 450px; border-style: solid; background-color: rgb(88, 84, 84); color: rgb(255, 255, 255); border-color: rgb(25, 58, 85); border-radius: 6px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px 15px; position: absolute; left: 300px; top: 0px; margin: 0px;\">Developer Console<div>---------------------------</div><div><br></div></div><div contenteditable=\"true\" class=\"textArea\" id=\"career_match_tips\" style=\"width: 185px; height: 95px; border-style: solid; background-color: rgb(253, 246, 214); color: rgb(48, 55, 59); border-color: rgb(25, 58, 85); border-radius: 6px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 55px; top: 135px; margin: 0px;\">Static career advice</div><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(8, 94, 140); background-color: rgba(0, 0, 0, 0); border-color: rgb(25, 58, 85); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; width: 185px; height: 40px; position: absolute; left: 55px; top: 90px; text-align: center;\" id=\"career_result_title\">Matched job</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(8, 94, 140); background-color: rgba(0, 0, 0, 0); border-color: rgb(25, 58, 85); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 13px; padding: 2px 15px; width: 185px; height: 25px; position: absolute; left: 55px; top: 245px; text-align: center;\" id=\"match_quality_label\">Percent Match: </label><button id=\"retake_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 45px; width: 80px; background-color: rgb(8, 94, 140); color: rgb(255, 255, 255); border-color: rgb(172, 207, 222); border-radius: 6px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 15px; position: absolute; left: 60px; top: 350px;\">Retake</button><button id=\"share_result_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 45px; width: 80px; background-color: rgb(8, 94, 140); color: rgb(255, 255, 255); border-color: rgb(172, 207, 222); border-radius: 6px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 15px; position: absolute; left: 155px; top: 350px;\">Share</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(8, 94, 140); background-color: rgba(0, 0, 0, 0); border-color: rgb(25, 58, 85); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 20px; padding: 2px 15px; width: 180px; height: 25px; position: absolute; left: 60px; top: 40px; text-align: center;\" id=\"label5\" data-mod-fontsize=\"1\">FutureForm</label></div><div class=\"screen\" tabindex=\"1\" data-theme=\"lemonade\" id=\"screen3\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 224, 73); display: none;\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1b/cellphone_wireframe.png\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"cellphone_BG3\" style=\"height: 450px; width: 225px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 35px; top: 0px; margin: 0px;\"><div contenteditable=\"false\" class=\"textArea\" id=\"share_console\" style=\"width: 260px; height: 450px; border-style: solid; background-color: rgb(88, 84, 84); color: rgb(255, 255, 255); border-color: rgb(25, 58, 85); border-radius: 6px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px 15px; position: absolute; left: 300px; top: 0px; margin: 0px;\">Developer Console<div>---------------------------</div><div><br></div></div><input id=\"recipient_input\" style=\"margin: 0px; width: 175px; height: 30px; border-style: solid; color: rgb(8, 94, 140); background-color: rgb(255, 255, 255); border-color: rgb(25, 58, 85); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 12px; padding: 5px 15px; position: absolute; left: 60px; top: 80px;\" placeholder=\"Recipient (friend/teacher)\"><input id=\"share_message_input\" style=\"margin: 0px; width: 175px; height: 150px; border-style: solid; color: rgb(29, 33, 35); background-color: rgb(253, 246, 214); border-color: rgb(25, 58, 85); border-radius: 4px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 12px; padding: 5px 15px; position: absolute; left: 60px; top: 180px;\" placeholder=\"Custom message/notes\"><button id=\"back_to_result_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 45px; width: 80px; background-color: rgb(8, 94, 140); color: rgb(255, 255, 255); border-color: rgb(172, 207, 222); border-radius: 6px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 15px; position: absolute; left: 60px; top: 350px;\">Results</button><button id=\"share_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 45px; width: 80px; background-color: rgb(8, 94, 140); color: rgb(255, 255, 255); border-color: rgb(172, 207, 222); border-radius: 6px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 15px; position: absolute; left: 155px; top: 350px;\">Share</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(8, 94, 140); background-color: rgba(0, 0, 0, 0); border-color: rgb(25, 58, 85); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 20px; padding: 2px 15px; width: 180px; height: 25px; position: absolute; left: 60px; top: 40px; text-align: center;\" id=\"label6\" data-mod-fontsize=\"1\">FutureForm</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(8, 94, 140); background-color: rgba(0, 0, 0, 0); border-color: rgb(25, 58, 85); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 11px; padding: 2px 15px; width: 175px; height: 30px; position: absolute; left: 60px; top: 115px;\" id=\"send_job_label\">text</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(8, 94, 140); background-color: rgba(0, 0, 0, 0); border-color: rgb(25, 58, 85); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 11px; padding: 2px 15px; width: 175px; height: 30px; position: absolute; left: 60px; top: 145px;\" id=\"send_percent_match_label\">text</label></div></div>",
    "starter_assets": {
      "cellphone_wireframe.png": "e309e4b6-cafb-483e-9f90-556f8aab060b.png"
