    "start_blocks": "//NOTE: in Design Mode, these are actually buttons due to an interaction with image types and dragging\nvar SOLUTIONARRAY = [\n\t[\"dragA\", \"labelA\"],\n\t[\"dragB\", \"labelB\"]\n];\n\nAssessmentDraggable.initialize(SOLUTIONARRAY);\n\n\n//This is my validation logic. When it's all true, I call \"success\", which is what the levelbuilder validation is looking for.\nonEvent(\"checkButton\", \"click\", function( ) {\n\tvar correct = 0;\n\tfor(var i = 0; i < SOLUTIONARRAY.length; i++) {\n\t  if(AssessmentDraggable.checkCenterInside(SOLUTIONARRAY[i][0], SOLUTIONARRAY[i][1])) {\n\t    console.log(\"Success: \" + SOLUTIONARRAY[i][0] + \" is inside \" + SOLUTIONARRAY[i][1]);\n\t    correct += 1;\n\t  } else {\n\t    console.log(\"FAIL: \" + SOLUTIONARRAY[i][0] + \" is not inside \" + SOLUTIONARRAY[i][1]);\n\t  }\n\t}\n\tif(correct >= SOLUTIONARRAY.length) {\n\t  AssessmentDraggable.success();\n\t}\n});",
    "start_html": "<div id=\"designModeViz\" class=\"appModern\" data-radium=\"true\" style=\"display: none; width: 600px; height: 450px;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"default\" id=\"screen1\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 255, 255);\"><img src=\"/level_starter_assets/musiclab-hotspot-functions-test-withlibrary/musiclab-hotspot-test.png\" data-canonical-image-url=\"image://musiclab-hotspot-test.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image1\" style=\"height: 375px; width: 545px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 0px; top: 0px; margin: 0px;\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; padding: 2px 15px; width: 90px; height: 30px; position: absolute; left: 10px; top: 180px; font-size: 70px; text-align: center;\" id=\"labelB\"></label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; padding: 2px 15px; width: 125px; height: 35px; position: absolute; left: 265px; top: 10px; font-size: 70px; text-align: center;\" id=\"labelA\"></label><button id=\"checkButton\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 35px; width: 150px; background-color: rgb(255, 164, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 435px; top: 405px;\">Check Answers</button><button id=\"dragA\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 25px; width: 65px; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 2px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; position: absolute; left: 475px; top: 5px; background-size: contain; background-position: 50% 50%; background-repeat: no-repeat; background-image: url(&quot;https://levelbuilder-studio.code.org/blockly/media/1x1.gif&quot;); font-size: 19px;\" data-canonical-image-url=\"\" data-image-type=\"default\">A</button><button id=\"dragB\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 25px; width: 65px; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 2px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; position: absolute; left: 475px; top: 40px; background-size: contain; background-position: 50% 50%; background-repeat: no-repeat; background-image: url(&quot;https://levelbuilder-studio.code.org/blockly/media/1x1.gif&quot;); font-size: 19px;\" data-canonical-image-url=\"\" data-image-type=\"default\">B</button></div></div>",
    "long_instructions": "Drag the \"A\" to the place where a function is **Defined**\r\n\r\nDrag the \"B\" to the place where a function is **Called**",
    "starter_assets": {
      "musiclab-hotspot-test.png": "7472bfe2-e424-45c3-807b-dd3ac8185739.png"
    },
    "start_libraries": "[{\"name\":\"AssessmentDraggable\",\"description\":\"For incorporating drag and drop behavior with correct answers in widgets\",\"functions\":[\"success\",\"resetDragObj\",\"initialize\",\"checkCenterInside\"],\"dropletConfig\":[{\"func\":\"AssessmentDraggable.success\",\"category\":\"Functions\",\"comment\":\"This function is necessary for Validation to work in App Lab.\\nThis thread has a bunch of historical knowledge: https://codedotorg.slack.com/archives/C1B3PNDL7/p1662482867134019\\nBut essentially, the way validation works in App Lab is it relies on this running log of every command that runs in the program is kept.\\nYou can access it in the developer console with Applab.currentExecutionLog\\nAnd then the validation works by comparing the log with an expected output.\\nSo in this case, I'm making a success function and only calling it when I'm sure the level is complete\\nAnd then if you look at the \\\"Edit\\\" screen for this level in the validation section, you'll see a JSON object that essentially checks that this function was called at least 1 time\\nThis makes the actual levelbuilding-validation pretty easy and could be re-used across different levels\\nAnd the actual validation logic can happen inside this starter code, which is what I do later in the program.\",\"type\":\"either\"},{\"func\":\"AssessmentDraggable.resetDragObj\",\"category\":\"Functions\",\"comment\":\"resets drag object\",\"type\":\"either\"},{\"func\":\"AssessmentDraggable.initialize\",\"category\":\"Functions\",\"comment\":\"Initializes everything. Pass it the 2D array of (draggable, solution) IDs\",\"type\":\"either\",\"params\":[\"solArray\"],\"paletteParams\":[\"solArray\"]},{\"func\":\"AssessmentDraggable.checkCenterInside\",\"category\":\"Functions\",\"comment\":\"Checks if the center (x, y) of id1 is inside the bounding box of id2\",\"type\":\"either\",\"params\":[\"id1\",\"id2\"],\"paletteParams\":[\"id1\",\"id2\"]}],\"source\":\"//Hey! I should comment my code!\\r\\n//This is a Proof of Concept level that shows a few things: drag-and-drop in App Lab, and Validation\\r\\n\\r\\n\\r\\n//This function is necessary for Validation to work in App Lab.\\r\\n//This thread has a bunch of historical knowledge: https://codedotorg.slack.com/archives/C1B3PNDL7/p1662482867134019\\r\\n//But essentially, the way validation works in App Lab is it relies on this running log of every command that runs in the program is kept. \\r\\n//You can access it in the developer console with Applab.currentExecutionLog\\r\\n//And then the validation works by comparing the log with an expected output.\\r\\n//So in this case, I'm making a success function and only calling it when I'm sure the level is complete\\r\\n//And then if you look at the \\\"Edit\\\" screen for this level in the validation section, you'll see a JSON object that essentially checks that this function was called at least 1 time\\r\\n//This makes the actual levelbuilding-validation pretty easy and could be re-used across different levels\\r\\n//And the actual validation logic can happen inside this starter code, which is what I do later in the program.\\r\\nfunction success() {\\r\\n  console.log(\\\"success\\\");\\r\\n}\\r\\n\\r\\n//A lot of the dragging logic came from this post on the forum: https://forum.code.org/t/is-there-a-way-to-code-a-drag-and-drop-behavior-on-an-image/13037/6\\r\\n//And then this project someone posted later with improvements on Baker's initial post: https://studio.code.org/projects/applab/g3Q6so46nK07lxfzyjF2waEkbpsJ6Rs5oFX3Meb18PE/view\\r\\n//One key detail is that in design mode, dragging works better on buttons than images. So all of the draggable elements are actually button design elements\\r\\n//The rest of the code is modeled after what the program above did, but abstracts some global variables to objects instead.\\r\\nvar dragObj = {\\r\\n  state: false,\\r\\n  curDraggable: null,\\r\\n  xOffset: 0,\\r\\n  yOffset: 0\\r\\n};\\r\\n\\r\\n//resets drag object\\r\\nfunction resetDragObj() {\\r\\n  dragObj.state = false;\\r\\n  dragObj.curDraggable = null;\\r\\n  dragObj.xOffset = 0;\\r\\n  dragObj.yOffset = 0;\\r\\n}\\r\\n\\r\\n//NOTE: in Design Mode, these are actually buttons due to an interaction with image types and dragging\\r\\n\\r\\n/*\\r\\nvar SOLUTIONARRAY = [\\r\\n\\t[\\\"dragA\\\", \\\"labelA\\\"],\\r\\n\\t[\\\"dragB\\\", \\\"labelB\\\"]\\r\\n];\\r\\n*/\\r\\n\\r\\nvar DRAGGABLEARRAY = [];\\r\\nvar SOLUTIONARRAY = [];\\r\\n\\r\\n//Initializes everything. Pass it the 2D array of (draggable, solution) IDs\\r\\nfunction initialize(solArray) {\\r\\n  for(var i = 0; i < solArray.length; i++) {\\r\\n    SOLUTIONARRAY.push(solArray[i]);\\r\\n  }\\r\\n  \\r\\n  for(var i = 0; i < SOLUTIONARRAY.length; i++) {\\r\\n    DRAGGABLEARRAY.push(SOLUTIONARRAY[i][0]);\\r\\n  }\\r\\n  \\r\\n  \\r\\n  \\r\\n  \\r\\n  //This is just a clever way to generalize making onEvents for each draggable element.\\r\\n  for(var i = 0; i < DRAGGABLEARRAY.length; i++) {\\r\\n    var curDraggable = DRAGGABLEARRAY[i];\\r\\n    \\r\\n    //visual change to show is draggable\\r\\n    onEvent(curDraggable, \\\"mouseover\\\", function(e) {\\r\\n      //Because of how events calculate the ID, I need to use the event ID instead of the curDraggable variable\\r\\n      setProperty(e.targetId, \\\"border-width\\\", 2);\\r\\n    });\\r\\n    onEvent(curDraggable, \\\"mouseout\\\", function(e) {\\r\\n      setProperty(e.targetId, \\\"border-width\\\", 0);\\r\\n    });\\r\\n    \\r\\n    // start dragging currrent element\\r\\n    onEvent(curDraggable, \\\"mousedown\\\", function(e) {\\r\\n      console.log(e);\\r\\n      dragObj.state = true;\\r\\n      dragObj.curDraggable = e.targetId;\\r\\n      dragObj.xOffset = e.x - getProperty(e.targetId, \\\"x\\\");\\r\\n      dragObj.yOffset = e.y - getProperty(e.targetId, \\\"y\\\");\\r\\n    });\\r\\n  }\\r\\n  \\r\\n  onEvent(\\\"screen1\\\", \\\"mouseup\\\", function() {\\r\\n    resetDragObj();\\r\\n  });\\r\\n  \\r\\n  onEvent(\\\"screen1\\\", \\\"mousemove\\\", function(e){\\r\\n    if(dragObj.state == true){\\r\\n      //console.log(dragObj.curDraggable);\\r\\n      var newX = e.x - dragObj.xOffset;\\r\\n      var newY = e.y - dragObj.yOffset;\\r\\n      //setPosition(dragObj.curDraggable, newX, newY);\\r\\n      setProperty(dragObj.curDraggable, \\\"x\\\", newX);\\r\\n      setProperty(dragObj.curDraggable, \\\"y\\\", newY);\\r\\n    }\\r\\n  });\\r\\n  \\r\\n}\\r\\n\\r\\n\\r\\n//var DRAGGABLEARRAY = [\\\"imgA\\\", \\\"imgB\\\", \\\"imgC\\\", \\\"imgD\\\"];\\r\\n\\r\\n\\r\\n\\r\\n\\r\\n//Checks if the center (x, y) of id1 is inside the bounding box of id2\\r\\nfunction checkCenterInside(id1, id2) {\\r\\n  var id1Obj = {};\\r\\n  id1Obj.x = getProperty(id1, \\\"x\\\");\\r\\n  id1Obj.y = getProperty(id1, \\\"y\\\");\\r\\n  id1Obj.width = getProperty(id1, \\\"width\\\");\\r\\n  id1Obj.height = getProperty(id1, \\\"height\\\");\\r\\n  id1Obj.centerX = id1Obj.x + (id1Obj.width / 2);\\r\\n  id1Obj.centerY = id1Obj.y + (id1Obj.height / 2);\\r\\n  \\r\\n  var id2Obj = {};\\r\\n  id2Obj.x = getProperty(id2, \\\"x\\\");\\r\\n  id2Obj.y = getProperty(id2, \\\"y\\\");\\r\\n  id2Obj.width = getProperty(id2, \\\"width\\\");\\r\\n  id2Obj.height = getProperty(id2, \\\"height\\\");\\r\\n  id2Obj.centerX = id2Obj.x + (id2Obj.width / 2);\\r\\n  id2Obj.centerY = id2Obj.y + (id2Obj.height / 2);\\r\\n  \\r\\n  if((id1Obj.centerX > id2Obj.x && id1Obj.centerX < (id2Obj.x + id2Obj.width)) && (id1Obj.centerY > id2Obj.y && id1Obj.centerY < (id2Obj.y + id2Obj.height))) {\\r\\n    return true;\\r\\n  } else {\\r\\n    return false;\\r\\n  }\\r\\n}\\r\\n\\r\\n\\r\\n/*\\r\\n\\r\\n//This is my validation logic. When it's all true, I call \\\"success\\\", which is what the levelbuilder validation is looking for.\\r\\nonEvent(\\\"checkButton\\\", \\\"click\\\", function( ) {\\r\\n\\tvar correct = 0;\\r\\n\\tfor(var i = 0; i < SOLUTIONARRAY.length; i++) {\\r\\n\\t  if(checkCenterInside(SOLUTIONARRAY[i][0], SOLUTIONARRAY[i][1])) {\\r\\n\\t    console.log(\\\"Success: \\\" + SOLUTIONARRAY[i][0] + \\\" is inside \\\" + SOLUTIONARRAY[i][1]);\\r\\n\\t    correct += 1;\\r\\n\\t  } else {\\r\\n\\t    console.log(\\\"FAIL: \\\" + SOLUTIONARRAY[i][0] + \\\" is not inside \\\" + SOLUTIONARRAY[i][1]);\\r\\n\\t  }\\r\\n\\t}\\r\\n\\tif(correct >= SOLUTIONARRAY.length) {\\r\\n\\t  success();\\r\\n\\t}\\r\\n});\\r\\n\\r\\n*/\",\"originalName\":\"AssessmentDraggable\",\"versionId\":\"KXZyyVXq208EXDhveZtNBuwcqYKxkNUd\",\"channelId\":\"zF88TlweURzxsrFTGD-V8w\",\"fromLevelbuilder\":true}]",
    "preload_asset_list": null
  },
  "published": true,
  "notes": "",
  "audit_log": "[{\"changed_at\":\"2025-02-11T18:25:45.432+00:00\",\"changed\":[\"cloned from \\\"musiclab-hotspot-functions-test\\\"\"],\"cloned_from\":\"musiclab-hotspot-functions-test\"},{\"changed_at\":\"2025-02-11 18:25:49 +0000\",\"changed\":[\"log_conditions\",\"preload_asset_list\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-02-11 18:26:10 +0000\",\"changed\":[\"log_conditions\",\"preload_asset_list\",\"encrypted_examples\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-02-11 18:26:42 +0000\",\"changed\":[\"log_conditions\",\"libraries_enabled\",\"preload_asset_list\",\"encrypted_examples\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-02-11 18:26:58 +0000\",\"changed\":[\"start_blocks\",\"start_html\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-02-11 18:27:44 +0000\",\"changed\":[\"start_blocks\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-02-11 21:11:38 +0000\",\"changed\":[\"start_html\",\"start_libraries\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-02-11 21:12:02 +0000\",\"changed\":[\"start_blocks\",\"start_html\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"},{\"changed_at\":\"2025-02-11 21:14:54 +0000\",\"changed\":[\"start_libraries\"],\"changed_by_id\":14639,\"changed_by_email\":\"dan+teacher@code.org\"}]"
}]]></config>
