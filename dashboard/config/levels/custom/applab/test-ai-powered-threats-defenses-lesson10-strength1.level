    "start_blocks": "// --------------------\r\n// Variables\r\n// --------------------\r\nvar passwordGuesses = [];\r\nvar aiGeneratedKey = \"\";\r\n\r\n// --------------------\r\n// Entropy Evaluation\r\n// --------------------\r\nfunction estimateEntropy(pw) {\r\n  var score = 0;\r\n  if (pw.length >= 16) score += 2;\r\n  else if (pw.length >= 12) score += 1;\r\n\r\n  if (pw.match(/[a-z]/) && pw.match(/[A-Z]/)) score += 1;\r\n  if (pw.match(/[0-9]/)) score += 1;\r\n  if (pw.match(/[^A-Za-z0-9]/)) score += 1;\r\n\r\n  if (score <= 2) return \"Low Entropy\";\r\n  else if (score <= 4) return \"Medium Entropy\";\r\n  else return \"High Entropy\";\r\n}\r\n\r\n// --------------------\r\n// AI Guesses: Regeneration Logic\r\n// --------------------\r\nfunction generateStrongAIKey() {\r\n  var lowercase = \"abcdefghijklmnopqrstuvwxyz\";\r\n  var uppercase = \"ABCDEFGHIJKLMNOPQRSTUVWXYZ\";\r\n  var digits = \"0123456789\";\r\n  var symbols = \"!@#$%^&*()-_=+[]{};:,.<>?\";\r\n\r\n  var allChars = lowercase + uppercase + digits + symbols;\r\n\r\n  // Ensure the key includes at least one from each category\r\n  var key = \"\";\r\n  key += lowercase[randomNumber(0, lowercase.length - 1)];\r\n  key += uppercase[randomNumber(0, uppercase.length - 1)];\r\n  key += digits[randomNumber(0, digits.length - 1)];\r\n  key += symbols[randomNumber(0, symbols.length - 1)];\r\n\r\n  // Randomly choose a total length between 12 and 16\r\n  var totalLength = randomNumber(12, 16);\r\n\r\n  // Fill in the rest with randomly selected characters from all pools\r\n  for (var i = key.length; i < totalLength; i++) {\r\n    key += allChars[randomNumber(0, allChars.length - 1)];\r\n  }\r\n\r\n  // Shuffle the result to avoid predictable category order\r\n  return shuffleString(key);\r\n}\r\n\r\nfunction shuffleString(str) {\r\n  var arr = str.split(\"\");\r\n  for (var i = arr.length - 1; i > 0; i--) {\r\n    var j = randomNumber(0, i);\r\n    var temp = arr[i];\r\n    arr[i] = arr[j];\r\n    arr[j] = temp;\r\n  }\r\n  return arr.join(\"\");\r\n}\r\n\r\n// --------------------\r\n// Event: Submit User Guess\r\n// --------------------\r\nonEvent(\"submitBtn\", \"click\", function() {\r\n  var userGuess = getText(\"password_input\");\r\n\r\n  if (userGuess !== \"\" && passwordGuesses.indexOf(userGuess) === -1) {\r\n    appendItem(passwordGuesses, userGuess);\r\n\r\n    setText(\"guess_list_output\", passwordGuesses.map(function(item) {\r\n      return \"- \" + item;\r\n    }).join(\"\\n\"));\r\n\r\n    if (passwordGuesses.length >= 1) {\r\n      showElement(\"compareBtn\");\r\n    }\r\n\r\n    setText(\"password_input\", \"\");\r\n  }\r\n});\r\n\r\n// --------------------\r\n// Event: Compare Button → Show Lists\r\n// --------------------\r\nonEvent(\"compareBtn\", \"click\", function() {\r\n  setText(\"user_list\", passwordGuesses.map(function(item, index) {\r\n    return (index + 1) + \". \" + item;\r\n  }).join(\"\\n\"));\r\n\r\n  aiGeneratedKey = generateStrongAIKey();\r\n  setText(\"ai_list\", aiGeneratedKey);\r\n\r\n  setScreen(\"compare_screen\");\r\n});\r\n\r\n// --------------------\r\n// Event: Evaluate Password Strengths\r\n// --------------------\r\nonEvent(\"evalBtn\", \"click\", function() {\r\n  // Student guesses with entropy labels\r\n  var labeledUserList = passwordGuesses.map(function(pw, index) {\r\n    return (index + 1) + \". \" + pw + \" (\" + estimateEntropy(pw) + \")\";\r\n  }).join(\"\\n\");\r\n  setText(\"user_list\", labeledUserList);\r\n\r\n  // AI key with entropy label\r\n  var aiEntropy = estimateEntropy(aiGeneratedKey);\r\n  setText(\"ai_list\", aiGeneratedKey + \" (\" + aiEntropy + \")\");\r\n});\r\n\r\n// --------------------\r\n// Event: Refresh AI Guesses\r\n// --------------------\r\nonEvent(\"refreshBtn\", \"click\", function() {\r\n  aiGeneratedKey = generateStrongAIKey();\r\n  setText(\"ai_list\", aiGeneratedKey);\r\n});\r\n\r\n// --------------------\r\n// Navigation Events\r\n// --------------------\r\nonEvent(\"patternBtn\", \"click\", function() {\r\n  setScreen(\"patterns_screen\");\r\n});\r\nonEvent(\"backBtn\", \"click\", function() {\r\n  setScreen(\"guessing_screen\");\r\n});\r\nonEvent(\"backBtn2\", \"click\", function() {\r\n  setScreen(\"guessing_screen\");\r\n});",
    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: none;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"millennial\" id=\"guessing_screen\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(254, 219, 208);\"><input id=\"password_input\" style=\"margin: 0px; width: 270px; height: 40px; border-style: solid; color: rgb(68, 44, 46); background-color: rgb(254, 219, 208); border-color: rgb(255, 255, 255); border-radius: 4px; border-width: 2px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 170px; top: 170px;\" placeholder=\"create your own password or key\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson10-strength1/key.png\" data-canonical-image-url=\"image://key.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"icon2\" style=\"height: 35px; width: 45px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 115px; top: 170px; margin: 0px;\"><button id=\"submitBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 95px; background-color: rgb(68, 44, 46); color: rgb(255, 255, 255); border-color: rgb(255, 255, 255); border-radius: 20px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 455px; top: 170px;\">Submit</button><div contenteditable=\"false\" class=\"textArea\" id=\"guess_list_output\" style=\"width: 365px; height: 140px; border-style: solid; background-color: rgb(254, 234, 230); color: rgb(68, 44, 46); border-color: rgb(255, 255, 255); border-radius: 8px; border-width: 1px; font-family: Arial, Helvetica, sans-serif; font-size: 15px; padding: 5px 15px; position: absolute; left: 125px; top: 235px; margin: 0px;\" data-mod-borderwidth=\"1\" data-mod-fontsize=\"1\"></div><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(1, 49, 28); background-color: rgb(254, 234, 230); border-color: rgb(255, 255, 255); border-radius: 4px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 26px; padding: 2px 15px; height: 60px; position: absolute; left: 160px; top: 10px; width: 300px; text-align: center;\" id=\"label1\" data-mod-textcolor=\"1\" data-mod-borderwidth=\"1\" data-mod-fontsize=\"1\">Create Your Own Password or Key</label><button id=\"patternBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 195px; background-color: rgb(186, 149, 208); color: rgb(255, 255, 255); border-color: rgb(255, 255, 255); border-radius: 20px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 50px; top: 390px;\" data-mod-backgroundcolor=\"1\">Strong Key Strategies</button><button id=\"compareBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 195px; background-color: rgb(68, 44, 46); color: rgb(255, 255, 255); border-color: rgb(255, 255, 255); border-radius: 20px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 360px; top: 390px;\" class=\"design-mode-hidden\">Compare with AI</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(1, 49, 28); background-color: rgb(254, 234, 230); border-color: rgb(255, 255, 255); border-radius: 4px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 2px 15px; width: 230px; height: 60px; position: absolute; left: 195px; top: 90px;\" id=\"label4\" data-mod-textcolor=\"1\" data-mod-borderwidth=\"1\">Create your own 12-16 character password or key. You can create more than one and they will all be stored</label></div><div class=\"screen\" tabindex=\"1\" data-theme=\"millennial\" id=\"patterns_screen\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(254, 219, 208); display: none;\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(68, 44, 46); background-color: rgb(254, 234, 230); border-color: rgb(255, 255, 255); border-radius: 4px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 20px; padding: 2px 15px; width: 270px; height: 30px; position: absolute; left: 155px; top: 10px; text-align: center;\" id=\"label3\" data-mod-fontsize=\"1\">Strong Key Strategies</label><div contenteditable=\"false\" class=\"textArea\" id=\"text_area4\" style=\"width: 280px; height: 185px; border-style: solid; background-color: rgb(254, 234, 230); color: rgb(68, 44, 46); border-color: rgb(255, 255, 255); border-radius: 8px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px 15px; position: absolute; left: 10px; top: 50px; margin: 0px;\">🔡 Mix Character Types<div><br></div><div>Use a variety of characters to increase randomness:</div><div>\t•\tUppercase &amp; lowercase letters</div><div>\t•\tNumbers</div><div>\t•\tSpecial symbols (!, %, &amp;, @)</div><div><br></div><div>➡️ Try something like: Qw8$rXp!t4Z@</div></div><div contenteditable=\"false\" class=\"textArea\" id=\"text_area5\" style=\"width: 280px; height: 190px; border-style: solid; background-color: rgb(254, 234, 230); color: rgb(68, 44, 46); border-color: rgb(255, 255, 255); border-radius: 8px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px 15px; position: absolute; left: 10px; top: 245px; margin: 0px;\">📏 Use More Characters<div><br></div><div>The longer your password, the better!</div><div>Aim for at least 12–16 characters.</div><div><br></div><div>➡️ Try something like: G8@mpZ4#xT1w9d</div></div><div contenteditable=\"false\" class=\"textArea\" id=\"text_area6\" style=\"width: 280px; height: 185px; border-style: solid; background-color: rgb(254, 234, 230); color: rgb(68, 44, 46); border-color: rgb(255, 255, 255); border-radius: 8px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px 15px; position: absolute; left: 305px; top: 50px; margin: 0px;\">🔀 Be Random, Not Personal<div><br></div><div>Avoid anything someone might guess (names, pets, dates).</div><div>Aim for a nonsense string with no personal meaning.</div><div><br></div><div>➡️ Try something like: x3@Fz!M9#qT2</div></div><div contenteditable=\"false\" class=\"textArea\" id=\"text_area8\" style=\"width: 280px; height: 190px; border-style: solid; background-color: rgb(254, 234, 230); color: rgb(68, 44, 46); border-color: rgb(255, 255, 255); border-radius: 8px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 14px; padding: 5px 15px; position: absolute; left: 305px; top: 245px; margin: 0px;\">🔍 Test Your Key<div><br></div><div>After you make your key, check how strong and random it really is.</div><div>A strong key should be hard to guess—even by an AI!</div><div><br></div><div>➡️ Ask yourself: Would someone ever think to guess this?</div></div><button id=\"backBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 100px; background-color: rgb(68, 44, 46); color: rgb(255, 255, 255); border-color: rgb(255, 255, 255); border-radius: 20px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 480px; top: 5px;\">Back</button></div><div class=\"screen\" tabindex=\"1\" data-theme=\"millennial\" id=\"compare_screen\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(254, 219, 208); display: none;\"><div contenteditable=\"false\" class=\"textArea\" id=\"user_list\" style=\"width: 285px; height: 160px; border-style: solid; background-color: rgb(254, 234, 230); color: rgb(68, 44, 46); border-color: rgb(255, 255, 255); border-radius: 8px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 10px; top: 90px; margin: 0px;\"></div><div contenteditable=\"false\" class=\"textArea\" id=\"ai_list\" style=\"width: 280px; height: 160px; border-style: solid; background-color: rgb(254, 234, 230); color: rgb(68, 44, 46); border-color: rgb(255, 255, 255); border-radius: 8px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 305px; top: 90px; margin: 0px;\"></div><button id=\"backBtn2\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 70px; width: 130px; background-color: rgb(68, 44, 46); color: rgb(255, 255, 255); border-color: rgb(255, 255, 255); border-radius: 20px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 70px; top: 295px;\">Create more of your own passwords</button><button id=\"evalBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 55px; width: 140px; background-color: rgb(68, 44, 46); color: rgb(255, 255, 255); border-color: rgb(255, 255, 255); border-radius: 20px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 225px; top: 365px;\">Test Passwords For Randomness</button><button id=\"refreshBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 145px; background-color: rgb(68, 44, 46); color: rgb(255, 255, 255); border-color: rgb(255, 255, 255); border-radius: 20px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 375px; top: 310px;\">Regenerate AI Password</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(68, 44, 46); background-color: rgb(254, 234, 230); border-color: rgb(255, 255, 255); border-radius: 4px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 18px; padding: 2px 15px; width: 160px; height: 23px; position: absolute; left: 85px; top: 55px;\" id=\"label5\" data-mod-fontsize=\"1\">Your Passwords</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(68, 44, 46); background-color: rgb(254, 234, 230); border-color: rgb(255, 255, 255); border-radius: 4px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 18px; padding: 2px 15px; width: 231px; height: 23px; position: absolute; left: 344.5px; top: 55px; text-align: center;\" id=\"label6\" data-mod-fontsize=\"1\">AI Generated Passwords</label></div></div>",
    "long_instructions": "## Do This:\r\n\r\n1. Create your own 12–16 character password or key.\r\n\r\n2. Generate a random key from the AI to compare with yours.\r\n\r\n3. Evaluate both to see which has more randomness (entropy).\r\n\r\n###Consider These Questions:\r\n\r\n::: details [*What made the AI-generated key stronger?*]\r\nThe AI key used more types of characters (like symbols and uppercase letters), had more randomness, and didn’t follow any predictable patterns that someone could guess.\r\n:::\r\n&nbsp\r\n\r\n::: details [*Why does unpredictability matter for encryption?*]\r\nIf something is unpredictable, it’s much harder for a hacker or computer to guess. Encryption works best when the key is so random that even powerful machines can’t crack it easily.\r\n:::\r\n&nbsp\r\n\r\n::: details [*When might people choose convenience over strength?*]\r\nPeople often make short or simple passwords because they’re easier to remember—but that also makes them easier to guess or break.\r\n\r\n:::\r\n\r\n",
