    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"citrus\" id=\"screen1\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(236, 162, 65);\"><div contenteditable=\"true\" class=\"textArea\" id=\"vote_console\" style=\"width: 255px; height: 450px; border-style: solid; background-color: rgb(98, 98, 98); color: rgb(255, 255, 255); border-color: rgb(105, 136, 61); border-radius: 4px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px 15px; position: absolute; left: 300px; top: 0px; margin: 0px;\">Developer Console<div>-------------------------</div></div><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1a/cellphone_wireframe.png\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"phone_BG\" style=\"height: 450px; width: 225px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 35px; top: 0px; margin: 0px;\"><button id=\"submit_vote\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 35px; width: 70px; background-color: rgb(205, 98, 41); color: rgb(239, 228, 215); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 2px; font-family: Georgia, serif; font-size: 15px; position: absolute; left: 65px; top: 375px;\">Vote!</button><input id=\"student_id_input\" style=\"margin: 0px; width: 155px; height: 30px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(255, 255, 255); border-color: rgb(205, 98, 41); border-radius: 4px; border-width: 1px; font-family: &quot;Palatino Linotype&quot;, &quot;Book Antiqua&quot;, Palatino, serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 70px; top: 105px;\" placeholder=\"Enter Student ID...\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(237, 227, 215); background-color: rgb(205, 98, 41); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 0px; font-family: Georgia, serif; font-size: 26px; padding: 2px 15px; width: 195px; height: 35px; position: absolute; left: 50px; top: 45px; text-align: center;\" id=\"vote_header\">LunchCrunch</label><select id=\"lunch_vote_menu\" style=\"width: 155px; height: 35px; margin: 0px; border-style: solid; background-color: rgb(205, 98, 41); color: rgb(239, 228, 215); background-image: url(&quot;data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%20256%20448%22%20enable-background%3D%22new%200%200%20256%20448%22%3E%3Cstyle%20type%3D%22text%2Fcss%22%3E.arrow%7Bfill%3A%23efe4d7%3B%7D%3C%2Fstyle%3E%3Cpath%20class%3D%22arrow%22%20d%3D%22M255.9%20168c0-4.2-1.6-7.9-4.8-11.2-3.2-3.2-6.9-4.8-11.2-4.8H16c-4.2%200-7.9%201.6-11.2%204.8S0%20163.8%200%20168c0%204.4%201.6%208.2%204.8%2011.4l112%20112c3.1%203.1%206.8%204.6%2011.2%204.6%204.4%200%208.2-1.5%2011.4-4.6l112-112c3-3.2%204.5-7%204.5-11.4z%22%2F%3E%3C%2Fsvg%3E&quot;); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 2px; font-family: Georgia, serif; font-size: 13px; padding: 0px 30px 0px 15px; position: absolute; left: 70px; top: 190px;\"><option>----------------------</option><option>Pizza</option><option>Pasta salad</option><option>Chicken nuggets</option><option>Hamburgers</option><option>Tacos</option><option>Chicken salad</option><option>Mac and cheese</option><option>Hot dogs</option><option>Fish sticks</option><option>Egg and cheese sandwiches</option><option>Grilled cheese</option><option>Hummus wrap</option></select><button id=\"to_results_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 35px; width: 70px; background-color: rgb(205, 98, 41); color: rgb(239, 228, 215); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 2px; font-family: Georgia, serif; font-size: 15px; position: absolute; left: 165px; top: 375px;\">Results</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(205, 98, 41); background-color: rgba(105, 136, 61, 0); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 0px; font-family: Georgia, serif; font-size: 13px; padding: 2px 15px; width: 165px; height: 30px; position: absolute; left: 60px; top: 155px;\" id=\"label2\">Select your choice for today's main course!</label></div><div class=\"screen\" tabindex=\"1\" data-theme=\"citrus\" id=\"screen2\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(236, 162, 65); display: none;\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1a/cellphone_wireframe.png\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"phone_BG2\" style=\"height: 450px; width: 225px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 35px; top: 0px; margin: 0px;\"><div contenteditable=\"true\" class=\"textArea\" id=\"results_console\" style=\"width: 255px; height: 450px; border-style: solid; background-color: rgb(98, 98, 98); color: rgb(255, 255, 255); border-color: rgb(105, 136, 61); border-radius: 4px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px 15px; position: absolute; left: 300px; top: 0px; margin: 0px;\">Developer Console<div>-------------------------</div></div><button id=\"refresh_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 30px; width: 170px; background-color: rgb(205, 98, 41); color: rgb(238, 227, 215); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 2px; font-family: Georgia, serif; font-size: 15px; position: absolute; left: 65px; top: 310px;\">Update Voting Chart</button><button id=\"to_vote_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 50px; width: 80px; background-color: rgb(205, 98, 41); color: rgb(238, 227, 215); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 2px; font-family: Georgia, serif; font-size: 16px; position: absolute; left: 65px; top: 365px;\">Back to my&nbsp;Vote</button><button id=\"to_submit_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 50px; width: 80px; background-color: rgb(205, 98, 41); color: rgb(238, 227, 215); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 2px; font-family: Georgia, serif; font-size: 16px; position: absolute; left: 155px; top: 365px;\">Special Order</button><div contenteditable=\"true\" class=\"textArea\" id=\"vote_chart_area\" style=\"width: 175px; height: 200px; border-style: solid; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border-color: rgb(205, 98, 41); border-radius: 4px; border-width: 1px; font-family: &quot;Palatino Linotype&quot;, &quot;Book Antiqua&quot;, Palatino, serif; font-size: 11px; padding: 5px 15px; position: absolute; left: 60px; top: 95px; margin: 0px;\"></div><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(237, 227, 215); background-color: rgb(205, 98, 41); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 0px; font-family: Georgia, serif; font-size: 26px; padding: 2px 15px; width: 195px; height: 35px; position: absolute; left: 50px; top: 45px; text-align: center;\" id=\"label1\" data-mod-textcolor=\"1\" data-mod-backgroundcolor=\"1\" data-mod-fontsize=\"1\">LunchCrunch</label></div><div class=\"screen\" tabindex=\"1\" data-theme=\"citrus\" id=\"screen3\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(236, 162, 65); display: none;\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1a/cellphone_wireframe.png\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image4\" style=\"height: 450px; width: 225px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 35px; top: 0px; margin: 0px;\"><div contenteditable=\"true\" class=\"textArea\" id=\"submit_console\" style=\"width: 255px; height: 450px; border-style: solid; background-color: rgb(98, 98, 98); color: rgb(255, 255, 255); border-color: rgb(105, 136, 61); border-radius: 4px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px 15px; position: absolute; left: 300px; top: 0px; margin: 0px;\">Developer Console<div>-------------------------</div></div><input id=\"notes_input\" style=\"margin: 0px; width: 175px; height: 65px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(255, 255, 255); border-color: rgb(204, 99, 41); border-radius: 4px; border-width: 1px; font-family: &quot;Palatino Linotype&quot;, &quot;Book Antiqua&quot;, Palatino, serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 60px; top: 125px;\" placeholder=\"Special Instructions...\"><select id=\"drink_choice\" style=\"width: 175px; height: 30px; margin: 0px; border-style: solid; background-color: rgb(204, 99, 41); color: rgb(238, 228, 217); background-image: url(&quot;data:image/svg+xml;charset=US-ASCII,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%20256%20448%22%20enable-background%3D%22new%200%200%20256%20448%22%3E%3Cstyle%20type%3D%22text%2Fcss%22%3E.arrow%7Bfill%3A%23eee4d9%3B%7D%3C%2Fstyle%3E%3Cpath%20class%3D%22arrow%22%20d%3D%22M255.9%20168c0-4.2-1.6-7.9-4.8-11.2-3.2-3.2-6.9-4.8-11.2-4.8H16c-4.2%200-7.9%201.6-11.2%204.8S0%20163.8%200%20168c0%204.4%201.6%208.2%204.8%2011.4l112%20112c3.1%203.1%206.8%204.6%2011.2%204.6%204.4%200%208.2-1.5%2011.4-4.6l112-112c3-3.2%204.5-7%204.5-11.4z%22%2F%3E%3C%2Fsvg%3E&quot;); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 2px; font-family: Georgia, serif; font-size: 13px; padding: 0px 30px 0px 15px; position: absolute; left: 60px; top: 225px;\"><option>--------------------------</option><option>Water</option><option>Milk </option><option>Juice </option><option>Infused water</option><option>Smoothies</option><option>Iced Tea</option><option>Lemonade</option><option>Sports drinks</option></select><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(204, 98, 40); background-color: rgba(105, 136, 61, 0); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 0px; font-family: Georgia, serif; font-size: 13px; padding: 2px 15px; width: 170px; height: 20px; position: absolute; left: 55px; top: 205px;\" id=\"drink_order\">Enter drink order:</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(204, 99, 41); background-color: rgba(105, 136, 61, 0); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 0px; font-family: Georgia, serif; font-size: 13px; padding: 2px 15px; width: 185px; height: 40px; position: absolute; left: 55px; top: 90px;\" id=\"label7\">Additional instructions (e.g., allergies)</label><button id=\"submit_order_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 65px; width: 70px; background-color: rgb(204, 98, 40); color: rgb(238, 227, 215); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 2px; font-family: Georgia, serif; font-size: 15px; position: absolute; left: 165px; top: 345px;\">Send Special Order</button><button id=\"back_to_results_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 65px; width: 70px; background-color: rgb(204, 98, 40); color: rgb(238, 227, 215); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 2px; font-family: Georgia, serif; font-size: 15px; position: absolute; left: 60px; top: 345px;\">Back to Results</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(237, 227, 215); background-color: rgb(205, 98, 41); border-color: rgb(105, 136, 61); border-radius: 2px; border-width: 0px; font-family: Georgia, serif; font-size: 26px; padding: 2px 15px; width: 195px; height: 35px; position: absolute; left: 50px; top: 45px; text-align: center;\" id=\"label3\" data-mod-textcolor=\"1\" data-mod-backgroundcolor=\"1\" data-mod-fontsize=\"1\">LunchCrunch</label></div></div>",
    "start_blocks": "// ---------- Global Variables ----------\r\nvar studentId = \"\";\r\nvar voteChoice = \"\";\r\nvar voteResults = {\r\n  \"Pizza\": 14,\r\n  \"Salad\": 11,\r\n  \"Burger\": 6\r\n};\r\nvar fakePhone = \"555-0134\";\r\nvar fakeIP = \"192.168.0.48\";\r\n\r\n// ---------- SCREEN 1: Vote Submission ----------\r\nonEvent(\"submit_vote\", \"click\", function() {\r\n  studentId = getText(\"student_id_input\");\r\n  voteChoice = getText(\"lunch_vote_menu\");\r\n  \r\n  var output = \"Developer Console\\n-------------------------\\n\";\r\n  \r\n  if (studentId === \"\" || voteChoice === \"\") {\r\n    output += \"⚠️ Student ID and lunch vote required.\";\r\n  } else {\r\n    // Update vote tally\r\n    if (voteResults.hasOwnProperty(voteChoice)) {\r\n      voteResults[voteChoice]++;\r\n    } else {\r\n      voteResults[voteChoice] = 1;\r\n    }\r\n\r\n    output += \"✅ Vote submitted.\\n\";\r\n    output += \"⚠️ Student ID not verified.\\n\";\r\n    output += \"⚠️ No rate limit — multiple votes allowed.\\n\";\r\n    output += \"⚠️ Confirmation reveals student ID: \" + studentId;\r\n  }\r\n\r\n  setText(\"vote_console\", output);\r\n});\r\n\r\nonEvent(\"to_results_button\", \"click\", function() {\r\n  setScreen(\"screen2\");\r\n  displayVoteResults(false);\r\n});\r\n\r\n\r\n// ---------- SCREEN 2: Results Display ----------\r\n\r\nfunction displayVoteResults(showTamperWarning) {\r\n  var consoleOutput = \"Developer Console\\n-------------------------\\n\";\r\n  var chartOutput = \"\";\r\n\r\n  // Step 1: Convert voteResults into an array of objects\r\n  var items = [];\r\n  var maxVotes = 1;\r\n\r\n  for (var item in voteResults) {\r\n    var count = Number(voteResults[item]);\r\n    if (isNaN(count) || count < 0) count = 0;\r\n\r\n    items.push({ label: item, count: count });\r\n    if (count > maxVotes) {\r\n      maxVotes = count;\r\n    }\r\n  }\r\n\r\n  // Step 2: Sort the array from highest to lowest votes\r\n  for (var i = 0; i < items.length - 1; i++) {\r\n    for (var j = i + 1; j < items.length; j++) {\r\n      if (items[j].count > items[i].count) {\r\n        var temp = items[i];\r\n        items[i] = items[j];\r\n        items[j] = temp;\r\n      }\r\n    }\r\n  }\r\n\r\n  // Step 3: Build sorted console and chart output\r\n  for (var i = 0; i < items.length; i++) {\r\n    var label = items[i].label;\r\n    var count = items[i].count;\r\n\r\n    var barLength = Math.round((count / maxVotes) * 15);\r\n    var bar = \"\";\r\n    for (var b = 0; b < barLength; b++) {\r\n      bar += \"█\";\r\n    }\r\n\r\n    consoleOutput += label + \": \" + count + \" votes\\n\";\r\n    chartOutput += label + \"\\n\" + bar + \"\\n\\n\";\r\n  }\r\n\r\n  // Step 4: Add tamper warning\r\n  if (showTamperWarning) {\r\n    consoleOutput += \"\\n⚠️ Vote data has been edited. Results may be inaccurate.\";\r\n  } else {\r\n    consoleOutput += \"\\n⚠️ Vote data is editable.\";\r\n  }\r\n\r\n  setText(\"results_console\", consoleOutput);\r\n  setText(\"vote_chart_area\", chartOutput);\r\n}\r\n\r\n\r\n\r\nonEvent(\"refresh_button\", \"click\", function() {\r\n  var consoleText = getText(\"results_console\").split(\"\\n\");\r\n  var integrityCompromised = false;\r\n\r\n  for (var i = 2; i < consoleText.length; i++) {\r\n    if (consoleText[i].includes(\":\")) {\r\n      var parts = consoleText[i].split(\":\");\r\n      var label = parts[0].trim();\r\n      var value = Number(parts[1].replace(\"votes\", \"\").trim());\r\n\r\n      if (!isNaN(value) && voteResults[label] !== value) {\r\n        voteResults[label] = value;\r\n        integrityCompromised = true;\r\n      }\r\n    }\r\n  }\r\n\r\n  displayVoteResults(integrityCompromised);\r\n});\r\n\r\nonEvent(\"to_vote_button\", \"click\", function() {\r\n  setScreen(\"screen1\");\r\n});\r\n\r\nonEvent(\"to_submit_button\", \"click\", function() {\r\n  setScreen(\"screen3\");\r\n});\r\n\r\n\r\n// ---------- SCREEN 3: Special Order Submission ----------\r\nonEvent(\"submit_order_button\", \"click\", function() {\r\n  var drink = getText(\"drink_choice\");\r\n  var notes = getText(\"notes_input\");\r\n\r\n  var payload = {\r\n    studentId: studentId,\r\n    drink: drink,\r\n    notes: notes,\r\n    phone: fakePhone,\r\n    ipAddress: fakeIP\r\n  };\r\n\r\n  var pretty = JSON.stringify(payload, null, 2);\r\n  var output = \"Developer Console\\n-------------------------\\n\";\r\n  output += \"📤 Sending Special Order Payload:\\n\" + pretty;\r\n\r\n  output += \"\\n\\n⚠️ Payload includes sensitive personal information.\";\r\n  if (notes.length > 100) {\r\n    output += \"\\n⚠️ Notes field exceeds recommended length.\";\r\n  }\r\n  if (notes.toLowerCase().includes(\"script\") || notes.includes(\"<\")) {\r\n    output += \"\\n⚠️ Possible code injection detected in notes.\";\r\n  }\r\n  output += \"\\n⚠️ No rate limiting — multiple submissions allowed.\";\r\n\r\n  setText(\"submit_console\", output);\r\n});\r\n\r\nonEvent(\"back_to_results_button\", \"click\", function() {\r\n  setScreen(\"screen2\");\r\n  displayVoteResults(false);\r\n});\r\n",
    "bubble_choice_description": "An app designed to allow students direct access to their school cafeteria. Vote on what lunch we serve!",
    "display_name": "LunchCrunch",
    "thumbnail_url": "https://images.code.org/3f9bcdb9df8699ae55b87bbe514a06e6-LunchCrunch_a.png",
    "preload_asset_list": null,
    "encrypted_examples": [

    ],
    "long_instructions": "Explore the LunchCrunch app!"
  },
