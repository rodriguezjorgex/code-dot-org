    "bubble_choice_description": "This app will be the launching pad of all future social media megastars and influencers! Create a profile and manage your reach and impact easily.",
    "display_name": "SocialStar",
    "start_blocks": "// ---------- Global Variables ----------\r\nvar name = \"\";\r\nvar email = \"\";\r\nvar bio = \"\";\r\nvar category = \"\";\r\nvar followerGoal = \"\";\r\nvar publicFollowers = \"\";\r\nvar publicLikes = \"\";\r\n\r\nvar previewPosts = {\r\n  \"Food Influencer\": \"Just perfected my avocado toast recipe 🥑✨ Brunch is saved.\",\r\n  \"Wellness Influencer\": \"Deep breaths, cold plunges, and morning matcha 💆‍♀️🌿\",\r\n  \"Fashion Influencer\": \"Today's outfit: confidence, layers, and a bold lip 💄👠\",\r\n  \"Lifestyle Influencer\": \"From bullet journaling to air-fryer hacks — I’ve got you. 📓✨\",\r\n  \"Gaming Influencer\": \"12 hours in, 1 raid boss down, zero regrets 🎮🔥\",\r\n  \"Beauty Influencer\": \"Glowy skin and winged liner coming in hot 💅✨\",\r\n  \"Travel Influencer\": \"Just landed in Tokyo ✈️🗼 Ramen recs, anyone?\",\r\n  \"Parenting Influencer\": \"Coffee first. Diapers second. Chaos always ☕🍼\",\r\n  \"Tech Influencer\": \"Unboxed my smart fridge. It knows when I’m sad 🤖📱\",\r\n  \"Craft Influencer\": \"Turned trash into treasure again. DIY magic 🔨🎨\",\r\n  \"Pet Influencer\": \"My dog has more followers than I do. And he deserves it 🐶💯\"\r\n};\r\n\r\n\r\n// ---------- SCREEN 1: Profile Input ----------\r\nfunction publishField(fieldName) {\r\n  var currentLog = getText(\"profile_console\");\r\n  if (!currentLog.includes(fieldName + \": Published!\")) {\r\n    var newLog = currentLog + \"\\n\" + fieldName + \": Published!\";\r\n    setText(\"profile_console\", newLog);\r\n  }\r\n}\r\n\r\nonEvent(\"name_input\", \"input\", function() {\r\n  name = getText(\"name_input\");\r\n  publishField(\"name_input\");\r\n});\r\n\r\nonEvent(\"email_input\", \"input\", function() {\r\n  email = getText(\"email_input\");\r\n  publishField(\"email_input\");\r\n});\r\n\r\nonEvent(\"bio_input\", \"input\", function() {\r\n  bio = getText(\"bio_input\");\r\n  publishField(\"bio_input\");\r\n});\r\n\r\nonEvent(\"category_input\", \"change\", function() {\r\n  category = getText(\"category_input\");\r\n  publishField(\"category_input\");\r\n});\r\n\r\nonEvent(\"follower_goal_input\", \"input\", function() {\r\n  followerGoal = getText(\"follower_goal_input\");\r\n  publishField(\"follower_goal_input\");\r\n});\r\n\r\nonEvent(\"preview_button\", \"click\", function() {\r\n  setText(\"preview_name\", name);\r\n  setText(\"preview_email\", email);\r\n  setText(\"preview_bio\", bio);\r\n  setText(\"preview_category\", category);\r\n\r\n  // Populate default values\r\n  publicFollowers = followerGoal;\r\n  publicLikes = \"0\";\r\n  setText(\"followers_label\", publicFollowers);\r\n  setText(\"likes_label\", publicLikes);\r\n\r\n  // Prepopulate post\r\n  if (previewPosts.hasOwnProperty(category)) {\r\n    setText(\"preview_post\", previewPosts[category]);\r\n  } else {\r\n    setText(\"preview_post\", \"Here’s a sneak peek at my content. Let’s grow together! 🚀\");\r\n  }\r\n\r\n  // Output console data\r\n  var consoleOutput = \"Developer Console\\n-------------------------\\n\";\r\n  consoleOutput += \"Likes: \" + publicLikes + \"\\n\";\r\n  consoleOutput += \"Followers: \" + publicFollowers + \"\\n\\n\";\r\n  consoleOutput += \"⚠️ Likes and Followers can be edited via this console.\\n\";\r\n  consoleOutput += \"⚠️ No option to remove or retract this post.\";\r\n  setText(\"preview_console\", consoleOutput);\r\n\r\n  publicFollowers = followerGoal;\r\n  publicLikes = \"0\";\r\n  setText(\"followers_label\", publicFollowers);\r\n  setText(\"likes_label\", publicLikes);\r\n  setScreen(\"screen2\");\r\n});\r\n\r\n\r\n// ---------- SCREEN 2: Profile Preview ----------\r\nonEvent(\"share_button\", \"click\", function() {\r\n  publicFollowers = getText(\"followers_label\");\r\n  publicLikes = getText(\"likes_label\");\r\n\r\n  setScreen(\"screen3\");\r\n\r\n \r\n});\r\n\r\nonEvent(\"back_button\", \"click\", function() {\r\n  setScreen(\"screen1\");\r\n\r\n  var output = \"Developer Console\\n-------------------------\\n\";\r\n  output += \"⚠️ Returning to profile builder.\\n\";\r\n  output += \"⚠️ Previously entered data remains published.\";\r\n\r\n  setText(\"profile_console\", output);\r\n});\r\n\r\nonEvent(\"preview_console\", \"input\", function() {\r\n  var content = getText(\"preview_console\");\r\n  var lines = content.split(\"\\n\");\r\n\r\n  for (var i = 0; i < lines.length; i++) {\r\n    var line = lines[i];\r\n\r\n    if (line.indexOf(\"Likes:\") === 0) {\r\n      publicLikes = line.replace(\"Likes:\", \"\").trim();\r\n      setText(\"likes_label\", publicLikes);\r\n    } else if (line.indexOf(\"Followers:\") === 0) {\r\n      publicFollowers = line.replace(\"Followers:\", \"\").trim();\r\n      setText(\"followers_label\", publicFollowers);\r\n    }\r\n  }\r\n});\r\n\r\n\r\n// ---------- SCREEN 3: Share Public Profile ----------\r\nonEvent(\"send_profile_button\", \"click\", function() {\r\n  var recipient = getText(\"recipient_input\");\r\n\r\n  var payload = {\r\n    name: name,\r\n    email: email,\r\n    followers: publicFollowers,\r\n    likes: publicLikes,\r\n    category: category,\r\n    bio: bio\r\n  };\r\n\r\n  var pretty = JSON.stringify(payload, null, 2);\r\n  var output = \"Developer Console\\n-------------------------\\n\";\r\n  output += \"📤 Sending profile to: \" + recipient + \"\\n\\n\";\r\n  output += pretty + \"\\n\\n\";\r\n  output += \"⚠️ Shared post includes private contact information. \\n\";\r\n  output += \"⚠️ No option to remove this post. \\n\";\r\n  \r\n  setText(\"share_console\", output);\r\n});\r\n\r\nonEvent(\"back_to_post_button\", \"click\", function() {\r\n  setScreen(\"screen2\");\r\n\r\n  var output = \"Developer Console\\n-------------------------\\n\";\r\n  output += \"Returned to profile preview.\\n\";\r\n  output += \"⚠️ Previously published data is still visible and editable.\";\r\n\r\n  setText(\"preview_console\", output);\r\n});\r\n",
    "thumbnail_url": "https://images.code.org/ed65ce0ea20cddf5646bb583034cb38d-SocialStar_d.png",
