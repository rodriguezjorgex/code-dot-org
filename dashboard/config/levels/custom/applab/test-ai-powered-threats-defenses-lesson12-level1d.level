    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: block;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"bubblegum\" id=\"screen1\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(255, 195, 230);\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson12-level1d/cellphone_wireframe.png?t=1754489721000\" data-canonical-image-url=\"image://cellphone_wireframe.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"cellphone_BG1\" style=\"height: 450px; width: 225px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 35px; top: 0px; margin: 0px;\"><div contenteditable=\"false\" class=\"textArea\" id=\"profile_console\" style=\"width: 260px; height: 450px; border-style: solid; background-color: rgb(65, 63, 63); color: rgb(249, 249, 249); border-color: rgb(0, 0, 0); border-radius: 8px; border-width: 0px; font-family: &quot;Courier New&quot;, Courier, monospace; font-size: 14px; padding: 5px 15px; position: absolute; left: 300px; top: 0px; margin: 0px;\">Developer Console<div>---------------------------</div><div><br></div></div><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(0, 0, 0); background-color: rgb(255, 212, 237); border-color: rgb(0, 0, 0); border-radius: 20px; border-width: 0px; font-family: Georgia, serif; font-size: 28px; padding: 2px 15px; width: 169px; height: 33px; position: absolute; left: 65px; top: 45px; text-align: center;\" id=\"label2\" data-mod-borderradius=\"1\" data-mod-fontsize=\"1\">SocialStar*</label><input id=\"name_input\" style=\"margin: 0px; width: 185px; height: 30px; border-style: solid; color: rgb(0, 0, 0); background-color: rgb(255, 255, 255); border-col