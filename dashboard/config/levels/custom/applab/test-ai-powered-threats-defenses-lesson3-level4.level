    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: block;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"polar\" id=\"login_screen\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(174, 226, 244); background-size: 600px 450px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/test-ai-powered-threats-defenses-lesson3-level4/bg.png&quot;);\" data-canonical-image-url=\"image://bg.png\" data-image-type=\"file\"><button id=\"button1\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 135px; background-color: rgb(239, 250, 255); color: rgb(0, 148, 202); border-color: rgb(172, 207, 222); border-radius: 20px; border-width: 2px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 335px; top: 210px;\">Submit</button><input id=\"text_input1\" style=\"margin: 0px; width: 285px; height: 35px; border-style: solid; color: rgb(68, 44, 46); background-color: rgb(172, 207, 222); border-color: rgb(255, 255, 255); border-radius: 4px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 260px; top: 100px;\" placeholder=\"username\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson3-level4/logo1.png\" data-canonical-image-url=\"image://logo1.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image1\" style=\"height: 150px; width: 190px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 15px; top: 65px; margin: 0px;\"><input id=\"text_input2\" style=\"margin: 0px; width: 285px; height: 35px; border-style: solid; color: rgb(68, 44, 46); background-color: rgb(172, 207, 222); border-color: rgb(255, 255, 255); border-radius: 4px; border-width: 1px; font-fa