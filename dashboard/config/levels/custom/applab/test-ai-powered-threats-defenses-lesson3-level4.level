div><div>[08:14:52] typed: c</div><div>[08:14:52] typed: u</div><div>[08:14:53] typed: R</div><div>[08:14:53] typed: 3</div><div>[08:14:53] typed: _</div><div>[08:14:53] typed: P</div><div>[08:14:53] typed: @</div><div>[08:14:53] typed: s</div><div>[08:14:53] typed: s</div><div>[08:14:53] typed: %</div><div>[08:14:54] BACKSPACE</div><div>[08:14:54] typed: #</div><div>[08:14:54] typed: 2025</div><div>[08:14:55] clicked: Remember Me ✔</div><div>[08:14:56] ENTER</div><div>[08:14:58] typed: done logging in...</div><div><br></div></div><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson3-level4/header.png?t=1752688254000\" data-canonical-image-url=\"image://header.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image5\" style=\"height: 50px; width: 600px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 0px; top: -5px; margin: 0px;\"><input type=\"checkbox\" id=\"checkbox1\" style=\"width: 20px; height: 20px; margin: 0px; position: absolute; left: 270px; top: 180px;\"><div contenteditable=\"true\" class=\"textArea\" id=\"text_area2\" style=\"width: 200px; height: 30px; border-style: solid; background-color: rgba(0, 148, 202, 0); color: rgb(0, 10, 15); border-color: rgba(255, 255, 255, 0); border-radius: 8px; border-width: 2px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 285px; top: 178px; margin: 0px;\">Remember Me</div><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson3-level4/access_granted.png?t=1752688917000\" data-canonical-image-url=\"image://access_granted.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"Access_Success\" style=\"height: 55px; width: 505px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 40px; top: 325px; margin: 0px;\"><div contenteditable=\"true\" class=\"textArea\" id=\"Access_Failure\" style=\"width: 280px; height: 40px; border-style: solid; background-color: rgba(0, 148, 202, 0); color: rgb(253, 14, 14); border-color: rgba(255, 255, 255, 0); border-radius: 8px; border-width: 2px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 25px; top: 225px; margin: 0px;\"></div><div contenteditable=\"true\" class=\"textArea\" id=\"text_area4\" style=\"width: 540px; height: 200px; border-style: solid; background-color: rgba(0, 148, 202, 0); color: rgb(0, 0, 0); border-color: rgba(255, 255, 255, 0); border-radius: 8px; border-width: 2px; font-family: Arial, Helvetica, sans-serif; font-size: 23px; padding: 5px 15px; position: absolute; left: 40px; top: 110px; margin: 0px;\">A keylogger is a program that secretly records everything a user types, often used by hackers to steal usernames, passwords, and other sensitive information.</div></div></div>",
    "start_blocks": "// Set initial login attempts\r\nvar loginAttempts = 3;\r\n\r\n// Expected fake credentials\r\nvar correctUsername = \"z_eriK@example.com\";\r\nvar correctPassword = \"!SecuR3_P@ss#2025\";\r\n\r\nsetProperty(\"Access_Success\", \"hidden\", true);\r\nsetProperty(\"text_area4\", \"hidden\", true);\r\n\r\n// On button1 click\r\nonEvent(\"button1\", \"click\", function() {\r\n  var inputUser = getText(\"text_input1\");\r\n  var inputPass = getText(\"text_input2\");\r\n\r\n  if (inputUser == correctUsername && inputPass == correctPassword) {\r\n    // Show success image, hide inputs\r\n    setProperty(\"Access_Success\", \"hidden\", false);\r\n    setProperty(\"text_input1\", \"hidden\", true);\r\n    setProperty(\"text_input2\", \"hidden\", true);\r\n    setProperty(\"button1\", \"hidden\", true);\r\n    setProperty(\"image1\", \"hidden\", true);\r\n    setProperty(\"image2\", \"hidden\", true);\r\n    setProperty(\"image3\", \"hidden\", true);\r\n    setProperty(\"image4\", \"hidden\", true);\r\n    setProperty(\"checkbox1\", \"hidden\", true);\r\n    setProperty(\"text_area2\", \"hidden\", true);\r\n    setProperty(\"text_area4\", \"hidden\", false);\r\n\r\n    setText(\"Access_Failure\", \"\"); // Clear failure text\r\n  } else {\r\n    // Reduce attempts and show failure message\r\n    loginAttempts--;\r\n    setProperty(\"Access_Failure\", \"hidden\", false);\r\n    setText(\"Access_Failure\", \"Access Denied. Attempts left: \" + loginAttempts);\r\n\r\n    // Optional: disable after 0 attempts\r\n    if (loginAttempts <= 0) {\r\n      setProperty(\"button1\", \"hidden\", true);\r\n      setText(\"Access_Failure\", \"Too many failed attempts. Try again later.\");\r\n    }\r\n  }\r\n});\r\n",
    "preload_asset_list": null,
    "encrypted_examples": [

    ],
    "long_instructions": "## Do This:\r\n\r\n1. A **keylogger** (*malware that records inputs*) was installed on this user's computer. Scroll through the keylogger output in the blue box.\r\n\r\n2. Find a possible `username` and `password` in the keylogger output. Enter them into the input boxes and press the `Submit` button to gain access."
  },
