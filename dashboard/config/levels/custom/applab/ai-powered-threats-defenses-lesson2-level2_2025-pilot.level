: rgba(255, 164, 0, 0); color: rgba(255, 255, 255, 0); border-color: rgba(77, 87, 95, 0); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 300px; top: 165px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-misconfig-3/image-removebg-preview%20(45).png&quot;); background-size: contain; background-position: 50% 50%; background-repeat: no-repeat; width: 110px;\" data-canonical-image-url=\"image://image-removebg-preview (45).png\" data-image-type=\"file\" class=\"design-mode-hidden\"></button><button id=\"document_3_button\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 130px; background-color: rgba(255, 164, 0, 0); color: rgba(255, 255, 255, 0); border-color: rgba(77, 87, 95, 0); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 15px; position: absolute; left: 420px; top: 165px; background-image: url(&quot;https://levelbuilder-studio.code.org/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-misconfig-3/image-removebg-preview%20(45).png&quot;); background-size: contain; background-position: 50% 50%; background-repeat: no-repeat; width: 110px;\" data-canonical-image-url=\"image://image-removebg-preview (45).png\" data-image-type=\"file\" class=\"design-mode-hidden\"></button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: &quot;Lucida Sans Unicode&quot;, &quot;Lucida Grande&quot;, sans-serif; font-size: 12px; padding: 2px 15px; height: 16px; position: absolute; left: 107px; top: 54px; width: 230px;\" id=\"url_chrome\" class=\"design-mode-hidden\">https://drive.google.com/drive</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: Tahoma, Geneva, sans-serif; font-size: 10px; padding: 2px 15px; width: 93px; position: absolute; left: 190px; top: 183px; height: 20px;\" id=\"document_1_label\" class=\"design-mode-hidden\">Amara Essay</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: Tahoma, Geneva, sans-serif; font-size: 10px; padding: 2px 15px; width: 75px; position: absolute; left: 320px; top: 183px; height: 20px;\" id=\"document_2_label\" class=\"design-mode-hidden\">Jon Essay</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(77, 87, 95); background-color: rgba(0, 0, 0, 0); border-color: rgb(77, 87, 95); border-radius: 0px; border-width: 0px; font-family: Tahoma, Geneva, sans-serif; font-size: 10px; padding: 2px 15px; width: 85px; position: absolute; left: 440px; top: 183px; height: 20px;\" id=\"document_3_label\" class=\"design-mode-hidden\">Haley Essay</label><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-misconfig-3/Pasted Graphic 12.png\" data-canonical-image-url=\"image://Pasted Graphic 12.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"document_2_window\" style=\"height: 390px; width: 560px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; top: 25px; margin: 0px; left: 35px;\" class=\"design-mode-hidden\"><button id=\"document_2_x\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 20px; width: 20px; background-color: rgb(255, 0, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; position: absolute; left: 566px; top: 27px; font-size: 8px;\" class=\"design-mode-hidden\">X</button><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-misconfig-3/Pasted Graphic 15.png\" data-canonical-image-url=\"image://Pasted Graphic 15.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"document_1_window\" style=\"height: 385px; width: 555px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; top: 35px; margin: 0px; left: 45px;\" class=\"design-mode-hidden\"><button id=\"document_1_x\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 18px; width: 18px; background-color: rgb(255, 0, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; position: absolute; left: 576px; top: 40px; font-size: 8px;\" class=\"design-mode-hidden\">X</button><div contenteditable=\"false\" class=\"textArea design-mode-hidden\" id=\"document_1_text\" style=\"width: 455px; height: 235px; border-style: solid; background-color: rgba(242, 242, 242, 0); color: rgb(77, 87, 95); border-color: rgb(255, 255, 255); border-radius: 2px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 100px; top: 185px; margin: 0px;\"><br><div>Amara Johnson</div><div>Western High School</div><div>July 18, 2025</div><div><br></div><div> &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp; &nbsp;How to Make Jollof Rice (Just Like My Auntie Does)</div><div><br></div><div>One of my favorite dishes in the world is Jollof rice. It’s a popular West African meal that’s full of flavor, color, and spice. Every country claims their version is the best, but in my opinion, nothing beats my auntie’s Nigerian-style Jollof.</div><div><br></div><div>To make it, you start with rice, tomatoes, onions, and red bell peppers. My auntie blends the tomatoes and peppers into a smooth mix, then cooks it with oil and spices like thyme, curry powder, and bouillon.It smells amazing when it starts bubbling in the pot. </div><div><br></div><div>Next, she adds the rice and stirs it into the red sauce. The trick, she says, is to cover it with foil so the steam stays in and gives the rice that perfect texture — not too soft, not too hard. While it’s cooking, she might fry some plantains or grill chicken to go with it.</div><div><br></div><div>Jollof rice is more than just food. We eat it at birthdays, weddings, and family gatherings. Everyone brings their own twist. Some people add shrimp or vegetables, and others keep it classic. &nbsp;Whenever I smell Jollof cooking, it reminds me of dancing in the kitchen and laughing with my cousins.</div><div><br></div><div>I like that this recipe brings people together. It’s not fancy, but it’s full of love. One day, I hope I can make it just as well as my auntie does, but she says the secret ingredient is cooking with joy.</div><div><br></div><div><br></div></div><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-misconfig-3/Pasted Graphic 14.png\" data-canonical-image-url=\"image://Pasted Graphic 14.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"document_3_window\" style=\"height: 385px; width: 555px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; top: 45px; margin: 0px; left: 45px;\" class=\"design-mode-hidden\"><button id=\"document_3_x\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 18px; width: 18px; background-color: rgb(255, 0, 0); color: rgb(255, 255, 255); border-color: rgb(77, 87, 95); border-radius: 4px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; position: absolute; left: 575px; top: 49px; font-size: 8px;\" class=\"design-mode-hidden\">X</button><div contenteditable=\"true\" class=\"textArea design-mode-hidden\" id=\"document_3_text\" style=\"width: 455px; height: 235px; border-style: solid; background-color: rgba(242, 242, 242, 0); color: rgb(77, 87, 95); border-color: rgb(255, 255, 255); border-radius: 2px; border-width: 0px; font-family: Arial, Helvetica, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 110px; top: 195px; margin: 0px;\"><br><div>Haley Morales</div><div>Western High School</div><div>July 18, 2025</div><div><br></div><div> &nbsp;I’m ready! I’m ready! I’m ready!</div><div><br></div><div>Leedle leedle leedle lee.</div><div><br></div><div>I wumbo, you wumbo, he, she, we wumbo.</div><div><br></div><div>Is mayonnaise an instrument?</div><div><br></div></div></div><div class=\"screen\" tabindex=\"1\" data-theme=\"default\" id=\"screen2\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(0, 0, 0); display: none;\"><div contenteditable=\"true\" class=\"textArea\" id=\"text_area1\" style=\"width: 365px; height: 200px; border-style: solid; background-color: rgba(242, 242, 242, 0); color: rgb(113, 255, 0); border-color: rgba(255, 255, 255, 0); border-radius: 2px; border-width: 1px; font-family: &quot;Arial Black&quot;, Gadget, sans-serif; font-size: 18px; padding: 5px 15px; position: absolute; left: 130px; top: 215px; margin: 0px; text-align: center;\">YOUR FILES ARE ENCRYPTED!!!<div><br></div><div>All your school files, photos, and saved games are locked. </div><div><br></div><div>To unlock them, you must pay $300 in Bitcoin within 10 minutes. If you don’t pay in time, your files will be deleted forever!</div></div><img src=\"/level_starter_assets/aif-ai-powered-threats-defenses-lesson2-misconfig-3/clock-wait-till-the-end.gif\" data-canonical-image-url=\"image://clock-wait-till-the-end.gif\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"image4\" style=\"height: 205px; width: 345px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 125px; top: 5px; margin: 0px;\"></div></div>",
