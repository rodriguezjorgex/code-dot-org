    "start_blocks": "// Opens Chrome window\r\nonEvent(\"chrome_button\", \"click\", function( ) {\r\n\tshowElement(\"chrome_window\");\r\n\tshowElement(\"chrome_window_x\");\r\n\tshowElement(\"url_chrome\");\r\n\tshowElement(\"document_1_button\");\r\n\tshowElement(\"document_1_label\");\r\n\tshowElement(\"document_2_button\");\r\n\tshowElement(\"document_2_label\");\r\n\tshowElement(\"document_3_button\");\r\n\tshowElement(\"document_3_label\");\r\n});\r\n\r\n// Closes Chrome window\r\nonEvent(\"chrome_window_x\", \"click\", function( ) {\r\n\thideElement(\"chrome_window\");\r\n\thideElement(\"chrome_window_x\");\r\n\thideElement(\"url_chrome\");\r\n\thideElement(\"document_1_button\");\r\n\thideElement(\"document_1_label\");\r\n\thideElement(\"document_2_button\");\r\n\thideElement(\"document_2_label\");\r\n\thideElement(\"document_3_button\");\r\n\thideElement(\"document_3_label\");\r\n});\r\n\r\n\r\n// Opens Document 1 (Amara Essay) window\r\nonEvent(\"document_1_button\", \"click\", function( ) {\r\n\tshowElement(\"document_1_window\");\r\n\tshowElement(\"document_1_x\");\r\n\tshowElement(\"document_1_text\");\r\n});\r\n\r\n// Closes Document 1 (Amara Essay) window\r\nonEvent(\"document_1_x\", \"click\", function( ) {\r\n\thideElement(\"document_1_window\");\r\n\thideElement(\"document_1_x\");\r\n\thideElement(\"document_1_text\");\r\n});\r\n\r\n\r\n// Opens Document 2 (Jon Essay) window\r\nonEvent(\"document_2_button\", \"click\", function( ) {\r\n\tshowElement(\"document_2_window\");\r\n\tshowElement(\"document_2_x\");\r\n});\r\n\r\n// Closes Document 2 (Jon Essay) window\r\nonEvent(\"document_2_x\", \"click\", function( ) {\r\n\thideElement(\"document_2_window\");\r\n\thideElement(\"document_2_x\");\r\n});\r\n\r\n// Opens Document 3 (Haley Essay) window\r\nonEvent(\"document_3_button\", \"click\", function( ) {\r\n\tshowElement(\"document_3_window\");\r\n\tshowElement(\"document_3_x\");\r\n\tshowElement(\"document_3_text\");\r\n});\r\n\r\n// Closes Document 2 (Haley Essay) window\r\nonEvent(\"document_3_x\", \"click\", function( ) {\r\n\thideElement(\"document_3_window\");\r\n\thideElement(\"document_3_x\");\r\n\thideElement(\"document_3_text\")\r\n});",
