    "start_blocks": "var currentQuestion = 0;\n\nvar questions = [\n  {\n    screen: \"screen1\",\n    header: \"Subject: Action Required - Account Alert\",\n    sender: \"Billing Department <service@google.com>\",\n    body: \"Dear user,\\n\\nWe detected unusual activity in your account.\\nPlease verify your account:\\n[Click here to login]\",\n    linkPreview: \"https://secure-google-login.com\",\n    answer: \"Phishing\",\n    hasImage: false,\n    feedback: {\n      Phishing: \"✅ Correct! The link looks like a Google page, but it's actually secure-google-login.com. Always hover to verify!\",\n      Legit: \"❌ Not quite. This email impersonates Google with a misleading link.\"\n    }\n  },\n  {\n    screen: \"screen2\",\n    header: \"Subject: Payment Confirmation\",\n    sender: \"Billing Department <service@paypel-support.com>\",\n    body: \"Thank you for your recent payment of $254.87.\\nIf this wasn't you, [click here to cancel the transaction]\",\n    linkPreview: \"https://paypel-support-secure.com\",\n    answer: \"Phishing\",\n    hasImage: false,\n    feedback: {\n      Phishing: \"✅ Correct! The domain is 'paypel', not 'paypal'. That's a huge red flag.\",\n      Legit: \"❌ Nope. This is a spoof. Always check for misspellings in sender domains.\"\n    }\n  },\n  {\n    screen: \"screen3\",\n    header: \"Subject: You’ve Won a Gift Card!\",\n    sender: \"Rewards Center <claim@promo.rewards-center.org>\",\n    body: \"\",\n    linkPreview: \"https://redeem-now.cards.win\",\n    answer: \"Phishing\",\n    hasImage: true,\n    feedback: {\n      Phishing: \"✅ Smart move! The image hides the link and makes it look like a legit offer. Classic trick.\",\n      Legit: \"❌ This is phishing. The image masks a bad URL, and fake rewards are common bait.\"\n    }\n  }\n];\n\n// Setup hover events\nfor (var i = 1; i <= questions.length; i++) {\n  setupHover(i);\n}\n\n// Question logic\nshowQuestion(0);\n\nfunction showQuestion(index) {\n  currentQuestion = index;\n  var q = questions[index];\n  setScreen(q.screen);\n\n  setText(\"label_header\" + (index + 1), q.header);\n  setText(\"label_sender\" + (index + 1), q.sender);\n\n  if (!q.hasImage) {\n    setText(\"label_body\" + (index + 1), q.body.replace(/\\n/g, \"\\n\"));\n    showElement(\"label_body\" + (index + 1));\n    hideElement(\"image_email3\");\n  } else {\n    hideElement(\"label_body\" + (index + 1)); // In case it somehow exists\n    showElement(\"image_email3\");\n  }\n\n  hideElement(\"label_feedback\" + (index + 1));\n  hideElement(\"label_url\" + (index + 1));\n  hideElement(\"button_next\" + (index + 1));\n}\n\nfunction setupHover(screenIndex) {\n  var id = screenIndex;\n\n  var linkElement = (id === 3) ? \"image_email3\" : \"button_link\" + id;\n\n  onEvent(linkElement, \"mouseover\", function() {\n    setText(\"label_url\" + id, questions[id - 1].linkPreview);\n    showElement(\"label_url\" + id);\n  });\n\n  onEvent(linkElement, \"mouseout\", function() {\n    hideElement(\"label_url\" + id);\n  });\n\n  onEvent(\"button_phish\" + id, \"click\", function() {\n    showFeedback(id, \"Phishing\");\n  });\n\n  onEvent(\"button_legit\" + id, \"click\", function() {\n    showFeedback(id, \"Legit\");\n  });\n\n  onEvent(\"button_next\" + id, \"click\", function() {\n    if (id < questions.length) {\n      showQuestion(id);\n    } else {\n      showEndScreen();\n    }\n  });\n}\n\nfunction showFeedback(id, choice) {\n  var q = questions[id - 1];\n  setText(\"label_feedback\" + id, q.feedback[choice]);\n  showElement(\"label_feedback\" + id);\n  showElement(\"button_next\" + id);\n}\n\nfunction showEndScreen() {\n  setText(\"label_header3\", \"Quiz Complete!\");\n  setText(\"label_sender3\", \"\");\n  hideElement(\"image_email3\");\n  hideElement(\"button_phish3\");\n  hideElement(\"button_legit3\");\n  hideElement(\"button_link3\");\n  hideElement(\"label_url3\");\n  hideElement(\"button_next3\");\n\n  setText(\"label_feedback3\",\n    \"🎉 Great job completing the quiz!\\n\\n✅ Before you click:\\n• Check for real sender addresses\\n• Hover over links\\n• Be wary of urgency or free offers\"\n  );\n  showElement(\"label_feedback3\");\n}\n",
