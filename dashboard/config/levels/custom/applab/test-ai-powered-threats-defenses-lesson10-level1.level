    "start_blocks": "// --------------------\r\n// Variables\r\n// --------------------\r\nvar passwordGuesses = [];\r\nvar aiGuesses = [\r\n  \"kahlil2008\", \"jessica08\", \"ruby8\", \"ozuna2008\", \"acmilan08\", \"tacos08\", \"speedyk08\",\r\n  \"charlotte2008\", \"kahlilruby\", \"ozunaFan\", \"milan4life\", \"kahlil08\", \"rubyacmilan\", \"tacoslover\",\r\n  \"speedy08\", \"kahlilJessica\", \"acmilanfan8\", \"ruby_08\", \"ozuna_8\", \"charlotte08\",\r\n  \"tacos4ever\", \"kahlilNC08\", \"kahlilOzuna\", \"speedyk2008\", \"milanRuby8\", \"jessicaRuby\",\r\n  \"ozunaMilan\", \"kahlilTacos8\", \"charlotteFan\", \"kahlil123\"\r\n];\r\n\r\nvar masterPasswordGuessList = [ /* 120 total guesses */ \r\n  \"kahlil2008\", \"jessica08\", \"ruby8\", \"ozuna2008\", \"acmilan08\", \"tacos08\", \"speedyk08\",\r\n  \"charlotte2008\", \"kahlilruby\", \"ozunaFan\", \"milan4life\", \"kahlil08\", \"rubyacmilan\", \"tacoslover\",\r\n  \"speedy08\", \"kahlilJessica\", \"acmilanfan8\", \"ruby_08\", \"ozuna_8\", \"charlotte08\", \"tacos4ever\",\r\n  \"kahlilNC08\", \"kahlilOzuna\", \"speedyk2008\", \"milanRuby8\", \"jessicaRuby\", \"ozunaMilan\", \"kahlilTacos8\",\r\n  \"charlotteFan\", \"kahlil123\", \"rubyiscute\", \"ozunaForever\", \"milan2024\", \"ac_milan\", \"tacotuesday\",\r\n  \"charlotte123\", \"rubyrocks\", \"speedy_rules\", \"ozuna4life\", \"jessicaRocks\", \"rubyTheDog\", \"acmilanchamp\",\r\n  \"charlotte4ever\", \"milanfan_08\", \"rubylover\", \"ozunaChar\", \"kahlilPower\", \"tacos_win\", \"jessSpeed\",\r\n  \"milan_tacos\", \"rubyMVP\", \"ozunaNo1\", \"kahlil_2024\", \"ncRuby\", \"rubyNumber1\", \"teamkahlil\", \"musicOzuna\",\r\n  \"charlotteLove\", \"milanHero\", \"rubyfan08\", \"milanNC\", \"charlotte_guy\", \"jessTacos\", \"ozunaNC\", \"rubySpeed\",\r\n  \"kahlilPro\", \"speedy_milan\", \"acmilano\", \"charlotte08fan\", \"kahlilplusruby\", \"ruby_star\", \"ozunaKing\",\r\n  \"tacoking08\", \"rubyTaco\", \"ozunaFanboy\", \"milanLover08\", \"rubyZoom\", \"gamerRuby\", \"ozuna_rocks\", \"rubyFast\",\r\n  \"speedRuby08\", \"jessFav\", \"milanUnderdog\", \"charlottetown\", \"rubyQueen\", \"ozuna_star\", \"fastkahlil\",\r\n  \"acmilangame\", \"milanMagic\", \"jessicaBoom\", \"ozunaLive\", \"ruby2025\", \"tacotime\", \"ozunaFresh\", \"rubypluskahlil\",\r\n  \"speedyTacos\", \"ozunaReal\", \"jessica88\", \"milan_passion\", \"rubyLove08\", \"charlottePride\", \"speedstar08\",\r\n  \"ozunaTacos\", \"rubyOzuna\", \"rubySong\", \"ozunaBeats\", \"milanWin08\", \"rubyCool\", \"milanNight\", \"speedPower\",\r\n  \"charlotteFC\", \"tacosandmusic\", \"rubyLife\", \"ozunaTrack\", \"speedAce\", \"rubyMilan\", \"milanRuby\", \"jessicaNC\",\r\n  \"tacosnc\", \"ruby123\", \"ozunaGirl\", \"rubyAndMe\"\r\n];\r\n\r\n// --------------------\r\n// Password Strength Evaluation\r\n// --------------------\r\nfunction evaluateStrength(password) {\r\n  var score = 0;\r\n\r\n  if (password.length >= 12) score += 2;\r\n  else if (password.length >= 8) score += 1;\r\n\r\n  if (password.match(/[a-z]/) && password.match(/[A-Z]/)) score += 1;\r\n  if (password.match(/[0-9]/)) score += 1;\r\n  if (password.match(/[^A-Za-z0-9]/)) score += 1;\r\n\r\n  if (score <= 1) return \"Weak\";\r\n  else if (score <= 3) return \"Medium\";\r\n  else return \"Strong\";\r\n}\r\n\r\n// --------------------\r\n// AI Guesses: Regeneration Logic\r\n// --------------------\r\nfunction regenerateAIGuesses() {\r\n  aiGuesses = [];\r\n\r\n  while (aiGuesses.length < 30) {\r\n    var guess = masterPasswordGuessList[randomNumber(0, masterPasswordGuessList.length - 1)];\r\n    if (aiGuesses.indexOf(guess) === -1) {\r\n      appendItem(aiGuesses, guess);\r\n    }\r\n  }\r\n}\r\n\r\n// --------------------\r\n// Event: Submit User Guess\r\n// --------------------\r\nonEvent(\"submitBtn\", \"click\", function() {\r\n  var userGuess = getText(\"password_input\");\r\n\r\n  if (userGuess !== \"\" && passwordGuesses.indexOf(userGuess) === -1) {\r\n    appendItem(passwordGuesses, userGuess);\r\n\r\n    setText(\"guess_list_output\", passwordGuesses.map(function(item) {\r\n      return \"- \" + item;\r\n    }).join(\"\\n\"));\r\n\r\n    if (passwordGuesses.length >= 5) {\r\n      showElement(\"compareBtn\");\r\n    }\r\n\r\n    setText(\"password_input\", \"\");\r\n  }\r\n});\r\n\r\n// --------------------\r\n// Event: Compare Button → Show Lists\r\n// --------------------\r\nonEvent(\"compareBtn\", \"click\", function() {\r\n  setText(\"user_list\", passwordGuesses.map(function(item, index) {\r\n    return (index + 1) + \". \" + item;\r\n  }).join(\"\\n\"));\r\n\r\n  setText(\"ai_list\", aiGuesses.map(function(item, index) {\r\n    return (index + 1) + \". \" + item;\r\n  }).join(\"\\n\"));\r\n\r\n  setScreen(\"compare_screen\");\r\n});\r\n\r\n// --------------------\r\n// Event: Evaluate Password Strengths\r\n// --------------------\r\nonEvent(\"evalBtn\", \"click\", function() {\r\n  setText(\"user_list\", passwordGuesses.map(function(pw, index) {\r\n    return (index + 1) + \". \" + pw + \" (\" + evaluateStrength(pw) + \")\";\r\n  }).join(\"\\n\"));\r\n\r\n  setText(\"ai_list\", aiGuesses.map(function(pw, index) {\r\n    return (index + 1) + \". \" + pw + \" (\" + evaluateStrength(pw) + \")\";\r\n  }).join(\"\\n\"));\r\n});\r\n\r\n// --------------------\r\n// Event: Refresh AI Guesses\r\n// --------------------\r\nonEvent(\"refreshBtn\", \"click\", function() {\r\n  regenerateAIGuesses();\r\n\r\n  setText(\"ai_list\", aiGuesses.map(function(item, index) {\r\n    return (index + 1) + \". \" + item;\r\n  }).join(\"\\n\"));\r\n});\r\n\r\n// --------------------\r\n// Navigation Events\r\n// --------------------\r\nonEvent(\"patternBtn\", \"click\", function() {\r\n  setScreen(\"patterns_screen\");\r\n});\r\nonEvent(\"backBtn\", \"click\", function() {\r\n  setScreen(\"guessing_screen\");\r\n});\r\nonEvent(\"backBtn2\", \"click\", function() {\r\n  setScreen(\"guessing_screen\");\r\n});",
    "start_html": "<div id=\"designModeViz\" class=\"appModern clip-content\" data-radium=\"true\" style=\"width: 600px; height: 450px; display: none;\"><div class=\"screen\" tabindex=\"1\" data-theme=\"cucumber\" id=\"guessing_screen\" style=\"display: block; height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(170, 235, 223);\"><input id=\"password_input\" style=\"margin: 0px; width: 235px; height: 40px; border-style: solid; color: rgb(32, 152, 100); background-color: rgb(239, 255, 249); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 355px; top: 20px;\" placeholder=\"password guess\"><img src=\"/level_starter_assets/test-ai-powered-threats-defenses-lesson10-level1/key.png\" data-canonical-image-url=\"image://key.png\" data-image-type=\"file\" data-object-fit=\"contain\" id=\"icon2\" style=\"height: 35px; width: 45px; border-style: solid; border-width: 0px; border-color: rgb(0, 0, 0); border-radius: 0px; position: absolute; left: 305px; top: 20px; margin: 0px;\"><button id=\"submitBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 95px; background-color: rgb(82, 199, 148); color: rgb(255, 255, 255); border-color: rgb(239, 255, 249); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 490px; top: 75px;\">Submit</button><div contenteditable=\"false\" class=\"textArea\" id=\"guess_list_output\" style=\"width: 285px; height: 255px; border-style: solid; background-color: rgb(239, 255, 249); color: rgb(32, 152, 100); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; padding: 5px 15px; position: absolute; left: 305px; top: 125px; margin: 0px;\"></div><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(1, 49, 28); background-color: rgba(239, 255, 249, 0); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 26px; padding: 2px 15px; width: 285px; height: 35px; position: absolute; left: 10px; top: 15px;\" id=\"label1\">Password Guessing</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(1, 49, 28); background-color: rgba(239, 255, 249, 0); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 18px; padding: 2px 15px; width: 134px; height: 23px; position: absolute; left: 80px; top: 90px;\" id=\"label2\">Known Info</label><div contenteditable=\"true\" class=\"textArea\" id=\"text_area3\" style=\"width: 280px; height: 245px; border-style: solid; background-color: rgb(191, 251, 225); color: rgb(10, 45, 30); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; padding: 5px 15px; position: absolute; left: 10px; top: 130px; margin: 0px;\"><br><div>Name: Kahlil</div><div>Sibling Name: Jessica</div><div>Birth Year: 2008</div><div>Pet Name: Ruby</div><div>Favorite Sports Team: AC Milan</div><div>Favorite Musical Artist: Ozuna</div><div>Favorite Number: 8</div><div>Hometown: Charlotte, NC</div><div>Favorite Food: Tacos</div><div>Gaming Handle: SpeedyK08</div></div><button id=\"patternBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 195px; background-color: rgb(186, 149, 208); color: rgb(255, 255, 255); border-color: rgb(239, 255, 249); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 50px; top: 390px;\">Common Password Patterns</button><button id=\"compareBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 195px; background-color: rgb(82, 199, 148); color: rgb(255, 255, 255); border-color: rgb(239, 255, 249); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 360px; top: 390px;\" class=\"design-mode-hidden\">Compare with AI</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(1, 49, 28); background-color: rgba(239, 255, 249, 0); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 13px; padding: 2px 15px; width: 160px; height: 45px; position: absolute; left: 325px; top: 70px;\" id=\"label4\">Guess at least 5 possible passwords for this user</label></div><div class=\"screen\" tabindex=\"1\" data-theme=\"cucumber\" id=\"patterns_screen\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(170, 235, 223); display: none;\"><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(32, 152, 100); background-color: rgb(239, 255, 249); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 20px; padding: 2px 15px; width: 320px; height: 40px; position: absolute; left: 150px; top: 5px;\" id=\"label3\">Common Password Patterns</label><div contenteditable=\"false\" class=\"textArea\" id=\"text_area4\" style=\"width: 280px; height: 185px; border-style: solid; background-color: rgb(239, 255, 249); color: rgb(32, 152, 100); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 10px; top: 50px; margin: 0px;\">🧑 Names<div><br></div><div>People often include:</div><div>\t•\tTheir own first or last name (kahlil, smith)</div><div>\t•\tNames of siblings, friends, or partners (jessica, tony)</div><div>\t•\tPet names (ruby, max)</div><div><br></div><div>➡️ Try mixing names with numbers or symbols: ruby08, jessica123</div></div><div contenteditable=\"false\" class=\"textArea\" id=\"text_area5\" style=\"width: 280px; height: 190px; border-style: solid; background-color: rgb(239, 255, 249); color: rgb(32, 152, 100); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 10px; top: 245px; margin: 0px;\">⚽ Favorite Things<div><br></div><div>Think about what the person loves:</div><div>\t•\tFavorite sports teams (acmilan, lakers)</div><div>\t•\tMusical artists (ozuna, beyonce)</div><div>\t•\tFoods or hobbies (tacos, guitar, soccer)</div><div><br></div><div>➡️ Try combos like: ozunaFan, tacos4life, milan08</div></div><div contenteditable=\"false\" class=\"textArea\" id=\"text_area6\" style=\"width: 280px; height: 185px; border-style: solid; background-color: rgb(239, 255, 249); color: rgb(32, 152, 100); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 305px; top: 50px; margin: 0px;\">📅 Dates and Numbers<div><br></div><div>Many passwords include:</div><div>\t•\tBirth years (2008, 99)</div><div>\t•\tSpecial dates like graduation, anniversaries, or jersey numbers (2022, 15)</div><div><br></div><div>➡️ Try combinations like: kahlil2008, milan15</div></div><div contenteditable=\"false\" class=\"textArea\" id=\"text_area8\" style=\"width: 280px; height: 190px; border-style: solid; background-color: rgb(239, 255, 249); color: rgb(32, 152, 100); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 305px; top: 245px; margin: 0px;\">🔁 Mix &amp; Match Patterns<div><br></div><div>People often mix info to make their passwords feel “unique,” like:</div><div>\t•\tName + birth year → jessica08</div><div>\t•\tPet + team → rubyMilan</div><div>\t•\tArtist + number → ozuna7</div><div><br></div><div>➡️ Try combining two or more clues in creative ways.</div></div><button id=\"backBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 100px; background-color: rgb(82, 199, 148); color: rgb(255, 255, 255); border-color: rgb(239, 255, 249); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 480px; top: 5px;\">Back</button></div><div class=\"screen\" tabindex=\"1\" data-theme=\"cucumber\" id=\"compare_screen\" style=\"height: 450px; width: 600px; left: 0px; top: 0px; position: absolute; z-index: 0; background-color: rgb(170, 235, 223); display: none;\"><div contenteditable=\"false\" class=\"textArea\" id=\"user_list\" style=\"width: 285px; height: 280px; border-style: solid; background-color: rgb(239, 255, 249); color: rgb(32, 152, 100); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 10px; top: 90px; margin: 0px;\"></div><div contenteditable=\"false\" class=\"textArea\" id=\"ai_list\" style=\"width: 285px; height: 280px; border-style: solid; background-color: rgb(239, 255, 249); color: rgb(32, 152, 100); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 0px; font-family: Verdana, Geneva, sans-serif; font-size: 13px; padding: 5px 15px; position: absolute; left: 305px; top: 90px; margin: 0px;\">\t1.\tkahlil2008<div>\t2.\tjessica08</div><div>\t3.\truby8</div><div>\t4.\tozuna2008</div><div>\t5.\tacmilan08</div><div>\t6.\ttacos08</div><div>\t7.\tspeedyk08</div><div>\t8.\tcharlotte2008</div><div>\t9.\tkahlilruby</div><div>\t10.\tozunaFan</div><div>\t11.\tmilan4life</div><div>\t12.\tkahlil08</div><div>\t13.\trubyacmilan</div><div>\t14.\ttacoslover</div><div>\t15.\tspeedy08</div><div>\t16.\tkahlilJessica</div><div>\t17.\tacmilanfan8</div><div>\t18.\truby_08</div><div>\t19.\tozuna_8</div><div>\t20.\tcharlotte08</div><div>\t21.\ttacos4ever</div><div>\t22.\tkahlilNC08</div><div>\t23.\tkahlilOzuna</div><div>\t24.\tspeedyk2008</div><div>\t25.\tmilanRuby8</div><div>\t26.\tjessicaRuby</div><div>\t27.\tozunaMilan</div><div>\t28.\tkahlilTacos8</div><div>\t29.\tcharlotteFan</div><div>\t30.\tkahlil123</div><div><br></div></div><button id=\"backBtn2\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 125px; background-color: rgb(82, 199, 148); color: rgb(255, 255, 255); border-color: rgb(239, 255, 249); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 75px; top: 385px;\">Make more guesses</button><button id=\"evalBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 100px; background-color: rgb(82, 199, 148); color: rgb(255, 255, 255); border-color: rgb(239, 255, 249); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 245px; top: 385px;\">Evaluate</button><button id=\"refreshBtn\" style=\"padding: 0px; margin: 0px; border-style: solid; height: 40px; width: 145px; background-color: rgb(82, 199, 148); color: rgb(255, 255, 255); border-color: rgb(239, 255, 249); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 15px; position: absolute; left: 385px; top: 385px;\">Regenerate AI Guesses</button><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(32, 152, 100); background-color: rgb(239, 255, 249); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 18px; padding: 2px 15px; width: 154px; height: 25px; position: absolute; left: 85px; top: 55px;\" id=\"label5\">Your Guesses</label><label style=\"margin: 0px; line-height: 1; overflow: hidden; overflow-wrap: break-word; max-width: 320px; border-style: solid; text-rendering: optimizespeed; color: rgb(32, 152, 100); background-color: rgb(239, 255, 249); border-color: rgb(32, 152, 100); border-radius: 30px; border-width: 1px; font-family: Verdana, Geneva, sans-serif; font-size: 18px; padding: 2px 15px; width: 154px; height: 25px; position: absolute; left: 385px; top: 55px; text-align: center;\" id=\"label6\">AI Guesses</label></div></div>",
    "long_instructions": "## Do This:\r\n\r\n1.\tUse what you know about Kahlil to guess passwords and add them to your list.\r\n\r\n2.\tClick “Compare” to reveal and review AI-generated password guesses.\r\n\r\n3.\tPress “Evaluate” to see how strong your guesses and the AI’s guesses really are.",
