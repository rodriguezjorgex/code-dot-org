    "encrypted": "false",
    "display_name": "Software Engineer",
    "long_instructions": "## Software Engineer 🖥️ \r\n<br/>\r\n\r\n\r\n<p style=\"font-size:16px\">Software engineers develop the AI, applications, and cloud-based systems that power smart technology. They ensure that software runs smoothly, collects data efficiently, and improves user experience.</p>\r\n\r\n\r\n---\r\n\r\n\r\n\r\n## Do This:\r\n\r\n<ol style=\"font-size:16px\">\r\n<li>Use AI Chat to conduct the interview and take notes on their responses. Ask questions about their work, including:</li>\r\n\t<ul style=\"font-size:16px\">\r\n    \t<li>Key roles and responsibilities</li>\r\n    \t<li>How their role contributes to building your innovation</li>\r\n    \t<li>The challenges they face in designing, developing, or refining innovations</li>\r\n\t</ul>\r\n<br/>\r\n<li>Summarize key insights in your activity guide.</li>\r\n</ol>\r\n\r\n",
    "aichat_settings": {
      "initialCustomizations": {
        "selectedModelId": "gpt-4o-mini",
