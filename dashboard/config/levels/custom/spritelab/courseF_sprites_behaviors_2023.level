   },\n    \"55bde74f-0f20-4a6c-8511-645513d0ddd7\": {\n      \"name\": \"flower1_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/rGVvQNYG0eq9tSWRjzzuhTl5311HeCE5/category_icons/flower1.png\",\n      \"frameSize\": {\n        \"x\": 288,\n        \"y\": 395\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"rGVvQNYG0eq9tSWRjzzuhTl5311HeCE5\",\n      \"categories\": [\n        \"icons\"\n      ]\n    },\n    \"e5d76b00-b457-4ae2-9893-12a85c2fe185\": {\n      \"name\": \"flower2_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/s6i1zvtSA2V8GMDTmS_Wdbgd3_TbnGA3/category_icons/flower2.png\",\n      \"frameSize\": {\n        \"x\": 256,\n        \"y\": 353\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"s6i1zvtSA2V8GMDTmS_Wdbgd3_TbnGA3\",\n      \"categories\": [\n        \"icons\"\n      ]\n    },\n    \"8b45e5b5-a6a7-41b9-96dd-53632ee7b289\": {\n      \"name\": \"gradient_01_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/UXLibXLPPb5ofYkbGpXPPKBf.txNOBHP/category_backgrounds/gradient_01.png\",\n      \"frameSize\": {\n        \"x\": 400,\n        \"y\": 400\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"UXLibXLPPb5ofYkbGpXPPKBf.txNOBHP\",\n      \"categories\": [\n        \"backgrounds\"\n      ]\n    },\n    \"7e3bac02-049e-4b76-ad6c-60d3c13721ac\": {\n      \"name\": \"bg_landscape10_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/bd70yXmt3QhSWOcEF8grNZiWfnsKW4d8/category_backgrounds/bg_landscape10.png\",\n      \"frameSize\": {\n        \"x\": 400,\n        \"y\": 385\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"bd70yXmt3QhSWOcEF8grNZiWfnsKW4d8\",\n      \"categories\": [\n        \"backgrounds\"\n      ]\n    },\n    \"d118d4ec-20da-4e03-a987-dc2206da1127\": {\n      \"name\": \"bg_underwater_02_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/WZ9Eh0Mt6gY_h6uGTwUn_qal4ZBKP8gX/category_backgrounds/bg_underwater_02.png\",\n      \"frameSize\": {\n        \"x\": 400,\n        \"y\": 395\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"WZ9Eh0Mt6gY_h6uGTwUn_qal4ZBKP8gX\",\n      \"categories\": [\n        \"backgrounds\"\n      ]\n    },\n    \"016ec141-1ccb-42aa-9949-9e6e48ad6abb\": {\n      \"name\": \"desert_road_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/uexnVGl6IX_C6YzQENPPXtel_lCwoG7F/category_backgrounds/desert_road.png\",\n      \"frameSize\": {\n        \"x\": 400,\n        \"y\": 400\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"uexnVGl6IX_C6YzQENPPXtel_lCwoG7F\",\n      \"categories\": [\n        \"backgrounds\"\n      ]\n    },\n    \"739a610c-d428-4b5a-84c3-e0a71db94f1e\": {\n      \"name\": \"court_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/T.BLfNn.3XTblWtBQ7GC1tSx4_8IsEJV/category_backgrounds/background_court.png\",\n      \"frameSize\": {\n        \"x\": 400,\n        \"y\": 400\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"T.BLfNn.3XTblWtBQ7GC1tSx4_8IsEJV\",\n      \"categories\": [\n        \"backgrounds\"\n      ]\n    },\n    \"3527509c-6912-4404-9e3a-c69a0155eee4\": {\n      \"name\": \"cactus_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/6dYocBOA_QkVNgyffQfdOR.qmxMF5oup/category_game_blocks/cactus.png\",\n      \"frameSize\": {\n        \"x\": 117,\n        \"y\": 160\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"6dYocBOA_QkVNgyffQfdOR.qmxMF5oup\",\n      \"categories\": [\n        \"game_blocks\"\n      ]\n    },\n    \"ee35e064-87b2-4c61-bc43-c95995103b7f\": {\n      \"name\": \"planeRed1_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/doNsuLSldRWw4EqNUuQ0oxoMGvLIMOca/category_vehicles/planeRed1.png\",\n      \"frameSize\": {\n        \"x\": 88,\n        \"y\": 73\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"doNsuLSldRWw4EqNUuQ0oxoMGvLIMOca\",\n      \"categories\": [\n        \"vehicles\"\n      ]\n    },\n    \"a29016ae-23e1-4fc8-9705-580bdace8a25\": {\n      \"name\": \"planeYellow1_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/qcaNo2jTsMDoG3w9CrSW9hQCgsyRleaC/category_vehicles/planeYellow1.png\",\n      \"frameSize\": {\n        \"x\": 88,\n        \"y\": 73\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"qcaNo2jTsMDoG3w9CrSW9hQCgsyRleaC\",\n      \"categories\": [\n        \"vehicles\"\n      ]\n    },\n    \"ed611eea-92d9-48e0-a543-de2ba6a12584\": {\n      \"name\": \"sun_2\",\n      \"sourceUrl\": \"https://studio.code.org/v3/animations/Rm5DYUAYYjl_J_son0TO0D9iO_-SQs5ZFPuQvHm9LhY/ed611eea-92d9-48e0-a543-de2ba6a12584.png?version=xitSo2RyV1Ct4XwqSfX8E8KdbtW6TzSi\",\n      \"frameSize\": {\n        \"x\": 150,\n        \"y\": 150\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 12,\n      \"version\": \"xitSo2RyV1Ct4XwqSfX8E8KdbtW6TzSi\",\n      \"categories\": [\n        \"game_blocks\"\n      ]\n    },\n    \"5066c079-b1a7-4a71-8767-b95b59fd4e50\": {\n      \"name\": \"sunshine_showers_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/2RNMR6.K0ycRUzGH2f_.KDC56AlzdXPI/category_backgrounds/sunshine_showers.png\",\n      \"frameSize\": {\n        \"x\": 400,\n        \"y\": 400\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"2RNMR6.K0ycRUzGH2f_.KDC56AlzdXPI\",\n      \"categories\": [\n        \"backgrounds\"\n      ]\n    }\n  }\n}",
    "validation_enabled": "true",
    "mini_toolbox": "true",
    "validation_code": "if (!validationProps.successCriteria) {\r\n  validationProps.successCriteria = {\r\n    madeSprite: false,\r\n    spriteHasBehavior: false,\r\n    bonus: false\r\n  };\r\n}\r\n\r\n// Helper variables\r\nvar spriteIds = getSpriteIdsInUse();\r\nvar animations = getAnimationsInUse();\r\n\r\nvar failTime=10;\r\n\r\n// Check for sprites\r\nif (!validationProps.successCriteria.madeSprite) {\r\n  validationProps.successCriteria.madeSprite = (spriteIds.length >= 1);\r\n}\r\n\r\n\r\n// Check for behavior\r\nif (validationProps.successCriteria.madeSprite) {\r\n  for (var i = 0; i < animations.length; i++) {\r\n    if(getNumBehaviorsForAnimation(animations[i]) >= 1){\r\n      validationProps.successCriteria.spriteHasBehavior = true;\r\n    }\r\n    if(getNumBehaviorsForAnimation(animations[i]) >= 2){\r\n      validationProps.successCriteria.bonus = true;\r\n    }\r\n  }\r\n}\r\n\r\nif (World.frameCount > failTime) {\r\n  // Check criteria and give failure feedback\r\n  if (!validationProps.successCriteria.madeSprite) {\r\n    levelFailure(3, \"starterSprites\");\r\n  } else if (!validationProps.successCriteria.spriteHasBehavior) {\r\n    levelFailure(3, \"noBehavior\");\r\n  }\r\n}\r\n\r\n//if we haven’t failed yet, pass\r\nvar waitTime=150;\r\nif (World.frameCount > waitTime) {\r\n  if(validationProps.successCriteria.bonus){\r\n    levelFailure(0, \"genericBonusSuccess\");\r\n  } else {\r\n  \tlevelFailure(0, \"genericExplore\");\r\n  }\r\n}\r\n\r\nif(!validationProps.successCriteria.madeSprite || !validationProps.successCriteria.spriteHasBehavior) {\r\n  fill(rgb(118,102,160));\r\n  rect(0,390,(World.frameCount*400/failTime),10);\r\n} else {\r\n   fill(rgb(0,173,188));\r\n  rect(0,390,(World.frameCount*400/waitTime),10);\r\n}\r\n",
    "display_name": "Sprite Behaviors",
