    "callout_json": "[{\"localization_key\":\"hello_world_new\",\"callout_text\":\"New block!\",\"element_id\":\".svgFlyoutGroup [block-id=\\\"10\\\"]\",\"on\":\"\",\"qtip_config\":{\"codeStudio\":{\"canReappear\":true,\"dropletPaletteCategory\":\"\"},\"style\":{\"classes\":\"\"},\"position\":{\"my\":\"left center\",\"at\":\"right center\",\"adjust\":{\"x\":0,\"y\":0}}}},{\"localization_key\":\"hello_world_new_block\",\"callout_text\":\"New block!\",\"element_id\":\".svgFlyoutGroup [block-id=\\\"13\\\"]\",\"on\":\"\",\"qtip_config\":{\"codeStudio\":{\"canReappear\":true,\"dropletPaletteCategory\":\"\"},\"style\":{\"classes\":\"\"},\"position\":{\"my\":\"left center\",\"at\":\"right center\",\"adjust\":{\"x\":0,\"y\":0}}}},{\"element_id\":\".blocklyFlyout [data-id=\\\"10\\\"]\",\"localization_key\":\"hello_world_new\",\"callout_text\":\"New block!\",\"qtip_config\":{\"codeStudio\":{\"canReappear\":true,\"dropletPaletteCategory\":\"\"},\"style\":{\"classes\":\"\"},\"position\":{\"my\":\"left center\",\"at\":\"right center\",\"adjust\":{\"x\":0,\"y\":0}}},\"on\":\"\"},{\"element_id\":\".blocklyFlyout [data-id=\\\"13\\\"]\",\"localization_key\":\"hello_world_new_block\",\"callout_text\":\"New block!\",\"qtip_config\":{\"codeStudio\":{\"canReappear\":true,\"dropletPaletteCategory\":\"\"},\"style\":{\"classes\":\"\"},\"position\":{\"my\":\"left center\",\"at\":\"right center\",\"adjust\":{\"x\":0,\"y\":0}}},\"on\":\"\"}]",
    "hide_pause_button": "true",
    "hint_prompt_attempts_threshold": "1",
    "short_instructions": "Let's learn to change the size of sprites.",
    "authored_hints": "[{\"hint_class\":\"content\",\"hint_markdown\":\"To set the size of a sprite just one time, you can use this block:\\n\\n<xml><block type=\\\"gamelab_setProp\\\">\\n      <title name=\\\"PROPERTY\\\">\\\"scale\\\"</title>\\n      <value name=\\\"SPRITE\\\">\\n        <block type=\\\"gamelab_allSpritesWithAnimation\\\">\\n          <title name=\\\"ANIMATION\\\">\\\"emoji_17_1\\\"</title>\\n        </block>\\n      </value>\\n      <value name=\\\"VAL\\\">\\n        <block type=\\\"math_number\\\">\\n          <title name=\\\"NUM\\\">50</title>\\n        </block>\\n      </value>\\n    </block></xml>\",\"hint_id\":\"storyboard_setProp\",\"hint_type\":\"general\",\"hint_path\":\"\",\"hint_video\":\"\",\"tts_url\":\"https://tts.code.org/sharon22k/180/100/56b8cfafde672fecebe3d9ab39a2170c/helloworld_emoji_sizes.mp3\"},{\"hint_class\":\"content\",\"hint_markdown\":\"If you want to change a sprite's size over and over (with events), use this block:\\n\\n<xml><block type=\\\"gamelab_changePropBy\\\">\\n      <title name=\\\"PROPERTY\\\">\\\"scale\\\"</title>\\n      <value name=\\\"SPRITE\\\">\\n        <block type=\\\"gamelab_allSpritesWithAnimation\\\">\\n          <title name=\\\"ANIMATION\\\">\\\"emoji_33_1\\\"</title>\\n        </block>\\n      </value>\\n      <value name=\\\"VAL\\\">\\n        <block type=\\\"math_number\\\">\\n          <title name=\\\"NUM\\\">10</title>\\n        </block>\\n      </value>\\n    </block></xml>\",\"hint_id\":\"storyboard_changePropBy\",\"hint_type\":\"general\",\"hint_path\":\"\",\"hint_video\":\"\",\"tts_url\":\"https://tts.code.org/sharon22k/180/100/1763da358898c81d34dceb47dd1bfc79/helloworld_emoji_sizes.mp3\"}]",
