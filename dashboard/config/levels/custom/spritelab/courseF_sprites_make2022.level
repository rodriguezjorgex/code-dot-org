-library/gamelab/doNsuLSldRWw4EqNUuQ0oxoMGvLIMOca/category_vehicles/planeRed1.png\",\n      \"frameSize\": {\n        \"x\": 88,\n        \"y\": 73\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"doNsuLSldRWw4EqNUuQ0oxoMGvLIMOca\",\n      \"categories\": [\n        \"vehicles\"\n      ]\n    },\n    \"a29016ae-23e1-4fc8-9705-580bdace8a25\": {\n      \"name\": \"planeYellow1_1\",\n      \"sourceUrl\": \"/api/v1/animation-library/gamelab/qcaNo2jTsMDoG3w9CrSW9hQCgsyRleaC/category_vehicles/planeYellow1.png\",\n      \"frameSize\": {\n        \"x\": 88,\n        \"y\": 73\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 2,\n      \"version\": \"qcaNo2jTsMDoG3w9CrSW9hQCgsyRleaC\",\n      \"categories\": [\n        \"vehicles\"\n      ]\n    },\n    \"ed611eea-92d9-48e0-a543-de2ba6a12584\": {\n      \"name\": \"sun_2\",\n      \"sourceUrl\": \"https://studio.code.org/v3/animations/Rm5DYUAYYjl_J_son0TO0D9iO_-SQs5ZFPuQvHm9LhY/ed611eea-92d9-48e0-a543-de2ba6a12584.png?version=xitSo2RyV1Ct4XwqSfX8E8KdbtW6TzSi\",\n      \"frameSize\": {\n        \"x\": 150,\n        \"y\": 150\n      },\n      \"frameCount\": 1,\n      \"looping\": true,\n      \"frameDelay\": 12,\n      \"version\": \"xitSo2RyV1Ct4XwqSfX8E8KdbtW6TzSi\",\n      \"categories\": [\n        \"game_blocks\"\n      ]\n    }\n  }\n}",
    "validation_enabled": "true",
    "mini_toolbox": "true",
    "validation_code": "if (!validationProps.successCriteria) {\r\n  validationProps.successCriteria = {\r\n    madeSprites: false,\r\n  };\r\n}\r\n\r\n// Helper variables\r\nvar spriteIds = getSpriteIdsInUse();\r\n\r\n// Count Sprites\r\nif(!validationProps.successCriteria.madeSprites){\r\n  validationProps.successCriteria.madeSprites = (spriteIds.length >= 1);\r\n}\r\n\r\n// Check criteria and give failure feedback\r\nif (!validationProps.successCriteria.madeSprites) {\r\n  levelFailure(3, \"noSprites\");\r\n} else {\r\n  levelFailure(0, \"genericSuccess\");\r\n}",
    "display_name": "Making Sprites",
    "bubble_choice_description": "Practice making sprites.\r\n",
    "project_template_level_name": "courseF_sprites_template2022",
    "callout_json": "[{\"localization_key\":\"sprites_category\",\"callout_text\":\"Click here to open the Sprites category.\",\"element_id\":\"[id=':2.label']\",\"on\":\"\",\"qtip_config\":{\"codeStudio\":{\"canReappear\":true,\"dropletPaletteCategory\":\"\"},\"style\":{\"classes\":\"\"},\"position\":{\"my\":\"left center\",\"at\":\"right center\",\"adjust\":{\"x\":0,\"y\":0}}}},{\"element_id\":\"[id='blockly-2.label']\",\"localization_key\":\"sprites_category\",\"callout_text\":\"Click here to open the Sprites category.\",\"qtip_config\":{\"codeStudio\":{\"canReappear\":true,\"dropletPaletteCategory\":\"\"},\"style\":{\"classes\":\"\"},\"position\":{\"my\":\"left center\",\"at\":\"right center\",\"adjust\":{\"x\":0,\"y\":0}}},\"on\":\"\"}]",
