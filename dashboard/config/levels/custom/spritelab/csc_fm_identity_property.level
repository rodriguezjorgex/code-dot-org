  <blocks>
    <start_blocks>
      <xml>
        <block type="when_run" movable="false">
          <next>
            <block type="gamelab_makeNewSpriteAnon">
              <field name="ANIMATION_NAME">"alienBlue"</field>
              <value name="LOCATION">
                <block type="gamelab_location_picker">
                  <field name="LOCATION">{"x":200,"y":234}</field>
                </block>
              </value>
              <next>
                <block type="gamelab_setPrompt">
                  <value name="QUESTION">
                    <block type="text" can_disconnect_from_parent="false">
                      <field name="TEXT">Pick a number</field>
                    </block>
                  </value>
                  <value name="VAR">
                    <block type="variables_get" can_disconnect_from_parent="false">
                      <field name="VAR">input</field>
                    </block>
                  </value>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="gamelab_whenPromptAnswered">
          <value name="VAR">
            <block type="variables_get" can_disconnect_from_parent="false">
              <field name="VAR">input</field>
            </block>
          </value>
          <next>
            <block type="FunctionBlocks_spriteSayVar">
              <value name="SPRITE">
                <block type="gamelab_allSpritesWithAnimation">
                  <field name="ANIMATION">"alienBlue"</field>
                </block>
              </value>
              <value name="TEXT1">
                <block type="variables_get">
                  <field name="VAR">input</field>
                </block>
              </value>
              <next>
                <block type="FunctionBlocks_representManipulative">
                  <field name="ANIMATION_NAME">"ice_cream_cup_1"</field>
                  <value name="NUM">
                    <block type="variables_get">
                      <field name="VAR">input</field>
                    </block>
                  </value>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="procedures_defnoreturn">
          <mutation/>
          <field name="NAME">timesTwo</field>
          <statement name="STACK">
            <block type="variables_set">
              <field name="VAR">output</field>
              <value name="VALUE">
                <block type="math_arithmetic">
                  <field name="OP">MULTIPLY</field>
                  <value name="A">
                    <block type="variables_get">
                      <field name="VAR">input</field>
                    </block>
                  </value>
                  <value name="B">
                    <block type="math_number">
                      <field name="NUM">0</field>
                    </block>
                  </value>
                </block>
              </value>
            </block>
          </statement>
        </block>
        <block type="gamelab_spriteClicked">
          <field name="CONDITION">"when"</field>
          <value name="SPRITE">
            <block type="gamelab_allSpritesWithAnimation">
              <field name="ANIMATION">"alienBlue"</field>
            </block>
          </value>
          <next>
            <block type="procedures_callnoreturn">
              <mutation name="timesTwo"/>
              <next>
                <block type="FunctionBlocks_representManipulative">
                  <field name="ANIMATION_NAME">"ice_cream_cup_2"</field>
                  <value name="NUM">
                    <block type="variables_get">
                      <field name="VAR">output</field>
                    </block>
                  </value>
                  <next>
                    <block type="FunctionBlocks_spriteSayVar" editable="false">
                      <value name="SPRITE">
                        <block type="gamelab_allSpritesWithAnimation">
                          <field name="ANIMATION">"alienBlue"</field>
                        </block>
                      </value>
                      <value name="TEXT1">
                        <block type="variables_get">
                          <field name="VAR">output</field>
                        </block>
                      </value>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
      </xml>
    </start_blocks>
    <toolbox_blocks>
      <xml>
        <block type="procedures_callnoreturn">
          <mutation name="timesTwo"/>
        </block>
      </xml>
    </toolbox_blocks>
  </blocks>
</GamelabJr>