                    <block type="gamelab_location_picker">
                      <title name="LOCATION">{"x":300,"y":300}</title>
                    </block>
                  </value>
                  <next>
                    <block type="gamelab_addBehaviorSimple" inline="true">
                      <value name="SPRITE">
                        <block type="sprite_variables_get">
                          <title name="VAR">dusty</title>
                        </block>
                      </value>
                      <value name="BEHAVIOR">
                        <block type="gamelab_swimming"/>
                      </value>
                      <next>
                        <block type="gamelab_createNewSprite" inline="false">
