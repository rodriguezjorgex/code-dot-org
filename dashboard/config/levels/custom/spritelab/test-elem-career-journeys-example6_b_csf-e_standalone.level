        <block type="behavior_definition" x="0" y="0">
          <mutation behaviorId="wandering"/>
          <field name="button_behavior_definition"/>
          <field name="NAME">wandering</field>
          <statement name="STACK">
            <block type="gamelab_withPercentChance">
              <value name="NUM">
