    "name_suffix": "_2023",
    "validation_code": "//validation\r\n\r\n//Make sure [CSC Module Helper Library] is included as a library in this level\r\nif (World.frameCount == 1) {\r\n  //Everything in this if-statement will just run once, during the first frame of your level\r\n  //README() //uncomment this to see the README for the helper library in the console of this level\r\n  //turnOnDebugging() //uncomment this to use a DEBUG global variable to control console.log statements in your code\r\n  \r\n  setFailTime(150); // Frames to wait before failing student\r\n  setDelayTime(90); // Frames to wait after success before stopping program\r\n  setupPrevious(); //Defines the validationProps.previous{} object. To use it, call updatePrevious() at the end of this box\r\n  \r\n  //use addCriteria to setup the validation logic.\r\n  //You can use criterion commands as helper functions: \r\n  //https://github.com/code-dot-org/code-dot-org/blob/staging/apps/src/p5lab/spritelab/commands/criterionCommands.js\r\n  \r\n  //These are snowballing validation functions. They are defined in the helper library\r\n  //They can be called on future levels to carry forward validation\r\n  //To STOP validating a particular criteria, set the boolean value of the function to false\r\n  //for example: level2Validation(false, false, false) won't actually validate any of the criteria from level 2\r\n  \r\n  //Level 1 Validation Functions\r\n  //check if the background changed\r\n  addCriteria(function() {\r\n    return checkSetBackground();\r\n  }, \"spritelabFeedbackChangeBackgroundColor\");  // include i18n feedback string\r\n\r\n  // Feedback criteria for when the student forgot to create a sprite\r\n  addCriteria(function() {\r\n    return spriteIds.length >= 1;\r\n  }, \"createNewSprite\"); // needs custom feedback string potentially\r\n  \r\n  //Level 2 Validation Functions\r\n  //check for a new location on 1st sprite\r\n  addCriteria(function() {\r\n    return spriteIds.length >= 1 && checkMovedSpritePin(spriteIds[0]);\r\n  }, \"changeLocation\");  // include i18n feedback string\r\n  \r\n  //Level 3 Validation Functions\r\n  //Checks if the first sprite says something\r\n  //addCriteria(function() {\r\n    //return spriteIds.length >= 1 && checkSpriteSpeech(spriteIds[0]);\r\n  //}, \"noSpeech\");  // include i18n feedback string\r\n  //checkSpriteSpeech();\r\n  \r\n  //Level 4 Validation Functions\r\n  //Checks whether 2 sprites exist\r\n    addCriteria(function() {\r\n    return spriteIds.length > 1;\r\n  }, \"cscLandmarkMissing\");\r\n  \r\n  addCriteria(function() {\r\n    return spriteIds.length > 2;\r\n  }, \"cscLandmarkAddAnotherSprite\");  // include i18n feedback string\r\n \r\n  //Checks whether the second sprite is not the default costume\r\n  addCriteria(function() {\r\n    return spriteIds.length >= 3 && checkNotDefaultCostume(spriteIds[1], \"green_shirt_wave2\");\r\n  }, \"cscLandmarkChangeCostume\");  // include i18n feedback string\r\n  \r\n  //Checks whether the second sprite has moved locations\r\n  addCriteria(function() {\r\n    return spriteIds.length >= 3 && checkMovedSpritePin(spriteIds[1]) && checkMovedSpritePin(spriteIds[2]);\r\n  }, \"changeLocation\");  // include i18n feedback string\r\n  \r\n  \r\n  //Checks that a movement behavior has been added\r\n  addCriteria(function() {\r\n    return checkInteractiveSpriteMovement();\r\n  }, \"cscLandmarkBehavior\");  // include i18n feedback string\r\n  \r\n  addCriteria(function() {\r\n    console.log(getProp({ \"costume\": \"location_pin_a\" }, \"scale\"));\r\n\treturn !(getProp({ \"costume\": \"location_pin_a\" }, \"scale\") === 100 || getProp({ \"costume\": \"location_pin_b\" }, \"scale\") === 100);\r\n  }, \"useTwoSetpropBlocks\" );\r\n  \r\n\r\n  \r\n}\r\n//Everything after this will run during each 'tick' of the draw loop in your level\r\n//Be careful about putting console.log statements here\r\n\r\n//Always have this first to get most up-to-date helper variables\r\ngetHelperVars();\r\n\r\n//This is what calls updateValidation in \r\n//https://github.com/code-dot-org/code-dot-org/blob/staging/apps/src/p5lab/spritelab/commands/validationCommands.js\r\n//To check the validation criteria\r\ncheck();\r\n\r\n//Always have this at end to store previous state in validationProps.previous\r\nupdatePrevious();",
    "standalone_app_name": "spritelab",
    "start_animations": "{\n  \"orderedKeys\": [\n    \"35bc18db-1f5d-4e00-a387-c9b44c614a6f\",\n    \"f1e7edbc-f8ba-4faa-a91b-6bf9d331afa6\",\n    \"f90dfcc1-7757-4ed2-81d1-fea1b7c6e18e\",\n    \"56b223fb-d9f5-4807-a4ea-9f88e06c8874\",\n    \"75290e38-b505-4b7a-a081-dd0f624ceb67\",\n    \"46806d50-18d7-4c77-897c-7d32bb2422a0\",\n    \"be30ef15-0b41-42c2-9699-1c313f07c3d5\",\n    \"6bef418e-bc26-4f0c-870a-dc577e430588\",\n    \"5e21f036-c4d1-49e6-8341-3c25a5a82b9e\",\n    \"248e1eb0-b6ee-4a43-88e1-3c300852f63b\",\n    \"e8fcf33f-81f6-4302-bd7c-9fd6925cc4e9\",\n    \"5d1fb733-c6dc-440c-9ac0-869cc51f9b0f\",\n    \"5523aef7-28a7-4a7c-9d68-0d7cca92b089\",\n    \"68e7bd89-1bca-40c6-8d20-435ce3ef58ee\",\n    \"0f63959f-2145-4d3d-a34d-49fbad38247a\",\n    \"a37b98bc-ed92-4996-90d4-0748d6cc8a79\",\n    \"53ebcc87-bebb-48cf-b48d-dce5e6972b15\",\n    \"3e5228dc-92d9-43e9-87aa-2c8744964ea9\",\n    \"511a140a-6a34-46b3-bddf-58545dbfa106\",\n    \"ad065df1-67df-43bd-8e4b-bacfdc7fb8cf\",\n    \"4c9c5700-2492-4074-8c9a-4ca7f756242b\",\n    \"322d2620-dfae-43ff-acea-0476359b94b0\",\n    \"cdd82d16-1e38-4973-81a5-ff764d85e963\",\n    \"92b5407a-220e-4402-bd09-c12ce9dadf4e\",\n    \"c74a81bf-3992-4185-93f4-ffacbf971d1e\",\n    \"ed978572-dace-4b53-ace5-6e92616651b5\",\n    \"44324883-2adb-4820-b1f3-18e4a7bba75d\",\n    \"59e0211d-23f6-4bd8-9269-4aa1b152e50d\",\n    \"fe5ea10f-755a-4edc-8d05-a66bd78c7c41\",\n    \"e98fd7cb-e25e-486e-a1b8-bcd246990b8b\",\n    \"59b6789e-8405-4846-ac73-a923962a6bdb\",\n    \"9b56dd6f-50b3-43b4-939f-d2f902a536e8\",\n    \"68f4e49a-c7cf-4418-9a67-9717af4bade5\",\n    \"71453fde-8dc6-4e1f-a0dc-20232940eba6\",\n    \"1f62ad94-7229-451e-b5a5-c984f883bf30\",\n    \"19c1ab99-f976-4342-91f5-0fcd5fdbc449\",\n    \"4c60c0e8-0ffd-421a-ae26-3ce52297366a\",\n    \"3499ed44-9be9-43b1-bc3d-91fe2e586c19\",\n    \"03ea31ef-ff5f-4db6-ab94-ff281d284f2a\",\n    \"bfe70efc-1aca-406f-9ec7-1622936755d6\",\n    \"a59a38ba-5d6a-4008-acf1-7cc3c04469a6\",\n    \"6aefeaa8-0032-46b