        <block type="gamelab_playSoundOptions" id="4">
          <title name="SOUND" config="'sound://category_collect/trill_stings.mp3', 'sound://category_instrumental/harpe_pluck_1.mp3', 'sound://category_tap/vibrant_positive_tap_1.mp3', 'sound://category_notifications/vibrant_game_tonal_hit_6_correct.mp3', 'sound://category_digital/boing_2.mp3', 'sound://category_swish/quick_swing.mp3', 'sound://category_accent/puzzle_game_accent_a_01.mp3'">'sound://category_digital/boing_2.mp3'</title>
        </block>
        <block type="gamelab_makeNewSpriteAnon">
          <title name="ANIMATION_NAME">"emoji_01_1"</title>
          <value name="LOCATION">
            <block type="gamelab_location_picker" can_disconnect_from_parent="false">
              <title name="LOCATION">{"x":200,"y":200}</title>
            </block>
          </value>
        </block>
        <block type="gamelab_spriteSay">
          <title name="SPEECH">Ouch! I stubbed my toe!</title>
          <value name="SPRITE">
            <block type="gamelab_allSpritesWithAnimation" can_disconnect_from_parent="false">
              <title name="ANIMATION">"emoji_01_1"</title>
            </block>
          </value>
        </block>
        <block type="gamelab_setProp">
          <title name="PROPERTY">"scale"</title>
          <value name="SPRITE">
            <block type="gamelab_allSpritesWithAnimation" can_disconnect_from_parent="false">
              <title name="ANIMATION">"emoji_01_1"</title>
            </block>
          </value>
          <value name="VAL">
            <block type="math_number" can_disconnect_from_parent="false">
              <title name="NUM">50</title>
            </block>
          </value>
        </block>
        <block type="gamelab_changePropBy">
          <title name="PROPERTY">"scale"</title>
          <value name="SPRITE">
            <block type="gamelab_allSpritesWithAnimation" can_disconnect_from_parent="false">
              <title name="ANIMATION">"emoji_01_1"</title>
            </block>
          </value>
          <value name="VAL">
            <block type="math_number" can_disconnect_from_parent="false">
              <title name="NUM">10</title>
            </block>
          </value>
        </block>
        <block type="gamelab_setAnimation">
          <title name="ANIMATION">"emoji_04_1"</title>
