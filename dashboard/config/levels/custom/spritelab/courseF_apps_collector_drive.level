  <blocks>
    <start_blocks>
      <xml>
        <block type="when_run" deletable="false">
          <next>
            <block type="gamelab_setBackground">
              <value name="COLOR">
                <block type="colour_picker">
                  <field name="COLOUR">#000000</field>
                </block>
              </value>
              <next>
                <block type="gamelab_makeNewSpriteAnon">
                  <field name="ANIMATION_NAME">"rocket1_1"</field>
                  <value name="LOCATION">
                    <block type="gamelab_location_picker">
                      <field name="LOCATION">{"x":100,"y":200}</field>
                    </block>
                  </value>
                  <next>
                    <block type="gamelab_addBehaviorSimple">
                      <value name="SPRITE">
                        <block type="gamelab_allSpritesWithAnimation">
                          <field name="ANIMATION">"rocket1_1"</field>
                        </block>
                      </value>
                      <value name="BEHAVIOR">
                        <block type="gamelab_playerBehaviors">
                          <field name="BEHAVIOR">new Behavior(driving_with_arrow_keys, [])</field>
                        </block>
                      </value>
                      <next>
                        <block type="gamelab_makeNumSprites">
                          <field name="ANIMATION_NAME">"star1_1"</field>
                          <value name="NUM">
                            <block type="math_number">
                              <field name="NUM">10</field>
                            </block>
                          </value>
                          <next>
                            <block type="gamelab_setProp">
                              <field name="PROPERTY">"scale"</field>
                              <value name="SPRITE">
                                <block type="gamelab_allSpritesWithAnimation">
                                  <field name="ANIMATION">"star1_1"</field>
                                </block>
                              </value>
                              <value name="VAL">
                                <block type="math_number">
                                  <field name="NUM">50</field>
                                </block>
                              </value>
                              <next>
                                <block type="gamelab_addBehaviorSimple">
                                  <value name="SPRITE">
                                    <block type="gamelab_allSpritesWithAnimation">
                                      <field name="ANIMATION">"star1_1"</field>
                                    </block>
                                  </value>
                                  <value name="BEHAVIOR">
                                    <block type="gamelab_collectibleBehaviors">
                                      <field name="BEHAVIOR">new Behavior(moving_west_and_looping, [])</field>
                                    </block>
                                  </value>
                                  <next>
                                    <block type="variables_set">
                                      <field name="VAR">score</field>
                                      <value name="VALUE">
                                        <block type="math_number">
                                          <field name="NUM">0</field>
                                        </block>
                                      </value>
                                      <next>
                                        <block type="gamelab_printText">
                                          <value name="TEXT">
                                            <block type="text">
                                              <field name="TEXT">Press the arrow keys to move.</field>
                                            </block>
                                          </value>
                                        </block>
                                      </next>
                                    </block>
                                  </next>
                                </block>
                              </next>
                            </block>
                          </next>
                        </block>
                      </next>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="gamelab_atTime">
          <field name="UNIT">"seconds"</field>
          <value name="N">
            <block type="math_number">
              <field name="NUM">3</field>
            </block>
          </value>
          <next>
            <block type="gamelab_makeNumSprites">
              <field name="ANIMATION_NAME">"star2_1"</field>
              <value name="NUM">
                <block type="math_number">
                  <field name="NUM">5</field>
                </block>
              </value>
              <next>
                <block type="gamelab_setProp">
                  <field name="PROPERTY">"scale"</field>
                  <value name="SPRITE">
                    <block type="gamelab_allSpritesWithAnimation">
                      <field name="ANIMATION">"star2_1"</field>
                    </block>
                  </value>
                  <value name="VAL">
                    <block type="math_number">
                      <field name="NUM">60</field>
                    </block>
                  </value>
                  <next>
                    <block type="gamelab_addBehaviorSimple">
                      <value name="SPRITE">
                        <block type="gamelab_allSpritesWithAnimation">
                          <field name="ANIMATION">"star2_1"</field>
                        </block>
                      </value>
                      <value name="BEHAVIOR">
                        <block type="gamelab_collectibleBehaviors">
                          <field name="BEHAVIOR">new Behavior(moving_east_and_looping, [])</field>
                        </block>
                      </value>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="gamelab_atTime">
          <field name="UNIT">"seconds"</field>
          <value name="N">
            <block type="math_number">
              <field name="NUM">6</field>
            </block>
          </value>
          <next>
            <block type="gamelab_makeNumSprites">
              <field name="ANIMATION_NAME">"star1_1"</field>
              <value name="NUM">
                <block type="math_number">
                  <field name="NUM">10</field>
                </block>
              </value>
              <next>
                <block type="gamelab_setProp">
                  <field name="PROPERTY">"scale"</field>
                  <value name="SPRITE">
                    <block type="gamelab_allSpritesWithAnimation">
                      <field name="ANIMATION">"star1_1"</field>
                    </block>
                  </value>
                  <value name="VAL">
                    <block type="math_number">
                      <field name="NUM">50</field>
                    </block>
                  </value>
                  <next>
                    <block type="gamelab_addBehaviorSimple">
                      <value name="SPRITE">
                        <block type="gamelab_allSpritesWithAnimation">
                          <field name="ANIMATION">"star1_1"</field>
                        </block>
                      </value>
                      <value name="BEHAVIOR">
                        <block type="gamelab_collectibleBehaviors">
                          <field name="BEHAVIOR">new Behavior(moving_west_and_looping, [])</field>
                        </block>
                      </value>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="gamelab_atTime">
          <field name="UNIT">"seconds"</field>
          <value name="N">
            <block type="math_number">
              <field name="NUM">10</field>
            </block>
          </value>
          <next>
            <block type="gamelab_printText">
              <value name="TEXT">
                <block type="gamelab_textJoin">
                  <field name="TEXT1">Great job! Your score: </field>
                  <value name="TEXT2">
                    <block type="variables_get">
                      <field name="VAR">score</field>
                    </block>
                  </value>
                </block>
              </value>
              <next>
                <block type="gamelab_destroy">
                  <value name="THIS">
                    <block type="gamelab_allSpritesWithAnimation">
                      <field name="ANIMATION">"star1_1"</field>
                    </block>
                  </value>
                  <next>
                    <block type="gamelab_destroy">
                      <value name="THIS">
                        <block type="gamelab_allSpritesWithAnimation">
                          <field name="ANIMATION">"star2_1"</field>
                        </block>
                      </value>
                      <next>
                        <block type="gamelab_removeAllBehaviors">
                          <value name="SPRITE">
                            <block type="gamelab_allSpritesWithAnimation">
                              <field name="ANIMATION">"rocket1_1"</field>
                            </block>
                          </value>
                          <next>
                            <block type="gamelab_playSound">
                              <field name="SOUND">sound://category_achievements/peaceful_win_8.mp3</field>
                            </block>
                          </next>
                        </block>
                      </next>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="gamelab_checkTouching">
          <field name="CONDITION">"when"</field>
          <value name="SPRITE1">
            <block type="gamelab_allSpritesWithAnimation">
              <field name="ANIMATION">"rocket1_1"</field>
            </block>
          </value>
          <value name="SPRITE2">
            <block type="gamelab_allSpritesWithAnimation">
              <field name="ANIMATION">"star1_1"</field>
            </block>
          </value>
          <next>
            <block type="gamelab_destroy">
              <value name="THIS">
                <block type="gamelab_objectSpritePointer"/>
              </value>
              <next>
                <block type="math_change">
                  <field name="VAR">score</field>
                  <value name="DELTA">
                    <block type="math_number">
                      <field name="NUM">1</field>
                    </block>
                  </value>
                  <next>
                    <block type="gamelab_playSound">
                      <field name="SOUND">sound://category_collect/clicky_crunch.mp3</field>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="gamelab_checkTouching">
          <field name="CONDITION">"when"</field>
          <value name="SPRITE1">
            <block type="gamelab_allSpritesWithAnimation">
              <field name="ANIMATION">"rocket1_1"</field>
            </block>
          </value>
          <value name="SPRITE2">
            <block type="gamelab_allSpritesWithAnimation">
              <field name="ANIMATION">"star2_1"</field>
            </block>
          </value>
          <next>
            <block type="gamelab_destroy">
              <value name="THIS">
                <block type="gamelab_objectSpritePointer"/>
              </value>
              <next>
                <block type="math_change">
                  <field name="VAR">score</field>
                  <value name="DELTA">
                    <block type="math_number">
                      <field name="NUM">2</field>
                    </block>
                  </value>
                  <next>
                    <block type="gamelab_playSound">
                      <field name="SOUND">sound://category_collect/energy_bar_recharge_4.mp3</field>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="behavior_definition" deletable="false" movable="false" editable="false" uservisible="false">
          <mutation>
            <arg name="this sprite" type="Sprite"/>
            <description>move a sprite, changing its direction randomly</description>
          </mutation>
          <field name="NAME" id="wandering">wandering</field>
          <statement name="STACK">
            <block type="gamelab_withPercentChance" uservisible="false">
              <value name="NUM">
                <block type="math_number" uservisible="false">
                  <field name="NUM">20</field>
                </block>
              </value>
              <statement name="STATEMENT">
                <block type="gamelab_changePropBy" uservisible="false">
                  <field name="PROPERTY">"direction"</field>
                  <value name="SPRITE">
                    <block type="sprite_parameter_get" uservisible="false">
                      <field name="VAR">this sprite</field>
                    </block>
                  </value>
                  <value name="VAL">
                    <block type="math_random_int" uservisible="false">
                      <value name="FROM">
                        <block type="math_number" uservisible="false">
                          <field name="NUM">-25</field>
                        </block>
                      </value>
                      <value name="TO">
                        <block type="math_number" uservisible="false">
                          <field name="NUM">25</field>
                        </block>
                      </value>
                    </block>
                  </value>
                </block>
              </statement>
              <next>
                <block type="gamelab_moveForward" uservisible="false">
                  <value name="SPRITE">
                    <block type="sprite_parameter_get" uservisible="false">
                      <field name="VAR">this sprite</field>
                    </block>
                  </value>
                  <value name="DISTANCE">
                    <block type="gamelab_getProp" uservisible="false">
                      <field name="PROPERTY">"speed"</field>
                      <value name="SPRITE">
                        <block type="sprite_parameter_get" uservisible="false">
                          <field name="VAR">this sprite</field>
                        </block>
                      </value>
                    </block>
                  </value>
                  <next>
                    <block type="controls_if" uservisible="false">
                      <value name="IF0">
                        <block type="gamelab_isTouchingEdges" uservisible="false">
                          <value name="SPRITE">
                            <block type="sprite_parameter_get" uservisible="false">
                              <field name="VAR">this sprite</field>
                            </block>
                          </value>
                        </block>
                      </value>
                      <statement name="DO0">
                        <block type="gamelab_edgesDisplace" uservisible="false">
                          <value name="SPRITE">
                            <block type="sprite_parameter_get" uservisible="false">
                              <field name="VAR">this sprite</field>
                            </block>
                          </value>
                          <next>
                            <block type="gamelab_changePropBy" uservisible="false">
                              <field name="PROPERTY">"direction"</field>
