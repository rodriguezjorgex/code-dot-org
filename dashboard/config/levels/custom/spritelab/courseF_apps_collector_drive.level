    "validation_enabled": "false",
    "mini_toolbox": "true",
    "display_name": "Star Collector",
    "bubble_choice_description": "Collect as many stars as you can before time runs out.",
    "thumbnail_url": "https://images.code.org/8e1c830e2b26f5ca2b15809a4ed0a282-image-1642800513290.png",
    "callout_json": "[\r\n {\r\n  \"localization_key\": \"visualizationResizeBar\",\r\n  \"callout_text\": \"Drag the 3 dots to resize the play area.\",\r\n  \"element_id\": \"#visualizationResizeBar\",\r\n  \"on\": \"\",\r\n  \"qtip_config\": {\r\n   \"codeStudio\": {\r\n    \"canReappear\": true,\r\n    \"dropletPaletteCategory\": \"\"\r\n   },\r\n   \"style\": {\r\n    \"classes\": \"\"\r\n   },\r\n   \"position\": {\r\n    \"my\": \"left center\",\r\n    \"at\": \"top center\",\r\n    \"adjust\": {\r\n     \"x\": 0,\r\n     \"y\": 100\r\n    }\r\n   }\r\n  }\r\n }\r\n]",
    "hide_pause_button": "false",
    "short_instructions": "Read the code below. Press \"Run\" to play this game. Make changes to the code. Press \"Finish\" when you are done.",
    "instructions_icon": "purplebunny",
    "preload_asset_list": null
  },
