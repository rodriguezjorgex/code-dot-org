  <blocks>
    <start_blocks>
      <xml>
        <block type="when_run" deletable="false">
  </block>
      </xml>
    </start_blocks>
    <toolbox_blocks>
      <xml>
        <category name="World">
          <block type="gamelab_setBackgroundImageAs">
            <field name="IMG">"hw_retro_background_1"</field>
          </block>
          <block type="gamelab_setBackground">
            <value name="COLOR">
              <block type="colour_picker">
                <field name="COLOUR">#99ff99</field>
              </block>
            </value>
          </block>
          <block type="gamelab_randomColor"/>
          <block type="gamelab_playSound">
            <field name="SOUND">Choose</field>
          </block>
          <block type="gamelab_showTitleScreen">
            <value name="TITLE">
              <block type="text">
                <field name="TEXT"/>
              </block>
            </value>
            <value name="SUBTITLE">
              <block type="text">
                <field name="TEXT"/>
              </block>
            </value>
          </block>
          <block type="gamelab_hideTitleScreen"/>
          <block type="gamelab_printText">
            <value name="TEXT">
              <block type="text">
                <field name="TEXT"/>
              </block>
            </value>
          </block>
          <block type="gamelab_setPrompt">
            <value name="QUESTION">
              <block type="text" can_disconnect_from_parent="false">
                <field name="TEXT"/>
              </block>
            </value>
            <value name="VAR">
              <block type="variables_get" can_disconnect_from_parent="false">
                <field name="VAR">???</field>
              </block>
            </value>
          </block>
          <block type="gamelab_setPromptWithChoices">
            <value name="QUESTION">
              <block type="text">
                <field name="TEXT"/>
              </block>
            </value>
            <value name="VAR">
              <block type="variables_get" movable="false">
                <field name="VAR">???</field>
              </block>
            </value>
            <value name="A">
              <block type="text">
                <field name="TEXT">choice 1</field>
              </block>
            </value>
            <value name="B">
              <block type="text">
                <field name="TEXT">choice 2</field>
              </block>
            </value>
            <value name="C">
              <block type="text">
                <field name="TEXT">choice 3</field>
              </block>
            </value>
          </block>
          <block type="gamelab_textJoin">
            <field name="TEXT1"/>
          </block>
          <block type="gamelab_textVariableJoin">
            <field name="VAR">???</field>
          </block>
          <block type="text">
            <field name="TEXT"/>
          </block>
          <block type="gamelab_locationMouse"/>
        </category>
        <category name="Sprites">
          <block type="gamelab_makeNewSpriteAnon">
            <field name="ANIMATION_NAME">"retrocreature_18"</field>
            <value name="LOCATION">
              <block type="gamelab_location_picker">
                <field name="LOCATION">{"x":200,"y":200}</field>
              </block>
            </value>
          </block>
          <block type="gamelab_makeNumSprites">
            <field name="ANIMATION_NAME">"retrocreature_18"</field>
            <value name="NUM">
              <block type="math_number">
                <field name="NUM">3</field>
              </block>
            </value>
          </block>
          <block type="gamelab_makeBurst">
            <field name="EFFECT">"pop"</field>
            <field name="ANIMATION_NAME">"retrocreature_18"</field>
            <value name="NUM">
              <block type="math_number">
                <field name="NUM">10</field>
              </block>
            </value>
          </block>
          <block type="gamelab_allSpritesWithAnimation">
            <field name="ANIMATION">"retrocreature_18"</field>
          </block>
          <block type="gamelab_getAllSprites"/>
          <block type="gamelab_destroy"/>
          <block type="gamelab_setProp">
            <field name="PROPERTY">"scale"</field>
            <value name="VAL">
              <block type="math_number">
                <field name="NUM">50</field>
              </block>
            </value>
          </block>
          <block type="gamelab_changePropBy">
            <field name="PROPERTY">"scale"</field>
            <value name="VAL">
              <block type="math_number">
                <field name="NUM">10</field>
              </block>
            </value>
          </block>
          <block type="gamelab_spriteSay">
            <field name="SPEECH"/>
          </block>
          <block type="gamelab_spriteSayTime">
            <value name="TEXT1">
              <block type="text">
                <field name="TEXT"/>
              </block>
            </value>
            <value name="NUM">
              <block type="math_number">
                <field name="NUM">4</field>
              </block>
            </value>
          </block>
          <block type="gamelab_setTint">
            <value name="COLOR">
              <block type="colour_picker">
                <field name="COLOUR">#ff0000</field>
              </block>
            </value>
          </block>
          <block type="gamelab_setTint">
            <value name="COLOR">
              <block type="gamelab_randomColor"/>
            </value>
          </block>
          <block type="gamelab_removeTint"/>
          <block type="gamelab_setAnimation">
            <field name="ANIMATION">"retrocreature_18"</field>
          </block>
          <block type="gamelab_jumpTo">
            <value name="LOCATION">
              <block type="gamelab_randomLocation"/>
            </value>
          </block>
          <block type="gamelab_moveInDirection">
            <field name="DIRECTION">"North"</field>
            <value name="SPRITE">
              <block type="gamelab_allSpritesWithAnimation">
                <field name="ANIMATION">"retrocreature_18"</field>
              </block>
            </value>
            <value name="DISTANCE">
              <block type="math_number">
                <field name="NUM">10</field>
              </block>
            </value>
          </block>
          <block type="gamelab_turn">
            <field name="DIRECTION">"right"</field>
            <value name="SPRITE">
              <block type="gamelab_allSpritesWithAnimation">
                <field name="ANIMATION">"retrocreature_18"</field>
              </block>
            </value>
            <value name="N">
              <block type="math_number">
                <field name="NUM">90</field>
              </block>
            </value>
          </block>
          <block type="gamelab_mirrorSprite">
            <field name="DIRECTION">"right"</field>
            <value name="SPRITE">
              <block type="gamelab_allSpritesWithAnimation">
                <field name="ANIMATION">"retrocreature_18"</field>
              </block>
            </value>
          </block>
          <block type="gamelab_moveForward">
            <value name="SPRITE">
              <block type="gamelab_allSpritesWithAnimation">
                <field name="ANIMATION">"retrocreature_18"</field>
              </block>
            </value>
            <value name="DISTANCE">
              <block type="math_number">
                <field name="NUM">10</field>
              </block>
            </value>
          </block>
          <block type="gamelab_moveToward">
            <value name="SPRITE">
              <block type="gamelab_allSpritesWithAnimation">
                <field name="ANIMATION">"retrocreature_18"</field>
              </block>
            </value>
            <value name="DISTANCE">
              <block type="math_number">
                <field name="NUM">10</field>
              </block>
            </value>
            <value name="TARGET">
              <block type="gamelab_locationOf"/>
            </value>
          </block>
          <block type="gamelab_setDefaultSpriteSize">
            <field name="SIZE">100</field>
          </block>
          <block type="gamelab_getProp">
            <field name="PROPERTY">"scale"</field>
          </block>
        </category>
        <category name="Locations">
          <block type="gamelab_location_picker">
            <field name="LOCATION">{"x":200,"y":200}</field>
          </block>
          <block type="gamelab_randomLocation"/>
        </category>
        <category name="Behaviors" custom="Behavior">
          <block type="gamelab_addBehaviorSimple"/>
          <block type="gamelab_removeBehaviorSimple"/>
          <block type="gamelab_removeAllBehaviors"/>
          <block type="gamelab_draggable"/>
        </category>
        <category name="Events">
          <block type="gamelab_atTime">
            <field name="UNIT">"seconds"</field>
            <value name="N">
              <block type="math_number">
                <field name="NUM">3</field>
              </block>
            </value>
          </block>
          <block type="gamelab_keyPressed">
            <field name="CONDITION">"when"</field>
            <field name="KEY">"up"</field>
          </block>
          <block type="gamelab_whenPromptAnswered">
            <value name="VAR">
              <block type="variables_get" can_disconnect_from_parent="false">
                <field name="VAR">???</field>
              </block>
            </value>
          </block>
          <block type="gamelab_whenAllPromptsAnswered"/>
          <block type="gamelab_spriteClicked">
            <field name="CONDITION">"when"</field>
            <value name="SPRITE">
              <block type="gamelab_allSpritesWithAnimation" can_disconnect_from_parent="false">
                <field name="ANIMATION">"retrocreature_18"</field>
              </block>
            </value>
          </block>
          <block type="gamelab_checkTouching">
            <field name="CONDITION">"when"</field>
            <value name="SPRITE1">
              <block type="gamelab_allSpritesWithAnimation" can_disconnect_from_parent="false">
                <field name="ANIMATION">"retrocreature_18"</field>
              </block>
            </value>
            <value name="SPRITE2">
              <block type="gamelab_allSpritesWithAnimation" can_disconnect_from_parent="false">
                <field name="ANIMATION">"retrocreature_18"</field>
              </block>
            </value>
          </block>
        </category>
        <category name="Variables ">
          <block type="gamelab_setPrompt">
            <value name="QUESTION">
              <block type="text" can_disconnect_from_parent="false">
                <field name="TEXT"/>
              </block>
            </value>
            <value name="VAR">
              <block type="variables_get" can_disconnect_from_parent="false">
                <field name="VAR">???</field>
              </block>
            </value>
          </block>
          <block type="gamelab_setPromptWithChoices">
            <value name="QUESTION">
              <block type="text">
                <field name="TEXT"/>
              </block>
            </value>
            <value name="VAR">
              <block type="variables_get" movable="false">
                <field name="VAR">???</field>
              </block>
            </value>
            <value name="A">
              <block type="text">
                <field name="TEXT">choice 1</field>
              </block>
            </value>
            <value name="B">
              <block type="text">
                <field name="TEXT">choice 2</field>
              </block>
            </value>
            <value name="C">
              <block type="text">
                <field name="TEXT">choice 3</field>
              </block>
            </value>
          </block>
          <block type="gamelab_textVariableJoin">
            <field name="VAR">???</field>
          </block>
          <block type="variables_get">
            <field name="VAR">???</field>
          </block>
        </category>
      </xml>
    </toolbox_blocks>
  </blocks>
</GamelabJr>