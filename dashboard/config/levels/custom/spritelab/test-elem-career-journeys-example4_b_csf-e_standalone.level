  <blocks>
    <start_blocks>
      <xml xmlns="https://developers.google.com/blockly/xml">
        <block type="when_run" deletable="false" movable="false" x="16" y="16">
          <next>
            <block type="gamelab_setBackgroundImageAs">
              <field name="IMG">"doodle_journal"</field>
              <next>
                <block type="gamelab_makeNewSpriteAnon">
                  <field name="ANIMATION_NAME">"commercial_13"</field>
                  <value name="LOCATION">
                    <block type="gamelab_location_picker">
                      <field name="LOCATION">{"x":149,"y":97}</field>
                    </block>
                  </value>
                  <next>
                    <block type="gamelab_makeNewSpriteAnon">
                      <field name="ANIMATION_NAME">"pupilportrait_03"</field>
                      <value name="LOCATION">
                        <block type="gamelab_location_picker">
                          <field name="LOCATION">{"x":247,"y":310}</field>
                        </block>
                      </value>
                      <next>
                        <block type="gamelab_setProp">
                          <field name="PROPERTY">"scale"</field>
                          <value name="SPRITE">
                            <block type="gamelab_allSpritesWithAnimation">
                              <field name="ANIMATION">"pupilportrait_03"</field>
                            </block>
                          </value>
                          <value name="VAL">
                            <block type="math_number">
                              <field name="NUM">200</field>
                            </block>
                          </value>
                          <next>
                            <block type="gamelab_spriteSayTime">
                              <value name="SPRITE">
                                <block type="gamelab_allSpritesWithAnimation" movable="false">
                                  <field name="ANIMATION">"pupilportrait_03"</field>
                                </block>
                              </value>
                              <value name="TEXT1">
                                <block type="text">
                                  <field name="TEXT">I'd like to be a teacher. Click me, and the school!</field>
                                </block>
                              </value>
                              <value name="NUM">
                                <block type="math_number">
                                  <field name="NUM">3</field>
                                </block>
                              </value>
                            </block>
                          </next>
                        </block>
                      </next>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="gamelab_spriteClicked" x="26" y="380">
          <field name="CONDITION">"when"</field>
          <value name="SPRITE">
            <block type="gamelab_allSpritesWithAnimation">
              <field name="ANIMATION">"commercial_13"</field>
            </block>
          </value>
          <next>
            <block type="gamelab_setBackgroundImageAs">
              <field name="IMG">"library_color"</field>
              <next>
                <block type="gamelab_spriteSayTime">
                  <value name="SPRITE">
                    <block type="gamelab_allSpritesWithAnimation" movable="false">
                      <field name="ANIMATION">"commercial_13"</field>
                    </block>
                  </value>
                  <value name="TEXT1">
                    <block type="text">
                      <field name="TEXT">My school uses AI to help students learn to read.</field>
                    </block>
                  </value>
                  <value name="NUM">
                    <block type="math_number">
                      <field name="NUM">4</field>
                    </block>
                  </value>
                  <next>
                    <block type="gamelab_setAnimation">
                      <field name="ANIMATION">"book"</field>
                      <value name="THIS">
                        <block type="gamelab_allSpritesWithAnimation">
                          <field name="ANIMATION">"commercial_13"</field>
                        </block>
                      </value>
                      <next>
                        <block type="gamelab_jumpTo">
                          <value name="SPRITE">
                            <block type="gamelab_allSpritesWithAnimation">
                              <field name="ANIMATION">"book"</field>
                            </block>
                          </value>
                          <value name="LOCATION">
                            <block type="gamelab_location_picker">
                              <field name="LOCATION">{"x":86,"y":269}</field>
                            </block>
                          </value>
                        </block>
                      </next>
                    </block>
                  </next>
                </block>
              </next>
            </block>
          </next>
        </block>
        <block type="gamelab_spriteClicked" x="18" y="728">
          <field name="CONDITION">"when"</field>
          <value name="SPRITE">
            <block type="gamelab_allSpritesWithAnimation">
              <field name="ANIMATION">"pupilportrait_03"</field>
            </block>
          </value>
          <next>
            <block type="gamelab_spriteSayTime">
              <value name="SPRITE">
                <block type="gamelab_allSpritesWithAnimation" movable="false">
                  <field name="ANIMATION">"pupilportrait_03"</field>
                </block>
              </value>
              <value name="TEXT1">
