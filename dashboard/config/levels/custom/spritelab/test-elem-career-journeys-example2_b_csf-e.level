        <block type="gamelab_spriteClicked" x="47" y="516">
          <field name="CONDITION">"when"</field>
          <value name="SPRITE">
            <block type="gamelab_allSpritesWithAnimation" movable="false">
              <field name="ANIMATION">"microscope"</field>
            </block>
          </value>
          <next>
            <block type="gamelab_spriteSay">
              <field name="SPEECH">I will collect data on the plants</field>
              <value name="SPRITE">
                <block type="gamelab_allSpritesWithAnimation" movable="false">
                  <field name="ANIMATION">"microscope"</field>
                </block>
              </value>
            </block>
          </next>
        </block>
        <block type="gamelab_spriteClicked" x="473" y="521">
          <field name="CONDITION">"when"</field>
          <value name="SPRITE">
            <block type="gamelab_allSpritesWithAnimation" movable="false">
              <field name="ANIMATION">"laptop"</field>
            </block>
          </value>
          <next>
            <block type="gamelab_spriteSay">
