              </block>
            </value>
            <value name="SPRITE2">
              <block type="sprite_variables_get">
                <title name="VAR">other</title>
              </block>
            </value>
          </block>
          <block type="gamelab_whenTouching">
            <value name="SPRITE1">
              <block type="sprite_variables_get">
                <title name="VAR">mySprite</title>
              </block>
            </value>
            <value name="SPRITE2">
              <block type="sprite_variables_get">
                <title name="VAR">other</title>
              </block>
            </value>
          </block>
          <block type="gamelab_clickedOn">
            <value name="SPRITE">
              <block type="sprite_variables_get">
                <title name="VAR">mySprite</title>
              </block>
            </value>
          </block>
        </category>
        <category name="Behaviors">
          <block type="gamelab_addBehaviorSimple">
