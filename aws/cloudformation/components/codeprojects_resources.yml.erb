# -----------------------------------------------
# Begin codeprojects.org resources
# 
# This template component includes resources for the codeprojects.org
# infrastructure. Currently this is mostly manually deployed.
#
# Notes during IaC adoption:
#
# Domains:
# - staging.codeprojects.org
# - test.codeprojects.org
# - codeprojects.org
# - www.codeprojects.org
# - static.codeprojects.org
# - bramble-download.codeprojects.org
# - adhoc-bethany-nginx-update.codeprojects.org
# - localhost.codeprojects.org
# - localhost.preview.codeprojects.org
# - localhost.staging.codeprojects.org
# 
# Therefore we're using <env>.codeprojects.org, except in prod, where we use the base domain.
#
# TODO:
#   - Cloudfront distribution and function for www redirect
#   - Adopt/Replace the existing codeprojects.org base domain resources, which don't use Cloudfront. Add them to this single distribution if reasonable.
# -----------------------------------------------

<%- if rack_env?(:staging) -%>
# Developer Resources (Deployed with Staging)
LocalhostCodeprojectsRecord:
  Type: AWS::Route53::RecordSet
  Properties:
    HostedZoneId: !Ref CodeprojectsHostedZoneId
    Name: !Sub localhost.${CodeprojectsBaseDomainName}
    Type: A
    TTL: 3600
    ResourceRecords:
      - 127.0.0.1

LocalhostPreviewCodeprojectsRecord:
  Type: AWS::Route53::RecordSet
  Properties:
    HostedZoneId: !Ref CodeprojectsHostedZoneId
    Name: !Sub preview.localhost.${CodeprojectsBaseDomainName}
    Type: A
    TTL: 3600
    ResourceRecords:
      - 127.0.0.1
<%- end -%>

# A shared codeprojects certificate for this environment, avoiding wildcard certificates.
CodeprojectsCertificate:
  Type: AWS::CertificateManager::Certificate
  Properties:
    DomainName: !Ref CodeprojectsBaseDomainName
    SubjectAlternativeNames:
      - !Sub preview.${CodeprojectsBaseDomainName}
      - !Sub www.${CodeprojectsBaseDomainName}
      - !Sub static.${CodeprojectsBaseDomainName}
      - !Sub bramble-download.${CodeprojectsBaseDomainName}
    ValidationMethod: DNS
    DomainValidationOptions:
      - DomainName: !Ref CodeprojectsBaseDomainName
        HostedZoneId: !Ref CodeprojectsHostedZoneId
      - DomainName: !Sub preview.${CodeprojectsBaseDomainName}
        HostedZoneId: !Ref CodeprojectsHostedZoneId
      - DomainName: !Sub www.${CodeprojectsBaseDomainName}
        HostedZoneId: !Ref CodeprojectsHostedZoneId
      - DomainName: !Sub static.${CodeprojectsBaseDomainName}
        HostedZoneId: !Ref CodeprojectsHostedZoneId
      - DomainName: !Sub bramble-download.${CodeprojectsBaseDomainName}
        HostedZoneId: !Ref CodeprojectsHostedZoneId

CodeprojectsRecords:
  Type: AWS::Route53::RecordSetGroup
  Properties:
    HostedZoneId: !Ref CodeprojectsHostedZoneId
    RecordSets:
      - Name: !Sub preview.${CodeprojectsBaseDomainName}
        Type: A
        AliasTarget:
          DNSName: !GetAtt CodeprojectsCloudFrontDistribution.DomainName
          HostedZoneId: Z2FDTNDATAQYW2

# Codeprojects CloudFront Distribution
CodeprojectsCloudFrontDistribution:
  Type: AWS::CloudFront::Distribution
  Properties:
    DistributionConfig:
      Enabled: true
      Comment: !Sub ${CodeprojectsBaseDomainName} main distribution
      PriceClass: PriceClass_All
      Aliases:
        # - !Ref CodeprojectsBaseDomainName
        - !Sub preview.${CodeprojectsBaseDomainName}
      Origins:
        - Id: DashboardOrigin
          DomainName: origin-autoscale-prod.code.org
          CustomOriginConfig:
            OriginProtocolPolicy: https-only
            OriginSSLProtocols:
              - TLSv1.2
      DefaultCacheBehavior:
        TargetOriginId: DashboardOrigin
        ViewerProtocolPolicy: redirect-to-https
        CachePolicyId: !Ref CodeprojectsCachePolicy
        OriginRequestPolicyId: !Ref CodeprojectsOriginRequestPolicy
        Compress: true
      ViewerCertificate:
        AcmCertificateArn: !Ref CodeprojectsCertificate
        MinimumProtocolVersion: TLSv1.2_2021
        SslSupportMethod: sni-only

# Cache policy for the main distribution
CodeprojectsCachePolicy:
  Type: AWS::CloudFront::CachePolicy
  Properties:
    CachePolicyConfig:
      Name: !Sub ${AWS::StackName}-codeprojects-cache-policy
      MinTTL: 0
      MaxTTL: 31536000
      DefaultTTL: 0
      ParametersInCacheKeyAndForwardedToOrigin:
        EnableAcceptEncodingGzip: true
        CookiesConfig: 
          CookieBehavior: all
        HeadersConfig: 
          HeaderBehavior: whitelist
          Headers:
            - CloudFront-Forwarded-Proto
            - Host
            - Origin
            - Referer
            - User-Agent
        QueryStringsConfig: 
          QueryStringBehavior: all

# Origin request policy for the main distribution
CodeprojectsOriginRequestPolicy:
  Type: AWS::CloudFront::OriginRequestPolicy
  Properties:
    OriginRequestPolicyConfig:
      Name: !Sub ${AWS::StackName}-codeprojects-origin-request-policy
      CookiesConfig:
        CookieBehavior: all
      HeadersConfig:
        HeaderBehavior: whitelist
        Headers:
          - CloudFront-Forwarded-Proto
          - Host
          - Origin
          - Referer
          - User-Agent
      QueryStringsConfig:
        QueryStringBehavior: all

# -----------------------------------------------
# End codeprojects.org resources
# -----------------------------------------------
