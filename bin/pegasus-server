#!/usr/bin/env ruby
require_relative '../deployment'

def main
  Dir.chdir(pegasus_dir) do
    system <<~BASH
      bundle exec rerun \
        -p '**/*.{rb,ru,yml}' \
        -d '../lib,../shared/middleware,../pegasus' \
        -i '**/public/fonts' \
        'thin start -p #{CDO.pegasus_port}'
    BASH
  end
end

main
