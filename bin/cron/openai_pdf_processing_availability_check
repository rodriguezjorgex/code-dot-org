#!/usr/bin/env ruby
require_relative 'only_one'
abort 'Script already running' unless only_one_running?(__FILE__)

require_relative '../../dashboard/config/environment'

def main
  # An encoded version of a PDF that contains the string "CODE" and nothing else.
  pdf_base64_encoding = ''

  options = {
    text: {
      format: {
        name: "pdf_processing_availability_check",
        type: "json_schema",
        schema: {
          type: "object",
          properties: {
            classification: {
              type: "string",
              description: "Define whether the PDF contains a specific string or not.",
              enum: ["YES", "NO"]
            }
          },
          required: ["classification"],
          additionalProperties: false
        }
      }
    }
  }

  input = [
    {
      role: 'user',
      content: [
        {type: 'input_text', text: "Does this PDF contain the text 'CODE'?"},
        {
          type: 'input_file',
          filename: 'test.pdf',
          file_data: "data:application/pdf;base64,#{pdf_base64_encoding}"
        }
      ]
    }
  ]

  client = AichatOpenaiResponsesHelper::Client.new(
    CDO.openai_student_learning_api_key,
    'gpt-4o-mini-2024-07-18'
  )

  response = client.request_chat_completion(input, 0, options: options)
  raw_content = JSON.parse(response.body).dig('output', 0, 'content', 0, 'text')
  classification = JSON.parse(raw_content)['classification']

  # In the case that OpenAI returns a response outside the enumerated YES or NO,
  # we have an alarm set up in CloudWatch to alert if we get 0 successes in an hour.
  # This would also start alarming if this health check started failing for another reason.
  if classification == 'YES'
    put_metric('Success')
  elsif classification == 'NO'
    put_metric('Failure')
  end
end

def put_metric(event)
  Cdo::Metrics.push(
    SharedConstants::AICHAT_METRICS_NAMESPACE,
    [
      {
        metric_name: "OpenaiPdfProcessingAvailabilityTest.#{event}",
        value: 1,
        unit: 'Count',
        timestamp: Time.now,
        dimensions: [
          {name: 'Environment', value: CDO.rack_env}
        ],
      }
    ]
  )
end

main
